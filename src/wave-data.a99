       byte >10,>B0,>41,>21
       byte >0E,>0E,>A2,>51
       byte >B0,>10,>41,>21
       byte >B2,>B2,>A2,>81
       byte >98,>38,>24,>A1
       byte >9D,>06,>61,>51
