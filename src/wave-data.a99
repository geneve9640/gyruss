       byte >BC,>23,>61,>81
       byte >1C,>94,>46,>D0
       byte >0C,>B4,>47,>51
       byte >3C,>B4,>46,>D0
       byte >94,>2C,>47,>61
       byte >08,>B8,>89,>D1
       byte >0E,>B2,>8A,>52
       byte >98,>28,>89,>D1
       byte >92,>2E,>8A,>82
       byte >3C,>A4,>2C,>51
       byte >20,>A0,>2D,>A1
