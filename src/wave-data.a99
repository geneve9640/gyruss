       byte >04,>9C,>30,>51
       byte >95,>2B,>2F,>D1
       byte >BC,>23,>30,>81

* Polar y for wave sprites
wave_init_polar_y:                     ; >a57e
       byte >2A,>F7,>FB

* Wave data address table
*
* Bits 0-3 of wave init byte 2 determines entry. Value is stored in sprite data
* bytes 6 and 7.
wave_address_table:                    ; >a581
       data wave_path_0
       data wave_path_6
       data wave_path_7
       data wave_path_1
       data wave_path_8
       data wave_path_2
       data wave_path_9
       data wave_path_10
       data wave_path_3
       data wave_path_11
       data wave_path_12
       data wave_path_4
       data wave_path_13
       data wave_path_14
       data wave_path_5
       data wave_path_15
       data wave_path_16

