* Init data for wave sprites
*
* Data for 24 waves, 4 bytes each
* #TABLE(default, default)
* { =h Byte | =h Purpose }
* { $00 | Polar x for even enemies }
* { $01 | Polar x for odd enemies }
* { $02 | Bits 0-4 are the index into the table at #R$A581, which contains the address of the path data; bits 4-7 are ? }
* { $03 | Bits 0-3 are the index into the table at #R$A57E, which determines the start polar y; bits 4-7 are the color of the sprites }
* TABLE#
wave_init_data:                        ; >a4be
       byte >A8,>18,>83,>50
       byte >A0,>10,>80,>E0
       byte >B0,>20,>80,>A0
       byte >88,>38,>80,>80
       byte >12,>14,>63,>51
       byte >AE,>AC,>63,>E1
       byte >22,>24,>63,>A1
       byte >9E,>9C,>63,>81
       byte >1E,>1E,>65,>51
       byte >A2,>A2,>65,>E1
       byte >84,>84,>65,>A1
       byte >3C,>3C,>65,>81
       byte >20,>20,>68,>50
       byte >B0,>B0,>68,>E0
       byte >00,>00,>68,>A0
       byte >3F,>3F,>68,>80
       byte >30,>30,>6B,>50
       byte >8F,>8F,>6B,>E0
       byte >01,>01,>6B,>A0
       byte >81,>81,>6B,>80
       byte >10,>B0,>6E,>51
       byte >10,>B0,>6E,>E1
       byte >90,>30,>6E,>A1
       byte >90,>30,>6E,>81

