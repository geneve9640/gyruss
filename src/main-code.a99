;
;* Rotate pattern
;*
;* Take a pattern pointed to by #R$72DE and rotate it left 90 degrees. Returns
;* address of rotate pattern in #R$72DE. Used by the routine at #R$AE94.
;rotate:                                ; >af6b
;       mov  @pattern_address,hl        ; LD HL,($72DE)     ; HL = source address
;;       .push hl                        ; PUSH HL           ; Copy source into IY
;;       .pop iy                         ; POP IY            ; ...
;       mov  hl,iy
;       li   de,>0008                   ; LD DE,$0008       ; HL = destination address
;       a    de,hl                      ; ADD HL,DE         ; ...
;       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
;       li   r0,1                       ; Number of bits to shift
;rotate_1:
;       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
;       clr  r2                         ; Result
;_af7a:                                 ; >af7a
;;       sla  *iy,1                      ; RL (IY+$00)       ; Shift bit 7 of source byte 0 into carry
;;       sra  *hl,1                      ; RR (HL)           ; Shift carry into bit 7 of destination byte
;;       sla  @>01(iy),1                 ; RL (IY+$01)       ; x2
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>02(iy),1                 ; RL (IY+$02)       ; x3
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>03(iy),1                 ; RL (IY+$03)       ; x4
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>04(iy),1                 ; RL (IY+$04)       ; x5
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>05(iy),1                 ; RL (IY+$05)       ; x6
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>06(iy),1                 ; RL (IY+$06)       ; x7
;;       sra  *hl,1                      ; RR (HL)           ; ...
;;       sla  @>07(iy),1                 ; RL (IY+$07)       ; x8
;;       sra  *hl,1                      ; RR (HL)           ; ...
;       srl  r2,1                       ; Shift result right
;       movb *iy+,r1                    ; Get source byte
;       sla  r1,0                       ; Shift bit n into carry
;       jnc  !
;       socb @bytes+>80,r2              ; Set msb of result
;!      sb   one,b                      ; DJNZ $AF7A        ; Repeat 8 times
;       jne  _af7a                      ;
;       movb r2,*hl+                    ; Save result
;       ai   iy,-8                      ; Move source back to start
;;       inc  hl                         ; INC HL            ; Next destination
;       inc  r0                         ; Move to next bit
;       ci   r0,8
;       jle  rotate_1
;        .ret                            ; RET               ;
;
;* Flip pattern vertically
;*
;* Take a pattern pointed to by #R$72DE and flip it vertically (upside down).
;* Returns address of result in #R$72DE. Used by the routine at #R$AE94.
;flip_vertical:                         ; >afae
;       mov  @pattern_address,de        ; LD DE,($72DE)     ; DE = source address
;       li   hl,>0010                   ; LD HL,$0010       ; HL = right after end of destination buffer
;       a    de,hl                      ; ADD HL,DE         ; ...
;       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
;_afb8:                                 ; >afb8
;       movb *de,a                      ; LD A,(DE)         ; Get source byte
;       dec  hl                         ; DEC HL            ; Destination address moves backwards
;       movb a,*hl                      ; LD (HL),A         ; Store result
;       inc  de                         ; INC DE            ; Next source
;       sb   one,b                      ; DJNZ $AFB8        ; Repeat 8 times
;       jne  _afb8                      ;
;       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
;       .ret                            ; RET               ;
;
;* Flip pattern horizontally
;*
;* Take a pattern pointed to by #R$72DE and flip it horizontally (mirrored).
;* Returns address of result in #R$72DE. Used by the routine at #R$AE94.
;flip_horizontal:                       ; >afc2
;       mov  @pattern_address,de        ; LD DE,($72DE)     ; DE = source address
;       li   hl,>0008                   ; LD HL,$0008       ; HL = destination address
;       a    de,hl                      ; ADD HL,DE         ; ...
;       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
;       .ex_de_hl                       ; EX DE,HL          ; HL = source, DE = destination
;       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
;_afd0:                                 ; >afd0
;;       movb @bytes+>80,a               ; LD A,$80          ; Result starts with 10000000
;       li   r1,>8000
;       li   r2,8
;       sb   a,a
;       movb *hl,r0
;_afd2:                                 ; >afd2
;;       sla  *hl,1                      ; RL (HL)           ; Shift source byte left, bit 7 to carry
;;       srl  a,1                        ; RRA               ; Shift right, carry to bit 7, bit 0 to carry
;;       jnc  _afd2                      ; JR NC,$AFD2       ; Repeat until bit 7 reaches carry (8 times)
;       srl  a,1
;       sla  r0,1
;       jnc  !
;       socb r1,a
;!      dec  r2
;       jne  _afd2
