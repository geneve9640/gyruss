* Handle sprite outside visible screen
*
* Used by the routine at #R$ADD1.
handle_off_screen_sprite:              ; >ae54
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>0c               ; CP $0C            ; If < $0C
       jl   handle_off_screen_sprite_3 ; JR C,$AE86        ; Then set off-screen values and return
       cb   a,@bytes+>0e               ; CP $0E            ; If >= $0C and < $0E
       jl   handle_off_screen_sprite_1 ; JR C,$AE67        ; Then jump ahead
       cb   a,@bytes+>12               ; CP $12            ; If >= $0E and < $12
;       jl   _ae4e                      ; JR C,$AE4E        ; Then just return
       jl   handle_off_screen_sprite_4
       cb   a,@bytes+>18               ; CP $18            ; If >= $18
;       jhe  _ae4e                      ; JR NC,$AE4E       ; Then just return
       jhe  handle_off_screen_sprite_4
handle_off_screen_sprite_1:            ; >ae67
       cb   a,@bytes+>12               ; CP $12            ; If >= $12 and < $12 (not possible)
       jl   handle_off_screen_sprite_2 ; JR C,$AE75        ; Then decrement total enemies
       cb   a,@bytes+>14               ; CP $14            ; If >= $14 and < $18
       jhe  handle_off_screen_sprite_2 ; JR NC,$AE75       ; Then decrement total enemies
;       li   hl,active_enemy_shots      ; LD HL,$7252       ; Decrement active enemy shots
;       sb   one,*hl                    ; DEC (HL)          ; ...
       sb   one,@active_enemy_shots    ; Decrement active enemy shots
       jmp  handle_off_screen_sprite_3                      ; JR $AE86          ; Set off-screen values and return
handle_off_screen_sprite_2:            ; >ae75
;       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies
;       sb   one,*hl                    ; DEC (HL)          ; ...
       sb   one,@total_enemies         ; Decrement total enemies
       cb   a,@bytes+>15               ; CP $15            ; If < $15
       jl   handle_off_screen_sprite_3                      ; JR C,$AE86        ; Then set off-screen values and return
       cb   a,@bytes+>18               ; CP $18            ; If >= $18
       jhe  handle_off_screen_sprite_3                      ; JR NC,$AE86       ; Then set off-screen values and return
;       li   hl,other_flags             ; LD HL,$7256       ; $15 - $17 Reset flag
;       szcb @bits+3,*hl                ; RES 3,(HL)        ; ...
       szcb @bits+3,@other_flags
handle_off_screen_sprite_3:            ; >ae86
       movb @bytes+>7f,*ix             ; LD (IX+$00),$7F   ; Set as not allocated
       movb @zero,@>09(ix)             ; LD (IX+$09),$00   ; Set x
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
handle_off_screen_sprite_4:
;       jmp  _ae4e                      ; JR $AE4E          ;
       rt

;* Upload sprite patterns
;*
;* Fill VDP RAM from $2100 to $3868 with sprite patterns that may be rotated and
;* flipped. One new pattern is generated with each call. Builds a table of VDP
;* addresses in #R$72E0. Used by the routine at #R$90D6.
;upload_sprite_patterns:                ; >ae94
;       seto @carry                     ; Set return value as not complete
;       movb @sprite_type_processed,a   ; LD A,($72D5)      ; Get sprite type
;       cb   a,@b255                    ; CP $FF            ; If maxed out
;       jne  !                          ; RET Z             ; Then return
;       b    @upload_sprite_patterns_end
;!      mov  @upload_destination,hl     ; LD HL,($72D8)     ; Get destination address (only used locally)
;;       movb h,a                        ; LD A,H            ; Is it zero?
;;       socb @l,a                       ; OR L              ; ...
;       jne  _aead                      ; JR NZ,$AEAD       ; No - skip ahead
;       li   hl,>2100                   ; LD HL,$2100       ; Yes - set it to $2100
;       mov  hl,@upload_destination     ; LD ($72D8),HL     ; ...
;       li   hl,sprite_pattern_vdp_addrs_table ; LD HL,$72E0       ; Set source to #R$72E0 (pointer to a RAM block)
;       mov  hl,@upload_source          ; LD ($72DC),HL     ; ...
;_aead:                                 ; >aead
;       movb @transformation_processed,a ; LD A,($72D6)      ; Get transformation processed
;       li   hl,pattern_processed       ; LD HL,$72D7       ; OR with pattern processed
;       socb *hl,a                      ; OR (HL)           ; ...
;       jne  _aec4                      ; JR NZ,$AEC4       ; If any is non-zero skip ahead
;       mov  @upload_source,hl          ; LD HL,($72DC)     ; HL = #R$72E0 initially. Table for storing VDP
;                                                           ; addresses.
