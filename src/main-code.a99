;       movb *hl,b                      ; LD B,(HL)         ; B = transformation
;       movb a,@c                       ; LD C,A            ; C = scale
;       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get polar x
;       ab   @bytes+>02,a               ; ADD A,$02         ; Plus 2
;       andi a,>3f00                    ; AND $3F           ; Mod 64
;       movb a,@>05(ix)                 ; LD (IX+$05),A     ; Save in sprite data
;;       ab   one,b                      ; INC B             ; If transformation > 0
;;       sb   one,b                      ; DEC B             ; ...
;       movb b,b
;       jne  _add1                      ; JR NZ,$ADD1       ; Then skip ahead
;       sb   a,a                        ; XOR A             ; Else set A = 0
;       jmp  _add7                      ; JR $ADD7          ; And skip ahead
;_add1:                                 ; >add1
;;       srl  a,1                        ; SRL A             ; Divide polar x by 2
;;       sb   one,b                      ; DJNZ $ADD1        ; B times
;;       jne  _add1                      ;
;;       ab   a,a                        ; ADD A,A           ; * 4
;;       ab   a,a                        ; ADD A,A           ; ...
;       clr  r0
;       movb b,@r0lb
;       srl  a,0
;       andi af,>ff00
;       sla  a,2
;_add7:                                 ; >add7
;       ab   @c,a                       ; ADD A,C           ; + number of patterns - 1
;       movb a,b                        ; LD B,A            ; Copy result into B, which is the index of pattern to
;                                                           ; fetch within sprite type
;       cb   a,@>04(ix)                 ; CP (IX+$04)       ; Same as existing?
;       jeq  _ae11                      ; JR Z,$AE11        ; If so, skip ahead
;       movb a,@>04(ix)                 ; LD (IX+$04),A     ; Save new value
