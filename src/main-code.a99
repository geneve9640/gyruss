* Handle collisions
*
* Used by the routine at #R$80E8.
handle_collisions:                     ; >9796
       movb @allocated_sprites,a       ; LD A,($7182)      ; Allocated sprites
       sb   @bytes+>02,a               ; SUB $02           ; Return if only the ship sprites are allocated
       jne  !                          ; RET Z             ; ...
       .ret                            ;
!
       movb a,b                        ; LD B,A            ; Loop counter for allocated sprites - 2
       li   hl,sprite_allocation_table+>0002 ; LD HL,$7185       ; Table address #R$7183+2 (skip ship sprites)
       sb   a,a                        ; XOR A             ; Reset a flag
       movb a,@offer_double_shot_flag  ; LD ($726E),A      ; ...
handle_collisions_1:                   ; >97a4
       .push hl                        ; PUSH HL           ; Loop start; Save table address
       .push bc                        ; PUSH BC           ; Save counter
;       movb *hl,@l                     ; LD L,(HL)         ; Get sprites allocation table byte
;       sb   h,h                        ; LD H,$00          ; MSB = 0
;       a    hl,hl                      ; ADD HL,HL         ; x4
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       movb h,d                        ; LD D,H            ; DE = x4
;       movb @l,@e                      ; LD E,L            ; ...
;       mov  hl,de
;       a    hl,hl                      ; ADD HL,HL         ; x8
;       a    de,hl                      ; ADD HL,DE         ; x12
;       .ex_de_hl                       ; EX DE,HL          ; DE = x12
       clr  de
       movb *hl,@e
       li   hl,12
       mpy  hl,de
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data table base
       a    hl,ix                      ; ADD IX,DE         ; Add offset so that IX = current sprite data
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>7f               ; CP $7F            ; If deallocated value
       jeq  handle_collisions_2        ; JR Z,$97F3        ; Then move to next sprite
       movb @>01(ix),r0                ; BIT 7,(IX+$01)    ; If bit 7 of polar y is set
       jlt  handle_collisions_2        ; JR NZ,$97F3       ; Then move to next sprite
       cb   a,@bytes+>02               ; CP $02            ; Is it a shot?
       jne  !                          ; JP Z,$9861        ; Then jump to handler
       b    @handle_shot_collision     ;
!
       cb   a,@bytes+>0d               ; CP $0D            ; Is it < $0D (numbers or destroyed enemy)?
       jl   handle_collisions_2        ; JR C,$97F3        ; Then move on to next sprite
       movb @status_flags,a            ; LD A,($71EB)      ; Is it chance stage?
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jne  handle_collisions_2        ; JR NZ,$97F3       ; Then move to next sprite
       movb @>07(ix),r0                ; BIT 7,(IX+$07)    ; If the flag bit 7 set in sprite data
       jlt  handle_collisions_2        ; JR NZ,$97F3       ; Then move to next sprite
       li   iy,sprite_data             ; LD IY,$7002       ; Ship sprite data
;       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Is polar x = ship x?
;       cb   a,@>01(iy)                 ; CP (IY+$01)       ; ...
       cb   @>01(ix),@>01(iy)
       jne  handle_collisions_2        ; JR NZ,$97F3       ; If not, move to next sprite
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Polar x for sprite
       movb @>02(iy),b                 ; LD B,(IY+$02)     ; Polar x for ship
       bl   @polar_x_distance          ; CALL $9A86        ; Polar x distance
       cb   a,@bytes+>02               ; CP $02            ; Is distance < 2
       jhe  handle_collisions_2        ; JP C,$9A38        ; Then jump to collision handler
       b    @ship_hit_sprite           ;
* This entry point is used by the routines at #R$9861, #R$9978 and #R$9A49.
handle_collisions_2:                                 ; >97f3
       .pop bc                         ; POP BC            ; Restore counter
       .pop hl                         ; POP HL            ; Restore table address
       inc  hl                         ; INC HL            ; Next table address
       sb   one,b                      ; DJNZ $97A4        ; Loop for each allocated sprites (except ship)
       jne  handle_collisions_1                      ;
       movb @mines_left,a              ; LD A,($722D)      ; Are there any mines left?
;       socb a,a                        ; OR A              ; ...
       jeq  _982e                      ; JR Z,$982E        ; Skip ahead if not
       li   iy,mines_background_data   ; LD IY,$7237       ; Mine data address
       li   de,>0009                   ; LD DE,$0009       ; Size of each mine structure
       movb @bytes+>03,b               ; LD B,$03          ; 3 mines
       li   ix,sprite_data             ; LD IX,$7002       ; Ship sprite data
_980b:                                 ; >980b
       .push bc                        ; PUSH BC           ; Save counter
       movb @>04(iy),a                 ; LD A,(IY+$04)     ; If mine is gone
       socb @>05(iy),a                 ; OR (IY+$05)       ; ...
       jeq  _9829                      ; JR Z,$9829        ; Then move to next mine
       movb @>07(iy),a                 ; LD A,(IY+$07)     ; Get mine polar y?
       cb   a,@bytes+>06               ; CP $06            ; If >= 6
       jhe  _9829                      ; JR NC,$9829       ; Then move to next mine
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get ship polar x
       movb @>08(iy),b                 ; LD B,(IY+$08)     ; Get mine polar x
       bl   @polar_x_distance          ; CALL $9A86        ; Polar x distance
       cb   a,@bytes+>07               ; CP $07            ; If < 7
       jhe  _9829
       .call @ship_hit_mine            ; CALL C,$9A75      ; Then call collision routine
_9829:                                 ; >9829
       a    de,iy                      ; ADD IY,DE         ; Next mine
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $980B        ; Loop for 3 mines
       jne  _980b                      ;
_982e:                                 ; >982e
       movb @offer_double_shot_flag,a ; LD A,($726E)      ; Check a flag
       movb a,r0                       ; BIT 0,A           ; ...
       andi r0,>0100                   ;
       jne  !                          ; RET Z             ; Return if not
       .ret                            ;
!
       .call @create_double_shot_sprite ; CALL $9845        ; Create double shot sprite
       movb @bytes+>02,@>07(ix)        ; LD (IX+$07),$02   ; Polar x velocity
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       .call @create_double_shot_sprite ; CALL $9845        ; Create double shot sprite
       movb @b254,@>07(ix)             ; LD (IX+$07),$FE   ; Polar x velocity
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       .ret                            ; RET               ;

* Create double shot pickup sprite
*
* Used by the routine at #R$9796.
create_double_shot_sprite:             ; >9845
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>03,*ix             ; LD (IX+$00),$03   ; Double shot circle
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Get ship polar x
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set as sprite polar x
       movb @bytes+>10,@>03(ix)        ; LD (IX+$03),$10   ; Set counter
       movb @bytes+>02,@>0b(ix)        ; LD (IX+$0B),$02   ; Set color
       li   hl,total_enemies           ; LD HL,$7206       ; Increment total enemies
       ab   one,*hl                    ; INC (HL)          ; ...
       .ret                            ; RET               ;

* Handle shot (from ship) collision
*
* Used by the routine at #R$9796.
*
* I:IX Sprite data address of shot
handle_shot_collision:                 ; >9861
       movb @other_flags,a             ; LD A,($7256)      ; Flags
       movb a,@c                       ; LD C,A            ; C = flags
* Check collision with sprites
       li   iy,sprite_data_2           ; LD IY,$701A       ; Data for sprite  2
       movb @bytes+>1e,b               ; LD B,$1E          ; 30 sprites
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
_986e:                                 ; >986e
       movb *iy,r0                     ; BIT 7,(IY+$00)    ; If deallocated
       andi r0,>8000                   ;
       jne  _98bb                      ; JR NZ,$98BB       ; Then move to next sprite
       movb @>01(iy),r0                ; BIT 7,(IY+$01)    ; If polar y is out of range
       andi r0,>8000                   ;
       jne  _98bb                      ; JR NZ,$98BB       ; Then move to next sprite
       movb *iy,a                      ; LD A,(IY+$00)     ; Get sprite type
       cb   a,@bytes+>7f               ; CP $7F            ; If deallocated
       jeq  _98bb                      ; JR Z,$98BB        ; Then move to next sprite
       cb   a,@bytes+>0d               ; CP $0D            ; If < $0D (explosion dot, should this have been $0E?)
       jl   _98bb                      ; JR C,$98BB        ; Then move to next sprite
       cb   a,@bytes+>17               ; CP $17            ; If laser fence
       jeq  _98bb                      ; JR Z,$98BB        ; Then move to next sprite
       cb   a,@bytes+>12               ; CP $12            ; If < $12 (enemy missile)
       jl   _9891                      ; JR C,$9891        ; Then do further checks
       cb   a,@bytes+>15               ; CP $15            ; if < $15 (last fence end)
       jl   _98bb                      ; JR C,$98BB        ; Then move to next sprite
* $0D <= type <= $11 or type >= $15 except $17
_9891:                                 ; >9891
       movb @>01(iy),a                 ; LD A,(IY+$01)     ; Polar y other sprite
       sb   @>01(ix),a                 ; SUB (IX+$01)      ; Minus polar y shot
;       jnc  _989b                      ; JR NC,$989B       ; Absolute value
;       neg a                           ; NEG               ; ...
;_989b:                                 ; >989b
       andi af,>ff00
       abs  a
       cb   a,@bytes+>02               ; CP $02            ; If >= 2
       jhe  _98bb                      ; JR NC,$98BB       ; Then move to next sprite
       movb @>02(iy),a                 ; LD A,(IY+$02)     ; Polar x other sprite
       movb @c,r0                      ; BIT 1,C           ; Is double shot activated?
       andi r0,>0200                   ;
       jeq  _98b5                      ; JR Z,$98B5        ; If not, we need a precise match on x
       .push bc                        ; PUSH BC           ; Save counter
       movb @>02(ix),b                 ; LD B,(IX+$02)     ; Polar x other sprite
       bl   @polar_x_distance          ; CALL $9A86        ; Polar x distance
       .pop bc                         ; POP BC            ; Restore counter
       cb   a,@bytes+>03               ; CP $03            ; If distance < 3
       jhe  !                          ; JP C,$9924        ; Then we have a hit
       b    @shot_hit_sprite           ;
!
       jmp  _98bb                      ; JR $98BB          ; Then move to next sprite
_98b5:                                 ; >98b5
       cb   a,@>02(ix)                 ; CP (IX+$02)       ; Compare to polar x of shot
       jne  !                          ; JP Z,$9924        ; If equal we have a hit
       b    @shot_hit_sprite           ;
!
_98bb:                                 ; >98bb
       equ  $
       a    de,iy                      ; ADD IY,DE         ; Next sprite address
       sb   one,b                      ; DJNZ $986E        ; Loop for 30 sprites
       jne  _986e                      ;
* Check for collision with center enemies
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>23               ; CP $23            ; if < 35
       jl   _98ee                      ; JR C,$98EE        ; Then skip this step (not in center)
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of enemies in map
;       socb a,a                        ; OR A              ; If zero
       jeq  _98ee                      ; JR Z,$98EE        ; Then skip this step
       li   hl,center_enemy_map        ; LD HL,$7207       ; Map address
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
_98d1:                                 ; >98d1
       movb *hl,r0                     ; BIT 7,(HL)        ; If not allocated
       andi r0,>8000                   ;
       jne  _98eb                      ; JR NZ,$98EB       ; Then move on to next
       bl   @polar_coord_from_map     ; CALL $AB38        ; Now DE contains polar y,x
       movb d,a                        ; LD A,D            ; Polar y
       sb   @>01(ix),a                 ; SUB (IX+$01)      ; Subtract polar y of shot
;       jnc  _98e0                      ; JR NC,$98E0       ; Take absolute value
;       neg a                           ; NEG               ; ...
;_98e0:                                 ; >98e0
       andi af,>ff00
       abs  a
       cb   a,@bytes+>02               ; CP $02            ; If < 2
       jhe  _98eb                      ; JR NC,$98EB       ; Then move on to next
       movb @e,a                       ; LD A,E            ; Polar x
       cb   a,@>02(ix)                 ; CP (IX+$02)       ; Compare to polar x of shot
       jne  !                          ; JP Z,$99A0        ; If equal we have a hit
       b    @shot_hit_center_enemy     ;
!
_98eb:                                 ; >98eb
       equ  $
       inc  hl                         ; INC HL            ; Next map address
       sb   one,b                      ; DJNZ $98D1        ; Loop for all map entries
       jne  _98d1                      ;
* Check for collision with mines
_98ee:                                 ; >98ee
       li   iy,mines_background_data   ; LD IY,$7237       ; Mine data
       li   de,>0009                   ; LD DE,$0009       ; Size of each mine structure
       movb @bytes+>03,b               ; LD B,$03          ; 3 mines
_98f7:                                 ; >98f7
       movb @>04(iy),a                 ; LD A,(IY+$04)     ; If mine is gone
       socb @>03(iy),a                 ; OR (IY+$03)       ; ...
       jeq  _991d                      ; JR Z,$991D        ; Then move to next mine
       movb @>07(iy),a                 ; LD A,(IY+$07)     ; Get polar y of mine
       sb   @>01(ix),a                 ; SUB (IX+$01)      ; Subtract polar y of shot
;       jnc  _9909                      ; JR NC,$9909       ; Absolute value
;       neg a                           ; NEG               ; ...
;_9909:                                 ; >9909
       andi af,>ff00
       abs  a
       cb   a,@bytes+>02               ; CP $02            ; >= 2
       jhe  _991d                      ; JR NC,$991D       ; Then move on to next mine
       .push bc                        ; PUSH BC           ; Save counter
       movb @>08(iy),a                 ; LD A,(IY+$08)     ; Get polar x of mine
       movb @>02(ix),b                 ; LD B,(IX+$02)     ; Get polar x of shot
       bl   @polar_x_distance          ; CALL $9A86        ; Polar x distance
       .pop bc                         ; POP BC            ; Restore counter
       cb   a,@bytes+>04               ; CP $04            ; If distance is < 4
       jhe  !                          ; JP C,$99B1        ; Then we have a hit
       b    @shot_hit_mine             ;
!
_991d:                                 ; >991d
       equ  $
       a    de,iy                      ; ADD IY,DE         ; Next mine address
       sb   one,b                      ; DJNZ $98F7        ; Loop for 3 mines
       jne  _98f7                      ;
       b    @handle_collisions_2                     ; JP $97F3          ; Jump back into collisions loop

* Shot hit sprite
*
* Used by the routines at #R$9861.
*
* I:IX Sprite data of shot
* I:IY Sprite data of other
shot_hit_sprite:                       ; >9924
       movb *iy,a                      ; LD A,(IY+$00)     ; Get sprite type
       cb   a,@bytes+>18               ; CP $18            ; If >= $18 (uncommon enemies)
       jhe  shot_hit_sprite_enemy      ; JR NC,$9934       ; Then jump to enemy handler
       cb   a,@bytes+>15               ; CP $15            ; If >= $15 and =< $17 (laser fence)
       jl   !                          ; JP NC,$9A08       ; Then jump to handler
       b    @shot_hit_laser_fence      ;
!
       movb one,a                      ; LD A,$01          ; Else set sound to 1
       jmp  _9936                      ; JR $9936          ; And jump to enemy handler

* Shot hit sprite enemy
*
* Used by the routine at #R$9924.
*
* I:A Sound to play
* I:IX Sprite data of shot
* I:IY Sprite data of enemy
shot_hit_sprite_enemy:                 ; >9934
       movb @bytes+>04,a               ; LD A,$04          ; Sound = 4
* This entry point is used by the routine at #R$9924.
_9936:                                 ; >9936
       .call @call_play_sound          ; CALL $9EA3        ; Play sound
       .push ix                        ; PUSH IX           ; Save shot address
       .push iy                        ; PUSH IY           ; Save enemy address
       .pop ix                         ; POP IX            ; IX = enemy address
       .call @deallocate_sprite_from_map ; CALL $AB53        ; Deallocate from map
       .pop ix                         ; POP IX            ; IX = shot address
       movb @bytes+>7f,*iy             ; LD (IY+$00),$7F   ; Set enemy sprite type to unallocated
       movb @>0b(iy),d                 ; LD D,(IY+$0B)     ; Get color
       .call @remove_shot              ; CALL $9A1C        ; Remove shot
       li   de,>0100                   ; LD DE,$0100       ; Points
       li   hl,bonus_enemies_hit       ; LD HL,$7255       ; Record hit
       ab   one,*hl                    ; INC (HL)          ; ...
       li   hl,active_enemies          ; LD HL,$722C       ; Decrement active enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne  add_points_in_de           ; JR NZ,$9999       ; If still active enemies then add default points
       movb @status_flags,a            ; LD A,($71EB)      ; Are all waves complete?
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jeq  add_points_from_enemy      ; JR Z,$9978        ; If not add points from enemy
       movb @other_flags,a             ; LD A,($7256)      ; Test wave flag
       czc  @bit5,a                    ; BIT 5,A           ; ...
       jne  add_points_in_de           ; JR NZ,$9999       ; If not wave then add default points
       movb @center_map_entries,a      ; LD A,($722B)      ; Get center enemies
;       socb a,a                        ; OR A              ; Is it zero?
       jne  add_points_in_de           ; JR NZ,$9999       ; If not, add default points
       li   de,>1100                   ; LD DE,$1100       ; A lot more points
       movb @bytes+>07,@>06(ix)        ; LD (IX+$06),$07   ; Points sprite to show?
       jmp  add_points_in_de           ; JR $9999          ; Add points

* Add score when enemy destroyed
*
* Used by the routine at #R$9934.
*
* I:IX Sprite data of shot
* I:DE Points to add
add_points_from_enemy:                 ; >9978
       movb @other_flags,a             ; LD A,($7256)      ; Flags
       andi a,>6000                    ; AND $60           ; If bit 5 or 6 set?
       jne  add_points_in_de           ; JR NZ,$9999       ; Then just add score
       li   hl,status_flags            ; LD HL,$71EB       ; Flags
       movb @enemies_hit,a             ; LD A,($7202)      ; Enemies destroyed
       ab   one,a                      ; INC A             ; +1
       movb *hl,r0                     ; BIT 3,(HL)        ; Check for chance stage
       andi r0,>0800                   ;
       jne  _998d                      ; JR NZ,$998D       ; Skip ahead if chance stage
       movb a,@enemies_hit             ; LD ($7202),A      ; Save if not chance stage
_998d:                                 ; >998d
       ab   a,a                        ; ADD A,A           ; x2
       li   hl,score_table             ; LD HL,$9AA7       ; Score table
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
       movb *hl,d                      ; LD D,(HL)         ; Get points (hundreds)
       inc  hl                         ; INC HL            ; Next address in table
       movb *hl,a                      ; LD A,(HL)         ; Get replacement number sprite type ($06 - $0B)
       movb a,@>06(ix)                 ; LD (IX+$06),A     ; Save in sprite data
       ab   one,d                      ; INC D             ; 100 more
* This entry point is used by the routines at #R$9934, #R$99A0, #R$99D3 and
* #R$9A08.
add_points_in_de:                      ; >9999
       .ex_de_hl                       ; EX DE,HL          ; HL = points
       .call @add_score                ; CALL $A6EC        ; Add score
       b    @handle_collisions_2                     ; JP $97F3          ; Jump back into collisions loop

* Shot hit center enemy
*
* Used by the routine at #R$9861.
*
* I:IX Sprite data of shot
* I:HL Map address of other
shot_hit_center_enemy:                 ; >99a0
       movb *hl,d                      ; LD D,(HL)         ; Get map entry (color)
       bl   @deallocate_map_entry     ; CALL $AAE3        ; Deallocate map entry
       .call @remove_shot              ; CALL $9A1C        ; Remove shot
       movb one,a                      ; LD A,$01          ; Play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       li   de,>0100                   ; LD DE,$0100       ; Add points
       jmp  add_points_in_de           ; JR $9999          ; ...

* Shot hit mine
*
* Used by the routine at #R$9861.
*
* I:IX Sprite data of shot
* I:IY Mine data
shot_hit_mine:                         ; >99b1
       movb @bytes+>0f,d               ; LD D,$0F          ; Color
       .call @remove_shot              ; CALL $9A1C        ; Remove shot
       movb @>06(iy),a                 ; LD A,(IY+$06)     ; Get mine data ?
       cb   a,@bytes+>80               ; CP $80            ; If not $80
       jne  _99d3                      ; JR NZ,$99D3       ; Then jump ahead
       movb @bytes+>08,a               ; LD A,$08          ; Play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       movb @other_flags,a             ; LD A,($7256)      ; If double shot is enabled
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jne  _99d3                      ; JR NZ,$99D3       ; Then skip offering double shot
       li   hl,offer_double_shot_flag  ; LD HL,$726E       ; Set flag for offering double shot
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
       li   de,>0500                   ; LD DE,$0500       ; Points
       jmp  _99ea                      ; JR $99EA          ; Jump ahead
_99d3:                                 ; >99d3
       movb @bytes+>04,a               ; LD A,$04          ; Play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       li   hl,mines_destroyed         ; LD HL,$7254       ; Get mines destroyed
       movb *hl,a                      ; LD A,(HL)         ; ...
       ab   one,*hl                    ; INC (HL)          ; Increment mines destroyed
       ab   a,a                        ; ADD A,A           ; x2
       li   hl,score_table             ; LD HL,$9AA7       ; Score table
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
       movb *hl,d                      ; LD D,(HL)         ; Get points (hundreds)
       inc  hl                         ; INC HL            ; Next address in table
       movb *hl,a                      ; LD A,(HL)         ; Get points sprite type ($06 - $0B)
       movb a,@>06(ix)                 ; LD (IX+$06),A     ; Save in sprite data
       sb   @e,@e                      ; LD E,$00          ; LSB of points
* This entry point is used by the routine at #R$99B1.
_99ea:                                 ; >99ea
       .push de                        ; PUSH DE           ; Save score
       sb   @>04(iy),@>04(iy)          ; LD (IY+$04),$00   ; Remove mine
       sb   @>05(iy),@>05(iy)          ; LD (IY+$05),$00   ; ...
       .push ix                        ; PUSH IX           ;
       .call @display_background_patterns ; CALL $8B12        ; Display background patterns
       li   hl,mines_left              ; LD HL,$722D       ; Decrement mines left
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne  _9a03                      ; JR NZ,$9A03       ; Skip ahead if any left
       li   hl,other_flags             ; LD HL,$7256       ; Clear mines flag
       szcb @bits+2,*hl                ; RES 2,(HL)        ; ...
_9a03:                                 ; >9a03
       .pop ix                         ; POP IX            ;
       .pop de                         ; POP DE            ; Restore score
       jmp  add_points_in_de           ; JR $9999          ; Add points to score

* Shot hit laser fence
*
* Used by the routine at #R$9924.
*
* I:IX Sprite data of shot
shot_hit_laser_fence:                  ; >9a08
       movb @bytes+>7f,*iy             ; LD (IY+$00),$7F   ; Set sprite type to unallocated
       li   hl,other_flags             ; LD HL,$7256       ; Reset flag
       szcb @bits+3,*hl                ; RES 3,(HL)        ; ...
       movb @bytes+>0f,d               ; LD D,$0F          ; Color
       .call @remove_shot              ; CALL $9A1C        ; Remove shot
       li   de,>0200                   ; LD DE,$0200       ; Points
       b    @add_points_in_de          ; JP $9999          ; Add points

* Remove shot
*
* Used by the routines at #R$9934, #R$99A0, #R$99B1 and #R$9A08.
*
* I:D Color of 'explosion'
* I:IX Sprite data of shot
remove_shot:                           ; >9a1c
       movb @bytes+>04,*ix             ; LD (IX+$00),$04   ; Set sprite type to destroyed
       movb d,@>0b(ix)                 ; LD (IX+$0B),D     ; Set color
       movb @bytes+>0f,@>03(ix)        ; LD (IX+$03),$0F   ; Set animation counter
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ;
       li   hl,active_shots            ; LD HL,$7253       ; Decrement active shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies (hmm, why here?)
       sb   one,*hl                    ; DEC (HL)          ; ...
       .ret                            ; RET               ;

* Collision of ship with sprite
*
* Used by the routine at #R$9796.
*
* I:IX Sprite data of other sprite
* I:IY Sprite data of ship
ship_hit_sprite:                       ; >9a38
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>12               ; CP $12            ; If < $12
       jl   ship_hit_enemy             ; JR C,$9A49        ; Then handle collision with enemy
       cb   a,@bytes+>14               ; CP $14            ; If >= $14
       jhe  ship_hit_enemy             ; JR NC,$9A49       ; Then handle collision with enemy
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Decrement enemy shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       jmp  ship_hit_enemy_2           ; JR $9A6D          ; Set died flag and return

* Collision of ship with enemy
*
* Used by the routine at #R$9A38.
*
* I:A enemy type
* I:IX Sprite data of other sprite
* I:IY Sprite data of ship
ship_hit_enemy:                        ; >9a49
       cb   a,@bytes+>0e               ; CP $0E            ; If < $0E
       jl   ship_hit_enemy_2           ; JR C,$9A6D        ; Then set died flag and return
       cb   a,@bytes+>12               ; CP $12            ; If >= $12
       jhe  ship_hit_enemy_2           ; JR NC,$9A6D       ; Then set died flag and return
       li   hl,active_enemies          ; LD HL,$722C       ; Decrement active enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       .call @deallocate_sprite_from_map ; CALL $AB53        ; Deallocate from map
       movb @bytes+>04,*ix             ; LD (IX+$00),$04   ; Set sprite type to destroyed
       movb @bytes+>0f,@>03(ix)        ; LD (IX+$03),$0F   ; Set animation counter
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ;
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
* This entry point is used by the routine at #R$9A75.
ship_hit_enemy_1:                      ; >9a69
       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
* This entry point is used by the routine at #R$9A38.
ship_hit_enemy_2:                      ; >9a6d
       li   hl,status_flags            ; LD HL,$71EB       ; Set died flag
       socb @bits+2,*hl                ; SET 2,(HL)        ; ...
       b    @handle_collisions_2       ; JP $97F3          ; Jump back into collisions loop

* Collision of ship with mine
*
* Used by the routine at #R$9796.
*
* I: IX Sprite data of ship
* I: IY Mine data
ship_hit_mine:                         ; >9a75
       movb @zero,@>04(iy)             ; LD (IY+$04),$00   ; Remove mine
       movb @zero,@>05(iy)             ; LD (IY+$05),$00   ; ...
       .call @display_background_patterns ; CALL $8B12        ; Display background patterns
       li   hl,mines_left              ; LD HL,$722D       ; Decrement mines left
       sb   one,*hl                    ; DEC (HL)          ; ...
       jmp  ship_hit_enemy_1                      ; JR $9A69          ; Die and return to loop

* Polar x distance
*
* Used by the routines at #R$870C, #R$9796, and #R$9861.
*
* I: A Polar x1
* I: B Polar x2
polar_x_distance:                      ; >9a86
       movb a,r0                       ; LD ($726F),A      ; Store polar x1
       sb   b,a                        ; SUB B             ; Polar x1 - polar x2
;       jnc  _9a8e                      ; JR NC,$9A8E       ; Jump ahead of >= 0
;       neg a                           ; NEG               ; Else make positive
;_9a8e:                                 ; >9a8e
       andi af,>ff00
       abs  a
       cb   a,@bytes+>20               ; CP $20            ; Is it < 32?
       jl   polar_x_distance_3         ; RET C             ; Then return
       movb r0,a                       ; LD A,($726F)      ; Restore polar x1
       cb   a,@bytes+>20               ; CP $20            ; Is it >= 32?
       jhe  polar_x_distance_1         ; JR NC,$9A9A       ; Then skip ahead
       ab   @bytes+>40,a               ; ADD A,$40         ; Else add 64
polar_x_distance_1:                    ; >9a9a
       movb a,r0                       ; LD C,A            ; Store in C
       movb b,a                        ; LD A,B            ; Get polar x2
       cb   a,@bytes+>20               ; CP $20            ; Is it >= 32?
       jhe  polar_x_distance_2         ; JR NC,$9AA2       ; Then skip ahead
       ab   @bytes+>40,a               ; ADD A,$40         ; Else add 64
polar_x_distance_2:                    ; >9aa2
       movb a,r1
       sb   r0,a                       ; SUB C             ; Subtract the modified polar x1
       cb   r0,r1
       jhe  polar_x_distance_3         ; RET NC            ; Return if >= 0
       andi af,>ff00
       neg a                           ; NEG               ; Else make positive
polar_x_distance_3:
       rt                              ; RET               ; And return

* Score table
score_table:                           ; >9aa7
       byte >05,>06
       byte >10,>07
       byte >15,>08
       byte >20,>09
       byte >25,>0A
       byte >30,>0B

* Add A to HL (RST $08)
*
* Used by the routine at #R$800C.
add_a_to_hl:                           ; >9ab3
;       .push af                        ; PUSH AF           ;
;       ab   @l,a                       ; ADD A,L           ;
;       movb a,@l                       ; LD L,A            ;
;       jnc  _9ab9                      ; JR NC,$9AB9       ;
;       ab   one,h                      ; INC H             ;
;_9ab9:                                 ; >9ab9
;       .pop af                         ; POP AF            ;
       clr  r0
       movb a,@r0lb
       a    r0,hl
       rt                              ; RET               ;

vdp_write_address:
       movb @e,@vdpwa
       mov  de,r0
       ori  r0,>4000
       movb r0,@vdpwa
       rt

* VDP write byte (RST $10)
*
* Used by the routine at #R$800F.
*
* I:DE Write address I:A byte to write
vdp_write_byte:                        ; >9ac3
;       .push af                        ; PUSH AF           ;
;       movb @e,a                       ; LD A,E            ; LSB
;       movb a,@vdpwa                   ; OUT ($BF),A       ; Set LSB of VDP address
       movb @e,@vdpwa
;       movb d,a                        ; LD A,D            ; MSB
;       socb @bytes+>40,a               ; OR $40            ; Setup write address
;       movb a,@vdpwa                   ; OUT ($BF),A       ; Set MSB of VDP address
;       .pop af                         ; POP AF            ;
       movb d,r0
       ori  r0,>4000
       movb r0,@vdpwa
       movb a,@vdpwd                   ; OUT ($BE),A       ; Write byte
       rt                              ; RET               ;

* VDP read byte
*
* Used by the routine at #R$AFE5.
*
* I:DE Read address
* O:A Byte read
vdp_read_byte:                         ; >9ad0
;       movb @e,a                       ; LD A,E            ; Set LSB of VDP address
;       movb a,@vdpwa                   ; OUT ($BF),A       ;
       movb @e,@vdpwa
;       movb d,a                        ; LD A,D            ;
;       movb a,@vdpwa                   ; OUT ($BF),A       ; Set MSB of VDP address
       movb d,@vdpwa
;       .push ix                        ; PUSH IX           ; Delay
;       .pop ix                         ; POP IX            ;
       nop                             ; NOP               ;
       movb @vdprd,a                   ; IN A,($BE)        ; Read byte
       rt                              ; RET               ;

* Initial game loop
*
* Used by the routine at #R$82BF.
initial_game_loop:                     ; >a33b
       li   hl,>80b5                   ; LD HL,$80B5       ; New center of projection at bottom center for
                                                           ; implosion
       mov  hl,@tmp_center_of_projection ; LD ($72C5),HL     ; Set #R$72C5, which will be copied to #R$7000
       li   hl,status_flags            ; LD HL,$71EB       ; Status flags
       socb @bits+4,*hl                ; SET 4,(HL)        ; Set bit 4
* Allocate 6 dot sprites for the implosion that becomes the ship
       li   iy,_a4b2                   ; LD IY,$A4B2       ; Sprite init data
       movb @bytes+>06,b               ; LD B,$06          ; Allocate 6 sprites
display_implosion:                     ; >a34c
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>0d,*ix             ; LD (IX+$00),$0D   ; Sprite type is $0D (a dot)
       movb @zero,@>01(ix)             ; LD (IX+$01),$00   ; Polar y
       movb @zero,@>02(ix)             ; LD (IX+$02),$00   ; Polar x
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       movb @bytes+>16,@>01(ix)        ; LD (IX+$01),$16   ; Polar y
       movb *iy,a                      ; LD A,(IY+$00)     ; Get init data
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Polar x
       movb @bytes+>09,@>0b(ix)        ; LD (IX+$0B),$09   ; Set color (pink)
       inc  iy                         ; INC IY            ; Next init data
       sb   one,b                      ; DJNZ $A34C        ; Loop for 6 sprites
       jne  display_implosion                      ;
* Display implosion
       movb @bytes+>14,b               ; LD B,$14          ; 20
implosion_loop:                        ; >a36e
       .push bc                        ; PUSH BC           ; Save counter
        bl   @wait_int_play_sound
       .call @move_dots                ; CALL $A471        ; Move dots
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $A36E        ; Loop 20 times
       jne  implosion_loop                      ;
* Allocate ship etc.
       .call @init_sprite_data         ; CALL $ACDF        ;
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       sb   *ix,*ix                    ; LD (IX+$00),$00   ; Sprite type $00 (ship body)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>06,@>0b(ix)        ; LD (IX+$0B),$06   ; Set color (red)
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb one,*ix                    ; LD (IX+$00),$01   ; Sprite type $01 (ship exhaust)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>04,@>0b(ix)        ; LD (IX+$0B),$04   ; Set color (blue)
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       .call @display_ship_bg_patterns ; CALL $A808        ; Display ship background patterns
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       movb @bytes+>07,a               ; LD A,$07          ; Play a sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
* Game loop 60 times
       movb @bytes+>3c,b               ; LD B,$3C          ; 60
stage_init_loop:                       ; >a3b6
       .push bc                        ; PUSH BC           ; Save counter
       bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $A3B6        ; Loop 60 times
       jne  stage_init_loop                      ;
       li   hl,>1a00                   ; LD HL,$1A00       ; Clear warps line
       li   de,>0020                   ; LD DE,$0020       ; ...
       sb   a,a                        ; XOR A             ; ...
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       movb @status_flags,a            ; LD A,($71EB)      ; Status
       czc  @bit7,a                    ; BIT 7,A           ; Check bit for two players
       jeq  initial_game_loop_1        ; RET Z             ; Return if not
       li   hl,>192c                   ; LD HL,$192C       ; Clear player message
       li   de,>0008                   ; LD DE,$0008       ; ...
       sb   a,a                        ; XOR A             ; ...
       bl   @fill_vram                 ; JP $1F82          ; FILL_VRAM and return
initial_game_loop_1:
       .ret

* Explode
*
* Used by the routine at #R$8139.
explode:                               ; >a3e1
       movb @bytes+>2a,a               ; LD A,$2A          ;
       movb a,@sprite_data+>0001       ; LD ($7003),A      ;
       .call @display_ship_bg_patterns ; CALL $A808        ; Display ship background patterns
       movb @bytes+>7f,a               ; LD A,$7F          ; Not allocated
       movb a,@sprite_data             ; LD ($7002),A      ; 1st sprite
       movb a,@sprite_data_1           ; LD ($700E),A      ; 2nd sprite
       movb @active_shots,a            ; LD A,($7253)      ; Active shots
;       socb a,a                        ; OR A              ; If zero
       jeq  explode_3                  ; JR Z,$A413        ; Then skip ahead
* Deallocate all shots
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data table
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       movb @bytes+>20,b               ; LD B,$20          ; 32 sprites
       movb @bytes+>02,a               ; LD A,$02          ; Is it type $02 (shot)?
explode_1:                             ; >a402
       cb   a,*ix                      ; CP (IX+$00)       ; ...
       jne  explode_2                  ; JR NZ,$A40F       ; No, then skip
       movb @bytes+>7f,*ix             ; LD (IX+$00),$7F   ; Set as not allocated
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
explode_2:                             ; >a40f
       a    de,ix                      ; ADD IX,DE         ; Next sprite
       sb   one,b                      ; DJNZ $A402        ; Loop 32 times
       jne  explode_1                      ;
* Set center of projection for explosion
explode_3:                              ; >a413
;       mov  @sprite_data+>0008,hl      ; LD HL,($700A)     ; Y and X of 1st sprite
       movb @sprite_data+8,@l
       movb @sprite_data+9,h
;       li   bc,>0404                   ; LD BC,$0404       ; Add 4 to each
;       a    bc,hl                      ; ADD HL,BC         ; ...
       ai   hl,>0404
       mov  hl,@tmp_center_of_projection ; LD ($72C5),HL     ; Save it in #R$72C5, which will be copied to #R$7000
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Byte 2 of 1st sprite
       movb a,@tmp_sprite_data         ; LD ($72C7),A      ; Save it temporary
* Allocate 6 sprites for explosion
       li   iy,_a4b8                   ; LD IY,$A4B8       ;
       movb @bytes+>06,b               ; LD B,$06          ; Allocate 6 sprites
explode_4:                                 ; >a429
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>0d,*ix             ; LD (IX+$00),$0D   ; Sprite type is $0D (a dot)
       movb @zero,@>01(ix)             ; LD (IX+$01),$00   ; Polar y
       movb @zero,@>02(ix)             ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>09,@>0b(ix)        ; LD (IX+$0B),$09   ; Set color (pink)
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       movb @tmp_sprite_data,a         ; LD A,($72C7)      ; Restore byte 2 of 1st sprite
       ab   *iy,a                      ; ADD A,(IY+$00)    ; Add data from table
       andi a,>3f00                    ; AND $3F           ; Mod $40
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x on new sprite
       movb @bytes+>2a,@>01(ix)        ; LD (IX+$01),$2A   ; Set polar y
       inc  iy                         ; INC IY            ; Next init data
       sb   one,b                      ; DJNZ $A429        ; Loop for 6 sprites
       jne  explode_4                  ;
* Game loop for 3 seconds
       movb @bytes+>14,b               ; LD B,$14          ; 20
explode_loop_1:                        ; >a450
       .push bc                        ; PUSH BC           ; Outer loop
       .call @move_dots                ; CALL $A471        ; Move dots
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       movb @bytes+>09,b               ; LD B,$09          ; 9
explode_loop_2:                        ; >a459
       .push bc                        ; PUSH BC           ;
       bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @create_or_display_mines  ; CALL $8E2D        ;
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ;
       sb   one,b                      ; DJNZ $A459        ; Loop 9 times
       jne  explode_loop_2             ;
       .pop bc                         ; POP BC            ;
       sb   one,b                      ; DJNZ $A450        ; Loop 20 times
       jne  explode_loop_1             ;
       .ret                            ; RET               ;

* Move explosion dots
*
* Change polar y of sprite types $0D, according to bit 2 of #R$71EB. Used by
* the routines at #R$A33B and #R$A3E1.
move_dots:                             ; >a471
       mov  @tmp_center_of_projection,hl ; LD HL,($72C5)     ; Copy #R$72C5 to #R$7000
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       movb @bytes+>20,b               ; LD B,$20          ; 32 sprites
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data
* This entry point is used by the routine at #R$A4A0.
move_dots_1:                           ; >a47d
       movb *ix,a                      ; LD A,(IX+$00)     ; Get type
       cb   a,@bytes+>0d               ; CP $0D            ; Is it $0D (a dot)?
       jne  move_dots_4                ; JR NZ,$A4A4       ; If not then move to next sprite
       .push bc                        ; PUSH BC           ; Save counter
       movb @>01(ix),d                 ; LD D,(IX+$01)     ; Polar y
       movb @>02(ix),@e                ; LD E,(IX+$02)     ; Polar x
       bl   @polar_to_screen           ; CALL $B1C6        ; Polar to screen
       movb d,@>08(ix)                 ; LD (IX+$08),D     ; Set y
       movb @e,@>09(ix)                ; LD (IX+$09),E     ; Set x
       movb @status_flags,a            ; LD A,($71EB)      ; Status
       czc  @bit2,a                    ; BIT 2,A           ; Test bit
       jne  move_dots_2                ; JR NZ,$A4A0       ; If 1, decrement polar y
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Else increment polar y
       jmp  move_dots_3                ; JR $A4A3          ; Skip next
move_dots_2:                           ; >a4a0
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
move_dots_3:                           ; >a4a3
       .pop bc                         ; POP BC            ; Restore counter
move_dots_4:                           ; >a4a4
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       a    de,ix                      ; ADD IX,DE         ; Next sprite
       sb   one,b                      ; DJNZ $A47D        ; Loop 32 times
       jne  move_dots_1                      ;
       li   hl,>8060                   ; LD HL,$8060       ; Set #R$7000 back to original value
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       .ret                            ; RET               ;

* Init data for implosion
_a4b2:                                 ; >a4b2
       byte >10,>16,>1C,>24,>2A,>30

* Sprite init data (polar x)
_a4b8:                                 ; >a4b8
       byte >F0,>EA,>E4,>1C,>16,>10

* Display score
*
* Used by the routines at #R$8024, #R$80E8 and #R$846B.
*
* I:A Player 0 or 1
display_score:                         ; >a699
       li   ix,score_player_1          ; LD IX,$71F3       ; Score player 1
       movb @bytes+>04,@e              ; LD E,$04          ; Offset into name table player 1
;       socb a,a                        ; OR A              ; If it player 1
       movb a,a
       jeq  display_score_1            ; JR Z,$A6A8        ; The skip ahead
       li   ix,score_player_2          ; LD IX,$71F9       ; Score player 2
       movb @bytes+>18,@e              ; LD E,$18          ; Offset into name table player 2
display_score_1:                       ; >a6a8
       movb @bytes+>18,d               ; LD D,$18          ; MSB of name table in VDP
       li   bc,>0300                   ; LD BC,$0300       ; B = 3 (digits), C = 0 (zero character offset)
display_score_2:                       ; >a6ad
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get 3rd score byte (most significant)
;       srl  a,1                        ; RRA               ; Shift BCD digit into place
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
       srl  a,4
       .call @display_digit            ; CALL $A6C8        ; Display most significant digit
       sb   one,b                      ; DEC B             ; If B > 1
       jne  _a6bc                      ; JR NZ,$A6BC       ; Then don't choose new zero character offset
       movb @bytes+>30,@c              ; LD C,$30          ; Else choose ASCII 0 as zero character offset
_a6bc:                                 ; >a6bc
       ab   one,b                      ; INC B             ; Increment again
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get 3rd score byte (most significant)
       .call @display_digit            ; CALL $A6C8        ; Display least significant digit
       dec  ix                         ; DEC IX            ; Proceed to less significant score bytes
       sb   one,b                      ; DJNZ $A6AD        ; Loop 3 times
       jne  display_score_2                      ;
       .ret                            ; RET               ;

* Display digit
*
* Used by the routine at #R$A699.
*
* I:A Digit 0 - 9
display_digit:                         ; >a6c8
       andi a,>0f00                    ; AND $0F           ; Isolate BCD digit
       jeq  display_digit_1            ; JR Z,$A6CE        ; If zero, skip displaying leading zeros by not setting C
       movb @bytes+>30,@c              ; LD C,$30          ; Use ASCII 0 as zero character offset by default
display_digit_1:                       ; >a6ce
       socb @c,a                       ; OR C              ; Add zero character offset
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next VDP address
       .ret                            ; RET               ;

* Display lives
*
* Used by the routines at #R$82BF and #R$A6EC.
display_lives:                         ; >a6d2
       li   hl,>1ae2                   ; LD HL,$1AE2       ; VDP address of 'lives'
       li   de,>0009                   ; LD DE,$0009       ; Count
       sb   a,a                        ; XOR A             ; Value
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       movb @lives,a                   ; LD A,($71FF)      ; Get lives
       sb   one,a                      ; DEC A             ; Display one less live
       jeq  display_lives_2            ; RET Z             ; Return if none to display
       movb a,b                        ; LD B,A            ; Count
       li   de,>1ae2                   ; LD DE,$1AE2       ; VDP address
       movb @bytes+>21,a               ; LD A,$21          ; Ship character
display_lives_1:                       ; >a6e7
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next VDP address
       sb   one,b                      ; DJNZ $A6E7        ; Loop
       jne  display_lives_1            ;
display_lives_2:
       .ret                            ; RET               ;

* Add points to score
*
* Used by the routines at #R$846B and #R$9978.
*
* I: HL Points to add (BCD, hundreds)
add_score:                             ; >a6ec
       .push de                        ; PUSH DE           ;
       .push bc                        ; PUSH BC           ;
;       mov  hl,@points_to_add          ; LD ($72C8),HL     ; Save points to add (this buffer has one more byte)
       movb @l,@points_to_add
       movb h,@points_to_add+1
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       li   de,score_player_1          ; LD DE,$71F3       ; Score player 1
;       socb a,a                        ; OR A              ; Is it player 1?
       movb a,a
       jeq  add_score_1                ; JR Z,$A6FD        ; The skip ahead
       li   de,score_player_2          ; LD DE,$71F9       ; Score player 2
add_score_1:                           ; >a6fd
       .push de                        ; PUSH DE           ; Save pointer to score
       li   hl,points_to_add           ; LD HL,$72C8       ; Pointer to points to add
       movb @bytes+>03,b               ; LD B,$03          ; 3 bytes in score
       clr  r1
add_score_2:                           ; >a703
       movb *de,a                      ; LD A,(DE)         ; Get score byte
       andi  r1,>1000                  ; Check and add carry
       jeq  !                          ; ...
       ab   one,a                      ; ...
!      ab   *hl,a                      ; ADC A,(HL)        ; Add points
       .daa                            ; DAA               ; Adjust for BCD
       stst r1
       movb a,*de                      ; LD (DE),A         ; Store score byte
       inc  de                         ; INC DE            ; Next score byte
       inc  hl                         ; INC HL            ; Next points byte
       sb   one,b                      ; DJNZ $A703        ; Loop 3 times
       jne  add_score_2                      ;
       .pop de                         ; POP DE            ; Restore pointer to score
;       inc  de                         ; INC DE            ; Advance to last byte of extra life score $71F5 or $71FB
;       inc  de                         ; INC DE            ; ...
       inct de
       li   hl,>0003                   ; LD HL,$0003       ; Point HL to byte at #R$71F8 or #R$71FE (initially set to
                                                           ; 6)
       a    de,hl                      ; ADD HL,DE         ; ...
       .push hl                        ; PUSH HL           ; Save pointer
       movb @bytes+>03,b               ; LD B,$03          ; 3 bytes to check
add_score_3:                           ; >a715
       movb *de,a                      ; LD A,(DE)         ; Get score byte
       cb   a,*hl                      ; CP (HL)           ; Compare with extra life byte
       jne  add_score_4                ; JR NZ,$A71E       ; Exit loop if not equal
       dec  de                         ; DEC DE            ; Previous score byte
       dec  hl                         ; DEC HL            ; Previous extra life byte
       sb   one,b                      ; DJNZ $A715        ; Loop 3 times
       jne  add_score_3                ;
       sb   a,a                        ; XOR A             ; All equal, set A = 0
       mov  a,r0
       jmp  !
add_score_4:                           ; >a71e
       movb *hl,r0
!      .pop hl                         ; POP HL            ; Restore pointer to #R$71F8 or #R$71FE
       cb   a,r0
       jl  add_score_5                 ; JR C,$A739        ; Return if extra life byte was bigger
       movb *hl,a                      ; LD A,(HL)         ; Next extra life at 80000 more points
       ab   @bytes+>08,a               ; ADD A,$08         ; ...
       .daa                            ; DAA               ; ...
       movb a,*hl                      ; LD (HL),A         ; ...
       movb @lives,a                   ; LD A,($71FF)      ; Get lives
       cb   a,@bytes+>09               ; CP $09            ; Return if already 9
       jhe  add_score_5                ; JR NC,$A739       ; ...
       ab   one,a                      ; INC A             ; Extra life
       movb a,@lives                   ; LD ($71FF),A      ; Save it
       .call @display_lives            ; CALL $A6D2        ; Display lives
       movb @bytes+>06,a               ; LD A,$06          ; Play a sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
add_score_5:                           ; >a739
       .pop bc                         ; POP BC            ;
       .pop de                         ; POP DE            ;
       .ret                            ; RET               ;

* Control ship
*
* Control ship movement and fire using controllers.
* Used by the routines at #R$8024, #R$832A, #R$832A, #R$846B and #R$A33B.
control_ship:                          ; >a73c
       movb @frame_counter,a           ; LD A,($71F2)      ; Get frame counter
       andi a,>0100                    ; AND $01           ; Test bit 0
       jne  control_ship_5             ; RET NZ            ; Return every 2nd frame
;       mov  @countdown_to_wave,hl      ; LD HL,($71F0)     ; Controller: #R$71F1
       movb  @current_player,h
       sb   @l,@l                      ; LD L,$00          ; Segment 0
       bl   @decoder                   ; CALL $1F79        ; DECODER (H = fire, L = joystick (bit 0: up, bit 1:
                                                           ; right, bit 2: down, bit 3: left))
       sb   h,h                        ; LD H,$00          ; Reset fire
       li   de,movement_table          ; LD DE,$A865       ; Movement table
       a    de,hl                      ; ADD HL,DE         ; Add joystick result (0 - 12, some values not possible)
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite 0 data (ship body)
       movb one,b                      ; LD B,$01          ; Direction = 1 (clockwise)
       movb *hl,a                      ; LD A,(HL)         ; Get table value, which is the value of polar x to move
                                                           ; towards
       cb   a,@b255                    ; CP $FF            ; Is it an impossible joystick value, e.g. up + down?
       jeq  control_ship_3             ; JR Z,$A781        ; Then skip ahead
       sb   @>02(ix),a                 ; SUB (IX+$02)      ; Table value - polar x
       jeq  control_ship_3             ; JR Z,$A781        ; If zero then skip ahead (already there)
       jgt  control_ship_1             ; JR NC,$A766       ; If positive skip ahead
       movb @b255,b                    ; LD B,$FF          ; Direction = -1 (anti-clockwise)
       andi af,>ff00
       neg a                           ; NEG               ; abs(value - polar x)
control_ship_1:                        ; >a766
;       cb   a,@bytes+>21               ; CP $21            ; Is the difference < 33?
       movb a,r0
       movb b,a                        ; LD A,B            ; Direction
       cb   r0,@bytes+>21
       jl   control_ship_2             ; JR C,$A76D        ; Then skip ahead
       andi af,>ff00
       neg a                           ; NEG               ; Otherwise reverse direction
control_ship_2:                        ; >a76d
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Polar x + direction
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Update polar x
       movb a,@>0e(ix)                 ; LD (IX+$0E),A     ; Also update sprite 1
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern sprite 0
       li   ix,sprite_data_1           ; LD IX,$700E       ; Sprite 1
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern sprite 1
       .call @display_ship_bg_patterns ; CALL $A808        ; Display ship background patterns
* Handle fire
control_ship_3:                        ; >a781
       movb @status_flags,a            ; LD A,($71EB)      ; Test stage init flag
       czc  @bit4,a                    ; BIT 4,A           ; Return if set
       jne  control_ship_5             ; RET NZ            ; ...
;       mov  @countdown_to_wave,hl      ; LD HL,($71F0)     ; Controller: #R$71F1
       movb  @current_player,h
       .push hl                        ; PUSH HL           ; Save current player
       sb   @l,@l                      ; LD L,$00          ; Segment 0
       bl   @decoder                   ; CALL $1F79        ; DECODER (H = fire, L = joystick)
       movb h,a                        ; LD A,H            ; Fire
       .pop hl                         ; POP HL            ; Restore current player
       .push af                        ; PUSH AF           ; Save fire segment 0
       movb one,@l                     ; LD L,$01          ; Segment 1
       bl   @decoder                   ; CALL $1F79        ; DECODER
       .pop af                         ; POP AF            ; Restore fire segment 0
       socb h,a                        ; OR H              ; Combine with fire segment 1
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       czc  @bit6,a                    ; BIT 6,A           ; Test fire pressed
       jeq  clear_fire_pressed         ; JR Z,$A805        ; If not, clear bit for fire pressed, and return
       movb *hl,r0                     ; BIT 0,(HL)        ; Check if fire was pressed last time
       andi r0,>0100                   ;
       jne  control_ship_5             ; RET NZ            ; Then return (must release after each shot)
       movb @active_shots,a            ; LD A,($7253)      ; Get number of active shots
       movb *hl,r0                     ; BIT 1,(HL)        ; Test for double shot
       andi r0,>0200                   ;
       jeq  control_ship_4             ; JR Z,$A7AD        ; Skip ahead if single shot
       srl  a,1                        ; SRL A             ; Divide by 2 (allow twice as many shots)
control_ship_4:                        ; >a7ad
       cb   a,@bytes+>02               ; CP $02            ; Return if >= 2
       jhe  control_ship_5             ; RET NC            ; ...
;       sb   a,a                        ; LD A,$00          ; No effect
;       nop                             ; NOP               ; Some instructions removed here?
;       nop                             ; NOP               ; ...
;       nop                             ; NOP               ; ...
;       movb @active_shots,a            ; LD A,($7253)      ; Increment number of active shots
;       ab   one,a                      ; INC A             ; ...
;       movb a,@active_shots            ; LD ($7253),A      ; ...
       ab   one,@active_shots
       socb @bits+0,*hl                ; SET 0,(HL)        ; Set bit for fire pressed
       movb *hl,r0                     ; BIT 1,(HL)        ; Test for double shot
       andi r0,>0200                   ;
       jne  fire_double_shot           ; JR NZ,$A7D5       ; Jump for double shot
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
;       mov  @sprite_data+>0001,hl      ; LD HL,($7003)     ; Ship's polar coordinates
;       movb @l,@>01(ix)                ; LD (IX+$01),L     ; Shot y = ship y
;       movb h,@>02(ix)                 ; LD (IX+$02),H     ; Shot x = ship x
       movb @sprite_data+1,@>01(ix)    ; Shot y = ship y
       movb @sprite_data+2,@>02(ix)    ; Shot x = ship x
       movb @bytes+>02,*ix             ; LD (IX+$00),$02   ; Shot type
       movb @bytes+>0a,@>0b(ix)        ; LD (IX+$0B),$0A   ; Set color (yellow)
control_ship_5:
       .ret                            ; RET               ; Return

* Fire double shot
*
* Used by the routine at #R$A73C.
fire_double_shot:                      ; >a7d5
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
;       mov  @sprite_data+>0001,hl      ; LD HL,($7003)     ; Ship's polar coordinates
;       .push hl                        ; PUSH HL           ; Save them
;       movb @l,@>01(ix)                ; LD (IX+$01),L     ;
       movb @sprite_data+1,@>01(ix)    ; Set polar y same as ship's
;       movb h,a                        ; LD A,H            ; Ship's polar x
       movb @sprite_data+2,a           ; Ship's polar x
       ab   one,a                      ; INC A             ; One step clockwise
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb @bytes+>02,*ix             ; LD (IX+$00),$02   ; Shot type
       movb @bytes+>0a,@>0b(ix)        ; LD (IX+$0B),$0A   ; Set color (yellow)
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
;       .pop hl                         ; POP HL            ; Restore ship's polar coordinates
;       movb @l,@>01(ix)                ; LD (IX+$01),L     ; Set polar y same as ship's
       movb @sprite_data+1,@>01(ix)    ; Set polar y same as ship's
;       movb h,a                        ; LD A,H            ; Ship's polar x
       movb @sprite_data+2,a           ; Ship's polar x
       sb   one,a                      ; DEC A             ; One step anti-clockwise
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb @bytes+>02,*ix             ; LD (IX+$00),$02   ; Shot type
       movb @bytes+>0a,@>0b(ix)        ; LD (IX+$0B),$0A   ; Set color (yellow)
;       li   hl,active_shots            ; LD HL,$7253       ; Increment number of active shots
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@active_shots
       .ret                            ; RET               ; Return

* Clear fire pressed
*
* Used by the routine at #R$A73C.
clear_fire_pressed:                    ; >a805
       szcb @bits+0,*hl                ; RES 0,(HL)        ; Clear bit for fire pressed
       .ret                            ; RET               ; Return

* Display ship background patterns
*
* Used by the routines at #R$832A, #R$A33B, #R$A3E1 and #R$A73C.
display_ship_bg_patterns:              ; >a808
       .push hl                        ; PUSH HL           ;
       .push de                        ; PUSH DE           ;
       .push bc                        ; PUSH BC           ;
       .push ix                        ; PUSH IX           ;
       .push iy                        ; PUSH IY           ;
       li   iy,ship_background_data    ; LD IY,$722E       ; Buffer for generated structure
       movb @bytes+>18,@>06(iy)        ; LD (IY+$06),$18   ;
       movb @zero,@>04(iy)             ; LD (IY+$04),$00   ; Patterns address LSB
       movb @zero,@>05(iy)             ; LD (IY+$05),$00   ; Patterns address MSB
       movb @sprite_data+>0001,a       ; LD A,($7003)      ; Ship's polar y
       cb   a,@bytes+>15               ; CP $15            ;
       jhe  _a85a                      ; JR NC,$A85A       ; Jump if >= 21
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship's polar x
       ab   @bytes+>02,a               ; ADD A,$02         ; Polar x + 2
;       srl  a,1                        ; RRCA              ; Rotate right 3 times
;       srl  a,1                        ; RRCA              ; 00XXXXXX -> XXX00XXX
;       srl  a,1                        ; RRCA              ; ...
       srl  a,3
       andi a,>0600                    ; AND $06           ; XXX00XXX -> 00000XX0 (quadrant)
       li   hl,adjust_ship_x_y_table   ; LD HL,$A875       ; Adjustment table
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
       movb @sprite_data+>0009,a       ; LD A,($700B)      ; Ship's screen x
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       movb a,*iy                      ; LD (IY+$00),A     ; Store x
       inc  hl                         ; INC HL            ; Next table address
       movb @sprite_data+>0008,a       ; LD A,($700A)      ; Ship's screen y
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       movb a,@>01(iy)                 ; LD (IY+$01),A     ; Store y
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship's polar x
       ab   @bytes+>02,a               ; ADD A,$02         ; Polar x + 2
       andi a,>3c00                    ; AND $3C           ; Keep 4 most significant bits, i.e. 16 offsets 4 bytes
                                                           ; apart
       movb a,@l                       ; LD L,A            ; HL = A
       sb   h,h                        ; LD H,$00          ; ...
;       a    hl,hl                      ; ADD HL,HL         ; x2
;       a    hl,hl                      ; ADD HL,HL         ; x4
;       a    hl,hl                      ; ADD HL,HL         ; x8, now 32 bytes apart
       sla  hl,3
       li   de,ship_patterns           ; LD DE,$A87D       ; Table of ship background patterns (32 bytes per frame)
       a    de,hl                      ; ADD HL,DE         ; Add to offset
       movb @l,@>04(iy)                ; LD (IY+$04),L     ; Save LSB
       movb h,@>05(iy)                 ; LD (IY+$05),H     ; Save MSB
_a85a:                                 ; >a85a
       .call @display_background_patterns ; CALL $8B12        ; Display background patterns
       .pop iy                         ; POP IY            ;
       .pop ix                         ; POP IX            ;
       .pop bc                         ; POP BC            ;
       .pop de                         ; POP DE            ;
       .pop hl                         ; POP HL            ;
       .ret                            ; RET               ;

* Controller movement table
movement_table:                        ; >a865
       byte >FF                                                      ; 0000
       byte >20                                                      ; 0001 Up
       byte >30                                                      ; 0010 Right
       byte >28                                                      ; 0011 Up + right
       byte >00                                                      ; 0100 Down
       byte >FF                                                      ; 0101
       byte >38                                                      ; 0110 Down + right
       byte >FF                                                      ; 0111
       byte >10                                                      ; 1000 Left
       byte >18                                                      ; 1001 Left + up
       byte >FF                                                      ; 1010
       byte >FF                                                      ; 1011
       byte >08                                                      ; 1100 Left + down
       byte >FF                                                      ; 1101
       byte >FF                                                      ; 1110
       byte >FF                                                      ; 1111

* Adjust ship coordinates table
adjust_ship_x_y_table:                 ; >a875
       byte >03,>01,>00,>FC,>05,>F9,>08,>FE

* Init center enemies
*
* Used by the routine at #R$8024.
init_center_enemies:                   ; >aa7d
       li   hl,center_enemy_map        ; LD HL,$7207       ; Set whole #R$7207 to $FF
       li   de,center_enemy_map+>0001  ; LD DE,$7208       ; ...
       li   bc,>0023                   ; LD BC,$0023       ; ...
       movb @b255,*hl                  ; LD (HL),$FF       ; ...
       .ldir                           ; LDIR              ; ...
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@center_map_entries      ; LD ($722B),A      ; Clear number of map entries
       movb a,@center_enemy_processed  ; LD ($72CD),A      ; Clear center enemy processed
       movb a,@center_y_offset         ; LD ($72D3),A      ; Clear y offset
       movb a,@center_x_offset         ; LD ($72D4),A      ; Clear x offset
       ab   one,a                      ; INC A             ; A = 1
       movb a,@y_offset_direction      ; LD ($72D2),A      ; Set y offset direction
       movb @bytes+>e0,a               ; LD A,$E0          ; Set first name used for center enemies in buffer 1
       movb a,@center_enemies_name_1   ; LD ($72CE),A      ; ...
       ab   @bytes+>10,a               ; ADD A,$10         ; First name used for center enemies in buffer 2
       movb a,@center_enemies_name_2   ; LD ($72CF),A      ; ...
       .ret                            ; RET               ;

* Allocate map entry
*
* Used by the routines at #R$87D5 and #R$8D21.
*
* I: A value to place in #R$7207 at an unused spot
allocate_map_entry:                    ; >aaa6
;       .push hl                        ; PUSH HL           ;
;       .push de                        ; PUSH DE           ;
;       .push bc                        ; PUSH BC           ;
       .push af                        ; PUSH AF           ; Save value to write
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of entries
       cb   a,@bytes+>24               ; CP $24            ; If map is full
       jeq  allocate_map_entry_6       ; JR Z,$AADE        ; Then return
       movb @status_flags,a            ; LD A,($71EB)      ; If all waves completed flag is set
       czc  @bit1,a                    ; BIT 1,A           ; The search backwards
       jne  allocate_map_entry_3       ; JR NZ,$AAC6       ; Else search forwards
       li   r0,center_enemy_map+>0023  ; LD HL,$722A       ; Start at end of #R$7207
       movb @b255,a                    ; LD A,$FF          ; Byte to search for
allocate_map_entry_1:                  ; >aabd
       cb   a,*r0                      ; CP (HL)           ; Check byte
       jne  allocate_map_entry_2       ; JR NZ,$AAC3       ; Break out if not $FF
       dec  r0                         ; DEC HL            ; Previous address
       jmp  allocate_map_entry_1       ; JR $AABD          ; Loop forever
allocate_map_entry_2:                  ; >aac3
       inc  r0                         ; INC HL            ; HL now points to group of $FF at the end of buffer
       jmp  allocate_map_entry_5       ; JR $AAD1          ; Skip next loop
allocate_map_entry_3:                  ; >aac6
       li   r0,center_enemy_map        ; LD HL,$7207       ; Start at beginning of #R$7207
       movb @b255,a                    ; LD A,$FF          ; Byte to search for
allocate_map_entry_4:                  ; >aacb
       cb   a,*r0+                     ; CP (HL)           ; Check byte
       jeq  allocate_map_entry_4a      ; JR Z,$AAD1        ; Break out if found HL now points to first $FF in buffer
;      inc  hl                         ; INC HL            ; Next address
       jmp  allocate_map_entry_4       ; JR $AACB          ; Loop forever
allocate_map_entry_4a:
       dec  r0
allocate_map_entry_5:                  ; >aad1
       .pop af                         ; POP AF            ; Restore value to write
       movb a,*r0                      ; LD (HL),A         ; Set byte to A
;       li   hl,center_map_entries      ; LD HL,$722B       ; Increment number of entries
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@center_map_entries
;       li   r0,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
;       socb @bits+0,*r0                ; SET 0,(HL)        ; ...
       socb @bits+0,@center_enemies_redraw
       jmp  allocate_map_entry_7       ; JR $AADF          ; Skip popping AF
allocate_map_entry_6:                  ; >aade
       .pop af                         ; POP AF            ;
allocate_map_entry_7:                  ; >aadf
;       .pop bc                         ; POP BC            ;
;       .pop de                         ; POP DE            ;
;       .pop hl                         ; POP HL            ;
       rt                              ; RET               ;

* Deallocate map entry
*
* Used by the routines at #R$99A0, #R$AB17 and #R$AB53.
*
* I:HL Address in #R$7207
deallocate_map_entry:                  ; >aae3
;       .push hl                        ; PUSH HL           ; Save map address
       movb @b255,*hl                  ; LD (HL),$FF       ; Set entry to $FF
;       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
;       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
       socb @bits+0,@center_enemies_redraw
;       li   hl,center_map_entries      ; LD HL,$722B       ; Decrement number of entries
;       sb   one,*hl                    ; DEC (HL)          ; ...
       sb   one,@center_map_entries
;       .pop hl                         ; POP HL            ; Restore map address
       rt                               ; RET               ;

* Create enemy sprite from map entry
*
* Search for value >= $80 in map and deallocate if found. Then allocate a
* sprite with data from map. Used by the routine at #R$80E8.
create_sprite_from_map_entry:          ; >aaf1
       movb @status_flags,a            ; LD A,($71EB)      ; Is all waves completed flag set?
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jeq  create_sprite_from_map_entry_2 ; RET Z         ; Return if not
       czc  @bit2,a                    ; BIT 2,A           ; Is died flag set?
       jne  create_sprite_from_map_entry_2 ; RET NZ        ; Return if so
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       movb @active_enemies,a          ; LD A,($722C)      ; Get number of active enemies
       cb   a,@>04(iy)                 ; CP (IY+$04)       ; Compare with byte 4 of stage data
       jhe  create_sprite_from_map_entry_2 ; RET NC        ; Return if active enemies >= byte 4
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of map entries
;       socb a,a                        ; OR A              ; Return if zero
       jeq  create_sprite_from_map_entry_2 ; RET Z         ; ...
       li   hl,center_enemy_map+>0023  ; LD HL,$722A       ; End of #R$7207
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       movb @bytes+>80,a               ; LD A,$80          ; Value to compare with
create_sprite_from_map_entry_1:        ; >ab10
       cb   a,*hl                      ; CP (HL)           ; Test map byte
       jhe  create_sprite_from_map_entry_3 ; JR NC,$AB17   ; If map byte <= $80 then found
       dec  hl                         ; DEC HL            ; Previous byte
       sb   one,b                      ; DJNZ $AB10        ; Loop through whole map
       jne  create_sprite_from_map_entry_1 ;
create_sprite_from_map_entry_2:
       .ret                            ; RET               ; Not found - return
* Create sprite
create_sprite_from_map_entry_3:        ; >ab17
       movb *hl,a                      ; LD A,(HL)         ; Get value from map
       .push af                        ; PUSH AF           ; Save it
       bl   @deallocate_map_entry     ; CALL $AAE3        ; Deallocate map entry
       bl   @polar_coord_from_map     ; CALL $AB38         ; Now DE contains polar y,x
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @e,@>02(ix)                ; LD (IX+$02),E     ; Set polar x
       movb d,@>01(ix)                 ; LD (IX+$01),D     ; Set polar x
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       .pop af                         ; POP AF            ; Restore value from map
       movb a,@>0b(ix)                 ; LD (IX+$0B),A     ; Use it as color (maybe temporary since it's >= $80?)
       socb @bits+0,@>07(ix)           ; SET 0,(IX+$07)    ; Set flag
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
;       li   hl,active_enemies          ; LD HL,$722C       ; Increment number of active enemies
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@active_enemies
       .ret                            ; RET               ;

* Sprite coordinates from map
*
* Returns polar sprite coordinates from an entry in the map. Used by the
* routines at #R$87F5, #R$9861, #R$AB17 and #R$AB72.
*
* I:HL Map address
* O:D Polar y
* O:E Polar x
polar_coord_from_map:                  ; >ab38
       mov  hl,r1
;       .push hl                        ; PUSH HL           ; Save map address
;       li   de,center_enemy_map        ; LD DE,$7207       ; Base address of map
;       socb a,a                        ; OR A              ; Clear carry
;       s    de,hl                      ; SBC HL,DE         ; Map address - map base (offset 0 - 35)
       ai   r1,-center_enemy_map       ; SBC HL,DE         ; Map address - map base (offset 0 - 35)
       a    r1,r1                      ; ADD HL,HL         ; x2 = offset
;       li   de,start_coordinates_table ; LD DE,$AC87       ; Table address
       ai   r1,start_coordinates_table  ; ADD HL,DE         ; Add offset
       movb @center_x_offset,a         ; LD A,($72D4)      ; Get x offset
       ab   *r1+,a                     ; ADD A,(HL)        ; Add table value
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@e                       ; LD E,A            ; Store in E
;      inc  hl                         ; INC HL            ; Next table address
       movb @center_y_offset,a         ; LD A,($72D3)      ; Get y offset
       ab   *r1,a                      ; ADD A,(HL)        ; Add table value
       movb a,d                        ; LD D,A            ; Store in D
;       .pop hl                         ; POP HL            ; Restore map address
       rt                              ; RET               ;

* Deallocate sprite from map
*
* Search for sprite pattern in map and deallocate if found. Used by the
* routines at #R$9934 and #R$9A49.
*
* I: IX sprite data
deallocate_sprite_from_map:            ; >ab53
       movb @>07(ix),r0                ; BIT 6,(IX+$07)    ; Test bit
       andi r0,>4000                   ;
       jeq  deallocate_sprite_from_map_4 ; RET Z             ; Return if not set
       .push hl                        ; PUSH HL           ;
;       .push bc                        ; PUSH BC           ;
       li   hl,center_enemy_map        ; LD HL,$7207       ; Map address
;       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       li   r2,>0024
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get sprite pattern
       socb @bytes+>80,a               ; OR $80            ; Set bit 7
deallocate_sprite_from_map_1:          ; >ab64
       cb   a,*hl+                     ; CP (HL)           ; Compare with map entry
       jeq  deallocate_sprite_from_map_2 ; JR Z,$AB6C        ; Break out if found
;      inc  hl                         ; INC HL            ; Next map address
;       sb   one,b                      ; DJNZ $AB64        ; Loop through whole map
       dec  r2
       jne  deallocate_sprite_from_map_1 ;
       jmp  deallocate_sprite_from_map_3 ; JR $AB6F          ; Not found - return
deallocate_sprite_from_map_2:           ; >ab6c
       dec  hl
       bl   @deallocate_map_entry     ; CALL $AAE3        ; Deallocate map entry
deallocate_sprite_from_map_3:          ; >ab6f
;       .pop bc                         ; POP BC            ;
       .pop hl                         ; POP HL            ;
deallocate_sprite_from_map_4:
       .ret                            ; RET               ;

* Display distant enemies at the center of the screen
*
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$846B, #R$A33B and
* #R$A3E1.
display_center_enemies:                ; >ab72
       li   hl,update_counters_countdown ; LD HL,$72CB       ; Countdown for when to update counters
       sb   one,*hl                    ; DEC (HL)          ; -1
       jlt  !                          ; JP P,$ABA0        ; If > 0, then don't update other counters
       b    @display_center_enemies_2  ;
!
       movb @bytes+>0f,*hl             ; LD (HL),$0F       ; Reset to 15
       movb @center_y_offset,a         ; LD A,($72D3)      ; Y offset
       li   hl,y_offset_direction      ; LD HL,$72D2       ; Add direction 1 or -1
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       movb a,@center_y_offset         ; LD ($72D3),A      ; Store y offset
;       jgt  _ab8a                      ; JP P,$AB8A        ; If y counter > 0 then skip ahead
;       neg a                           ; NEG               ; Else make positive
;_ab8a:                                 ; >ab8a
       andi af,>ff00
       abs a
       cb   a,one                      ; CP $01            ; If not 1
       jne  display_center_enemies_1   ; JR NZ,$AB9B       ; Then skip ahead
       movb *hl,a                      ; LD A,(HL)         ; IF 1, get direction
       neg a                           ; NEG               ; Reverse direction
       movb a,*hl                      ; LD (HL),A         ; Store direction
       movb @center_x_offset,a         ; LD A,($72D4)      ; x offset
       ab   one,a                      ; INC A             ; +1
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@center_x_offset         ; LD ($72D4),A      ; Store x offset
display_center_enemies_1:              ; >ab9b
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
display_center_enemies_2:              ; >aba0
       movb @center_enemy_processed,a  ; LD A,($72CD)      ; Get enemy to process
       cb   a,@bytes+>24               ; CP $24            ; If 36,
       jne  !                          ; JP Z,$ABFF        ; Then jump to update name table
       b    @display_center_enemies_names ;
!
;       socb a,a                        ; OR A              ; If 0 then erase all enemies
       movb a,a
       jne  display_center_enemies_3   ; JR NZ,$ABC4       ; Else jump ahead
       mov  @center_enemies_name_2,hl  ; LD HL,($72CF)     ; Get first name used for center enemies
       sb   h,h                        ; LD H,$00          ; Set MSB to 0
;       a    hl,hl                      ; ADD HL,HL         ; Multiply by 8
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       a    hl,hl                      ; ADD HL,HL         ; ...
       sla  hl,3
       li   de,>0000                   ; LD DE,$0000       ; Add pattern table address
       a    de,hl                      ; ADD HL,DE         ; ...
       mov  hl,@center_enemies_pattern ; LD ($72D0),HL     ; Save VDP address
       li   de,>0080                   ; LD DE,$0080       ; Clear 16 patterns
       sb   a,a                        ; XOR A             ; ...
       bl   @unrolled_fill_vram        ; CALL $1F82        ; FILL_VRAM
       movb @center_enemy_processed,a  ; LD A,($72CD)      ; Get enemy to process
display_center_enemies_3:              ; >abc4
       movb a,@c                       ; LD C,A            ; BC = enemy to process
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,center_enemy_map        ; LD HL,$7207       ; Add map address
       a    bc,hl                      ; ADD HL,BC         ; ...
       movb *hl,r0                     ; BIT 7,(HL)        ; If unallocated
       andi r0,>8000                   ;
       jeq  !                          ; JP NZ,$ABFA       ; Then update counter and return
       b    @display_center_enemies_5  ;
!
       bl   @polar_coord_from_map     ; CALL $AB38        ; Now DE contains polar y,x
       bl   @polar_to_screen          ; CALL $B1C6        ; Convert polar to screen
       .push de                        ; PUSH DE           ; Save screen coordinates
       movb *hl,a                      ; LD A,(HL)         ; Get map value
;       srl  a,1                        ; RRA               ; Isolate 3 bits
;       srl  a,1                        ; RRA               ; ...
       srl  a,2
       andi a,>0e00                    ; AND $0E           ; ...
       movb a,@c                       ; LD C,A            ; And load into BC
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,pixel_offsets_table     ; LD HL,$ACCF       ; Add table base address
       a    bc,hl                      ; ADD HL,BC         ; ...
       bl   @plot_pixel               ; CALL $AC47        ; Plot pixel
       movb *hl,a                      ; LD A,(HL)         ; Get x offset
;       socb a,a                        ; OR A              ; If zero
       jeq  display_center_enemies_4   ; JR Z,$ABEF        ; Then skip ahead
       ab   @e,a                       ; ADD A,E           ; Add to screen x
       movb a,@e                       ; LD E,A            ; ...
       bl   @plot_pixel               ; CALL $AC47        ; Plot pixel
display_center_enemies_4:              ; >abef
       inc  hl                         ; INC HL            ; Next table address
       .pop de                         ; POP DE            ; Restore screen coordinates
       movb *hl,a                      ; LD A,(HL)         ; Get y offset
;       socb a,a                        ; OR A              ; If zero
       jeq  display_center_enemies_5   ; JR Z,$ABFA        ; Then skip ahead
       ab   d,a                        ; ADD A,D           ; Add to screen x
       movb a,d                        ; LD D,A            ; ...
       bl   @plot_pixel               ; CALL $AC47        ; Plot pixel
display_center_enemies_5:              ; >abfa
       li   hl,center_enemy_processed  ; LD HL,$72CD       ; Update counter
       ab   one,*hl                    ; INC (HL)          ; ...
       .ret                            ; RET               ;

* Update name table to display center enemies
*
* Used by the routine at #R$AB72.
display_center_enemies_names:          ; >abff
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Test flag
       movb *hl,r0                     ; BIT 0,(HL)        ; If not set
       andi r0,>0100                   ;
       jne  !                          ; RET Z             ; Then return
       .ret                            ;
!
       szcb @bits+0,*hl                ; RES 0,(HL)        ; Else reset flag
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of map entries
;       socb a,a                        ; OR A              ; Skip ahead if zero
       jeq  erase_center_enemies       ; JR Z,$AC32        ; ...
       li   de,>194e                   ; LD DE,$194E       ; Name table VDP address
       movb @center_enemies_name_2,a   ; LD A,($72CF)      ; Get first name used for center enemies
;       movb @bytes+>04,@c              ; LD C,$04          ; 4 rows
       li   bc,4
       li   r1,vdpwd
display_center_enemies_names_1:         ; >ac15
;       movb @bytes+>04,b               ; LD B,$04          ; 4 columns
       bl   @vdp_write_address
;_ac17:                                 ; >ac17
;       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
;       ab   one,a                      ; INC A             ; Next name
;       inc  de                         ; INC DE            ; Next VDP address
;       sb   one,b                      ; DJNZ $AC17        ; Loop for 4 columns
;       jne  _ac17                      ;
       movb a,*r1
       ab   one,a
       movb a,*r1
       ab   one,a
       movb a,*r1
       ab   one,a
       movb a,*r1
       ab   one,a
;       li   hl,>001c                   ; LD HL,$001C       ; One row down
;       a    de,hl                      ; ADD HL,DE         ; ...
;       .ex_de_hl                       ; EX DE,HL          ; ...
       ai   de,>0020
;       sb   one,@c                     ; DEC C             ; Row counter
       dec  bc
       jne  display_center_enemies_names_1 ; JR NZ,$AC15       ; Loop for 4 rows
       mov  @center_enemies_name_1,hl  ; LD HL,($72CE)     ; Swap #R$72CE and #R$72CF
;       movb @l,a                       ; LD A,L            ; ...
;       movb h,@l                       ; LD L,H            ; ...
;       movb a,h                        ; LD H,A            ; ...
       swpb hl
       mov  hl,@center_enemies_name_1  ; LD ($72CE),HL     ; ...
       sb   a,a                        ; XOR A             ; Reset center enemy to process
       movb a,@center_enemy_processed  ; LD ($72CD),A      ; ...
       .ret                            ; RET               ;

* Erase center enemies,
*
* Used by the routine at #R$ABFF.
erase_center_enemies:                  ; >ac32
       li   de,>194e                   ; LD DE,$194E       ; Name table VDP address
       sb   a,a                        ; XOR A             ; Space
;       movb @bytes+>04,@c              ; LD C,$04          ; 4 rows
       li   bc,4
       li   r1,vdpwd
erase_center_enemies_1:                ; >ac38
;       movb @bytes+>04,b               ; LD B,$04          ; 4 columns
       bl   @vdp_write_address
;_ac3a:                                 ; >ac3a
;       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
;       inc  de                         ; INC DE            ; Next VDP address
;       sb   one,b                      ; DJNZ $AC3A        ; Loop for 4 columns
;       jne  _ac3a                      ;
       movb a,*r1
       movb a,*r1
       movb a,*r1
       movb a,*r1
;       li   hl,>001c                   ; LD HL,$001C       ; One row down
;       a    de,hl                      ; ADD HL,DE         ; ...
;       .ex_de_hl                       ; EX DE,HL          ; ...
       ai   de,>0020
;       sb   one,@c                     ; DEC C             ; Row counter
       dec  bc
       jne  erase_center_enemies_1     ; JR NZ,$AC38       ; Lopp for 4 rows
       .ret                            ; RET               ;

* Plot pixel
*
* Plot pixel in center enemies bit map. Used by the routine at #R$AB72.
*
* D: Screen y
* E: Screen x
* I: HL Address in #R$ACCF
plot_pixel:                            ; >ac47
       .proc
       .push hl                        ; PUSH HL           ;
       movb d,a                        ; LD A,D            ; Screen y
       sb   @bytes+>50,a               ; SUB $50           ; - 80
       srl  a,1                        ; SRL A             ; / 2
       andi a,>fc00                    ; AND $FC           ; Y offset (byte offset * 4)
       movb a,@c                       ; LD C,A            ; Store in C
       movb @e,a                       ; LD A,E            ; Screen x
       movb a,r0
       sb   @bytes+>70,a               ; SUB $70           ; - 112
       cb   r0,@bytes+>70
       jhe  plot_pixel_1               ; JR NC,$AC56       ; If < 0
       sb   a,a                        ; XOR A             ; Then set to 0
plot_pixel_1:                          ; >ac56
       cb   a,@bytes+>20               ; CP $20            ; If < 32
       jl   plot_pixel_2               ; JR C,$AC5C        ; Then skip ahead
       movb @bytes+>0f,a               ; LD A,$0F          ; ELse set to 15
plot_pixel_2:                          ; >ac5c
;       srl  a,1                        ; SRL A             ; / 8
;       srl  a,1                        ; SRL A             ; ...
;       srl  a,1                        ; SRL A             ; ...
       srl  a,3
       ab   @c,a                       ; ADD A,C           ; Add y offset
;       ab   a,a                        ; ADD A,A           ; * 8
;       ab   a,a                        ; ADD A,A           ; ...
;       ab   a,a                        ; ADD A,A           ; ...
       andi af,>ff00
       sla  a,3
       movb a,@c                       ; LD C,A            ; Store in C
       movb d,a                        ; LD A,D            ; Screen y
       andi a,>0700                    ; AND $07           ; Pixel offset within pattern
       ab   @c,a                       ; ADD A,C           ; Add to offset
       movb a,@c                       ; LD C,A            ; Store in C
       sb   b,b                        ; LD B,$00          ; B = 0
       mov  @center_enemies_pattern,hl ; LD HL,($72D0)     ; Get VDP address of centre enemy patterns
       a    bc,hl                      ; ADD HL,BC         ; VDP address
       movb @e,a                       ; LD A,E            ; Screen x
       andi a,>0700                    ; AND $07           ; Pixel x offset within pattern
       movb @bytes+>80,b               ; LD B,$80          ; Leftmost pixel
       mov  a,r0
       jeq  plot_pixel_3               ; JR Z,$AC7E        ; Skip ahead if zero offset
;_ac79:                                 ; >ac79
;       srl  b,1                        ; SRL B             ; Shift right 0-7 times
;       sb   one,a                      ; DEC A             ; ...
;       jne  _ac79                      ; JR NZ,$AC79       ; ...
       swpb r0
       srl  b,0
plot_pixel_3:                          ; >ac7e
       .ex_de_hl                       ; EX DE,HL          ; DE = VDP address, HL = coordinates
       bl   @vdp_read_byte             ; CALL $9AD0        ; Read VDP byte
       socb b,a                        ; OR B              ; Apply pixel
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       .ex_de_hl                       ; EX DE,HL          ; DE = coordinates
       .pop hl                         ; POP HL            ;
       .endproc                              ; RET               ;

* Start coordinates for sprites
*
* Polar x, polar y
start_coordinates_table:               ; >ac87
       byte >05,>28,>10,>28,>1A,>28,>25,>28,>30,>28,>3A,>28
       byte >00,>28,>0A,>28,>15,>28,>20,>28,>2A,>28,>35,>28
       byte >05,>26,>10,>26,>1A,>26,>25,>26,>30,>26,>3A,>26
       byte >00,>26,>0A,>26,>15,>26,>20,>26,>2A,>26,>35,>26
       byte >05,>24,>10,>24,>1A,>24,>25,>24,>30,>24,>3A,>24
       byte >00,>24,>0A,>24,>15,>24,>20,>24,>2A,>24,>35,>24

* Table of pixel offsets for drawing center enemies
pixel_offsets_table:                   ; >accf
       byte >01,>00,>FF,>01,>00,>FF,>01,>01
       byte >01,>00,>FF,>01,>00,>01,>FF,>FF

* Init sprite data
*
* Used by the routines at #R$82BF, #R$90D6 and #R$A33B.
init_sprite_data:                      ; >acdf
       li   ix,sprite_data             ; LD IX,$7002       ; Address of sprite data
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       movb @bytes+>20,b               ; LD B,$20          ; Number of sprites
       sb   a,a                        ; XOR A             ;
       movb a,@allocated_sprites       ; LD ($7182),A      ; Number of allocated sprites
init_sprite_data_1:                    ; >acec
       movb a,@>0a(ix)                 ; LD (IX+$0A),A     ; Set pattern
* This entry point is used by the routine at #R$AC47.
       movb @b255,*ix                  ; LD (IX+$00),$FF   ; Set as unallocated
       ab   one,a                      ; INC A             ;
       a    de,ix                      ; ADD IX,DE         ; Advance to next sprite
       sb   one,b                      ; DJNZ $ACEC        ; Loop for 32 sprites
       jne  init_sprite_data_1         ;
       .ret                            ; RET               ;

* Upload sprite data to VDP
*
* Used by the routines at #R$832A, #R$84B1, #R$90D6, #R$A33B and #R$A3E1.
upload_sprite_data:                    ; >acf9
;      mov  @sat_vdp_address,de        ; LD DE,($73F2)     ; VDP address of sprite allocation table
;       li   hl,allocated_sprites       ; LD HL,$7182       ; Get number of allocated sprites
;       movb *hl,a                      ; LD A,(HL)         ; ...
;       movb a,b                        ; LD B,A            ; Store in B
       movb @allocated_sprites,b       ; Get number of allocated sprites
       li   hl,sprite_allocation_table
       mov  @sat_vdp_address,r0
       bl   @vwad
upload_sprite_data_1:                  ; >ad02
;       .push bc                        ; PUSH BC           ; Save counter
;       inc  hl                         ; INC HL            ; Next allocation
;       movb *hl,a                      ; LD A,(HL)         ; Get sprite index
;       ab   a,a                        ; ADD A,A           ; * 2
;       ab   a,a                        ; ADD A,A           ; * 4
;       movb a,@c                       ; LD C,A            ;
;       ab   a,a                        ; ADD A,A           ; * 8
;       ab   @c,a                       ; ADD A,C           ; * 12 (may overflow?)
;       .push hl                        ; PUSH HL           ; Save sprite allocation table address
;       li   hl,sprite_data+>0008       ; LD HL,$700A       ; First y address in sprite data table
;       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
;       li   bc,>0004                   ; LD BC,$0004       ; Write 4 bytes for each sprite
;       .push de                        ; PUSH DE           ; Save destination
;       .call @write_vram               ; CALL $1FDF        ; WRITE_VRAM
;       .pop hl                         ; POP HL            ; Restore destination
;       li   bc,>0004                   ; LD BC,$0004       ; Add 4 to destination
;       a    bc,hl                      ; ADD HL,BC         ; ...
;       .ex_de_hl                       ; EX DE,HL          ; ...
;       .pop hl                         ; POP HL            ; Restore sprite allocation table address
;       .pop bc                         ; POP BC            ; Restore counter
       clr  r0
       movb *hl+,@r0lb                 ; Sprite index * 12
       li   r1,12                      ; ...
       mpy  r1,r0                      ; ...
       ai   r1,sprite_data+8           ; Add airst y address in sprite data table
       movb *r1+,@vdpwd                ; Write 4 bytes to VDP
       movb *r1+,@vdpwd                ; ...
       movb *r1+,@vdpwd                ; ...
       movb *r1+,@vdpwd                ; ...
       sb   one,b                      ; DJNZ $AD02        ; Loop for each sprite
       jne  upload_sprite_data_1                      ;
;       movb @bytes+>d0,a               ; LD A,$D0          ; End marker byte
;       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       movb @bytes+>d0,@vdpwd
       movb @allocated_sprites,a       ; LD A,($7182)      ; Get number of allocation sprites
       cb   a,@bytes+>05               ; CP $05            ; Is it < 5
       jl   upload_sprite_data_2       ; RET C             ; Then return
* Rotate sprite allocation table
       jmp  upload_sprite_data_2       ; TODO: disabled
       sb   @bytes+>04,a               ; SUB $04           ;
       movb a,@c                       ; LD C,A            ; Number of sprites above 4
       sb   b,b                        ; LD B,$00          ;
       .push bc                        ; PUSH BC           ;
       li   hl,sprite_allocation_table+2 ; LD HL,$7185       ; From 2nd entry of allocation table
       li   de,buffer                  ; LD DE,$71A3       ; To buffer
       li   bc,>0002                   ; LD BC,$0002       ; Copy 2 bytes
       .ldir                           ; LDIR              ;
       li   de,sprite_allocation_table+2 ; LD DE,$7185       ; From 4th to 2nd entry of allocation table
       .pop bc                         ; POP BC            ; Copy number of sprites above 4 bytes
       .ldir                           ; LDIR              ;
       li   hl,buffer                  ; LD HL,$71A3       ; From buffer to end of allocation table
       li   bc,>0002                   ; LD BC,$0002       ; Copy 2 bytes
       .ldir                           ; LDIR              ;
upload_sprite_data_2:
       .ret                            ; RET               ;

* Allocate sprite (RST $28)
*
* Used by the routine at #R$8018.
*
* O:IX holds sprite address
allocate_sprite:                       ; >ad49
       .push hl                        ; PUSH HL           ;
       .push de                        ; PUSH DE           ;
       .push bc                        ; PUSH BC           ;
       li   hl,sprite_data             ; LD HL,$7002       ; Address of sprite data
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       li   bc,>2000                   ; LD BC,$2000       ; Number of sprites and sprite index
       movb @bytes+>7e,a               ; LD A,$7E          ;
allocate_sprite_1:                     ; >ad57
       cb   a,*hl                      ; CP (HL)           ;
       jl   allocate_sprite_2          ; JR C,$AD64        ; If >= $7F ($FF from init), sprite is available
       ab   one,@c                     ; INC C             ; Sprite index++
       a    de,hl                      ; ADD HL,DE         ; Advance to next sprite
       sb   one,b                      ; DJNZ $AD57        ; Loop for up to 32 sprites
       jne  allocate_sprite_1          ;
       li   ix,>03e8                   ; LD IX,$03E8       ; Not found, set to address in ROM (?)
       jmp  allocate_sprite_4          ; JR $AD87          ; And return
allocate_sprite_2:                     ; >ad64
       .push hl                        ; PUSH HL           ; Save sprite address
       movb *hl,r0                     ; BIT 7,(HL)        ; Is bit 7 set, i.e. $FF?
       andi r0,>8000                   ;
       jeq  allocate_sprite_3          ; JR Z,$AD75        ; If not, skip recoding in allocation table
       li   hl,allocated_sprites       ; LD HL,$7182       ; Allocated sprites
       ab   one,*hl                    ; INC (HL)          ; Record one more
       movb *hl,a                      ; LD A,(HL)         ; Read number back
;       ab   @l,a                       ; ADD A,L           ; Add number to HL
;       movb a,@l                       ; LD L,A            ; ...
;       joc  !                          ; JP NC,$AD74       ; ...
;       b    @_ad74                     ;
;!
;       ab   one,h                      ; INC H             ; ...
;_ad74:
       clr  r0
       movb a,@r0lb
       a    r0,hl
       movb @c,*hl                     ; LD (HL),C         ; Record sprite index in table
allocate_sprite_3:                     ; >ad75
       .pop ix                         ; POP IX            ; IX now holds sprite address
       movb @zero,@>07(ix)             ; LD (IX+$07),$00   ; Init sprite
       movb @zero,@>03(ix)             ; LD (IX+$03),$00   ; Set counter to 0
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
allocate_sprite_4:                     ; >ad87
       .pop bc                         ; POP BC            ;
       .pop de                         ; POP DE            ;
       .pop hl                         ; POP HL            ;
       rt                              ; RET               ;

* Load sprite pattern (RST $30)
*
* Ensure sprite pattern is loaded and set screen position.
* Used by the routine at #R$801B.
*
* I:IX Pointer to sprite data
load_sprite_pattern_fast:
       .proc
       clr  r1                                 ; r1 = sprite type
       movb *ix,@r1lb                          ; ...
       sla  r1,1                               ; Word offset
       mov  r1,r12                             ; Save it for later
       mov  @graphics_pointers_table(r1),r1    ; r1 = control word
       clr  r2                                 ; Scale
       movb @>01(ix),r0                        ; Get polar y, which determines which scale we want
       jlt  load_sprite_pattern_fast_1         ; If bit 7 of polar y is set, skip ahead with E=0
       cb   r0,@bytes+>15                      ; Skip ahead if polar y < 21
       jl   load_sprite_pattern_fast_1         ; ...
       inc  r2                                 ; Else set scale = 1
       cb   r0,@bytes+>1a                      ; Skip ahead if polar y < 26
       jl   load_sprite_pattern_fast_1         ; ...
       inc  r2                                 ; Else set scale = 2
       cb   r0,@bytes+>22                      ; Skip ahead if polar y < 34
       jl   load_sprite_pattern_fast_1         ; ...
       inc  r2                                 ; Else set scale = 3
load_sprite_pattern_fast_1:
       mov  r1,r0                              ; Get control word
       andi r0,>00ff                           ; Number of scales
       c    r2,r0                              ; Compare with requested scale
       jl   load_sprite_pattern_fast_2         ; If smaller we're good
       dec  r0                                 ; Else choose the last one
       mov  r0,r2                              ; ...
load_sprite_pattern_fast_2:
       movb @>02(ix),a                         ; Get polar x
       ab   @bytes+>02,a                       ; Plus 2
       andi a,>3f00                            ; Mod 64
       movb a,@>05(ix)                         ; Save in sprite data
       movb r1,r0                              ; Get number of rotations (0 = 2^0 = 1 or 2 = 2^2 = 4)
       jeq  load_sprite_pattern_fast_3         ; Jump ahead if zero
       movb a,r0
       andi r0,>fc00                           ; Shift two times right and multiply by 4
load_sprite_pattern_fast_3:
       swpb r2                                 ; Scale to LSB
       ab   r2,r0                              ; Add scale to rotation offset
       cb   r0,@>04(ix)                        ; Same as existing?
       jeq  load_sprite_pattern_fast_4         ; If so, skip uploading pattern
       movb r0,@>04(ix)                        ; Save new value
       andi r0,>ff00                           ; Clear LSB
       mov  r0,r1                              ; Copy to source address
       srl  r1,5                               ; To LSB and multiply by 8
       a    @sprite_pttrn_addrs_table(r12),r1  ; Add source base address
       movb @>0a(ix),r0                        ; Destination pattern
       swpb r0                                 ; To LSB
       sla  r0,3                               ; Multiply by 8
       ai   r0,>800                            ; Add destination base address
       bl   @vwad                              ; Setup VDP write adress
       li   r0,vdpwd
       movb *r1+,*r0                           ; Write 8 bytes
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
       movb *r1+,*r0                           ; ...
load_sprite_pattern_fast_4:
       cb   *ix,one                            ; Is sprite type ship exhaust?
       jeq  load_sprite_pattern_fast_5         ; Then skip ahead
       movb @>01(ix),d                         ; Polar y
       movb @>02(ix),@e                        ; Polar x
       bl   @polar_to_screen                  ; Polar to screen
       movb d,@>08(ix)                         ; Set y
       movb @e,@>09(ix)                        ; Set x
       abs  @carry                             ; If carry, sprite is outside visible screen
       jeq  load_sprite_pattern_fast_7         ; Return if no carry
       bl   @handle_off_screen_sprite          ; Else handle off-screen
       jmp  load_sprite_pattern_fast_7         ; Return
load_sprite_pattern_fast_5:
       li   r1,exhaust_position_table          ; If sprite type is ship exhaust, set r1 to table address
       movb @>04(ix),a                         ; Pattern index
       andi a,>0300                            ; Mod 4
       jne  load_sprite_pattern_fast_6         ; If not zero, skip ahead
       movb @>05(ix),a                         ; Get updated polar x (saved earlier)
       srl  a,1                                ; / 2
       andi a,>1e00                            ; 0, 2, 4 ... >1E
       li   r1,exhaust_position_table+>0002
       swpb af
       a    af,r1                              ; Add to table address
load_sprite_pattern_fast_6:
       movb @sprite_data+>0008,a               ; Ship screen y
       ab   *r1+,a                             ; Add table value
       movb a,@>08(ix)                         ; Set y
       movb @sprite_data+>0009,a               ; Ship screen x
       ab   *r1,a                              ; Add table value
       movb a,@>09(ix)                         ; Set x
load_sprite_pattern_fast_7:
       .endproc

;* Load sprite pattern (RST $30)
