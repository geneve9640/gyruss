* Entry point
entry:                                 ; >8024
       li   sp,stack                   ; LD SP,$73BA       ; Init stack pointer
       ; OUT ($C0),A                   ; OUT ($C0),A       ; Controller enable
       li   hl,center_of_projection    ; LD HL,$7000       ; Clear RAM
       li   de,center_of_projection+>0001 ; LD DE,$7001       ; #R$7000+1
       li   bc,star_frame-center_of_projection ; LD BC,$03B9       ; ...
       clr  *hl                        ; LD (HL),L         ; ...
       .ldir                           ; LDIR              ; ...
       li   hl,>8060                   ; LD HL,$8060       ; Set center of projection
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       .call @init_sound               ; CALL $9ADE        ; Init sound
       .call @start_screen             ; CALL $90D6        ; Start screen
       li   hl,>2A30                   ; LD HL,$2A30       ; 180 * 60 frames
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Set screensaver countdown
entry_wait_fire:                       ; >8047
       bl   @ti_wait_vsync             ; HALT              ; Wait for interrupt
       .call @display_stars            ; CALL $AFFF        ; Display stars
       li   hl,>0000                   ; LD HL,$0000       ; Controller 0, segment 0
       bl   @decoder                   ; CALL $1F79        ; DECODER
       movb h,r0                       ; BIT 6,H           ; Test fire
       andi r0,>4000                   ;
       jne  new_game                   ; JR NZ,$8064       ; Jump if fire pressed
       li   hl,>0100                   ; LD HL,$0100       ; Controller 1, segment 0
       bl   @decoder                   ; CALL $1F79        ; DECODER
       movb h,r0                       ; BIT 6,H           ; Test fire
       andi r0,>4000                   ;
       jeq  entry_wait_fire            ; JR Z,$8047        ; Loop until fire pressed
       li   hl,status_flags            ; LD HL,$71EB       ; Set two-player flag
       socb @bits+7,*hl                ; SET 7,(HL)        ; ...
* This entry point is used by the routine at #R$81ED. Fire pressed
new_game:                              ; >8064
       li   hl,>0000                   ; LD HL,$0000       ;
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Clear screensaver countdown
       li   hl,>1800                   ; LD HL,$1800       ; Name table address
       li   de,>0300                   ; LD DE,$0300       ; Name table size
       sb   a,a                        ; XOR A             ; Zero
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM (clear screen)
       li   hl,>201c                   ; LD HL,$201C       ; Last 4 bytes of color table
       li   de,>0004                   ; LD DE,$0004       ; 4 bytes
       movb @bytes+>f1,a               ; LD A,$F1          ; Set to white/black
       bl   @fill_vram                 ; CALL $1F82        ; FILL_VRAM
       li   hl,current_player          ; LD HL,$71F1       ; Clear RAM  from $71F1
       li   de,frame_counter           ; LD DE,$71F2       ; To $7256
       sb   a,a                        ; XOR A             ; ...
       movb a,*hl                      ; LD (HL),A         ; ...
       li   bc,other_flags-current_player ; LD BC,$0065       ; ...
       .ldir                           ; LDIR              ; ...
       movb @status_flags,a            ; LD A,($71EB)      ; Clear all flags but two-player flag
       andi a,>8000                    ; AND $80           ; ...
       movb a,@status_flags            ; LD ($71EB),A      ; ...
       movb @bytes+>05,a               ; LD A,$05          ; 5 Lives
       movb a,@lives                   ; LD ($71FF),A      ; Set lives
       ab   one,a                      ; INC A             ; Increment to 6
       movb a,@score_extra_life_1_msb  ; LD ($71F8),A      ; Set #R$71F6+2 to 6 (extra life at 60000)
       movb a,@score_extra_life_2_msb  ; LD ($71FE),A      ; Set #R$71FC+2 to 6 (extra life at 60000)
       movb one,a                      ; LD A,$01          ; Stage
       movb a,@stage                   ; LD ($7200),A      ; Set to 1
       .call @init_center_enemies      ; CALL $AA7D        ; Init center enemies
       li   hl,stage_msg               ; LD HL,$853C       ; Display stage message
       li   de,>1af8                   ; LD DE,$1AF8       ; ...
       li   bc,>0005                   ; LD BC,$0005       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   de,>1802                   ; LD DE,$1802       ; Display '1' at the top left corner
       movb @bytes+>31,a               ; LD A,$31          ; ...
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Display '-' next to '1'
       movb @bytes+>2d,a               ; LD A,$2D          ; ...
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       sb   a,a                        ; XOR A             ; Parameter to display score
       .call @display_score            ; CALL $A699        ; Display score player 1
       movb @status_flags,a            ; LD A,($71EB)      ; Flags
       czc  @bit7,a                    ; BIT 7,A           ; Test bit for two players
       jeq  new_game_1                 ; JR Z,$80E0        ; If bit is reset then skip ahead
       li   de,>181e                   ; LD DE,$181E       ; Display '-' at the top right corner
       movb @bytes+>2d,a               ; LD A,$2D          ; ...
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Display '2' next to '-'
       movb @bytes+>32,a               ; LD A,$32          ; ...
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       movb one,a                      ; LD A,$01          ;
       .call @display_score            ; CALL $A699        ; Display score player 2
       li   hl,lives                   ; LD HL,$71FF       ; Save player data in VDP RAM, starting with lives
       li   de,>1300                   ; LD DE,$1300       ; VDP address
       li   bc,active_enemies-lives    ; LD BC,$002D       ; 45 bytes
       bl   @write_vram                ; RST $38           ; WRITE_VRAM
       movb @status_flags,@vdpwd
new_game_1:                            ; >80e0
;       movb r,a                        ; LD A,R            ; Random number seed
;       movb a,@random_number+>0001     ; LD ($731C),A      ; Init random number
       .call @init_stage               ; CALL $8212        ; Initialize stage

* Main loop
*
* Used by the routines at #R$81AE and #R$83D0.
main_loop:                             ; >80e8
;       li   hl,interrupt_flag          ; LD HL,$725A       ; Flag set by interrupt routine
;_80eb:                                 ; >80eb
;       movb *hl,r0                     ; BIT 0,(HL)        ; Test flag
;       andi r0,>0100                   ;
;       jeq  _80eb                      ; JR Z,$80EB        ; Wait until set
;       szcb @bits+0,*hl                ; RES 0,(HL)        ; Clear flag
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER (read VDP status)
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       bl   @play_sound_if_int
       .call @handle_collisions        ; CALL $9796        ; Handle collisions
       .call @create_or_display_mines  ; CALL $8E2D        ;
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       bl   @play_sound_if_int
       .call @handle_waves             ; CALL $8BD9        ; Manage waves
       .call @create_sprite_from_map_entry ; CALL $AAF1        ; Create sprite from map entry
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       bl   @play_sound_if_int
       .call @create_laser_fence_or_meteor ; CALL $8D50        ; Create laser fence
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       .call @display_score            ; CALL $A699        ; Display score
       movb @status_flags,a            ; LD A,($71EB)      ; Status flags
       czc  @bit2,a                    ; BIT 2,A           ; Test bit 2
       jne  died                       ; JP NZ,$8139       ; Exit main loop if set
       czc  @bit1,a                    ; BIT 1,A           ; Test bit for all waves completed
       jeq  main_loop                  ; JR Z,$80E8        ; Loop if not set
       movb @total_enemies,a           ; LD A,($7206)      ; Get total enemies
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Add enemy shots
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       jne  main_loop                  ; JP Z,$832A        ; Stage completed when sum is zero
       b    @stage_completed           ;
;       jmp  main_loop                  ; JR $80E8          ; Loop

* Died
*
* Used by the routine at #R$80E8.
died:                                  ; >8139
       .call @stop_tune                ; CALL $9B87        ; Stop tune
       movb @bytes+>03,a               ; LD A,$03          ; Play explosion sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Reset main loop flag
       szcb @bits+6,*hl                ; RES 6,(HL)        ; ...
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       .call @reset_enemy_sprite_types ; CALL $8AE6        ; Update sprite types $0F - $11
       .call @explode                  ; CALL $A3E1        ; Explosion
died_1:                                 ; >814f
       movb @active_enemies,a          ; LD A,($722C)      ; Get active enemies
;       socb a,a                        ; OR A              ;
       jne  died_2                     ; JR NZ,$815E       ; If any left then keep waiting
       movb @total_enemies,a           ; LD A,($7206)      ; Get total enemies
       li   hl,center_map_entries      ; LD HL,$722B       ; Compare to center entries
       cb   a,*hl                      ; CP (HL)           ; ...
       jeq  lose_life                  ; JR Z,$8170        ; When all are centered then jump to lose life
died_2:                                ; >815e
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @create_or_display_mines  ; CALL $8E2D        ; Create or display mines
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       jmp  died_1                     ; JR $814F          ;

* Lose life
*
* Used by the routine at #R$8139.
lose_life:                             ; >8170
       .call @reset_outcoming_enemies  ; CALL $8D21        ; Reset outcoming enemies
       li   hl,stage_death_count       ; LD HL,$7204       ; Increase number of times died within stage
       ab   one,*hl                    ; INC (HL)          ; ...
       li   hl,lives                   ; LD HL,$71FF       ; Lives
       sb   one,*hl                    ; DEC (HL)          ; Lose life
       jne  switch_player              ; JR NZ,$81AE       ; Jump if lives left
* Game over
       li   de,>1c00                   ; LD DE,$1C00       ;
       movb @bytes+>d0,a               ; LD A,$D0          ;
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       .call @display_player           ; CALL $830E        ; Display player
       li   hl,game_over_msg           ; LD HL,$85DD       ; Display GAME OVER
       li   de,>19cb                   ; LD DE,$19CB       ; ...
       li   bc,>0009                   ; LD BC,$0009       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       sb   b,b                        ; LD B,$00          ; Stars for 256 frames
game_over_loop:                        ; >8192
       .push bc                        ; PUSH BC           ; ...
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .pop bc                         ; POP BC            ; ...
       sb   one,b                      ; DJNZ $8192        ; ...
       jne  game_over_loop             ;
       .call @clear_rows_9_and_14      ; CALL $84ED        ; Clear rows 9 and 14
       li   hl,status_flags            ; LD HL,$71EB       ; Test for two players
       movb *hl,r0                     ; BIT 7,(HL)        ; ...
       andi r0,>8000                   ;
       jne  !                          ; JP Z,$81ED        ; If not, wait for restart
       b    @wait_for_restart          ;
!
       movb *hl,r0                     ; BIT 5,(HL)        ; Is one player already game over?
       andi r0,>2000                   ;
       jeq  !                          ; JP NZ,$81ED       ; If so, wait for restart
       b    @wait_for_restart          ;
!
       socb @bits+5,*hl                ; SET 5,(HL)        ; Else flag that one player game over
       jmp  switch_player_1            ; JR $81B9          ; And switch player

* Switch player
*
* Used by the routine at #R$8170.
switch_player:                         ; >81ae
       movb @status_flags,a            ; LD A,($71EB)      ; Test for two players
       czc  @bit7,a                    ; BIT 7,A           ; ...
       jeq  switch_player_2            ; JR Z,$81E2        ; Skip ahead if one player
       movb *hl,r0                     ; BIT 5,(HL)        ; Is one player already game over?
       andi r0,>2000                   ;
       jne  switch_player_2            ; JR NZ,$81E2       ; Skip ahead if not set
* This entry point is used by the routine at #R$8170.
switch_player_1:                       ; >81b9
       li   hl,buffer                  ; LD HL,$71A3       ; Restore player data from VDP RAM into buffer
       li   de,>1300                   ; LD DE,$1300       ; ...
       li   bc,active_enemies-lives+1  ; LD BC,$002D       ; ...
       bl   @read_vram                 ; CALL $1FE2        ; READ_VRAM
       li   hl,lives                   ; LD HL,$71FF       ; Save player data to VDP RAM
       li   de,>1300                   ; LD DE,$1300       ; ...
       li   bc,active_enemies-lives    ; LD BC,$002D       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       movb @status_flags,@vdpwd
       li   hl,buffer                  ; LD HL,$71A3       ; Copy data from buffer to right place
       li   de,lives                   ; LD DE,$71FF       ; ...
       li   bc,active_enemies-lives    ; LD BC,$002D       ; ...
       .ldir                           ; LDIR              ; ...
       movb *hl,a                      ; Get saved status flags (bugfix)
       andi a,>0200                    ; Keep only waves completed flag
       szcb @bits+1,@status_flags      ; Apply flag
       socb a,@status_flags            ; ...
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       xor  one,a                      ; XOR $01           ; Switch player
       movb a,@current_player          ; LD ($71F1),A      ; Save again
switch_player_2:                       ; >81e2
       .call @init_stage               ; CALL $8212        ; Initialize stage
       li   hl,other_flags             ; LD HL,$7256       ; Set flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @main_loop                 ; JP $80E8          ; To main loop

* Wait for restart
*
* Used by the routine at #R$8170.
wait_for_restart:                      ; >81ed
       li   hl,>4650                   ; LD HL,$4650       ; 300 seconds
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Set screensaver countdown
wait_for_restart_loop:                 ; >81f3
        bl   @wait_int_play_sound
;       li   hl,>0001                   ; LD HL,$0001       ; Controller 0, segment 1
;       bl   @decoder                   ; CALL $1F79        ; DECODER
;       movb @l,a                       ; LD A,L            ;
;       cb   a,@bytes+>0a               ; CP $0A            ;
;       jne  !                          ; JP Z,$8064        ; Start a new game
;       b    @new_game                  ;
;!
;       cb   a,@bytes+>0f               ; CP $0F            ;
;       jeq  !                          ; JP NZ,$0000       ; Reset
;       b    @>0000                     ;
;!
       li   hl,>0000                   ; LD HL,$0000       ; Controller 0, segment 0
       bl   @decoder                   ; CALL $1F79        ; DECODER
       czc  @bit6,h                    ; BIT 6,H           ; Test fire
       jeq  wait_for_restart_loop      ; JP NZ,$8064       ; Start a new game
       b    @new_game                  ;

* Init stage
*
* Initialize stage and display X WARPS TO Y message. Used by the routines at
* #R$8024, #R$81AE and #R$83D0.
init_stage:                            ; >8212
       li   hl,ship_background_data    ; LD HL,$722E       ; Clear $28 bytes from $722E
       li   de,ship_background_data+>0001 ; LD DE,$722F       ; ...
       li   bc,>0028                   ; LD BC,$0028       ; ...
       sb   *hl,*hl                    ; LD (HL),$00       ; ...
       .ldir                           ; LDIR              ; ...
       movb one,a                      ; LD A,$01          ; Set sprite countdown to 1
       movb a,@sprite_countdown        ; LD ($71EE),A      ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Reset died flag
       szcb @bits+2,*hl                ; RES 2,(HL)        ; ...
* Calculate stage data index
       movb @completed_stages,a        ; LD A,($7205)      ; Get completed stages
;       socb a,a                        ; OR A              ; Test if zero
       jne  init_stage_1               ; JR NZ,$823E       ; If not, skip ahead to set max value
       movb @stage,a                   ; LD A,($7200)      ; Stage
       cb   a,@bytes+>04               ; CP $04            ; Compare stage to 4
       jhe  init_stage_2               ; JR NC,$8240       ; Jump if stage >= 4, to set value = stage / 4 + 1
       movb a,b                        ; LD B,A            ; B = stage 1-3
       sb   a,a                        ; XOR A             ; A = 0
       sb   one,b                      ; DEC B             ; B = 0-2
       jeq  init_stage_3               ; JR Z,$8245        ; If zero then skip ahead to save value
       ab   one,a                      ; INC A             ; Stage = 2 or 3, set A = 1
       jmp  init_stage_3               ; JR $8245          ; Skip ahead to save value
init_stage_1:                          ; >823e
       movb @bytes+>18,a               ; LD A,$18          ; 24
init_stage_2:                          ; >8240
       srl  a,1                        ; SRL A             ; Divide stage by 4
       srl  a,1                        ; SRL A             ; ...
       ab   one,a                      ; INC A             ; + 1
init_stage_3:                          ; >8245
       movb a,@stage_data_index        ; LD ($7203),A      ; Save value (0 - 7)
* Display stage number
       movb @stage,a                   ; LD A,($7200)      ; Current stage
       li   hl,completed_stages        ; LD HL,$7205       ; Completed stages
       ab   *hl,a                      ; ADD A,(HL)        ; Add to stage
       li   de,>1afe                   ; LD DE,$1AFE       ; VDP address (stage number tens)
       cb   a,@bytes+>0a               ; CP $0A            ;
       jl   init_stage_6               ; JR C,$8267        ; Jump if < 10
       sb   b,b                        ; LD B,$00          ; Divide by ten into B
init_stage_4:                          ; >8258
       sb   @bytes+>0a,a               ; SUB $0A           ; ...
       jlt  init_stage_5               ; JR C,$825F        ; ...
       ab   one,b                      ; INC B             ; ...
       jmp  init_stage_4               ; JR $8258          ; ...
init_stage_5:                          ; >825f
       ab   @bytes+>0a,a               ; ADD A,$0A         ; Restore ones
       movb a,@c                       ; LD C,A            ; Save in C
       movb b,a                        ; LD A,B            ; Tens
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       movb @c,a                       ; LD A,C            ; Ones
init_stage_6:                          ; >8267
       inc  de                         ; INC DE            ; Increment VDP address to stage number ones
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
* Display X WARPS TO Y message
       movb @wave,a                    ; LD A,($7201)      ; Check whether you just died
;       socb a,a                        ; OR A              ; So we want to display READY instead
       jne  init_stage_8               ; JR NZ,$82BA       ; And if so jump ahead
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       movb a,b                        ; LD B,A            ; Save in B
       srl  a,1                        ; SRL A             ; Divide by 2
       andi a,>0e00                    ; AND $0E           ; Clamp to 0, 2, 4, 6, 8, 10, 12
       li   hl,planet_table            ; LD HL,$9398       ; Base planet table
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
;       movb *hl,@e                     ; LD E,(HL)         ; Get LSB of planet data
;       inc  hl                         ; INC HL            ; To MSB
;       movb *hl,d                      ; LD D,(HL)         ; Get MSB of planet data
       mov  *hl,de
       li   hl,>0010                   ; LD HL,$0010       ; Planet name offset is 16
       a    de,hl                      ; ADD HL,DE         ; Add planet data address
       .push hl                        ; PUSH HL           ; Save it
       li   de,buffer+>0001            ; LD DE,$71A4       ; Buffer address for the string #R$71A3+1
       movb b,a                        ; LD A,B            ; Restore stage
       andi a,>0300                    ; AND $03           ; Clamp to 0, 1, 2, 3
       cb   a,@bytes+>03               ; CP $03            ; If 3 we have reached a chance stage
       jeq  init_stage_9               ; JR Z,$82BF        ; Then jump ahead
       li   r0,3*256                   ; XOR $03           ; Flip the bits, so we know how many warps TO the planet
       xor  r0,a                       ;
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       movb a,*de                      ; LD (DE),A         ; Store number in the buffer
       inc  de                         ; INC DE            ; Next buffer address
       li   hl,warps_msg               ; LD HL,$859C       ; WARPS message
       li   bc,>0005                   ; LD BC,$0005       ; Copy 5 bytes '_WARP'
       cb   a,@bytes+>31               ; CP $31            ; If the number is less than 2,
       jeq  init_stage_7               ; JR Z,$82A0        ; then skip ahead
       inc  bc                         ; INC BC            ; Otherwise copy one more byte '_WARPS'
init_stage_7:                          ; >82a0
       equ  $
       .ldir                           ; LDIR              ; Make the copy
       li   hl,to_msg                  ; LD HL,$85A2       ; Copy _TO_ message
       li   bc,>0004                   ; LD BC,$0004       ; 4 bytes
       .ldir                           ; LDIR              ; Make the copy
       .pop hl                         ; POP HL            ; Restore the planet name address
       movb *hl,@c                     ; LD C,(HL)         ; Get length of name
       inc  hl                         ; INC HL            ; Next byte
       .ldir                           ; LDIR              ; Copy planet name
       .ex_de_hl                       ; EX DE,HL          ; Now HL=destination and DE=source
       li   de,buffer+>0001            ; LD DE,$71A4       ; Buffer address for the string #R$71A3+1
       s    de,hl                      ; SBC HL,DE         ; Now HL contain the length of the string
       .ex_de_hl                       ; EX DE,HL          ; Now DE=length and HL=$71A4
       dec  hl                         ; DEC HL            ; HL=#R$71A3
       movb @e,*hl                     ; LD (HL),E         ; Set length
       jmp  init_stage_10              ; JR $82C3          ; Jump ahead
init_stage_8:                          ; >82ba
       li   hl,ready_msg               ; LD HL,$8589       ; Ready message
       jmp  init_stage_10              ; JR $82C3          ; Skip ahead
init_stage_9:                          ; >82bf
       .pop hl                         ; POP HL            ; Drop the pushed planet name address
       li   hl,chance_stage_msg        ; LD HL,$858F       ; Chance stage message
init_stage_10:                         ; >82c3
       movb @bytes+>20,a               ; LD A,$20          ; At this point HL contains a pointer to the length
                                                           ; prefixed message to print
       sb   *hl,a                      ; SUB (HL)          ; 32 - string length
       srl  a,1                        ; SRL A             ; / 2 = offset to center line
       li   de,>1a00                   ; LD DE,$1A00       ; VDP address of line start
       ab   @e,a                       ; ADD A,E           ; Add address to offset
       movb a,@e                       ; LD E,A            ; Copy back to destination
       movb *hl,@c                     ; LD C,(HL)         ; Length
       sb   b,b                        ; LD B,$00          ; MSB of length
       inc  hl                         ; INC HL            ; Increment source to text
       bl    @write_vram               ; RST $38           ; WRITE_VRAM Display the X WARPS TO Y message
* Display ship and stars with music for a short while
       .call @display_player           ; CALL $830E        ; Display player if two player
       sb   b,b                        ; LD B,$00          ; For calculating ...
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       li   hl,completed_stages        ; LD HL,$7205       ; Add completed stages
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       cb   a,one                      ; CP $01            ; If 1 then skip ahead with B = 0
       jeq  init_stage_11              ; JR Z,$82F6        ; ...
       andi a,>0300                    ; AND $03           ; Stage mod 4
       movb @bytes+>05,b               ; LD B,$05          ; Set B = 5
       cb   a,one                      ; CP $01            ; And skip ahead if stage mod 4 < 1
       jl   init_stage_11              ; JR C,$82F6        ; ...
       movb @bytes+>03,b               ; LD B,$03          ; Set B = 3
       jeq  init_stage_11              ; JR Z,$82F6        ; And skip ahead if stage mod 4 = 1
       movb @bytes+>04,b               ; LD B,$04          ; Set B = 4
       cb   a,@bytes+>02               ; CP $02            ; And skip ahead if stage mod 4 = 2
       jeq  init_stage_11              ; JR Z,$82F6        ; ...
       movb @bytes+>06,b               ; LD B,$06          ; Set B = 6
init_stage_11:                         ; >82f6
       movb b,a                        ; LD A,B            ; Set A = B
       .call @call_play_tune           ; CALL $9E91        ; Play selected tune
       .call @display_lives            ; CALL $A6D2        ; Display lives
       .call @init_sprite_data         ; CALL $ACDF        ; Init sprite data
       .call @initial_game_loop        ; CALL $A33B        ; Initial game loop
       .call @init_mine_variables_2    ; CALL $8E8D        ; Init some variables
       li   hl,status_flags            ; LD HL,$71EB       ; Update status flags
       szcb @bits+4,*hl                ; RES 4,(HL)        ; Reset init flag
       socb @bits+6,*hl                ; SET 6,(HL)        ; Set main loop flag
       .ret                            ; RET               ;

* Display player message
*
* Used by the routines at #R$8170 and #R$82BF.
display_player:                        ; >830e
       movb @status_flags,a            ; LD A,($71EB)      ; Status flags
       czc  @bit7,a                    ; BIT 7,A           ; Check bit for two players
       jeq  display_player_1           ; RET Z             ; Return if not set
       li   hl,player_msg              ; LD HL,$8581       ; PLAYER 1 message
       li   de,>192c                   ; LD DE,$192C       ; VDP address
       li   bc,>0008                   ; LD BC,$0008       ; 8 characters
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       movb @current_player,a          ; LD A,($71F1)      ; Current player
;       socb a,a                        ; OR A              ; Is it player 1?
       jeq  display_player_1           ; RET Z             ; The return
       movb @bytes+>32,a               ; LD A,$32          ; ASCII 2
       li   de,>1933                   ; LD DE,$1933       ; VDP address
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
display_player_1:
       .ret                            ; RET               ;

* Stage completed
*
* Used by the routine at #R$80E8.
stage_completed:                       ; >832a
       movb @bytes+>08,a               ; LD A,$08          ; Set counter for later
       movb a,@counter_stage_completed ; LD ($7259),A      ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Reset main loop flag
       szcb @bits+6,*hl                ; RES 6,(HL)        ; ...
;       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       movb *hl,r0                     ; BIT 3,(HL)        ; If bit 3 is set
       andi r0,>0800                   ;
       jeq  stage_completed_1          ; JP NZ,$8429       ; Then it was a chance stage
       b    @display_bonus             ;
* This entry point is used by the routines at #R$8450 and #R$846B.
stage_completed_1:                     ; >833c
       movb @bytes+>5a,b               ; LD B,$5A          ; 90
stage_completed_loop:                     ; >833e
       .push bc                        ; PUSH BC           ;
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ;
       sb   one,b                      ; DJNZ $833E        ; Loop for 90 frames
       jne  stage_completed_loop          ;
       .call @stop_tune                ; CALL $9B87        ; Stop tune
       .call @clear_rows_9_and_14      ; CALL $84ED        ; Clear rows 9 and 14
       movb @stage,a                   ; LD A,($7200)      ; Stage
       andi a,>0300                    ; AND $03           ; Stage mod 4
       cb   a,@bytes+>02               ; CP $02            ; If not planet reached (2)
       jne  stage_completed_3          ; JR NZ,$8368       ; Then skip ahead
       movb one,a                      ; LD A,$01          ; Play tune 1
       .call @call_play_tune           ; CALL $9E91        ; ...
       jmp  stage_completed_4          ; JR $836D          ;
stage_completed_3:                     ; >8368
       movb @bytes+>05,a               ; LD A,$05          ; If not planet reached then play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
stage_completed_4:                     ; >836d
       li   hl,status_flags            ; LD HL,$71EB       ;
       socb @bits+0,*hl                ; SET 0,(HL)        ; Set warp flag
       socb @bits+4,*hl                ; SET 4,(HL)        ; Set init flag
       movb @stage,a                   ; LD A,($7200)      ; Stage
       movb a,b                        ; LD B,A            ; B = stage
       andi a,>0300                    ; AND $03           ; Stage mod 4
       cb   a,@bytes+>02               ; CP $02            ; If not planet reached (2)
       jne  warp_loop          ; JR NZ,$838A       ; Then skip displaying planet
       movb b,a                        ; LD A,B            ; Stage
;       srl  a,1                        ; SRL A             ; Divide by 4
;       srl  a,1                        ; SRL A             ; ...
       srl  a,2
       ab   one,a                      ; INC A             ; + 1
       .call @display_planet           ; CALL $9175        ; Display planet A
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
* Warp
warp_loop:                             ; >838a
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       li   hl,counter_stage_completed ; LD HL,$7259       ; Decrement counter that start at 8
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne  stage_completed_8          ; JR NZ,$83CB       ; If not zero yet then skip loop body
       movb @bytes+>08,*hl             ; LD (HL),$08       ; Reset counter
       li   ix,sprite_data             ; LD IX,$7002       ; Pointer sprite 0
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment polar y
       ab   one,@>0d(ix)               ; INC (IX+$0D)      ; Increment polar y for sprite 1
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>12               ; CP $12            ; Is polar y 18?
       jne  stage_completed_6          ; JR NZ,$83B2       ; No, skip ahead
       .push af                        ; PUSH AF           ;
       .call @clear_row_7              ; CALL $920D        ; Clear row 7 (planet name)
       .pop af                         ; POP AF            ;
stage_completed_6:                     ; >83b2
       cb   a,@bytes+>2b               ; CP $2B            ; Is polar y 43?
       jeq  next_stage                 ; JR Z,$83D0        ; Yes, break out of loop
       cb   a,@bytes+>15               ; CP $15            ; Is polar y 21?
       jne  stage_completed_7          ; JR NZ,$83C2       ; No, skip ahead
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color of sprite 0
       movb @bytes+>09,@>17(ix)        ; LD (IX+$17),$09   ; Set color of sprite 1
stage_completed_7:                     ; >83c2
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern sprite 0
       li   ix,sprite_data_1           ; LD IX,$700E       ; Sprite 1
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern sprite 1
       .call @display_ship_bg_patterns ; CALL $A808        ; Display ship background patterns
stage_completed_8:                     ; >83cb
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       jmp  warp_loop          ; JR $838A          ; Loop

* Next stage
*
* Used by the routine at #R$832A.
next_stage:                            ; >83d0
       li   hl,status_flags            ; LD HL,$71EB       ; Flags
       szcb @bits+0,*hl                ; RES 0,(HL)        ; Reset warp flag
       szcb @bits+1,*hl                ; RES 1,(HL)        ; Reset all waves completed
       sb   a,a                        ; XOR A             ;
       movb a,@wave                    ; LD ($7201),A      ; Clear wave
       movb a,@enemies_hit             ; LD ($7202),A      ; Clear enemies destroyed
       movb @stage,a                   ; LD A,($7200)      ; Stage
       ab   one,a                      ; INC A             ; Next stage
       cb   a,@bytes+>18               ; CP $18            ; Did we reach 24?
       jl   next_stage_1               ; JR C,$83EC        ; No, skip ahead
       li   hl,completed_stages        ; LD HL,$7205       ; Get the total stages completed
       ab   *hl,a                      ; ADD A,(HL)        ; And add 24
       movb a,*hl                      ; LD (HL),A         ; Save again
       sb   a,a                        ; XOR A             ; And set stage to zero
next_stage_1:                          ; >83ec
       movb a,@stage                   ; LD ($7200),A      ; Save stage
       li   hl,status_flags            ; LD HL,$71EB       ; Flags
       szcb @bits+3,*hl                ; RES 3,(HL)        ; Reset chance stage flag
       movb @stage,a                   ; LD A,($7200)      ; Stage
       andi a,>0300                    ; AND $03           ; Mod 4
       cb   a,@bytes+>03               ; CP $03            ; Is it a chance stage?
       jne  next_stage_2               ; JR NZ,$83FF       ; No, skip ahead
       socb @bits+3,*hl                ; SET 3,(HL)        ; Yes, set flag
next_stage_2:                          ; >83ff
       sb   a,a                        ; XOR A             ; Reset death count
       movb a,@stage_death_count       ; LD ($7204),A      ; ...
       .call @display_planet           ; CALL $9175        ; Undraw planet
       li   hl,>201c                   ; LD HL,$201C       ; Set 4 colors to white/black
       li   de,>0004                   ; LD DE,$0004       ; ...
       movb @bytes+>f1,a               ; LD A,$F1          ; ...
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       li   hl,>0700                   ; LD HL,$0700       ; Address in pattern table
       li   de,>0100                   ; LD DE,$0100       ; 256 bytes = 32 patterns
       sb   a,a                        ; XOR A             ; Clear
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       movb @other_flags,a             ; LD A,($7256)      ; Save flags
       .push af                        ; PUSH AF           ; ...
       .call @init_stage               ; CALL $8212        ; Init stage
       .pop af                         ; POP AF            ; Restore flags
       movb a,@other_flags             ; LD ($7256),A      ; ...
       b    @main_loop                 ; JP $80E8          ; Jump to main loop

* Display bonus
*
* Used by the routine at #R$832A.
display_bonus:                         ; >8429
       movb @bonus_enemies_hit,a       ; LD A,($7255)      ; Number of ships destroyed in chance stage
       cb   a,@bytes+>28               ; CP $28            ; Is it 40?
       jeq  perfect_bonus              ; JR Z,$846B        ; Then it's perfect
       .push af                        ; PUSH AF           ; Save ships
       li   hl,bonus_msg               ; LD HL,$85A6       ; Display BONUS
       li   de,>192d                   ; LD DE,$192D       ; ...
       li   bc,>0005                   ; LD BC,$0005       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   hl,bonus_numbers_msg       ; LD HL,$85AB       ; Display 100 X ..  ..00
       li   de,>19c9                   ; LD DE,$19C9       ; ...
       li   bc,>000e                   ; LD BC,$000E       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       .pop af                         ; POP AF            ; Restore ships
       .push af                        ; PUSH AF           ; Save again
       movb @bytes+>30,b               ; LD B,$30          ; 48
display_bonus_1:                       ; >8449
       sb   @bytes+>0a,a               ; SUB $0A           ; Ships - 10
       jlt  display_hits               ; JR C,$8450        ; Jump if ships < 10, A is now -10 to -1
       ab   one,b                      ; INC B             ; +1 for every 10 ships
       jmp  display_bonus_1            ; JR $8449          ; Loop

* Display hits
*
* Used by the routine at #R$8429.
display_hits:                          ; >8450
       ab   @bytes+>3a,a               ; ADD A,$3A         ; Add ASCII for zero + 10
       li   de,>19d0                   ; LD DE,$19D0       ; Ones in number of ships
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       li   de,>19d4                   ; LD DE,$19D4       ; Hundreds in bonus
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       movb b,a                        ; LD A,B            ; Tens
       li   de,>19cf                   ; LD DE,$19CF       ; Tens in number of ships
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       li   de,>19d3                   ; LD DE,$19D3       ; Thousands in bonus
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       .pop bc                         ; POP BC            ; Restore ships destroyed
       movb b,a                        ; LD A,B            ; If it zero?
;       socb a,a                        ; OR A              ; ...
       jne  !                          ; JP Z,$833C        ; Then jump back to complete stage
       b    @stage_completed_1         ;
!
       jmp  display_bonus_score        ; JR $8486          ; Else add B x 100 bonus points

* Perfect bonus
*
* Used by the routine at #R$8429.
perfect_bonus:                         ; >846b
       movb @bytes+>02,a               ; LD A,$02          ; Play a tune
       .call @call_play_tune           ; CALL $9E91        ; ...
       li   hl,congratulations_msg     ; LD HL,$85B9       ; Display CONGRATULATIONS
       li   de,>1928                   ; LD DE,$1928       ; ...
       li   bc,>0010                   ; LD BC,$0010       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   hl,perfect_msg             ; LD HL,$85C9       ; Display PERFECT 10000 PTS
       li   de,>19c6                   ; LD DE,$19C6       ; ...
       li   bc,>0014                   ; LD BC,$0014       ; ...
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       movb @bytes+>64,b               ; LD B,$64          ; 100 times
* This entry point is used by the routine at #R$8450.
display_bonus_score:                   ; >8486
       li   hl,>0100                   ; LD HL,$0100       ; 100 points
display_bonus_score_1:                 ; >8489
       .push hl                        ; PUSH HL           ;
       .push bc                        ; PUSH BC           ;
       .call @add_score                ; CALL $A6EC        ; Add 100 points to score
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       .call @display_score            ; CALL $A699        ; Display score
       movb @bytes+>07,b               ; LD B,$07          ; 7 frames
bonus_score_loop:                 ; >8496
       .push bc                        ; PUSH BC           ;
        bl   @wait_int_play_sound
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ;
       sb   one,b                      ; DJNZ $8496        ; Loop 7 times
       jne  bonus_score_loop                      ;
       .pop bc                         ; POP BC            ;
       .pop hl                         ; POP HL            ;
       sb   one,b                      ; DJNZ $8489        ; Loop number of ships times
       jne  display_bonus_score_1                      ;
       b    @stage_completed_1         ; JP $833C          ; Jump back to complete stage

* Update frames and upload sprites
*
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$832A, #R$846B, #R$A33B
* and #R$A3E1.
next_frame_upl_sprites:                ; >84b1
       li   hl,frame_counter           ; LD HL,$71F2       ; Update frame counter
       ab   one,*hl                    ; INC (HL)          ; ...
       movb *hl,a                      ; LD A,(HL)         ; Get new value
       andi a,>0100                    ; AND $01           ; Every second frame ...
       jne  _84c8                      ; JR NZ,$84C8       ; go directly to upload sprite data
       movb @sprite_data_1,a           ; LD A,($700E)      ; Else get type of sprite 1
       cb   a,one                      ; CP $01            ; Is it 1 (ship 2)?
       jne  _84c8                      ; JR NZ,$84C8       ; If not upload sprite data
       li   hl,sprite_data_1+>000b     ; LD HL,$7019       ; Get color of sprite 1
       movb *hl,a                      ; LD A,(HL)         ; ...
       li   r0,4*256                   ; XOR $04           ; Flip bit 4
       xor  r0,a                       ;
       movb a,*hl                      ; LD (HL),A         ; And set color back
_84c8:                                 ; >84c8
       b    @upload_sprite_data        ; JP $ACF9          ; Upload sprite data

* Upload patterns
*
* Used by the routine at #R$90D6.
*
* I: HL Pointer to start index and count
upload_patterns:                       ; >84cb
       sb   d,d                        ; LD D,$00          ;
       movb *hl,@e                     ; LD E,(HL)         ; DE = start index
       inc  hl                         ; INC HL            ;
       movb *hl,@c                     ; LD C,(HL)         ;
       sb   b,b                        ; LD B,$00          ; BC = count
       .push bc                        ; PUSH BC           ;
       .pop iy                         ; POP IY            ; IY = count
       inc  hl                         ; INC HL            ; HL now points to graphics data
       movb @bytes+>03,a               ; LD A,$03          ; Table code (3 = pattern generator table)
       bl   @put_vram                  ; JP $1FBE          ; PUT_VRAM
       .ret

* Get stage data address
*
* Used by the routines at #R$8878, #R$8A53, #R$8A76, #R$8C68, #R$8D50, #R$8E9D,
* #R$900E and #R$AAF1.
*
* O:IY Stage data address
stage_data_addr:                       ; >84db
;       .push de                        ; PUSH DE           ;
       clr  iy       
       movb @stage_data_index,iy        ; LD A,($7203)      ; Get value (0 - 6)
;       ab   a,a                        ; ADD A,A           ; Multiply by 8
;       ab   a,a                        ; ADD A,A           ; ...
;       ab   a,a                        ; ADD A,A           ; ...
       sla  iy,3
;       movb a,@e                       ; LD E,A            ; Add #R$8541
;       sb   d,d                        ; LD D,$00          ; ...
       swpb iy
       ai   iy,stage_data_table
;       li   iy,stage_data_table        ; LD IY,$8541       ; ...
;       a    de,iy                      ; ADD IY,DE         ; ...
;       .pop de                         ; POP DE            ;
       rt                               ; RET               ;

* Clear rows 9 and 14
*
* Used by the routines at #R$8170 and #R$832A.
clear_rows_9_and_14:                   ; >84ed
       li   hl,>1920                   ; LD HL,$1920       ; Name table row 9
       li   de,>0020                   ; LD DE,$0020       ; 32 bytes
       sb   a,a                        ; XOR A             ; Clear
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       li   hl,>19c0                   ; LD HL,$19C0       ; Name table row 14
       li   de,>0020                   ; LD DE,$0020       ; 32 bytes
       sb   a,a                        ; XOR A             ; Clear
       bl   @fill_vram                 ; JP $1F82          ; FILL_VRAM
       .ret

;* Interrupt routine
;*
;* Calls sound player and handles screen saver Used by the routine at #R$8021.
;interrupt_routine:                     ; >8501
;       .push ix                        ; PUSH IX           ;
;       .push iy                        ; PUSH IY           ;
;       .push hl                        ; PUSH HL           ;
;       .push de                        ; PUSH DE           ;
;       .push bc                        ; PUSH BC           ;
;       .push af                        ; PUSH AF           ;
;       mov  @screensaver_countdown,hl  ; LD HL,($7257)     ; Counter
;       movb h,a                        ; LD A,H            ; Check if zero
;       socb @l,a                       ; OR L              ; ...
;       jeq  _8522                      ; JR Z,$8522        ; If counter is 0 then skip ahead
;       dec  hl                         ; DEC HL            ; Otherwise decrement
;       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; and save.
;       movb h,a                        ; LD A,H            ; Check again if zero
;       socb @l,a                       ; OR L              ; ...
;       jne  _8522                      ; JR NZ,$8522       ; If not then skip ahead, otherwise blank screen
;       li   bc,>0180                   ; LD BC,$0180       ; Display off, interrupt off
;       bl   @write_register            ; RST $18           ; WRITE_REGISTER
;       li   bc,>0701                   ; LD BC,$0701       ; Black border
;       bl   @write_register            ; RST $18           ; WRITE_REGISTER
;_8520:                                 ; >8520
;       jmp  _8520                      ; JR $8520          ; Loop
;_8522:                                 ; >8522
;       .call @sound_player             ; CALL $9B99        ; Sound player
;       movb @status_flags,a            ; LD A,($71EB)      ;
;       czc  @bit6,a                    ; BIT 6,A           ;
;       jne  !                          ; CALL Z,$1FDC      ; READ_REGISTER
;       .call @read_register            ;
;!
;       li   hl,interrupt_flag          ; LD HL,$725A       ;
;       socb @bits+0,*hl                ; SET 0,(HL)        ;
;       .pop af                         ; POP AF            ;
;       .pop bc                         ; POP BC            ;
;       .pop de                         ; POP DE            ;
;       .pop hl                         ; POP HL            ;
;       .pop iy                         ; POP IY            ;
;       .pop ix                         ; POP IX            ;
;       .ret                            ; RETN              ;

play_sound_if_int:
       movb @vdpsta,r0
       jlt  play_sound_if_int_1
       rt
play_sound_if_int_1:
       .proc
       .call @sound_player
       .endproc

wait_int_play_sound:
       movb @vdpsta,r0
       jlt  wait_int_play_sound_1
       jmp  wait_int_play_sound
wait_int_play_sound_1:
       .proc
       .call @sound_player
       .endproc

* STAGE message
stage_msg:                             ; >853c
       text 'STAGE'

* Stage data (8 bytes per stage)
*
* #TABLE(default, default)
* { =h Byte offset | =h Purpose }
* { $00 | Speed }
* { $01 | Max enemy shots }
* { $02 | Enemy shooting speed }
* { $03 | Unknown }
* { $04 | Unknown }
* { $05 | Unknown }
* { $06 | Time between waves }
* { $07 | Unknown }
* TABLE#
stage_data_table:                      ; >8541
       byte >02,>00,>28,>3F,>01,>50,>1E,>00
       byte >02,>01,>28,>3F,>02,>50,>19,>02
       byte >02,>01,>19,>1F,>02,>46,>14,>03
       byte >02,>02,>23,>1F,>03,>46,>14,>03
       byte >02,>02,>1E,>0F,>03,>32,>0A,>03
       byte >02,>03,>14,>0F,>03,>28,>0A,>03
       byte >01,>03,>0F,>0F,>04,>28,>05,>03
       byte >01,>03,>0F,>0F,>04,>1E,>05,>03

* PLAYER message
player_msg:                            ; >8581
       text 'PLAYER',>00,'1'

* READY message
ready_msg:                             ; >8589
       text >05,'READY'

* CHANCE STAGE message
chance_stage_msg:                      ; >858f
       text >0c,'CHANCE',>00,'STAGE'

* WARPS message
warps_msg:                             ; >859c
       text >00,'WARPS'

* TO message
to_msg:                                ; >85a2
       text >00,'TO',>00

* BONUS message
bonus_msg:                             ; >85a6
       text 'BONUS'

* Bonus points message
bonus_numbers_msg:                     ; >85ab
       text '100',>00,'X',>00,'..',>00,>00,'..00'

* CONGRATULATIONS message
congratulations_msg:                   ; >85b9
       text 'CONGRATULATIONS?'

* PERFECT message
perfect_msg:                           ; >85c9
       text 'PERFECT?',>00,>00,>00,'10000',>00,'PTS'

* GAME OVER message
game_over_msg:                         ; >85dd
       text 'GAME',>00,'OVER'

* Process sprites
*
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$832A, #R$846B and
* #R$A3E1.
process_sprites:                       ; >85e6
       li   hl,sprite_countdown        ; LD HL,$71EE       ; Decrement counter 1
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,attack_countdown        ; LD HL,$7260       ; Decrement counter 2
       sb   one,*hl                    ; DEC (HL)          ; ...
       movb @countdown_to_shoot,a      ; LD A,($71EF)      ; Decrement counter stopping at 0
       sb   one,a                      ; DEC A             ; ...
       jlt  process_sprites_1          ; JP M,$85F8        ; ...
       movb a,@countdown_to_shoot      ; LD ($71EF),A      ; ...
process_sprites_1:                     ; >85f8
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       szcb @bits+4,*hl                ; RES 4,(HL)        ; Reset laser fence flag
       li   hl,sprite_allocation_table+>0002 ; LD HL,$7185       ; Table address #R$7183+2 (skip ship sprites)
* This entry point is used by the routine at #R$8A41.
process_next_sprite:                   ; >8600
;       .push hl                        ; PUSH HL           ; Save table address
;       li   de,sprite_allocation_table ; LD DE,$7183       ; Sprite allocation table
;       sb   a,a                        ; XOR A             ; Clear carry
;       s    de,hl                      ; SBC HL,DE         ; HL = offset into table
;       movb @allocated_sprites,a       ; LD A,($7182)      ; Allocated sprites
;       cb   a,@l                       ; CP L              ; Compare to offset
;       .pop hl                         ; POP HL            ; Restore table address
;       movb a,a
       mov  hl,r0
       ai   r0,-sprite_allocation_table
       swpb r0
       cb   @allocated_sprites,r0
       jne  !                          ; JP Z,$8A53        ; Jump when we have reached the last allocation
       b    @all_sprites_processed     ;
!
       .push hl                        ; PUSH HL           ; Push allocation table address
;       movb *hl,@l                     ; LD L,(HL)         ; Get sprite data table index
;       sb   h,h                        ; LD H,$00          ; ...
;       a    hl,hl                      ; ADD HL,HL         ; Multiply by 4
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       sla  hl,2
;       movb h,d                        ; LD D,H            ; Store in DE
;       movb @l,@e                      ; LD E,L            ; ...
;       mov  hl,de
;       a    hl,hl                      ; ADD HL,HL         ; Multiplied by 8
;       a    de,hl                      ; ADD HL,DE         ; Multiplied by 12
;       .ex_de_hl                       ; EX DE,HL          ; DE = sprite data table offset
       clr  de
       movb *hl,@e
       li   hl,12
       mpy  hl,de
       li   ix,sprite_data             ; LD IX,$7002       ; Base sprite data table address
       a    hl,ix                      ; ADD IX,DE         ; IX = sprite data table address
       li   hl,return_from_sprite_handler ; LD HL,$8A41       ; Push return address of routine at #R$8A41
       .push hl                        ; PUSH HL           ; ...
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       movb a,@>05(ix)                 ; LD (IX+$05),A     ; Copy it to byte 5
       cb   a,@bytes+>7f               ; CP $7F            ; Is it to be deallocated?
       jeq  deallocate_sprite          ; JP NZ,$865A       ; If not, jump to handlers
       jh   process_next_sprite_1
       clr  r1
       movb a,@r1lb
       sla  r1,1
       mov  @sprite_type_handler_table(r1),r1
       b    *r1
process_next_sprite_1:
       .ret
                                       ; Continue into deallocate_sprite
* This entry point is used by the routines at #R$8654, #R$8673, #R$867D and
* #R$8815.
deallocate_sprite:                     ; >862f
       movb @b255,*ix                  ; LD (IX+$00),$FF   ; Set as not allocated
       .pop hl                         ; POP HL            ; Pop return address
;       .pop hl                         ; POP HL            ; Restore allocation table address of sprite to be
;                                                           ; deallocated
;       .push hl                        ; PUSH HL           ; Push it again
       .peek hl
       li   de,sprite_allocation_table ; LD DE,$7183       ; Sprite allocation table
;      sb   a,a                        ; XOR A             ; Clear carry
       s    de,hl                      ; SBC HL,DE         ; HL = offset into table
       movb @allocated_sprites,a       ; LD A,($7182)      ; Decrement number of allocated sprites
       sb   one,a                      ; DEC A             ; ...
       movb a,@allocated_sprites       ; LD ($7182),A      ; ...
       sb   @l,a                       ; SUB L             ; Allocated sprites - offset = number of allocations
                                                           ; after this one
       jeq  deallocate_sprite_1        ; JR Z,$8650        ; If it was the last one, there's nothing to do
       movb a,@c                       ; LD C,A            ; BC = number of allocations to move
       sb   b,b                        ; LD B,$00          ; ...
;       .pop de                         ; POP DE            ; DE = allocation table address
;       .push de                        ; PUSH DE           ; ...
       .peek de
;       movb d,h                        ; LD H,D            ; HL = allocation table address
;       movb @e,@l                      ; LD L,E            ; ...
       mov  de,hl
       inc  hl                         ; INC HL            ; HL = allocation table address + 1
       .ldir                           ; LDIR              ; Copy allocations after to close hole
deallocate_sprite_1:                   ; >8650
       .pop hl                         ; POP HL            ; Restore allocation table address
       jmp  process_next_sprite        ; JP $8600          ; Proceed with next sprite

* Deallocate enemy
*
* Used by the routines at #R$870C, #R$873E and #R$8848.
deallocate_enemy:                      ; >8654
       li   hl,total_enemies           ; LD HL,$7206       ; Decrease total enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       jmp  deallocate_sprite          ; JR $862F          ; Deallocate sprite

sprite_type_handler_table:
       data process_next_sprite_1      ; 00
       data process_next_sprite_1      ; 01
       data sprite_handler_02          ; 02
       data sprite_handler_03          ; 03
       data sprite_handler_04_0c       ; 04
       data sprite_handler_04_0c       ; 05
       data sprite_handler_04_0c       ; 06
       data sprite_handler_04_0c       ; 07
       data sprite_handler_04_0c       ; 08
       data sprite_handler_04_0c       ; 09
       data sprite_handler_04_0c       ; 0a
       data sprite_handler_04_0c       ; 0b
       data sprite_handler_04_0c       ; 0c
       data process_next_sprite_1      ; 0d
       data sprite_handler_0e_11       ; 0e
       data sprite_handler_0e_11       ; 0f
       data sprite_handler_0e_11       ; 10
       data sprite_handler_0e_11       ; 11
       data sprite_handler_12_13       ; 12
       data sprite_handler_12_13       ; 13
       data sprite_handler_14          ; 14
       data sprite_handler_15_17       ; 15
       data sprite_handler_15_17       ; 16
       data sprite_handler_15_17       ; 17
       data sprite_handler_18_19       ; 18
       data sprite_handler_18_19       ; 19
       data sprite_handler_1a_1c       ; 1A
       data sprite_handler_1a_1c       ; 1B
       data sprite_handler_1a_1c       ; 1C

* Handle sprite type $02
*
* Used by the routine at #R$85E6.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_type_02:                 ; >865a
;       cb   a,@bytes+>02               ; CP $02            ; Is sprite type $02?
;       jeq  !                          ; JP NZ,$867D       ; If not proceed to next handler
;       b    @handle_sprite_types_04_0c ;
;!
* Sprite type $02 (shot)
sprite_handler_02:
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       ab   one,a                      ; INC A             ; Move shot
       ab   one,a                      ; INC A             ; ...
       movb a,@>01(ix)                 ; LD (IX+$01),A     ; And save again
       cb   a,@bytes+>08               ; CP $08            ; Is polar y now 7?
       jne  _8673                      ; JR NZ,$8673       ; If not, jump ahead
       movb @bytes+>05,@>0b(ix)        ; LD (IX+$0B),$05   ; Set color
       .ret                            ; RET               ; Return to #R$8A41
_8673:                                 ; >8673
       cb   a,@bytes+>2b               ; CP $2B            ; Is polar y 43?
       jhe  !                          ; RET C             ; Return if less than
       .ret                            ;
!
       li   hl,active_shots            ; LD HL,$7253       ; Decrease active shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       b    @deallocate_sprite         ; JP $862F          ; Deallocate sprite

* Handle sprite type $04 - $0C
*
* Used by the routine at #R$865A.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_types_04_0c:             ; >867d
;       cb   a,@bytes+>04               ; CP $04            ; Is sprite type < $04
;       jl   handle_sprite_type_14      ; JR C,$86DE        ; Then jump
;       cb   a,@bytes+>0d               ; CP $0D            ; Is it >= $0D
;       jhe  handle_sprite_type_14      ; JR NC,$86DE       ; Then jump
* Sprite types $04 - $0C (enemy remains, numbers)
sprite_handler_04_0c:
       sb   one,@>03(ix)               ; DEC (IX+$03)      ; Decrement counter
       jeq  !                          ; RET NZ            ; Return if not zero
       .ret                            ;
!
       ab   one,*ix                    ; INC (IX+$00)      ; Increment sprite type
       movb @bytes+>0f,@>03(ix)        ; LD (IX+$03),$0F   ; Reset counter
       cb   a,@bytes+>04               ; CP $04            ; Is sprite type destroyed enemy?
       jne  !                          ; RET Z             ; Then return
       .ret                            ;
!
       movb @>06(ix),a                 ; LD A,(IX+$06)     ; Else get replacement type (probably number)
;       socb a,a                        ; OR A              ; If zero
       jne  !                          ; JP Z,$862F        ; Then deallocate sprite
       b    @deallocate_sprite         ;
!
       movb a,*ix                      ; LD (IX+$00),A     ; Set new type
       movb @bytes+>3c,@>03(ix)        ; LD (IX+$03),$3C   ; Counter
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ; No replacement type
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       .push ix                        ; PUSH IX           ; Save sprite data address
       bl   @allocate_sprite           ; RST $28           ; Allocate new sprite for last digits of points
       .pop iy                         ; POP IY            ; IY = old sprite
       movb @bytes+>0c,*ix             ; LD (IX+$00),$0C   ; Set type if new sprite (number 00)
       movb @bytes+>3c,@>03(ix)        ; LD (IX+$03),$3C   ; Counter
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Set polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Set polar x
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ; No replacement type
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       movb @>08(iy),a                 ; LD A,(IY+$08)     ; Get screen y of old sprite
       movb a,@>08(ix)                 ; LD (IX+$08),A     ; Set screen y of new sprite
       movb @>09(iy),a                 ; LD A,(IY+$09)     ; Get screen x of old sprite
       ab   @bytes+>08,a               ; ADD A,$08         ; Add 8
       movb a,@>09(ix)                 ; LD (IX+$09),A     ; Set screen x of new sprite
       .pop bc                         ; POP BC            ; Pop return address
       b    @return_from_sprite_handler_1                     ; JP $8A4E          ; Jump back into sprite handler loop

* Handle sprite type  $14
*
* Used by the routine at #R$867D.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_type_14:                 ; >86de
;       cb   a,@bytes+>14               ; CP $14            ; Is sprite type $014
;       jne  handle_sprite_types_12_13  ; JR NZ,$86E9       ; If not, jump ahead
* Sprite type $14 (meteor)
sprite_handler_14:
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite types $12 - $13
*
* Used by the routine at #R$86DE.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_types_12_13:             ; >86e9
;       cb   a,@bytes+>12               ; CP $12            ; Is sprite type < $012
;       jl   handle_sprite_type_03      ; JR C,$870C        ; If so, jump ahead
;       cb   a,@bytes+>14               ; CP $14            ; Is sprite type >= $014
;       jhe  handle_sprite_type_03      ; JR NC,$870C       ; If so, jump ahead
* Sprite types $12 - $13 (enemy missile)
sprite_handler_12_13:
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       movb a,b                        ; LD B,A            ; Store in B
       andi a,>0100                    ; AND $01           ; Every 2nd frame
       jeq  !                          ; RET NZ            ; Return to #R$8A41
       .ret                            ;
!
       movb b,a                        ; LD A,B            ; Frame counter
       andi a,>0f00                    ; AND $0F           ; Mod 16
       jne  _8705                      ; JR NZ,$8705       ; If not zero then skip animation
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       xor  one,a                      ; XOR $01           ; Flip bit 0 to change between $12 and $13
       movb a,*ix                      ; LD (IX+$00),A     ; Save new type
_8705:                                 ; >8705
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite type $03
*
* Used by the routine at #R$86E9.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_type_03:                 ; >870c
;       cb   a,@bytes+>03               ; CP $03            ; Is sprite type $03?
;       jne  handle_sprite_types_15_17  ; JR NZ,$873E       ; If not, jump ahead
* Sprite type $03 (double shot pickup)
sprite_handler_03:
       movb @status_flags,a            ; LD A,($71EB)      ; Check if you have died
       czc  @bit2,a                    ; BIT 2,A           ; ...
       jeq  !                          ; JP NZ,$8654       ; If so, deallocate and return
       b    @deallocate_enemy          ;
!
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>07(ix),a                 ; LD A,(IX+$07)     ; X velocity, set to $02 or $FE when created
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Add to polar x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save again
       sb   one,@>03(ix)               ; DEC (IX+$03)      ; Counter, set to $10 when created
       jlt  !                          ; RET P             ; Return if > 0
       .ret                            ;
!
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Get ship polar x
       movb @>02(ix),b                 ; LD B,(IX+$02)     ; Get polar x
       bl   @polar_x_distance          ; CALL $9A86        ; Polar x distance
       cb   a,@bytes+>04               ; CP $04            ; Is it >= 4
       jl   !                          ; RET NC            ; Then return
       .ret                            ;
!
       li   hl,other_flags             ; LD HL,$7256       ; Set double shot flag
       socb @bits+1,*hl                ; SET 1,(HL)        ; ...
       b    @deallocate_enemy          ; JP $8654          ; Deallocate and return

* Handle sprite types $15 - $17
*
* Used by the routine at #R$870C.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_types_15_17:             ; >873e
;       cb   a,@bytes+>15               ; CP $15            ; Is sprite type < $15
;       jl   handle_sprite_types_0e_11  ; JR C,$8790        ; If so, jump ahead
;       cb   a,@bytes+>18               ; CP $18            ; Is sprite type >= $18
;       jhe  handle_sprite_types_0e_11  ; JR NC,$8790       ; If so, jump ahead
* sprite types $15 - $17 (laser fence)
sprite_handler_15_17:
       movb @bytes+>f8,b               ; LD B,$07          ; Mask = 7
       movb @status_flags,a            ; LD A,($71EB)      ; Check if you have died
       czc  @bit2,a                    ; BIT 2,A           ; ...
       jeq  _8751                      ; JR Z,$8751        ; If not, skip next
       movb @bytes+>fc,b               ; LD B,$03          ; Else set mask = 3
_8751:                                 ; >8751
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       szcb b,a                        ; AND B             ; AND mask
       jne  _875d                      ; JR NZ,$875D       ; If not zero, skip next 2
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
_875d:                                 ; >875d
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       socb @bits+4,*hl                ; SET 4,(HL)        ; Set laser fence flag
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>17               ; CP $17            ; If not laser fence center
       jeq  !                          ; RET NZ            ; Then return to #R$8A41
       .ret                            ;
!
       movb @other_flags,a             ; LD A,($7256)      ; If bit 3 is reset
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jne  !                          ; JP Z,$8654        ; Then deallocate
       b    @deallocate_enemy          ;
!
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get polar x
       ab   @>03(ix),a                 ; ADD A,(IX+$03)    ; Add velocity
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save new polar x
       li   hl,_7261                   ; LD HL,$7261       ; Did center reach end 2?
       cb   a,*hl                      ; CP (HL)           ; ...
       jeq  _8787                      ; JR Z,$8787        ; Then skip ahead
       inc  hl                         ; INC HL            ; Did center reach end 1?
       cb   a,*hl                      ; CP (HL)           ; ...
       jeq  _8787                      ; RET NZ            ; If not, return to #R$8A41
       .ret                            ;
_8787:                                 ; >8787
       clr  af
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Switch direction
       neg a                           ; NEG               ; ...
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; ...
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite types $0E - $11
*
* Used by the routine at #R$873E.
*
* I:A Sprite type
* I:IX Sprite data
;handle_sprite_types_0e_11:             ; >8790
;       cb   a,@bytes+>0e               ; CP $0E            ; Is sprite type < $0E
;       jhe  !                          ; JP C,$899E        ; If so, jump ahead
;       b    @handle_sprite_types_18_1c ;
;!
;       cb   a,@bytes+>12               ; CP $12            ; Is sprite type >= $12
;       jl   !                          ; JP NC,$899E       ; If so, jump ahead
;       b    @handle_sprite_types_18_1c ;
;!
* Sprite type $0E - $11 (enemies)
sprite_handler_0e_11:
       movb @>07(ix),r0                ; BIT 7,(IX+$07)    ; Check bit 7 to see if a path address is set
       andi r0,>8000                   ;
       jeq  !                          ; JP NZ,$88FE       ; If set, update sprite path
       b    @update_sprite_path        ;
!
       movb @>01(ix),r0                ; BIT 7,(IX+$01)    ; Check bit 7 of polar y
       andi r0,>8000                   ;
       jeq  !                          ; JP NZ,$8825       ; If set, move towards viewer
       b    @move_towards_viewer       ;
!
       movb @>07(ix),r0                ; BIT 6,(IX+$07)    ; Check bit 6 of flags
       andi r0,>4000                   ;
       jne  move_to_center             ; JR NZ,$87D5       ; If set, create map entry for enemy sprite
       movb @>07(ix),r0                ; BIT 2,(IX+$07)    ; Check bit 2 of flags
       andi r0,>0400                   ;
       jeq  !                          ; JP NZ,$8825       ; If set, move towards viewer
       b    @move_towards_viewer       ;
!
       movb @>07(ix),r0                ; BIT 0,(IX+$07)    ; Check bit 0 of flags
       andi r0,>0100                   ;
       jeq  !                          ; JP NZ,$885F       ; If set, create enemy shot and move
       b    @create_enemy_shot_and_move ;
!
       movb @attack_countdown,a        ; LD A,($7260)          ; Attack countdown
;       socb a,a                        ; OR A              ; Return if not zero
       jne  !                          ; RET NZ            ; ...
       .call @maybe_create_enemy_shot  ; CALL $8A76        ; Create enemy shot
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship polar x
       .call @move_towards_x           ; CALL $8AC0        ; Move towards x
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
!      .ret                            ; RET               ; Return to #R$8A41

* Create map entry for enemy sprite
*
* Search for a value (pattern OR $80) in map. If not found, allocate an entry.
* If found, calculate coordinates and move towards them. Used by the routine at
* #R$8790.
*
* I: IX Sprite data of enemy
move_to_center:           ; >87d5
       movb @sprite_countdown,a        ; LD A,($71EE)      ; Return if countdown
;       socb a,a                        ; OR A              ; is not zero
       jne  move_to_center_5           ; RET NZ            ; ...
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
;      Check if already in map
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get pattern
       socb @bytes+>80,a               ; OR $80            ; Set bit 7
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       li   hl,center_enemy_map        ; LD HL,$7207       ; Address of map
move_to_center_1:                      ; >87e7
       cb   a,*hl+                     ; CP (HL)           ; Check entry
       jeq  move_to_center_2           ; JR Z,$87F5        ; Break out if found
;       inc  hl                         ; INC HL            ; Next map address
       sb   one,b                      ; DJNZ $87E7        ; Loop up to 36 times
       jne  move_to_center_1           ;
;      Not found
;       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get pattern
;       socb @bytes+>80,a               ; OR $80            ; Set bit 7
       bl   @allocate_map_entry        ; JP $AAA6          ; Add pattern to map. Return to #R$8A41
       jmp  move_to_center_5
;      Found
move_to_center_2:                      ; >87f5
       dec  hl
       bl   @polar_coord_from_map      ; CALL $AB38        ; Now DE contains polar y,x
       movb @e,a                       ; LD A,E            ; Get x from map
       cb   a,@>02(ix)                 ; CP (IX+$02)       ; Compare with polar x
       jeq  move_to_center_3           ; JR Z,$8801        ; If same, skip ahead
       b    @move_towards_x            ; JP $8AC0          ; Else jump out to #R$8AC0
move_to_center_3:                      ; >8801
       movb @bytes+>0e,*ix             ; LD (IX+$00),$0E   ; Change sprite type to enemy
* Move towards y
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,d                        ; CP D              ; Compare with polar y from map
       jeq  return_enemy_to_map        ; JR Z,$8815        ; If same, return enemy to map
       jl   move_to_center_4           ; JR C,$8811        ; If less than, skip to increment polar y
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       jmp  move_to_center_5           ; RET               ; Return to #R$8A41
move_to_center_4:                      ; >8811
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment polar y
move_to_center_5:
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Return enemy to map
*
* Used by the routine at #R$8801.
*
* I:IX Sprite data of enemy
* I:HL Map address
return_enemy_to_map:                   ; >8815
;       movb @>0b(ix),a                 ; LD A,(IX+$0B)     ; Get color (why not pattern?)
;       movb a,*hl                      ; LD (HL),A         ; Set in map
       movb @>0b(ix),*hl
;       li   hl,active_enemies          ; LD HL,$722C       ; Decrease active enemies
;       sb   one,*hl                    ; DEC (HL)          ; ...
       sb   one,@active_enemies        ; Decrease active enemies
       li   hl,other_flags             ; LD HL,$7256       ; Set a flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @deallocate_sprite         ; JP $862F          ; Deallocate sprite and return

* Enemy movement: Move enemy towards viewer
*
* Used by the routine at #R$8790.
*
* I:IX Sprite data of enemy
move_towards_viewer:                   ; >8825
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Change sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>f2               ; CP $F2            ; Return if not $F2 (-14)
       jeq  handle_out_of_screen       ; RET NZ            ; Else continue into #R$8835
       .ret                            ;

* Enemy movement: Determine action when out of screen
*
* Used by the routine at #R$8A2D.
*
* I:IX Sprite data of enemy
handle_out_of_screen:                  ; >8835
       movb @>07(ix),r0                ; BIT 3,(IX+$07)    ; If a flag is reset
       andi r0,>0800                   ;
       jeq  handle_out_of_screen_2     ; JR Z,$8848        ; Then skip ahead and determine what to do
* This entry point is used by the routine at #R$8848.
handle_out_of_screen_1:                ; >883b
       movb @bytes+>2a,@>01(ix)        ; LD (IX+$01),$2A   ; Reset polar y back to center
       movb @zero,@>02(ix)             ; LD (IX+$02),$00   ; Reset polar x
       movb @bytes+>40,@>07(ix)        ; LD (IX+$07),$40   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41
handle_out_of_screen_2:                ; >8848
       movb @>07(ix),r0                ; BIT 4,(IX+$07)    ; Test flag
       andi r0,>1000                   ;
       jeq  handle_out_of_screen_3     ; JR Z,$8853        ; If not set, skip ahead
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>0300                    ; AND $03           ; 0 - 3
       jne  handle_out_of_screen_1     ; JR NZ,$883B       ; If not 0, reset to center
handle_out_of_screen_3:                ; >8853
;       li   hl,active_enemies          ; LD HL,$722C       ; Decrement active enemies
;       sb   one,*hl                    ; DEC (HL)          ; ...
       sb   one,@active_enemies
       li   hl,other_flags             ; LD HL,$7256       ; Set flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @deallocate_enemy          ; JP $8654          ; Deallocate and return

* Enemy movement: Create enemy shot and move towards player.
*
* Used by the routine at #R$8790. Called and jumped.
*
* I:IX Sprite data of enemy
create_enemy_shot_and_move:            ; >885f
       .call @maybe_create_enemy_shot  ; CALL $8A76        ; Create enemy shot
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>22               ; CP $22            ; Is it < $22
       jl   _8878                      ; JR C,$8878        ; Then jump ahead
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @bytes+>02,@>03(ix)        ; LD (IX+$03),$02   ; Set counter
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ;

* Enemy movement: Polar Y of enemy < $22
*
* Used by the routine at #R$885F.
_8878:                                 ; >8878
       movb @sprite_countdown,a        ; LD A,($71EE)      ; Get sprite countdown
;       socb a,a                        ; OR A              ; Return if not zero
       jeq  !                          ; RET NZ            ; ...
       .ret                            ;
!
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       cb   a,@bytes+>40               ; CP $40            ; If >= $40
       jhe  _88d4                      ; JR NC,$88D4       ; Then jump to ...
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       bl   @ti_rnd                    ; RST $20           ; Random number
       ; AND (IY+$03)                  ; AND (IY+$03)      ; AND stage data byte 3 ($3F, $1F, $0F)
       movb @3(iy),r0
       inv  r0
       szcb r0,a
       jne  _88a7                      ; JR NZ,$88A7       ; If not all zeros, then jump (more likely on earlier
                                                           ; stages)
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>08               ; CP $08            ; If it's 8
       jeq  _88cf                      ; JR Z,$88CF        ; Then jump ahead
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>0f00                    ; AND $0F           ; 0 - 15
       jne  _88be                      ; JR NZ,$88BE       ; If it's not 0 then jump ahead
* This entry point is used by the routine at #R$88BE.
_889c:                                 ; >889c
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship polar x
       .call @move_towards_x           ; CALL $8AC0        ; Move towards x
       ab   one,b                      ; INC B             ;
       movb b,@>03(ix)                 ; LD (IX+$03),B     ; Set counter
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Called with random probability.
*
* Used by the routine at #R$8878.
_88a7:                                 ; >88a7
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       sb   one,a                      ; DEC A             ; Counter - 1
       movb a,b                        ; LD B,A            ; Store in B
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Add polar x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb @bytes+>10,a               ; LD A,$10          ; 16
       ab   b,a                        ; ADD A,B           ; 16 + counter - 1
       movb a,*ix                      ; LD (IX+$00),A     ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Called with random probability.
*
* Used by the routine at #R$8878.
_88be:                                 ; >88be
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>0700                    ; AND $07           ; 0 - 7
       li   hl,enemy_movement_table    ; LD HL,$8E25       ; Table base address
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
       movb *hl,a                      ; LD A,(HL)         ; Get table value
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; Set counter
       cb   a,@bytes+>40               ; CP $40            ; Compare to $40
       jl   _889c                      ; JR C,$889C        ; If < $40 then jump to move towards ship
       jne  _88d4                      ; JR NZ,$88D4       ; If > $40 then jump ahead
* This entry point is used by the routine at #R$8878.
_88cf:                                 ; >88cf
       movb @bytes+>10,@>07(ix)        ; LD (IX+$07),$10   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Counter is >(=) $40
*
* Used by the routines at #R$8878 and #R$88BE.
*
* I:A counter (IX+$03)
_88d4:                                 ; >88d4
       cb   a,@bytes+>41               ; CP $41            ; If $41
       jeq  _88f3                      ; JR Z,$88F3        ; Then jump to next routine
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Get ship polar x
       .call @move_towards_x           ; CALL $8AC0        ; Move towards x
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>08               ; CP $08            ; Return if not 8
       jne  !                          ; RET NZ            ; ...
       movb @bytes+>41,@>03(ix)        ; LD (IX+$03),$41   ; Set counter
!
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Counter is $41
*
* Used by the routine at #R$88D4.
_88f3:                                 ; >88f3
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment polar y
       movb @bytes+>0e,*ix             ; LD (IX+$00),$0E   ; Set type to enemy
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Update sprite path
*
* Used by the routine at #R$8790.
update_sprite_path:                    ; >88fe
       movb @sprite_countdown,a        ; LD A,($71EE)      ;
;       socb a,a                        ; OR A              ;
       jeq  !                          ; RET NZ            ;
       .ret                            ;
!
       .call @maybe_create_enemy_shot  ; CALL $8A76        ; Create enemy shot
       movb @>06(ix),@l                ; LD L,(IX+$06)     ; Get path address
       movb @>07(ix),h                 ; LD H,(IX+$07)     ; ...
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
* This entry point is used by the routine at #R$892B.
update_sprite_path_1:                  ; >890f
       movb a,r0
       sb   @bytes+>10,a               ; SUB $10           ; Decrement upper nybble
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; Store again
       cb   r0,@bytes+>10
       jhe  move_animate_sprite_along_path ; JR NC,$8936   ; If upper nybble >= 0, then jump to move sprite
* This entry point is used by the routine at #R$8986.
update_sprite_path_2:                  ; >8916
       inc  hl                         ; INC HL            ; Else increment path address
       movb @l,@>06(ix)                ; LD (IX+$06),L     ; Set path address
       movb h,@>07(ix)                 ; LD (IX+$07),H     ; ...
       movb *hl,a                      ; LD A,(HL)         ; Get path byte
       cb   a,@bytes+>10               ; CP $10            ; If upper nybble >= 1
       jhe  update_sprite_path_3       ; JR NC,$892B       ; Then jump ahead to update counter
       sb   one,a                      ; DEC A             ; Else decrement lower nybble
       jlt  set_sprite_flags_to_18_if_match ; JP M,$8986   ; If negative then set sprite flag to $18 if path byte matches and return
       jeq  set_sprite_flags_to_04     ; JR Z,$8994        ; If zero then set sprite flag to $04 and return
       jmp  set_sprite_flags_to_40     ; JP $8999          ; If positive then set sprite flag to $40 and return

* Enemy movement: Upper nybble >= 1
*
* Used by the routine at #R$88FE.
update_sprite_path_3:                  ; >892b
       andi a,>f000                    ; AND $F0           ; Isolate upper nybble
       movb a,b                        ; LD B,A            ; Save it
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       andi a,>0f00                    ; AND $0F           ; And apply upper nybble
       socb b,a                        ; OR B              ; ...
       jmp  update_sprite_path_1       ; JR $890F          ; Jump back into #R$88FE

* Enemy movement: Move sprite along path and update sprite type
*
* Used by the routine at #R$88FE.
*
* I:IX Sprite data
* I:HL Path address
move_animate_sprite_along_path:        ; >8936
       movb *hl,a                      ; LD A,(HL)         ; Get path byte
       mov  @wave_data_address,hl      ; LD HL,($725D)     ; Get wave data address
       movb @>03(ix),r0                ; BIT 0,(IX+$03)    ; If bit 0 of counter is reset
       andi r0,>0100                   ;
       jeq  move_animate_sprite_along_path_1 ; JR Z,$8941  ; Then skip moving to next byte
       inc  hl                         ; INC HL            ; Else move to next byte
move_animate_sprite_along_path_1:      ; >8941
       movb *hl,r0                     ; BIT 7,(HL)        ; Is bit 7 reset
       andi r0,>8000                   ;
       jeq  move_animate_sprite_along_path_2 ; JR Z,$8951  ; Then skip ahead
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       cb   a,one                      ; CP $01            ; If 1 (inc polar y)
       jeq  move_animate_sprite_along_path_2 ; JR Z,$8951  ; Then skip ahead
       cb   a,@bytes+>04               ; CP $04            ; If 4 (dec polar y)
       jeq  move_animate_sprite_along_path_2 ; JR Z,$8951  ; Then skip ahead
       li   r0,>0a00                   ; XOR $0A           ; Else flip bits 1 and 3
       xor  r0,a                       ;
move_animate_sprite_along_path_2:      ; >8951
       movb @>02(ix),@e                ; LD E,(IX+$02)     ; Get polar x
       movb @>01(ix),d                 ; LD D,(IX+$01)     ; Get polar y
       movb *ix,b                      ; LD B,(IX+$00)     ; Get sprite type
       czc  @bit0,a                    ; BIT 0,A           ; If bit for incrementing polar y is reset
       jeq  move_animate_sprite_along_path_3 ; JR Z,$8961  ; Then skip next
       ab   one,d                      ; INC D             ; Increment polar y
       movb @bytes+>0e,b               ; LD B,$0E          ; Sprite type $0E
move_animate_sprite_along_path_3:      ; >8961
       czc  @bit2,a                    ; BIT 2,A           ; If bit for decrementing polar y is reset
       jeq  move_animate_sprite_along_path_4 ; JR Z,$8968  ; Then skip next
       sb   one,d                      ; DEC D             ; Decrement polar y
       movb @bytes+>10,b               ; LD B,$10          ; Sprite type $10
move_animate_sprite_along_path_4:      ; >8968
       czc  @bit1,a                    ; BIT 1,A           ; If bit for decrementing polar x is reset
       jeq  move_animate_sprite_along_path_5 ; JR Z,$896F  ; Then skip next
       sb   one,@e                     ; DEC E             ; Decrement polar x
       movb @bytes+>0f,b               ; LD B,$0F          ; Sprite type $0F
move_animate_sprite_along_path_5:      ; >896f
       czc  @bit3,a                    ; BIT 3,A           ; If bit for incrementing polar x is reset
       jeq  move_animate_sprite_along_path_6 ; JR Z,$8976  ; Then skip next
       ab   one,@e                     ; INC E             ; Increment polar x
       movb @bytes+>11,b               ; LD B,$11          ; Sprite type $11
move_animate_sprite_along_path_6:      ; >8976
       movb b,*ix                      ; LD (IX+$00),B     ; Set sprite type
       movb d,@>01(ix)                 ; LD (IX+$01),D     ; Set polar y
       movb @e,a                       ; LD A,E            ; Polar x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Set sprite flags to $18 if ...
*
* Used by the routine at #R$88FE.
*
* I:IX Sprite data
* I:HL Path address
set_sprite_flags_to_18_if_match:       ; >8986
       inc  hl                         ; INC HL            ; Advance path address
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       andi a,>0f00                    ; AND $0F           ; Isolate sprite position in wave
       cb   a,*hl                      ; CP (HL)           ; Compare with path byte
       jne  update_sprite_path_2       ; JR NZ,$8916       ; If different, then jump back to #R$88FE
       movb @bytes+>18,@>07(ix)        ; LD (IX+$07),$18   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Set sprite flags to $04
*
* Used by the routine at #R$88FE.
*
* I:IX Sprite data
* I:HL Path address
set_sprite_flags_to_04:                ; >8994
       movb @bytes+>04,@>07(ix)        ; LD (IX+$07),$04   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Set sprite flags to $40
*
* Used by the routine at #R$88FE.
*
* I:IX Sprite data
* I:HL Path address
set_sprite_flags_to_40:                ; >8999
       movb @bytes+>40,@>07(ix)        ; LD (IX+$07),$40   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite types $18 - $1C
*
* Used by the routine at #R$8790.
;handle_sprite_types_18_1c:             ; >899e
;       cb   a,@bytes+>18               ; CP $18            ; Is sprite type < $18
;       jhe  !                          ; RET C             ; Then return
;       .ret                            ;
;!
;       cb   a,@bytes+>1a               ; CP $1A            ; Is sprite type < $1A
;       jl   sprite_handler_18_19       ; JR C,$89B8        ; If so, jump ahead
* Sprite types $1A - $1C (circular enemies)
sprite_handler_1a_1c:
       movb a,b                        ; LD B,A            ; B = sprite type
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0300                    ; AND $03           ; Mod 4
       jne  sprite_handler_18_19       ; JR NZ,$89B8       ; If not zero the skip ahead
       movb b,a                        ; LD A,B            ; A = sprite type
       ab   one,a                      ; INC A             ; A = sprite type + 1
       cb   a,@bytes+>1d               ; CP $1D            ; Is sprite type + 1 < $1D, i.e. sprite type < $1C, i.e.
                                                           ; $1A or $1B
       jl   _89b5                      ; JR C,$89B5        ; Then skip next
       movb @bytes+>1a,a               ; LD A,$1A          ; Else set sprite type to $1A
_89b5:                                 ; >89b5
       movb a,*ix                      ; LD (IX+$00),A     ; This means rotate between $1A, $1B, and $1C
* Sprite types $18 - $19 (three spheres, star shape) plus $1A - 1C
sprite_handler_18_19:                  ; >89b8
       movb @>07(ix),r0                ; BIT 7,(IX+$07)    ; Text flag bit 7
       andi r0,>8000                   ;
       jeq  _8a2d                      ; JR Z,$8A2D        ; If reset, move towards viewer
       movb @sprite_countdown,a        ; LD A,($71EE)      ; Return if countdown
;       socb a,a                        ; OR A              ; is not zero
       jeq  !                          ; RET NZ            ; ...
       .ret                            ;
!
       movb @>06(ix),@l                ; LD L,(IX+$06)     ; Get path address
       movb @>07(ix),h                 ; LD H,(IX+$07)     ; ...
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       movb a,r0
       sb   @bytes+>10,a               ; SUB $10           ; Decrement upper nybble
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; Save counter
       cb   r0,@bytes+>10
       jhe  move_sprite_along_path     ; JR NC,$89EB       ; If upper nybble >= 0 then jump ahead
       inc  hl                         ; INC HL            ; Next path address
       movb *hl,a                      ; LD A,(HL)         ; Get path byte
       movb a,r0
       sb   @bytes+>10,a               ; SUB $10           ; Decrement upper nybble
       cb   r0,@bytes+>10
       jl   _8a3c                      ; JR C,$8A3C        ; If < 0 then set flag and return
       andi a,>f000                    ; AND $F0           ; Isolate upper nybble
       movb a,b                        ; LD B,A            ; Save it
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       andi a,>0f00                    ; AND $0F           ; And apply upper nybble
       socb b,a                        ; OR B              ; ...
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; ...
       movb @l,@>06(ix)                ; LD (IX+$06),L     ; Set path address
       movb h,@>07(ix)                 ; LD (IX+$07),H     ; ... (continue into #R$89EB)

* Circular enemy movement: Move sprite along path
*
* Used by the routine at #R$899E. Identical to code at #R$8936
move_sprite_along_path:                ; >89eb
       movb *hl,a                      ; LD A,(HL)         ; Get path byte
       mov  @wave_data_address,hl      ; LD HL,($725D)     ; Get wave data address
       movb @>03(ix),r0                ; BIT 0,(IX+$03)    ; If bit 0 of counter is reset
       andi r0,>0100                   ;
       jeq  move_sprite_along_path_1   ; JR Z,$89F6        ; Then skip moving to next byte
       inc  hl                         ; INC HL            ; Else move to next byte
move_sprite_along_path_1:              ; >89f6
       movb *hl,r0                     ; BIT 7,(HL)        ; Is bit 7 reset
       andi r0,>8000                   ;
       jeq  move_sprite_along_path_2   ; JR Z,$8A06        ; Then skip ahead
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       cb   a,one                      ; CP $01            ; If 1 (inc polar y)
       jeq  move_sprite_along_path_2   ; JR Z,$8A06        ; Then skip ahead
       cb   a,@bytes+>04               ; CP $04            ; If 4 (dec polar y)
       jeq  move_sprite_along_path_2   ; JR Z,$8A06        ; Then skip ahead
       li   r0,>a000                   ; XOR $0A           ; Else flip bits 1 and 3
       xor  r0,a                       ;
move_sprite_along_path_2:              ; >8a06
       movb @>02(ix),@e                ; LD E,(IX+$02)     ; Get polar x
       movb @>01(ix),d                 ; LD D,(IX+$01)     ; Get polar y
* Identical to code at #R$895A except doesn't set sprite type
       czc  @bit0,a                   ; BIT 0,A           ; If bit for incrementing polar y is reset
       jeq  move_sprite_along_path_3   ; JR Z,$8A11        ; Then skip next
       ab   one,d                      ; INC D             ; Increment polar y
move_sprite_along_path_3:              ; >8a11
       czc  @bit2,a                   ; BIT 2,A           ; If bit for decrementing polar y is reset
       jeq  move_sprite_along_path_4   ; JR Z,$8A16        ; Then skip next
       sb   one,d                      ; DEC D             ; Decrement polar y
move_sprite_along_path_4:              ; >8a16
       czc  @bit1,a                   ; BIT 1,A           ; If bit for decrementing polar x is reset
       jeq  move_sprite_along_path_5   ; JR Z,$8A1B        ; Then skip next
       sb   one,@e                     ; DEC E             ; Decrement polar x
move_sprite_along_path_5:              ; >8a1b
       czc  @bit3,a                   ; BIT 3,A           ; If bit for incrementing polar x is reset
       jeq  move_sprite_along_path_6   ; JR Z,$8A20        ; Then skip next
       ab   one,@e                     ; INC E             ; Increment polar x
move_sprite_along_path_6:              ; >8a20
       movb d,@>01(ix)                 ; LD (IX+$01),D     ; Set polar y
       movb @e,a                       ; LD A,E            ; Polar x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Circular enemy movement: Move enemy towards viewer
*
* Used by the routine at #R$899E.
_8a2d:                                 ; >8a2d
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>f2               ; CP $F2            ; If $F2 (-14)
       jne  !                          ; JP Z,$8835        ; Then jump to handler
       b    @handle_out_of_screen      ;
!
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Circular enemy movement: Set sprite flags to $04
*
* Used by the routine at #R$899E.
_8a3c:                                 ; >8a3c
       movb @bytes+>04,@>07(ix)        ; LD (IX+$07),$04   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41

* Return from sprite handler
*
* Sprite handler branching out from #R$8600
return_from_sprite_handler:            ; >8a41
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@>05(ix)                 ; CP (IX+$05)       ; Same as before?
       jeq  return_from_sprite_handler_1 ; JR Z,$8A4E        ; Skip ahead if so
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
* This entry point is used by the routine at #R$867D.
return_from_sprite_handler_1:          ; >8a4e
       .pop hl                         ; POP HL            ; Restore sprite allocation table address
       inc  hl                         ; INC HL            ; Increment address
       b    @process_next_sprite       ; JP $8600          ; Jump back into loop at #R$8600

* When all sprites have been processed
*
* Used by the routine at #R$85E6.
all_sprites_processed:                 ; >8a53
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       movb @sprite_countdown,a        ; LD A,($71EE)      ; Get sprite countdown
;       socb a,a                        ; OR A              ; Is it zero
       jne  all_sprites_processed_1    ; JR NZ,$8A62       ; No, skip ahead
       movb *iy,a                      ; LD A,(IY+$00)     ; Reset to first byte of stage data (speed?)
       movb a,@sprite_countdown        ; LD ($71EE),A      ; ...
all_sprites_processed_1:               ; >8a62
       movb @attack_countdown,a        ; LD A,($7260)      ; Get sprite countdown 2
;       socb a,a                        ; OR A              ; Return if not zero
       jne  all_sprites_processed_3    ; RET NZ            ; ...
       movb @stage_data_index,a        ; LD A,($7203)      ; Get stage data index
;       cb   a,@bytes+>02               ; CP $02            ; Compare to 2
       movb a,r0
       movb *iy,a                      ; LD A,(IY+$00)     ; Get first byte of stage data (speed?)
       cb   a,@bytes+>02
       jhe  all_sprites_processed_2    ; JR NC,$8A72       ; If stage index >= 2, then skip ahead
       ab   a,a                        ; ADD A,A           ; Else multiply by 2
all_sprites_processed_2:               ; >8a72
       movb a,@attack_countdown        ; LD ($7260),A      ; Save sprite countdown 2
all_sprites_processed_3:
       .ret                            ; RET               ; Return from sprite processing

* Create enemy shot if conditions are met
*
* Used by the routines at #R$8790, #R$885F and #R$88FE.
maybe_create_enemy_shot:               ; >8a76
       movb @countdown_to_shoot,a      ; LD A,($71EF)      ; Is countdown zero?
;       socb a,a                       ; OR A              ; ...
       jeq  !                          ; RET NZ            ; Return if not
       .ret                            ;
!
       movb @active_enemy_shots,a      ; LD A,($7252)      ; Get enemy shots
       cb   a,@bytes+>07               ; CP $07            ; Return if >= 7
       jl   !                          ; RET NC            ; ...
       .ret                            ;
!
       movb @status_flags,a            ; LD A,($71EB)      ; Flags
       andi a,>0c00                    ; AND $0C           ; Is chance stage or died?
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       movb @active_enemy_shots,a      ; LD A,($7252)      ; Get enemy shots
       cb   a,@>01(iy)                 ; CP (IY+$01)       ; Compare with stage data byte 1
       jl   !                          ; RET NC            ; Return if shots >= max shots
       .ret                            ;
!
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship polar x
       cb   a,@>02(ix)                 ; CP (IX+$02)       ; Compare with sprite polar x
       jeq  !                          ; RET NZ            ; Return if not equal
       .ret                            ;
!
       movb @>02(iy),a                 ; LD A,(IY+$02)     ; Reset countdown
       movb a,@countdown_to_shoot      ; LD ($71EF),A      ; ...
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Increment enemy shots
       ab   one,*hl                    ; INC (HL)          ; ...
       .push ix                        ; PUSH IX           ; Save enemy sprite address
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       .pop iy                         ; POP IY            ; Now IY = enemy sprite and IX = shot
       .push iy                        ; PUSH IY           ; Save enemy sprite
;       movb @>01(iy),a                 ; LD A,(IY+$01)     ; Set polar y of shot to polar x of enemy
;       movb a,@>01(ix)                 ; LD (IX+$01),A     ; ...
       movb @>01(iy),@>01(ix)
;       movb @>02(iy),a                 ; LD A,(IY+$02)     ; Set polar x of shot to polar x of enemy
;       movb a,@>02(ix)                 ; LD (IX+$02),A     ; ...
       movb @>02(iy),@>02(ix)
       movb @bytes+>12,*ix             ; LD (IX+$00),$12   ; Set sprite type
       movb @bytes+>0a,@>0b(ix)        ; LD (IX+$0B),$0A   ; Set color
       .pop ix                         ; POP IX            ; Restore enemy sprite
       .ret                            ; RET               ;

* Move towards x
*
* Used by the routines at #R$8790, #R$87F5, #R$8878 and #R$88D4.
*
* I:IX Sprite data
* I:A Polar x to move towards
move_towards_x:                        ; >8ac0
       movb one,b                      ; LD B,$01          ; Direction = 1
       movb a,r0
       sb   @>02(ix),a                 ; SUB (IX+$02)      ; Distance = desired x - x
       jeq  move_towards_x_3           ; RET Z             ; Return if same
       cb   r0,@>02(ix)
       jhe  move_towards_x_1           ; JR NC,$8ACC       ; Jump if distance > 0
       movb @b255,b                    ; LD B,$FF          ; Direction = -1
       andi af,>ff00
       neg a                           ; NEG               ; abs(distance)
move_towards_x_1:                      ; >8acc
;       cb   a,@bytes+>21               ; CP $21            ; Is it longer than half way around?
       movb a,r0
       movb b,a                        ; LD A,B            ; A = direction
       cb   r0,@bytes+>21
       jl   move_towards_x_2           ; JR C,$8AD3        ; Jump if not
       andi af,>ff00
       neg a                           ; NEG               ; Else switch direction
move_towards_x_2:                      ; >8ad3
       movb a,b                        ; LD B,A            ; B = direction
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Direction + x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save new x
       movb @bytes+>10,a               ; LD A,$10          ; $10
       ab   b,a                        ; ADD A,B           ; $10 + direction, i.e. $0F or $11
       movb a,*ix                      ; LD (IX+$00),A     ; Change sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
move_towards_x_3:
       .ret                            ; RET               ;

* Reset enemy sprite types after dying
*
* Used by the routine at #R$8139.
reset_enemy_sprite_types:              ; >8ae6
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       movb @bytes+>20,b               ; LD B,$20          ; 32 sprites
_8aef:                                 ; >8aef
       movb *ix,a                      ; LD A,(IX+$00)     ; Get type
       cb   a,@bytes+>0e               ; CP $0E            ; If < $0E then move on
       jl   _8b0d                      ; JR C,$8B0D        ; ...
       cb   a,@bytes+>12               ; CP $12            ; If >= $12 then move on
       jhe  _8b0d                      ; JR NC,$8B0D       ; ...
       movb @>07(ix),r0                ; BIT 6,(IX+$07)    ; For types $0E - $11 (enemies), test flag bit 6
       andi r0,>4000                   ;
       jne  _8b0d                      ; JR NZ,$8B0D       ; If not set, move on
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set type to $10
       movb @bytes+>0c,@>07(ix)        ; LD (IX+$07),$0C   ; Set flags to $0C
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
_8b0d:                                 ; >8b0d
       a    de,ix                      ; ADD IX,DE         ; Next sprite
       sb   one,b                      ; DJNZ $8AEF        ; Loop for 32 sprites
       jne  _8aef                      ;
       .ret                            ; RET               ;

* Draw background patterns for sprite
*
* Used by the routines at #R$8F0F, #R$8F55, #R$99D3, #R$9A75 and #R$A808.
*
* I:IY Data structure
display_background_patterns:           ; >8b12
       movb @>02(iy),@l                ; LD L,(IY+$02)     ; Get name table address of 3 x 3 area to clear
       movb @>03(iy),h                 ; LD H,(IY+$03)     ; ...
;       movb h,a                        ; LD A,H            ; If zero
;       socb @l,a                       ; OR L              ; ...
       mov  hl,hl
       jeq  _8b2d                      ; JR Z,$8B2D        ; Then skip ahead
* Clear name table area
       li   bc,3                       ; LD C,$03          ; 3 rows
       li   r1,vdpwd
       mov  hl,de
display_background_patterns_1:          ; >8b1e
;       .ex_de_hl                       ; EX DE,HL          ; DE now VDP address
;       movb @bytes+>03,b               ; LD B,$03          ; 3 columns
       sb   a,a                        ; XOR A             ; Zero to clear
;_8b22:                                 ; >8b22
;       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
;       inc  de                         ; INC DE            ; Next VDP address
;       sb   one,b                      ; DJNZ $8B22        ; Inner loop
;       jne  _8b22                      ;
       bl   @vdp_write_address
       movb a,*r1
       movb a,*r1
       movb a,*r1
;       li   hl,>001d                   ; LD HL,$001D       ; One row down and 3 columns back
;       a    de,hl                      ; ADD HL,DE         ; ...
       ai   de,>0020
       dec  bc                         ; DEC C             ; Row counter
       jne  display_background_patterns_1 ; JR NZ,$8B1E       ; Outer loop
_8b2d:                                 ; >8b2d
       movb @zero,@>02(iy)             ; LD (IY+$02),$00   ; Reset name table address
       movb @zero,@>03(iy)             ; LD (IY+$03),$00   ; ...
       movb @>04(iy),@l                ; LD L,(IY+$04)     ; Background patterns LSB
       movb @>05(iy),h                 ; LD H,(IY+$05)     ; Background patterns MSB
       movb h,a                        ; LD A,H            ; If both zero
       socb @l,a                       ; OR L              ; ...
       jne  !                          ; RET Z             ; Then return
       .ret                            ;
!
* Shift/scroll patterns to the right pixel offset
       .push iy                        ; PUSH IY           ; Save structure pointer
       .push hl                        ; PUSH HL           ; Save background patterns address
       li   hl,buffer                  ; LD HL,$71A3       ; Clear 72 bytes starting from #R$71A3
;       li   de,buffer+>0001            ; LD DE,$71A4       ; ...
;       li   bc,>0047                   ; LD BC,$0047       ; ...
;       sb   *hl,*hl                    ; LD (HL),$00       ; ...
;       .ldir                           ; LDIR              ; ...
       li   bc,>0048
       bl   @ti_clear
       movb @>01(iy),a                 ; LD A,(IY+$01)     ; Get screen y
       andi a,>0700                    ; AND $07           ; Pixel offset y
       li   ix,buffer                  ; LD IX,$71A3       ; Cleared buffer
       movb a,@e                       ; LD E,A            ; DE = pixel offset y
       sb   d,d                        ; LD D,$00          ; ...
       a    de,ix                      ; ADD IX,DE         ; Buffer address
       movb *iy,a                      ; LD A,(IY+$00)     ; Get screen x
       andi a,>0700                    ; AND $07           ; Pixel offset x
;       movb a,b                        ; LD B,A            ; B = pixel offset (counter for inner loop)
       clr  r0
       movb a,@r0lb
;       movb @bytes+>10,@c              ; LD C,$10          ; C = 16 (counter for outer loop)
       movb @bytes+>10,b
       .pop iy                         ; POP IY            ; Restore background patterns address
_8b66:                                 ; >8b66
;       .push bc                        ; PUSH BC           ; Save counters
       sb   @c,@c                      ; LD C,$00          ; C = 0
       movb *iy,d                      ; LD D,(IY+$00)     ; D = byte from left column of pattern
       movb @>10(iy),@e                ; LD E,(IY+$10)     ; E = byte from right column of pattern
;       ab   one,b                      ; INC B             ; If pixel offset = 0
;       sb   one,b                      ; DEC B             ; ...
;       movb b,b
       mov  r0,r0
       jeq  _8b7c                      ; JR Z,$8B7C        ; Then skip shifting
;_8b73:                                 ; >8b73
;       socb a,a                        ; OR A              ; Clear carry?
;       sra  d,1                        ; RR D              ; Shift first byte
;       RR E                            ; RR E              ; Shift second byte
;       RR C                            ; RR C              ; Shift third byte
;       sb   one,b                      ; DJNZ $8B73        ; Repeat 'pixel offset' times (inner loop)
;       jne  _8b73                      ;
       mov de,r1
       movb @e,r2
       movb @c,@r2lb
       srl r1,0
       mov r1,de
       srl r2,0
       movb @r2lb,@c
_8b7c:                                 ; >8b7c
       movb d,*ix                      ; LD (IX+$00),D     ; Save shifted bytes in buffer
       movb @e,@>18(ix)                ; LD (IX+$18),E     ; 3 patterns offset
       movb @c,@>30(ix)                ; LD (IX+$30),C     ; ...
       inc  ix                         ; INC IX            ; Next destination address
       inc  iy                         ; INC IY            ; Next source address
;       .pop bc                         ; POP BC            ; Restore counters
;       sb   one,@c                     ; DEC C             ; Repeat 16 times
       sb   one,b                      ; DEC C             ; Repeat 16 times
       jne  _8b66                      ; JR NZ,$8B66       ; Outer loop
* Update pattern table
       .pop iy                         ; POP IY            ;
       movb @>06(iy),@l                ; LD L,(IY+$06)     ; VDP pattern index (name)
       sb   h,h                        ; LD H,$00          ;
;       a    hl,hl                      ; ADD HL,HL         ; * 8
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       a    hl,hl                      ; ADD HL,HL         ; ...
       sla  hl,3
       .ex_de_hl                       ; EX DE,HL          ; DE now VDP address in pattern table
       li   hl,buffer                  ; LD HL,$71A3       ; Source address
       li   bc,>0048                   ; LD BC,$0048       ; 72 bytes (9 patterns)
       bl    @unrolled_write_vram      ; RST $38           ; WRITE_VRAM
* Update name table (3 x 3)
       movb @>01(iy),a                 ; LD A,(IY+$01)     ; Get screen y
       andi a,>f800                    ; AND $F8           ; Round to characters
       movb a,@l                       ; LD L,A            ; HL = A
       sb   h,h                        ; LD H,$00          ; ...
;       a    hl,hl                      ; ADD HL,HL         ; * 4 = row offset in name table
;       a    hl,hl                      ; ADD HL,HL         ; ...
       sla  hl,2
       movb *iy,a                      ; LD A,(IY+$00)     ; Get screen x
;       srl  a,1                        ; SRL A             ; / 8 = column offset in name table
;       srl  a,1                        ; SRL A             ; ...
;       srl  a,1                        ; SRL A             ; ...
       srl  a,3
       sb   one,a                      ; DEC A             ; -1 (start one column before)
       movb a,@e                       ; LD E,A            ; DE = A
       sb   d,d                        ; LD D,$00          ; ...
       a    de,hl                      ; ADD HL,DE         ; Add to address
       li   de,>1800                   ; LD DE,$1800       ; Name table base address
       a    de,hl                      ; ADD HL,DE         ; Add to address in HL
       movb @l,@>02(iy)                ; LD (IY+$02),L     ; Store address
       movb h,@>03(iy)                 ; LD (IY+$03),H     ; ...
       li   bc,3                       ; LD C,$03          ; 3 rows
       movb @>06(iy),a                 ; LD A,(IY+$06)     ; Get name
       li   r1,vdpwd
       mov  hl,de
display_background_patterns_5:          ; >8bc6
;       .ex_de_hl                       ; EX DE,HL          ; DE is now VDP address
;       movb @bytes+>03,b               ; LD B,$03          ; 3 columns
;_8bc9:                                 ; >8bc9
;       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
;       ab   @bytes+>03,a               ; ADD A,$03         ; Name += 3 (columns 3 apart)
;       inc  de                         ; INC DE            ; Next VDP address
;       sb   one,b                      ; DJNZ $8BC9        ; Inner loop for 3 bytes
;       jne  _8bc9                      ;
       bl   @vdp_write_address
       movb a,*r1
       ab   @bytes+>03,a
       movb a,*r1
       ab   @bytes+>03,a
       movb a,*r1
;       sb   @bytes+>08,a               ; SUB $08           ; Name -= 8 (rows 1 apart)
       sb   @bytes+>05,a
;       li   hl,>001d                   ; LD HL,$001D       ; One row down and 3 columns back
;       a    de,hl                      ; ADD HL,DE         ; ...
       ai   de,>0020
       dec  bc                         ; DEC C             ; Row counter
       jne  display_background_patterns_5 ; JR NZ,$8BC6       ; Outer loop for 3 bytes
       .ret                            ; RET               ;

* Manage waves
*
* Used by the routine at #R$80E8.
handle_waves:                          ; >8bd9
       movb @status_flags,a            ; LD A,($71EB)      ; Check bit for all waves completed
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jne  handle_waves_2             ; RET NZ            ; Return if set
       movb @outcoming_enemies,a       ; LD A,($725C)      ; Outcoming enemies
;       socb a,a                        ; OR A              ; Is it zero?
       jne  handle_wave_outcoming      ; JP NZ,$8C68       ; If not, jump ahead to add enemy
       movb @active_enemies,a          ; LD A,($722C)      ; Get active enemies
;       socb a,a                        ; OR A              ; Return if not zero
       jne  handle_waves_2             ; RET NZ            ; ...
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0300                    ; AND $03           ; 3 of 4 times,
       jne  handle_waves_1             ; JR NZ,$8BFC       ; skip ahead
       movb @countdown_to_wave,a       ; LD A,($71F0)      ; Get counter value
       sb   one,a                      ; DEC A             ; Decrement value
       jlt  handle_waves_1             ; JP M,$8BFC        ; If negative, skip ahead
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; Save counter again
handle_waves_1:                        ; >8bfc
       movb @wave,a                    ; LD A,($7201)      ; Get wave
       cb   a,@bytes+>04               ; CP $04            ; Compare to 4
       jl   handle_wave_lt_4           ; JR C,$8C30        ; If < 4, jump to handler
       jeq  handle_wave_eq_4           ; JR Z,$8C07        ; If = 4, jump to handler
       jmp  all_waves_completed        ; JR $8C1E          ; If > 4 then all waves completed
handle_waves_2:
       .ret

* Manage wave = 4
*
* Used by the routine at #R$8BD9.
handle_wave_eq_4:                      ; >8c07
       movb @status_flags,a            ; LD A,($71EB)      ; Test for chance stage
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jne  all_waves_completed        ; JR NZ,$8C1E       ; If set then all waves completed
       movb @center_map_entries,a      ; LD A,($722B)      ; Number of center enemies
       cb   a,@bytes+>06               ; CP $06            ; If >= 6,
       jhe  all_waves_completed        ; JR NC,$8C1E       ; Then all waves completed
;      Less than 6 center enemies
       clr  af
       bl   @ti_rnd                    ; RST $20           ; Random number
handle_wave_eq_4_1:                    ; >8c16
       cb   a,@bytes+>14               ; CP $14            ; If < 20,
       jl   start_wave_in_a            ; JR C,$8C3E        ; Then start that wave
       sb   @bytes+>14,a               ; SUB $14           ; Else subtract 20
       jmp  handle_wave_eq_4_1         ; JR $8C16          ; Loop until small enough

* All waves completed
*
* Used by the routines at #R$8BD9 and #R$8C07. Init mine sub-stage when wave >
* 4 or wave = 4 and chance stage.
all_waves_completed:                   ; >8c1e
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@outcoming_enemies       ; LD ($725C),A      ; Reset outcoming enemies
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; Reset counter
       li   hl,status_flags            ; LD HL,$71EB       ; Set all waves completed flag
       socb @bits+1,*hl                ; SET 1,(HL)        ; ...
       li   hl,other_flags             ; LD HL,$7256       ; Reset flag
       szcb @bits+5,*hl                ; RES 5,(HL)        ; ...
       .ret                            ; RET               ;

* Manage wave < 4
*
* Used by the routine at #R$8BD9.
handle_wave_lt_4:                      ; >8c30
       movb @countdown_to_wave,a       ; LD A,($71F0)      ; Get counter
;       socb a,a                        ; OR A              ; Is it zero?
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       andi a,>fc00                    ; AND $FC           ; Isolate planet index bits
;       li   hl,wave                    ; LD HL,$7201       ; Add wave
;       ab   *hl,a                      ; ADD A,(HL)        ; ...
       ab   @wave,a
* This entry point is used by the routine at #R$8C07.
start_wave_in_a:                       ; >8c3e
;       ab   a,a                        ; ADD A,A           ; Multiply by 4
;       ab   a,a                        ; ADD A,A           ; ...
       sla  a,2                        ; Multiply by 4
       movb a,@c                       ; LD C,A            ; BC = offset into table
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,wave_init_data          ; LD HL,$A4BE       ; Table base address
       movb @status_flags,a            ; LD A,($71EB)      ; Is it chance stage?
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jeq  start_new_wave             ; JR Z,$8C52        ; If not, jump ahead
       li   hl,chance_wave_init_data   ; LD HL,$A51E       ; Else load other table
       jmp  start_new_wave_1           ; JR $8C57          ; And jump ahead

* Start new wave
*
* Used by the routine at #R$8C30.
start_new_wave:                        ; >8c52
       movb @bytes+>02,a               ; LD A,$02          ; Play a sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
* This entry point is used by the routine at #R$8C30.
start_new_wave_1:                      ; >8c57
       a    bc,hl                      ; ADD HL,BC         ; Add offset to table base
       mov  hl,@wave_data_address      ; LD ($725D),HL     ; Save table address
;       li   hl,wave                    ; LD HL,$7201       ; Next wave
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@wave
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       szcb @bits+5,*hl                ; RES 5,(HL)        ; Reset flag
       socb @bits+6,*hl                ; SET 6,(HL)        ; Set flag
       jmp  handle_wave_outcoming_1    ; JR $8C6D          ;

* When wave is initiating
*
* Called when there's still more outcoming enemies. Used by the routine at
* #R$8BD9.
handle_wave_outcoming:                 ; >8c68
       li   hl,wave_speed_counter      ; LD HL,$725B       ; Decrement wave speed counter
       sb   one,*hl                    ; DEC (HL)          ; ...
       jlt  !                          ; RET P             ; Return if > 0
       .ret                            ;
!
* This entry point is used by the routine at #R$8C52.
handle_wave_outcoming_1:                                 ; >8c6d
       mov  @wave_data_address,iy      ; LD IY,($725D)     ; Get wave data address
       .push iy                        ; PUSH IY           ; Save pointer
       movb @>02(iy),a                 ; LD A,(IY+$02)     ; Get byte 3
;       sla  a,1                        ; RLCA              ; Shift bit 5-7 into 0-2
;       sla  a,1                        ; RLCA              ; ...
;       sla  a,1                        ; RLCA              ; ...
       srl  a,5
       andi a,>0700                    ; AND $07           ; And isolate them
;       .push af                        ; PUSH AF           ;
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
;       .pop af                         ; POP AF            ;
       ab   *iy,a                      ; ADD A,(IY+$00)    ; Add 2 times stage speed
       ab   *iy,a                      ; ADD A,(IY+$00)    ; ...
       movb a,@wave_speed_counter      ; LD ($725B),A      ; Store as new speed counter value
       .pop iy                         ; POP IY            ; Restore wave data address
       movb @bytes+>0e,b               ; LD B,$0E          ; Default sprite type (enemy)
       movb @status_flags,a            ; LD A,($71EB)      ; Is it chance stage?
       czc  @bits+3,a                  ; BIT 3,A           ; ...
       jeq  handle_wave_outcoming_2    ; JR Z,$8CA2        ; If not, skip ahead
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       andi a,>fc00                    ; AND $FC           ; Isolate planet index bits
;       li   hl,wave                    ; LD HL,$7201       ; Add wave
;       ab   *hl,a                      ; ADD A,(HL)        ; ...
       ab   @wave,a
       li   hl,enemies_by_wave_table-1 ; LD HL,$8E0C       ; Table at #R$8E0D - 1
       bl   @add_a_to_hl               ; RST $08           ; Add A (1-24) to HL
       movb *hl,b                      ; LD B,(HL)         ; Get table value
handle_wave_outcoming_2:               ; >8ca2
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb b,*ix                      ; LD (IX+$00),B     ; Set sprite type
       movb @>03(iy),a                 ; LD A,(IY+$03)     ; Get wave data byte 3
;       srl  a,1                        ; RRA               ; Shift bits 4-7 to 0-3
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
       srl  a,4
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       movb a,@>0b(ix)                 ; LD (IX+$0B),A     ; Set color
       movb @>03(iy),a                 ; LD A,(IY+$03)     ; Get wave data byte 3
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       movb a,@c                       ; LD C,A            ; BC = A = table offset (actually only 0 - 2)
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,wave_init_polar_y       ; LD HL,$A57E       ; Table base address
       a    bc,hl                      ; ADD HL,BC         ; Table address
;       movb *hl,a                      ; LD A,(HL)         ; Get table byte
;       movb a,@>01(ix)                 ; LD (IX+$01),A     ; Save as polar y
       movb *hl,@>01(ix)
       movb @outcoming_enemies,a       ; LD A,($725C)      ; Outcoming enemies
       movb *iy,@c                     ; LD C,(IY+$00)     ; Get wave data byte 0
       czc  @bit0,a                    ; BIT 0,A           ; Even number of outcoming enemies?
       jeq  handle_wave_outcoming_3    ; JR Z,$8CCF        ; Skip ahead if so
       movb @>01(iy),@c                ; LD C,(IY+$01)     ; Get wave data byte 1
handle_wave_outcoming_3:               ; >8ccf
       movb @c,a                       ; LD A,C            ; A = wave data byte
       andi a,>7f00                    ; AND $7F           ; Clear bit 7
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save as polar x
       movb @>02(iy),a                 ; LD A,(IY+$02)     ; Get wave data byte 2
       andi a,>1f00                    ; AND $1F           ; Isolate bits 0-4
       ab   a,a                        ; ADD A,A           ; x2
       movb a,@c                       ; LD C,A            ; BC = offset
       li   hl,wave_address_table      ; LD HL,$A581       ; Table base address
       a    bc,hl                      ; ADD HL,BC         ; Table address
;       movb *hl,a                      ; LD A,(HL)         ; Get LSB
;       inc  hl                         ; INC HL            ; Next table address
;       movb *hl,h                      ; LD H,(HL)         ; Get MSB
;       movb a,@l                       ; LD L,A            ; L = LSB
       mov  *hl,hl
       movb @l,@>06(ix)                ; LD (IX+$06),L     ; Store in sprite data (pointer to path data)
       movb h,@>07(ix)                 ; LD (IX+$07),H     ; ...
       movb *hl,a                      ; LD A,(HL)         ; Get first byte
       andi a,>f000                    ; AND $F0           ; Isolate bits 4-7
       movb a,b                        ; LD B,A            ; Store in B
       movb @outcoming_enemies,a       ; LD A,($725C)      ; Outcoming enemies
       socb b,a                        ; OR B              ; OR bits 4-7
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; Store in sprite data
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
;       li   hl,active_enemies          ; LD HL,$722C       ; Increment active enemies
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@active_enemies
;       li   hl,total_enemies           ; LD HL,$7206       ; Increment total enemies
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@total_enemies
;       li   hl,outcoming_enemies       ; LD HL,$725C       ; Increment outcoming enemies
;       ab   one,*hl                    ; INC (HL)          ; ...
       ab   one,@outcoming_enemies
       movb @bytes+>09,b               ; LD B,$09          ; B = 9 enemies
       movb @status_flags,a            ; LD A,($71EB)      ; Is it chance stage?
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jeq  handle_wave_outcoming_4    ; JR Z,$8D0D        ; If not, skip ahead
       movb @bytes+>0a,b               ; LD B,$0A          ; Else B = 10 enemies
handle_wave_outcoming_4:               ; >8d0d
;       movb *hl,a                      ; LD A,(HL)         ; Increased outcoming enemies
;       cb   a,b                        ; CP B              ; Compare with 9 or 10
       cb   @outcoming_enemies,b
       jne  handle_wave_outcoming_5     ; RET NZ            ; Return if all are not out
;       sb   *hl,*hl                    ; LD (HL),$00       ; Set outcoming enemies to 0
       movb @zero,@outcoming_enemies
       li   hl,other_flags             ; LD HL,$7256       ; Clear flag that was set
       szcb @bits+6,*hl                ; RES 6,(HL)        ; when the wave started
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       movb @>06(iy),a                 ; LD A,(IY+$06)     ; Set countdown
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; ...
handle_wave_outcoming_5:
       .ret                            ; RET               ;

* Reset outcoming enemies
*
* Used by the routine at #R$8170.
reset_outcoming_enemies:               ; >8d21
       movb @status_flags,a            ; LD A,($71EB)      ; Are all waves completed?
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jne  reset_outcoming_enemies_2  ; RET NZ            ; Then return
       movb @outcoming_enemies,a       ; LD A,($725C)      ; Outcoming enemies
;       socb a,a                        ; OR A              ; If none
       jeq  reset_outcoming_enemies_2  ; RET Z             ; Then return
       movb a,b                        ; LD B,A            ; B = outcoming enemies
       movb @bytes+>09,a               ; LD A,$09          ; B = 9 - outcoming enemies
       sb   b,a                        ; SUB B             ; ...
       movb a,b                        ; LD B,A            ; ...
;       li   hl,total_enemies           ; LD HL,$7206       ; Total enemies
;       ab   *hl,a                      ; ADD A,(HL)        ; Add outcoming enemies
;       movb a,*hl                      ; LD (HL),A         ; Save again
       ab   a,@total_enemies
       mov  @wave_data_address,iy      ; LD IY,($725D)     ; Wave data address
       movb @>03(iy),a                 ; LD A,(IY+$03)     ; Get bits 4-7 of byte 3
;       srl  a,1                        ; RRA               ; Shift bits 4-7 into bits 0-4
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
       srl  a,4
       andi a,>0f00                    ; AND $0F           ; ...
reset_outcoming_enemies_1:                                 ; >8d43
       bl   @allocate_map_entry        ; CALL $AAA6        ; Return enemies to center
       sb   one,b                      ; DJNZ $8D43        ; ...
       jne  reset_outcoming_enemies_1                      ;
       sb   a,a                        ; XOR A             ; Reset outcoming enemies
       movb a,@outcoming_enemies       ; LD ($725C),A      ; ...
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; Reset countdown to wave
reset_outcoming_enemies_2:
       .ret                            ; RET               ;

* Create "laser fence" or meteor
*
* Used by the routine at #R$80E8.
create_laser_fence_or_meteor:          ; >8d50
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0300                    ; AND $03           ; If not every 4th frame
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       movb @status_flags,a            ; LD A,($71EB)      ; Is it chance stage?
       czc  @bit3,a                    ; BIT 3,A           ; ...
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       movb @laser_meteor_countdown,a  ; LD A,($725F)      ; Is countdown zero?
;       socb a,a                        ; OR A              ; ...
       jne  !                          ; JP Z,$8E04        ; Then start another countdown
       b    @_8e04                     ;
!
       sb   one,a                      ; DEC A             ; Else decrement it
       movb a,@laser_meteor_countdown  ; LD ($725F),A      ; And save it
       jeq  !                          ; RET NZ            ; If it's still not zero then return
       .ret                            ;
!
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>e000                    ; AND $E0           ; If any of 3 bits are set
       jne  create_meteor              ; JR NZ,$8DD7       ; Then jump to create meteor
       movb @>07(iy),r0                ; BIT 0,(IY+$07)    ; ...
       andi r0,>0100                   ;
       jeq  create_meteor              ; JR Z,$8DD7        ; ...
       li   hl,other_flags             ; LD HL,$7256       ; If laser fence flag is set
       movb *hl,r0                     ; BIT 4,(HL)        ; ...
       andi r0,>1000                   ;
       jne  create_meteor              ; JR NZ,$8DD7       ; Then jump to create meteor
* Allocate laser fence
       socb @bits+4,*hl                ; SET 4,(HL)        ;
       socb @bits+3,*hl                ; SET 3,(HL)        ;
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>15,*ix             ; LD (IX+$00),$15   ; Set type to laser fence end 1
       movb @bytes+>25,@>01(ix)        ; LD (IX+$01),$25   ; Set polar y
       movb @bytes+>0c,@>0b(ix)        ; LD (IX+$0B),$0C   ; Set color
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>3f00                    ; AND $3F           ; 0-63
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb a,@_7262                   ; LD ($7262),A      ; Store polar x
       .push af                        ; PUSH AF           ; Save polar x
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>16,*ix             ; LD (IX+$00),$16   ; Set type to laser fence end 2
       movb @bytes+>25,@>01(ix)        ; LD (IX+$01),$25   ; Set polar y
       movb @bytes+>0c,@>0b(ix)        ; LD (IX+$0B),$0C   ; Set color
       .pop af                         ; POP AF            ; Restore polar x
       .push af                        ; PUSH AF           ; Save polar x
       ab   @bytes+>08,a               ; ADD A,$08         ; Polar x + 8
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb a,@_7261                   ; LD ($7261),A      ; Store polar x
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>17,*ix             ; LD (IX+$00),$17   ; Set type to laser fence center
       movb @bytes+>25,@>01(ix)        ; LD (IX+$01),$25   ; Set polar y
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color
       movb one,@>03(ix)               ; LD (IX+$03),$01   ; Set velocity
       .pop af                         ; POP AF            ; Restore polar x
       ab   @bytes+>04,a               ; ADD A,$04         ; Polar x + 4
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
       movb @total_enemies,a           ; LD A,($7206)      ; Total enemies
       ab   @bytes+>03,a               ; ADD A,$03         ; Add 3
       movb a,@total_enemies           ; LD ($7206),A      ; Store again
       jmp  _8e04                      ; JR $8E04          ; Jump to return

* Create meteor
*
* Used by the routine at #R$8D50.
create_meteor:                         ; >8dd7
       movb @>07(iy),r0                ; BIT 1,(IY+$07)    ;
       andi r0,>0200                   ;
       jeq  _8e04                      ; JR Z,$8E04        ;
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>14,*ix             ; LD (IX+$00),$14   ; Set type to meteor
       movb @bytes+>2a,@>01(ix)        ; LD (IX+$01),$2A   ; Set polar y
       bl   @ti_rnd                    ; RST $20           ; Random number
       movb a,@c                       ; LD C,A            ; Store it in C
       andi a,>0700                    ; AND $07           ; Offset 0-7
       ab   @bytes+>02,a               ; ADD A,$02         ; 2-9
       movb @c,r0                      ; BIT 6,C           ; If a bit in the random number is set
       andi r0,>4000                   ;
       jeq  _8df2                      ; JR Z,$8DF2        ; ...
       neg a                           ; NEG               ; Then make offset negative
_8df2:                                 ; >8df2
       movb a,b                        ; LD B,A            ; Stor offset
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Get ship polar x
       ab   b,a                        ; ADD A,B           ; Add offset
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x
       movb @bytes+>0e,@>0b(ix)        ; LD (IX+$0B),$0E   ; Set color
       li   hl,total_enemies           ; LD HL,$7206       ; Increment total enemies
       ab   one,*hl                    ; INC (HL)          ; ...
* This entry point is used by the routine at #R$8D50.
_8e04:                                 ; >8e04
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>3f00                    ; AND $3F           ; $00 - $3F
       ab   @bytes+>10,a               ; ADD A,$10         ; $10 - $4F
       movb a,@laser_meteor_countdown  ; LD ($725F),A      ; Store countdown
       .ret                            ; RET               ;

* Enemy types in different waves (chance stage)
enemies_by_wave_table:                 ; >8e0d
       byte >18,>0E,>18,>0E,>19,>0E,>19,>0E
       byte >1A,>0E,>1A,>0E,>1A,>0E,>1A,>0E
       byte >19,>0E,>19,>0E,>1A,>0E,>1A,>0E

* Enemy movement table
*
* A random value is selected for the counter.
enemy_movement_table:                  ; >8e25
       byte >42,>41,>40,>00,>42,>42,>40,>42

* Create or display mines
*
* Used by the routines at #R$80E8, #R$8139 and #R$A3E1.
create_or_display_mines:               ; >8e2d
       movb @status_flags,a            ; LD A,($71EB)      ; Get flags
       czc  @bit1,a                    ; BIT 1,A           ; If all waves completed bit is not set
       jeq  init_mine_variables        ; JR Z,$8E89        ; Then init variables and return
       movb @mines_action,a            ; LD A,($7264)      ; Get mines action (0-2)
       cb   a,one                      ; CP $01            ; If 1
       jne  !                          ; JP Z,$8E9D        ; Then create mines
       b    @create_mines              ;
!
       jl  !                           ; JP NC,$8F55       ; If 2 then display mines
       b    @display_mines             ;
!
       movb @status_flags,a            ; LD A,($71EB)      ; If died
       czc  @bit2,a                    ; BIT 2,A           ; ...
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       movb @other_flags,a             ; LD A,($7256)      ; If mines flag is set
       czc  @bit2,a                    ; BIT 2,A           ; ...
       jeq  !                          ; RET NZ            ; The return
       .ret                            ;
!
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0f00                    ; AND $0F           ; If not every 16th frame
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       li   hl,mines_time_left         ; LD HL,$7263       ; Get countdown
       sb   one,*hl                    ; DEC (HL)          ; Decrement it
       jeq  !                          ; RET NZ            ; Return if not zero
       .ret                            ;
!
       movb @center_map_entries,a      ; LD A,($722B)      ; Get center enemies
       cb   a,@bytes+>03               ; CP $03            ; If < 3
       jhe  !                          ; RET C             ; Then return
       .ret                            ;
!
       movb @stage,a                   ; LD A,($7200)      ; Stage
       srl  a,1                        ; SRL A             ; Shift out stage within planet bits
       srl  a,1                        ; SRL A             ; ...
       movb a,b                        ; LD B,A            ; B = planet
       movb @bytes+>05,a               ; LD A,$05          ; A = 5
       sb   b,a                        ; SUB B             ; 5 - planet
       jlt  create_or_display_mines_1                      ; JR C,$8E6D        ; If planet > 5 then skip ahead and set to 2
       cb   a,@bytes+>02               ; CP $02            ; If 5 - planet >= 2 then skip ahead
       jhe  create_or_display_mines_2                      ; JR NC,$8E6F       ; ...
create_or_display_mines_1:             ; >8e6d
       movb @bytes+>02,a               ; LD A,$02          ; Set to 2
create_or_display_mines_2:             ; >8e6f
       li   hl,stage_death_count       ; LD HL,$7204       ; Number of times died within stage
       cb   a,*hl                      ; CP (HL)           ; Return if >= calculated value (2, 3, 4, 5)
       jhe  !                          ; RET C             ; ...
       .ret                            ;
!
       movb @mines_reappear,a          ; LD A,($7266)      ; If stored value is 2
       cb   a,@bytes+>02               ; CP $02            ; ...
       jne  !                          ; RET Z             ; Then return
       .ret                            ;
!
       ab   one,a                      ; INC A             ; Else increment calculated value
       movb a,@mines_reappear          ; LD ($7266),A      ; And store
       li   hl,other_flags             ; LD HL,$7256       ; Set mines flag
       socb @bits+2,*hl                ; SET 2,(HL)        ; ...
       movb one,a                      ; LD A,$01          ; Set action to create mines
       movb a,@mines_action            ; LD ($7264),A      ; ...
       .ret                            ; RET               ;

* Init mine variables
*
* Used by the routine at #R$8E2D.
init_mine_variables:                   ; >8e89
       sb   a,a                        ; XOR A             ;
       movb a,@mines_reappear          ; LD ($7266),A      ;
* This entry point is used by the routines at #R$82BF and #R$8FED.
init_mine_variables_2:                 ; >8e8d
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>0f00                    ; AND $0F           ; 0 - 15
       ab   @bytes+>05,a               ; ADD A,$05         ; 5  - 20
       movb a,@mines_time_left         ; LD ($7263),A      ; Store
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@destroy_mines_flag      ; LD ($7265),A      ; Set to 0
       movb a,@mines_action            ; LD ($7264),A      ; Set action to 0
       .ret                            ; RET               ;

* Create mines
*
* Used by the routine at #R$8E2D.
create_mines:                          ; >8e9d
       li   iy,ship_background_data    ; LD IY,$722E       ; Ship background data
       movb @bytes+>80,a               ; LD A,$80          ; Store name
       movb a,@mine_name               ; LD ($7268),A      ; ...
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship polar x
       ab   @bytes+>08,a               ; ADD A,$08         ; Polar x + 8
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@e                       ; LD E,A            ; E = new polar x
       movb @bytes+>17,d               ; LD D,$17          ; D = polar y
       .push de                        ; PUSH DE           ; Save coordinates
       li   hl,three_spheres_graphics  ; LD HL,$9056       ; 3 spheres graphics (if double shot on)
       movb @bytes+>40,@c              ; LD C,$40          ; Color
       movb @other_flags,a             ; LD A,($7256)      ; Test double shot flag
       czc  @bit1,a                    ; BIT 1,A           ; ...
       jne  create_mines_1             ; JR NZ,$8EC2       ; If set then skip ahead
       li   hl,mine_graphics           ; LD HL,$9096       ; Mine graphics (if double shot off)
       movb @bytes+>90,@c              ; LD C,$90          ;
create_mines_1:                        ; >8ec2
       .call @create_mine              ; CALL $8F0F        ; Create mine
       .pop de                         ; POP DE            ; Restore coordinates
       .push de                        ; PUSH DE           ; Save coordinates
       movb @e,a                       ; LD A,E            ; Polar x
       ab   @bytes+>08,a               ; ADD A,$08         ; Polar x + 8
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@e                       ; LD E,A            ; Set new polar x
       li   hl,three_spheres_graphics  ; LD HL,$9056       ; 3 spheres graphics
       movb @bytes+>40,@c              ; LD C,$40          ; Color
       .call @create_mine              ; CALL $8F0F        ; Create mine
       .pop de                         ; POP DE            ; Restore coordinate
       movb @e,a                       ; LD A,E            ; Polar x
       sb   @bytes+>08,a               ; SUB $08           ; Polar x - 8
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@e                       ; LD E,A            ; Set new polar x
       li   hl,three_spheres_graphics  ; LD HL,$9056       ; 3 spheres graphics
       movb @bytes+>40,@c              ; LD C,$40          ; Color
       .call @create_mine              ; CALL $8F0F        ; Create mine
       movb @bytes+>02,a               ; LD A,$02          ; Set action to display mines
       movb a,@mines_action            ; LD ($7264),A      ; ...
       ab   one,a                      ; INC A             ; A = 3
       movb a,@mines_left              ; LD ($722D),A      ; Set mines left
       li   hl,total_enemies           ; LD HL,$7206       ; Total enemies
       ab   *hl,a                      ; ADD A,(HL)        ; Add 3
       movb a,*hl                      ; LD (HL),A         ; Save again
       sb   a,a                        ; XOR A             ;
       movb a,@mines_movement_table_offset ; LD ($7267),A      ;
       movb a,@mines_destroyed         ; LD ($7254),A      ; No mines destroyed
       ab   one,a                      ; INC A             ;
       movb a,@mine_countdown_to_shoot ; LD ($7269),A      ; Set countdown to shoot to 1
       .call @create_shot_from_mine    ; CALL $900E        ; Create shot from mine
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       movb @>05(iy),a                 ; LD A,(IY+$05)     ;
       movb a,@mines_time_left         ; LD ($7263),A      ;
       movb @bytes+>07,a               ; LD A,$07          ; Play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       .ret                            ; RET               ;

* Create mine
*
* Used by the routine at #R$8E9D.
*
* I: IY Points to ship background data
* I: DE Polar coordinates
* I: HL Graphics patterns
* I: C Color
create_mine:                           ; >8f0f
       .push bc                        ; PUSH BC           ; Save color
       li   bc,>0009                   ; LD BC,$0009       ; Advance IY to mine background data
       a    bc,iy                      ; ADD IY,BC         ; ...
       movb @l,@>04(iy)                ; LD (IY+$04),L     ; Patterns address LSB
       movb h,@>05(iy)                 ; LD (IY+$05),H     ; Patterns address MSB
       movb d,@>07(iy)                 ; LD (IY+$07),D     ; Polar y
       movb @e,@>08(iy)                ; LD (IY+$08),E     ; Polar x
       bl   @polar_to_screen           ; CALL $B1C6        ; Polar to screen
       movb d,a                        ; LD A,D            ; Screen y
       sb   @bytes+>04,a               ; SUB $04           ; Screen y - 4
       movb a,@>01(iy)                 ; LD (IY+$01),A     ; Save in structure
       movb @e,a                       ; LD A,E            ; Screen x
       sb   @bytes+>04,a               ; SUB $04           ; Screen x - 4
       movb a,*iy                      ; LD (IY+$00),A     ; Save in structure
       movb @mine_name,a               ; LD A,($7268)      ; Get name
;       srl  a,1                        ; RRA               ; Divide by 8
;       srl  a,1                        ; RRA               ; ...
;       srl  a,1                        ; RRA               ; ...
       srl  a,3
       andi a,>1f00                    ; AND $1F           ; Mod 32
       movb a,@l                       ; LD L,A            ; HL = color set
       sb   h,h                        ; LD H,$00          ; ...
       li   de,>2000                   ; LD DE,$2000       ; Color table
       a    de,hl                      ; ADD HL,DE         ; Add color set offset
       li   de,>0002                   ; LD DE,$0002       ; Update 2 color sets
       .pop bc                         ; POP BC            ; Restore color
       movb @c,a                       ; LD A,C            ; A = color
       bl   @fill_vram                 ; CALL $1F82        ; FILL_VRAM
       movb @mine_name,a               ; LD A,($7268)      ; Get name
       movb a,@>06(iy)                 ; LD (IY+$06),A     ; Save in structure
       ab   @bytes+>10,a               ; ADD A,$10         ; Add 16 (when will this be used?)
       movb a,@mine_name               ; LD ($7268),A      ; Set name
       b    @display_background_patterns ; JP $8B12          ; Display background patterns

* Display mines
*
* Used by the routine at #R$8E2D.
display_mines:                         ; >8f55
       .call @create_shot_from_mine    ; CALL $900E        ; Create shot from mine
       li   iy,mines_background_data   ; LD IY,$7237       ; Mine data
       movb @bytes+>03,b               ; LD B,$03          ; 3 mines
display_mines_1:                       ; >8f5e
       .push bc                        ; PUSH BC           ; Save counter
       movb @>04(iy),@l                ; LD L,(IY+$04)     ; Get patterns address LSB
       movb @>05(iy),h                 ; LD H,(IY+$05)     ; Get patterns address MSB
       movb h,a                        ; LD A,H            ; If zero
       socb @l,a                       ; OR L              ; ...
       jeq  display_mines_3            ; JR Z,$8FC6        ; Then return
       movb @status_flags,a            ; LD A,($71EB)      ; Test died flag
       czc  @bit2,a                    ; BIT 2,A           ; ...
       jne  destroy_mine               ; JR NZ,$8FED       ; If we died then destroy mine
       movb @destroy_mines_flag,a      ; LD A,($7265)      ; Test flag
       movb a,r0                       ; BIT 0,A           ; If set
       andi r0,>0100                   ;
       jne  destroy_mine               ; JR NZ,$8FED       ; Then destroy mine
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0700                    ; AND $07           ; If not every 8th frame
       jne  display_mines_3            ; JR NZ,$8FC6       ; Then skip to next mine
       movb @mines_movement_table_offset,a ; LD A,($7267)      ; Get table offset
       movb a,@c                       ; LD C,A            ; BC = A
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,mines_movement_table    ; LD HL,$9046       ; Table base address
       a    bc,hl                      ; ADD HL,BC         ; Add offset
       movb *hl,a                      ; LD A,(HL)         ; Get table byte
       ab   @>07(iy),a                 ; ADD A,(IY+$07)    ; Add to polar y
       movb a,@>07(iy)                 ; LD (IY+$07),A     ; ...
       inc  hl                         ; INC HL            ; Next table address
       movb *hl,a                      ; LD A,(HL)         ; Get table byte
       ab   @>08(iy),a                 ; ADD A,(IY+$08)    ; Add to polar x
       movb a,@>08(iy)                 ; LD (IY+$08),A     ; ...
       movb @>04(iy),@l                ; LD L,(IY+$04)     ; Get patterns address
       movb @>05(iy),h                 ; LD H,(IY+$05)     ; ...
       li   de,three_spheres_graphics  ; LD DE,$9056       ; 3 spheres graphics
       sb   a,a                        ; XOR A             ; Patterns offset
       s    de,hl                      ; SBC HL,DE         ; ...
       movb @l,a                       ; LD A,L            ; Flip bit value 32 (animate)
       li   r0,32*256                  ; XOR $20           ; ...
       xor  r0,a                       ;
       movb a,@l                       ; LD L,A            ; ...
       a    de,hl                      ; ADD HL,DE         ; New patterns address
       movb @l,@>04(iy)                ; LD (IY+$04),L     ; Save in structure
       movb h,@>05(iy)                 ; LD (IY+$05),H     ; ...
* This entry point is used by the routine at #R$8FED.
display_mines_2:                       ; >8fae
       movb @>07(iy),d                 ; LD D,(IY+$07)     ; Polar y
       movb @>08(iy),@e                ; LD E,(IY+$08)     ; Polar x
       bl   @polar_to_screen          ; CALL $B1C6        ; Polar to screen
       movb d,a                        ; LD A,D            ; Screen y
       sb   @bytes+>04,a               ; SUB $04           ; Screen y - 4
       movb a,@>01(iy)                 ; LD (IY+$01),A     ; Save in structure
       movb @e,a                       ; LD A,E            ; Screen x
       sb   @bytes+>04,a               ; SUB $04           ; Screen x - 4
       movb a,*iy                      ; LD (IY+$00),A     ; Save in structure
       .call @display_background_patterns ; CALL $8B12        ; Display background patterns
display_mines_3:                       ; >8fc6
       li   bc,>0009                   ; LD BC,$0009       ; Next mine
       a    bc,iy                      ; ADD IY,BC         ; ...
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $8F5E        ; Loop for 3 mines
       jne  display_mines_1            ;
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0700                    ; AND $07           ; If not the 8th frame
       jeq  !                          ; RET NZ            ; Then return
       .ret                            ;
!
       li   hl,mines_time_left         ; LD HL,$7263       ; Get countdown
       sb   one,*hl                    ; DEC (HL)          ; Decrement it
       jne  display_mines_4            ; JR NZ,$8FDF       ; Return if not zero
       li   hl,destroy_mines_flag      ; LD HL,$7265       ; Set flag to destroy mines
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
display_mines_4:                       ; >8fdf
       movb @mines_movement_table_offset,a ; LD A,($7267)      ; Offset movement table offset
       ab   @bytes+>02,a               ; ADD A,$02         ; Add 2
       cb   a,@bytes+>10               ; CP $10            ; If < 16
       jl   display_mines_5            ; JR C,$8FE9        ; Then update
       sb   a,a                        ; XOR A             ; Else reset
display_mines_5:                       ; >8fe9
       movb a,@mines_movement_table_offset ; LD ($7267),A      ; Save offset
       .ret                            ; RET               ;

* Destroy mine
*
* Used by the routine at #R$8F55.
destroy_mine:                          ; >8fed
       sb   one,@>07(iy)               ; DEC (IY+$07)      ;
       jne  display_mines_2            ; JR NZ,$8FAE       ;
       sb   @>04(iy),@>04(iy)          ; LD (IY+$04),$00   ;
       sb   @>05(iy),@>05(iy)          ; LD (IY+$05),$00   ;
       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,mines_left              ; LD HL,$722D       ; Decrement mines left
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne  display_mines_2            ; JR NZ,$8FAE       ;
       li   hl,other_flags             ; LD HL,$7256       ; Clear mines flag
       szcb @bits+2,*hl                ; RES 2,(HL)        ; ...
       .call @init_mine_variables_2    ; CALL $8E8D        ;
       jmp  display_mines_2            ; JR $8FAE          ;

* Create shot from mine
*
* Used by the routines at #R$8E9D and #R$8F55.
create_shot_from_mine:                                 ; >900e
       li   hl,mine_countdown_to_shoot ; LD HL,$7269       ; Decrement countdown
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne create_shot_from_mine_2     ; RET NZ            ; Return if not 0
       li   iy,mines_background_data   ; LD IY,$7237       ; Mine data
       movb @>04(iy),a                 ; LD A,(IY+$04)     ; Check if mine exists
       socb @>05(iy),a                 ; OR (IY+$05)       ; ...
       jeq  create_shot_from_mine_1    ; JR Z,$9039        ; Skip ahead if not
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Increment enemy shots
       ab   one,*hl                    ; INC (HL)          ; ...
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       movb @bytes+>12,*ix             ; LD (IX+$00),$12   ; Missile
       movb @bytes+>0a,@>0b(ix)        ; LD (IX+$0B),$0A   ; Set color
       movb @>07(iy),a                 ; LD A,(IY+$07)     ; Set polar y to mine polar y
       movb a,@>01(ix)                 ; LD (IX+$01),A     ; ...
       movb @>08(iy),a                 ; LD A,(IY+$08)     ; Set polar x to mine polar x
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; ...
       bl   @load_sprite_pattern_fast  ; RST $30           ; Load sprite pattern
create_shot_from_mine_1:               ; >9039
       bl   @stage_data_addr           ; CALL $84DB        ; Get stage data address in IY
       bl   @ti_rnd                    ; RST $20           ; Random number
       andi a,>3f00                    ; AND $3F           ; 0-63
       ab   @>06(iy),a                 ; ADD A,(IY+$06)    ; Add ?
       movb a,@mine_countdown_to_shoot ; LD ($7269),A      ; Set countdown to random value
create_shot_from_mine_2:
       .ret                            ; RET               ;

* Mines movement table
mines_movement_table:                  ; >9046
       byte >01,>FF,>01,>FF,>01,>01,>01,>01
       byte >FF,>01,>FF,>01,>FF,>FF,>FF,>FF

* Start screen
*
* Used by the routine at #R$8024.
start_screen:                          ; >90d6
       bl   @mode_1                   ; CALL $1F85         ; MODE_1 (pattern generator table at  $0000, name table at
                                                           ; $1800, color table at $2000)
       li   hl,>0800                   ; LD HL,$0800       ; Set sprite generator table at $0800 (was $3800)
       movb one,a                      ; LD A,$01          ;
       bl   @init_table               ; CALL $1FB8        ; INIT_TABLE
       li   hl,>1c00                   ; LD HL,$1C00       ; Set sprite attribute table at $1C00 (was $1B00)
       sb   a,a                        ; LD A,$00          ;
       bl   @init_table               ; CALL $1FB8        ; INIT_TABLE
       sb   a,a                        ; LD A,$00          ; Clear all VDP RAM
       li   hl,>0000                   ; LD HL,$0000       ;
       li   de,>4000                   ; LD DE,$4000       ;
       bl   @fill_vram                  ; CALL $1F82       ; FILL_VRAM
       bl   @load_ascii               ; CALL $1F7F         ; LOAD_ASCII
       li   hl,stars                   ; LD HL,$B134       ; Stars
       .call @upload_patterns          ; CALL $84CB        ; Upload 18 star patterns starting with 1
       li   hl,buffer                  ; LD HL,$71A3       ; Save pattern 33 from VDP to RAM
       li   de,>0108                   ; LD DE,$0108       ;
       li   bc,>0008                   ; LD BC,$0008       ;
       bl   @read_vram                 ; CALL $1FE2        ; READ_VRAM
       li   hl,buffer                  ; LD HL,$71A3       ; Write it back to VDP patern 63
       li   de,>01f8                   ; LD DE,$01F8       ;
       li   bc,>0008                   ; LD BC,$0008       ;
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   hl,ship_pattern            ; LD HL,$92D6       ; Write ship pattern to pattern 33
       li   de,>0108                   ; LD DE,$0108       ;
       li   bc,>0008                   ; LD BC,$0008       ;
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       .call @decompress_patterns      ; CALL $921F        ; Upload patterns to VDP buffer
       li   hl,_9380                   ; LD HL,$9380       ; Gyruss logo names
       li   de,>18a8                   ; LD DE,$18A8       ; Name table address
       movb @bytes+>02,@c              ; LD C,$02          ; 2 rows
logo_row:                              ; >9128
       movb @bytes+>06,b               ; LD B,$06          ; 6 letters
logo_letter:                           ; >912a
       movb *hl,a                      ; LD A,(HL)         ; Get name
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next destination
       inc  hl                         ; INC HL            ; Next source
       movb *hl,a                      ; LD A,(HL)         ; Get name
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next destination
       inc  de                         ; INC DE            ; Next destination (skip space)
       inc  hl                         ; INC HL            ; Next source
       sb   one,b                      ; DJNZ $912A        ; Loop for 6 letters
       jne  logo_letter                ;
       li   de,>18c8                   ; LD DE,$18C8       ; Name table address of next row
       sb   one,@c                     ; DEC C             ; Row counter
       jne  logo_row                   ; JR NZ,$9128       ; Loop for 2 rows
       .call @init_sprite_data         ; CALL $ACDF        ; Init sprites
       movb @bytes+>06,a               ; LD A,$06          ; Planet number
       .call @display_planet           ; CALL $9175        ; Draw planet 6 (Earth)
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       .call @clear_row_7              ; CALL $920D        ; Clear row 7
       li   hl,copyright_msg           ; LD HL,$92AC       ; Copyright message
       li   de,>1ae4                   ; LD DE,$1AE4       ; Name table address
       li   bc,>0017                   ; LD BC,$0017       ; 23 bytes
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   de,>2000                   ; LD DE,$2000       ; Color table address
       li   hl,colors                  ; LD HL,$92C3       ; Colors
       li   bc,>0013                   ; LD BC,$0013       ; Update 19 color sets
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   hl,gyruss_logo             ; LD HL,$92DE       ; Gyruss logo
       .call @upload_patterns          ; CALL $84CB        ; Upload 20 patterns starting with 128
       li   r0,>2100
       li   r1,sprite_graphics_bin
       li   r2,sprite_graphics_bin_end-sprite_graphics_bin
       bl   @vmbw
       li   bc,>01e0                   ; LD BC,$01E0       ; Display on, interrupt on
       bl   @write_register            ; RST $18           ; WRITE_REGISTER
;start_screen_loop:                     ; >9167
;       .halt                           ; HALT              ; Wait for interrupt
;       .call @display_stars            ; CALL $AFFF        ; Display stars
;       .call @upload_sprite_patterns   ; CALL $AE94        ;
;;       joc  !                          ; RET NC            ; Return if no carry
;       abs @carry
;       jeq start_screen_1
;       .call @upload_sprite_patterns   ; CALL $AE94        ;
;       abs  @carry
;       jne  start_screen_loop          ; JR C,$9167        ; Loop until no carry
;start_screen_1:
       .ret                            ; RET               ;

* Display planet
*
* Used by the routines at #R$832A, #R$83D0 and #R$90D6.
*
* I:A Index of planet (1 based, 0 = undraw)
display_planet:                        ; >9175
       ab   a,a                        ; ADD A,A           ; a *= 2
       jeq  erase_planet               ; JR Z,$91A1        ; If zero then undraw planet
       li   hl,planet_table-2          ; LD HL,$9396       ; Planet table minus 2: #R$9398-2
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
;       movb *hl,@e                     ; LD E,(HL)         ; Get LSB of planet data
;       inc  hl                         ; INC HL            ;
;       movb *hl,d                      ; LD D,(HL)         ; Get MSB of planet data
       mov  *hl,de
       .ex_de_hl                       ; EX DE,HL          ; Address now in HL
       .call @display_planet_name_table ; CALL $91B4        ; Draw to name table
       .call @display_planet_name_and_sprites ; CALL $91CC        ;
       li   hl,>0400                   ; LD HL,$0400       ;
       .call @copy_135_patterns        ; CALL $9285        ;
       li   hl,planet_colors           ; LD HL,$96EE       ; Planet colors
       li   de,>2010                   ; LD DE,$2010       ; Address in color table
       li   bc,>0010                   ; LD BC,$0010       ; 16 color sets
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       li   de,>0900                   ; LD DE,$0900       ; Address in sprite pattern table
       li   hl,planet_sprite_patterns  ; LD HL,$96FE       ; Sprite patterns
       li   bc,>0098                   ; LD BC,$0098       ; 19 patterns
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       .ret                            ; RET               ;

* Erase planet
*
* Used by the routine at #R$9175.
erase_planet:                          ; >91a1
       .call @clear_row_7              ; CALL $920D        ; Clear row 7
       li   hl,buffer                  ; LD HL,$71A3       ; Clear 16 bytes in RAM
       li   de,buffer+>0001            ; LD DE,$71A4       ; ...
       li   bc,>000f                   ; LD BC,$000F       ; ...
       sb   *hl,*hl                    ; LD (HL),$00       ; ...
       .ldir                           ; LDIR              ; ...
       li   hl,buffer                  ; LD HL,$71A3       ; Use cleared bytes as planet data
* This entry point is used by the routine at #R$9175.
display_planet_name_table:             ; >91b4
       li   de,>194e                   ; LD DE,$194E       ; Address in name table
       movb @bytes+>04,@c              ; LD C,$04          ; 4 rows
_91b9:                                 ; >91b9
       movb @bytes+>04,b               ; LD B,$04          ; 4 columns
_91bb:                                 ; >91bb
       movb *hl,a                      ; LD A,(HL)         ; Get name to write
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next destination
       inc  hl                         ; INC HL            ; Next source
       sb   one,b                      ; DJNZ $91BB        ; Loop for 4 columns
       jne  _91bb                      ;
       .push hl                        ; PUSH HL           ; Save source
       li   hl,>001c                   ; LD HL,$001C       ; 32 - 4
       a    de,hl                      ; ADD HL,DE         ; One row down
       .ex_de_hl                       ; EX DE,HL          ; To DE
       .pop hl                         ; POP HL            ; Restore source
       sb   one,@c                     ; DEC C             ; Row counter
       jne  _91b9                      ; JR NZ,$91B9       ; Loop for 4 rows
       .ret                            ; RET               ;

* Display planet name and sprites
*
* Used by the routine at #R$9175.
*
* I:HL Address of planet name prefixed by length
display_planet_name_and_sprites:       ; >91cc
       .push hl                        ; PUSH HL           ; Save address
       .call @clear_row_7              ; CALL $920D        ; clear_row_7 where the planet name is displayed
       movb @bytes+>20,a               ; LD A,$20          ; 32
       sb   *hl,a                      ; SUB (HL)          ; 32 - length
       srl  a,1                        ; SRL A             ; (32 - length) / 2
       li   de,>18e0                   ; LD DE,$18E0       ; Name table address of row
       .ex_de_hl                       ; EX DE,HL          ;
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
       .ex_de_hl                       ; EX DE,HL          ; DE = display address
       movb *hl,@c                     ; LD C,(HL)         ; Get length
       sb   b,b                        ; LD B,$00          ;
       inc  hl                         ; INC HL            ; Advance source to text
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       .pop hl                         ; POP HL            ; Restore address
       movb *hl,a                      ; LD A,(HL)         ; Get length
       ab   one,a                      ; INC A             ; Length + 1
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL. Now HL points after text.
       movb *hl,b                      ; LD B,(HL)         ; Get number of sprites
       inc  hl                         ; INC HL            ; Next source byte
       movb *hl,@c                     ; LD C,(HL)         ; Get color
       inc  hl                         ; INC HL            ; Next source byte
       movb *hl,a                      ; LD A,(HL)         ; Get pattern?
       ab   @bytes+>20,a               ; ADD A,$20         ; Add 32
       movb a,@e                       ; LD E,A            ; Store in E
       inc  hl                         ; INC HL            ; Next source byte
_91ed:                                 ; >91ed
       bl   @allocate_sprite           ; RST $28           ; Allocate sprite
       sb   *ix,*ix                    ; LD (IX+$00),$00   ; Mark as allocated (set type)
       movb *hl,a                      ; LD A,(HL)         ; Get y
       movb a,d                        ; LD D,A            ; Store in D
       andi a,>7f00                    ; AND $7F           ; Only use 7 bits of y
       movb a,@>08(ix)                 ; LD (IX+$08),A     ; Set y
       inc  hl                         ; INC HL            ; Next source byte
       movb *hl,a                      ; LD A,(HL)         ; Get x
       movb a,@>09(ix)                 ; LD (IX+$09),A     ; Set x
       inc  hl                         ; INC HL            ; Next source byte
       movb @e,@>0a(ix)                ; LD (IX+$0A),E     ; Set pattern
       movb @c,@>0b(ix)                ; LD (IX+$0B),C     ; Set color
       movb d,r0                       ; BIT 7,D           ; If bit 7 of y is set
       andi r0,>8000                   ;
       jne  _920a                      ; JR NZ,$920A       ; Then skip
       ab   one,@e                     ; INC E             ; Else increment pattern
_920a:                                 ; >920a
       sb   one,b                      ; DJNZ $91ED        ; Loop to next sprite
       jne  _91ed                      ;
       .ret                            ; RET               ;

* Clear name table row 7
*
* Where the planet name is displayed Used by the routines at #R$832A, #R$90D6,
* #R$91A1 and #R$91CC.
clear_row_7:                           ; >920d
       .push hl                        ; PUSH HL           ;
       .push de                        ; PUSH DE           ;
       .push bc                        ; PUSH BC           ;
       sb   a,a                        ; LD A,$00          ; Space
       li   hl,>18e0                   ; LD HL,$18E0       ; Address in name table (row 7)
       li   de,>0020                   ; LD DE,$0020       ; 32 bytes
       bl   @fill_vram                  ; CALL $1F82        ; FILL_VRAM
       .pop bc                         ; POP BC            ;
       .pop de                         ; POP DE            ;
       .pop hl                         ; POP HL            ;
       .ret                            ; RET               ;

* Decompress and upload patterns
*
* Decompress and upload patterns to VDP buffer at $1400. Used by the routine at
* #R$90D6.
decompress_patterns:                   ; >921f
       li   hl,>0279                   ; LD HL,$0279       ; Number of bytes in block at $9475
       mov  hl,@decompress_length      ; LD ($726A),HL     ; Save it
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@decompress_bits_left    ; LD ($726C),A      ; Save it
       li   hl,planet_graphics-1       ; LD HL,$9474       ; #R$9475 - 1
       li   de,>1400                   ; LD DE,$1400       ; Destination address in VDP RAM
* This entry point is used by the routine at #R$924E.
_922f:                                 ; >922f
;       movb @decompress_length,a       ; LD A,($726B)      ; MSB of counter
;       socb a,a                        ; OR A              ; Test MSB
       mov  @decompress_length,r0
       jgt  !                          ; RET M             ; Return when MSB is negative
       .ret                            ;
!
       movb one,b                      ; LD B,$01          ; Read 1 bit
       .call @read_B_bits_into_a       ; CALL $9257        ; Read it into A
;       socb a,a                        ; OR A              ; If zero, write multiple bytes
       movb a,a
       jne  decompress_write_single_byte ; JR NZ,$924E       ; Otherwise jump to write a single byte
       movb @bytes+>05,b               ; LD B,$05          ; Read 5 bits
       .call @read_B_bits_into_a       ; CALL $9257        ; Read them into A
       ab   @bytes+>02,a               ; ADD A,$02         ; Add 2 as the base
       .push af                        ; PUSH AF           ; Save number of repeats
       .call @read_8_bits_into_a       ; CALL $9255        ; Get byte to write in A
       .pop bc                         ; POP BC            ; Restore number of repeats
_9248:                                 ; >9248
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte in A to DE
       inc  de                         ; INC DE            ; Next VDP address
       sb   one,b                      ; DJNZ $9248        ; Loop B times
       jne  _9248                      ;
       jmp  _922f                      ; JR $922F          ; Loop

* Write single byte
*
* Used by the routine at #R$921F.
decompress_write_single_byte:          ; >924e
       .call @read_8_bits_into_a       ; CALL $9255        ; Get byte to write
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte in A to DE
       inc  de                         ; INC DE            ; Next VDP address
       jmp  _922f                      ; JR $922F          ; Loop

* Read B bits into A
*
* Used by the routines at #R$921F and #R$924E.
read_8_bits_into_a:                    ; >9255
       movb @bytes+>08,b               ; LD B,$08          ; Read 8 bits
* This entry point is used by the routine at #R$921F.
read_B_bits_into_a:                    ; >9257
       sb   a,a                        ; XOR A             ; Result
_9258:                                 ; >9258
       .push bc                        ; PUSH BC           ; Push number of bits to read
       .push af                        ; PUSH AF           ; Push result
       movb @decompress_bits_left,a    ; LD A,($726C)      ; Number of bits left in current byte
       sb   one,a                      ; DEC A             ; Decrement
       jgt  _9271                      ; JP P,$9271        ; Skip ahead if there are still bits left
       jeq  _9271                      ; JP P,$9271        ; Skip ahead if there are still bits left
       inc  hl                         ; INC HL            ; Increment source address
       movb *hl,a                      ; LD A,(HL)         ; get source byte
       movb a,@decompress_source_byte  ; LD ($726D),A      ; Save source byte
;       mov  @decoder_length,bc         ; LD BC,($726A)     ; Byte counter
;       dec  bc                         ; DEC BC            ; Decrement
;       mov  bc,@decoder_length         ; LD ($726A),BC     ; And save
       dec  @decompress_length
       movb @bytes+>07,a               ; LD A,$07          ; 8 bits - 1 left
_9271:                                 ; >9271
       movb a,@decompress_bits_left    ; LD ($726C),A      ; Save bits left
;       movb @decoder_source_byte,a     ; LD A,($726D)      ; Get source byte
;       sla  a,1                        ; RLA               ; Rotate left through carry
;       movb a,@decoder_source_byte     ; LD ($726D),A      ; Save again
;       sla  b,1                        ; RL B              ; Rotate carry into bite 0
;       .pop af                         ; POP AF            ; Pop result
;       sra  b,1                        ; RR B              ; Rotate bit 0 into carry
;       sla  a,1                        ; RLA               ; Rotate carry into result
       .pop af
       movb @decompress_source_byte,@f
       sla  a,1
       movb @f,@decompress_source_byte
       .pop bc                         ; POP BC            ; Pop number of bits to read
       sb   one,b                      ; DJNZ $9258        ; Repeat for n bits
       jne  _9258                      ;
       .ret                            ; RET               ;

* Copy 135 patterns
*
* Copy 135 patterns from VDP RAM buffer into pattern table from 128 Used by the
* routine at #R$9175.
*
* I:HL Pattern generator table destination address ($0400)
copy_135_patterns:                     ; >9285
       li   de,>1400                   ; LD DE,$1400       ;
       movb @bytes+>0e,b               ; LD B,$0E          ; Counter
_928a:                                 ; >928a
       .push bc                        ; PUSH BC           ;
       .push de                        ; PUSH DE           ;
       .push hl                        ; PUSH HL           ;
       li   bc,>0048                   ; LD BC,$0048       ; Read 9 patterns from $1400 (?)
       li   hl,buffer                  ; LD HL,$71A3       ; Into buffer
       bl   @read_vram                 ; CALL $1FE2        ; READ_VRAM
       .pop de                         ; POP DE            ; DE = $0400
       .push de                        ; PUSH DE           ;
       li   bc,>0048                   ; LD BC,$0048       ; Write 9 patterns from buffer
       li   hl,buffer                  ; LD HL,$71A3       ; To $0400 (pattern 128)
       bl    @write_vram               ; RST $38           ; WRITE_VRAM
       .pop hl                         ; POP HL            ; HL = $0400
       li   bc,>0048                   ; LD BC,$0048       ;
       a    bc,hl                      ; ADD HL,BC         ; Advance 9 patterns, HL = $0448
       .pop de                         ; POP DE            ; DE = $1400
       .ex_de_hl                       ; EX DE,HL          ;
       a    bc,hl                      ; ADD HL,BC         ;
       .ex_de_hl                       ; EX DE,HL          ; DE = $1448
       .pop bc                         ; POP BC            ;
       sb   one,b                      ; DJNZ $928A        ; Loop 15 times = 135 patterns
       jne  _928a                      ;
       .ret                            ; RET               ;

