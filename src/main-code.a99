;       movb @>05(ix),a                 ; LD A,(IX+$05)     ; Get polar x (saved by #R$ADC7?)
;       srl  a,1                        ; RRA               ; / 2
;       andi a,>1e00                    ; AND $1E           ; 0, 2, 4 ... $1E
;       li   hl,exhaust_position_table+>0002 ; LD HL,$AFDF       ; #R$AFDD+2
;       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
;_ae3f:                                 ; >ae3f
