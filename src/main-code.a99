;       inc  hl                         ; INC HL            ; Next table address
;       movb @sprite_data+>0009,a       ; LD A,($700B)      ; Ship screen x
;       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
;       movb a,@>09(ix)                 ; LD (IX+$09),A     ; Set x
;* This entry point is used by the routines at #R$AE54 and #R$AE75.
;_ae4e:                                 ; >ae4e
;       .pop iy                         ; POP IY            ;
