* Ship exhaust position relative to ship body
exhaust_position_table:                ; >afdd
       byte >00,>00,>08,>00,>06,>FF,>06,>FB
       byte >05,>FB,>00,>F9,>FF,>FA,>FB,>FB
       byte >FC,>FB,>F9,>00,>FA,>01,>FB,>05
       byte >FB,>05,>00,>07,>01,>05,>05,>05
       byte >05,>06

* Display stars
*
* Used by the routines at #R$8024, #R$8139, #R$8170, #R$832A, #R$832A, #R$846B,
* #R$90D6, #R$A33B and #R$A3E1.
display_stars:                         ; >afff
       li   hl,stars_countdown         ; LD HL,$71EC       ; Counter from 7 to 0
       sb   one,*hl                    ; DEC (HL)          ; Count down
       jlt  !                          ; RET P             ; Return
       .ret                            ;
!
       movb @bytes+>07,*hl             ; LD (HL),$07       ; Reset counter to 7
       movb @status_flags,a            ; LD A,($71EB)      ; Test warp flag
       czc  @bit0,a                    ; BIT 0,A           ; ...
       jeq  display_stars_1            ; JR Z,$B00F        ; If bit 0 is set then reset counter to 3
       movb @bytes+>02,*hl             ; LD (HL),$03       ; ...
display_stars_1:                       ; >b00f
       movb @b255,@c                   ; LD C,$00          ; Set mask to undraw (swapped since we use szcb)
       .call @display_star_frame       ; CALL $B023        ;
       movb @star_frame,a              ; LD A,($731A)      ; Get star frame
       ab   @bytes+>02,a               ; ADD A,$02         ; Add 2
       cb   a,@bytes+>0c               ; CP $0C            ; < 12 ?
       jl   display_stars_2            ; JR C,$B01E        ; Yes, skip ahead
       sb   a,a                        ; XOR A             ;
display_stars_2:                       ; >b01e
       movb a,@star_frame              ; LD ($731A),A      ; Set star frame to zero
       sb   @c,@c                      ; LD C,$FF          ; Set mask to draw (swapped since we use szcb)

* Display star frame
*
* Used by the routine at #R$AFFF.
*
* I:C Mask $00 or $FF
display_star_frame:                    ; >b023
       movb @star_frame,a              ; LD A,($731A)      ; 0, 2, 4, 6, 8, 10
       li   hl,star_frame_lookup       ; LD HL,$B04F       ; Table of pointers
       bl   @add_a_to_hl               ; RST $08           ; Add A to HL
;       movb *hl,@e                     ; LD E,(HL)         ; Get LSB
;       inc  hl                         ; INC HL            ;
;       movb *hl,d                      ; LD D,(HL)         ; Get MSB
       mov  *hl,de
       mov  @name_table_vdp_address,hl ; LD HL,($73F6)     ; Get VDP address (always 0)
       .ex_de_hl                       ; EX DE,HL          ; Now HL holds address of star frame table to use
display_star_frame_1:                  ; >b031
       movb *hl,a                      ; LD A,(HL)         ; Get byte from table
;       socb a,a                        ; OR A              ;
       jne  !                          ; RET Z             ; Zero terminates
       .ret                            ;
!
       jlt  display_star_frame_4       ; JP M,$B046        ; If bit 7 is set it's a change of VDP address
       bl   @vdp_read_byte             ; CALL $9AD0        ; vdp_read_byte from DE
       cb   a,@bytes+>18               ; CP $18            ; >= 18
       jhe  display_star_frame_2       ; JR NC,$B041       ; Then skip writing
       movb *hl,a                      ; LD A,(HL)         ; Get byte from table
       szcb @c,a                       ; AND C             ; Apply mask
       bl   @vdp_write_byte            ; RST $10           ; Write VDP byte A to DE
display_star_frame_2:                  ; >b041
       inc  de                         ; INC DE            ; Next VDP address
display_star_frame_3:                  ; >b042
       inc  hl                         ; INC HL            ; Next table address
       b    @display_star_frame_1      ; JP $B031          ; Loop
display_star_frame_4:                  ; >b046
       andi a,>7f00                    ; AND $7F           ; Reset bit 7
;       ab   @e,a                       ; ADD A,E           ; Add VDP address LSB
;       movb a,@e                       ; LD E,A            ; Write back to E
;       jnc  _b042                      ; JR NC,$B042       ; Loop if no carry
;       ab   one,d                      ; INC D             ; Increment MSB if carry
       swpb a
       a    a,de
       jmp  display_star_frame_3                      ; JR $B042          ; Loop

* Convert polar to screen coordinates
*
* Used by the routines at #R$8F0F, #R$8F55, #R$A471, #R$AB72 and #R$ADD1.
*
* I:IX Pointer to sprite data
* I:D Polar y
* I:E Polar x
* O:D Screen y
* O:E Screen x
* O:Carry flag set if out of screen
polar_to_screen:                       ; >b1c6
       clr  @carry
       movb @bytes+>0b,a               ; LD A,$0B          ; 11
       ab   d,a                        ; ADD A,D           ; Polar y + 11
       jlt  polar_to_screen_5          ; JP M,$B217        ; If this is 128 or more (polar y > 116 or polar y <
                                                           ; -11), then set position outside screen and return
       movb a,@r1lb                    ; LD L,A            ; Calculate table address, with polar y = -11
                                                           ; corresponding to row 0
       sb   r1,r1                        ; LD H,$00          ; and polar y = 0 corresponding to row 11
;       a    hl,hl                      ; ADD HL,HL         ; (y + 11) * 32
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       a    hl,hl                      ; ADD HL,HL         ; ...
;       a    hl,hl                      ; ADD HL,HL         ; ...
       sla  r1,5
       movb @e,a                       ; LD A,E            ; x
       czc  @bit4,a                    ; BIT 4,E           ; Is bit 4 set (top left or lower right quadrants)?
       jeq  polar_to_screen_1          ; JR Z,$B1DE        ; Jump if not
       inv  a                          ; CPL               ; Else invert (0 -> 15, 1 -> 14, etc.)
polar_to_screen_1:                     ; >b1de
       andi a,>0f00                    ; AND $0F           ; Use the first 4 inverted bits
       ab   a,a                        ; ADD A,A           ; x2 (2 bytes per x)
;       ab   @l,a                       ; ADD A,L           ; Add to address
;       movb a,@l                       ; LD L,A            ; ...
;       jnc  _b1e6                      ; JR NC,$B1E6       ; ...
;       ab   one,h                      ; INC H             ; ...
;_b1e6:                                 ; >b1e6
       swpb a
       a    a,r1
;       li   bc,polar_to_screen_table   ; LD BC,$B21D       ; Lookup table base address
;       a    bc,hl                      ; ADD HL,BC         ; Add to address
       ai   r1,polar_to_screen_table
       movb *r1,a                      ; LD A,(HL)         ; Get table value
       cb   a,@b255                    ; CP $FF            ; If $FF
       jeq  polar_to_screen_5          ; JR Z,$B217        ; Then set position outside screen and return
;      li   ix,center_of_projection    ; LD IX,$7000       ; Center of projection
       movb @e,a                       ; LD A,E            ; x
       movb a,r0
       srl  a,1                        ; RRCA              ; Shift right
       ; XOR E                         ; XOR E             ; Bit 4 is now set if bit 5 (left/right) and bit 4 (top
       xor  r0,a                                           ; left/lower right) were different, i.e. top of screen
       movb a,r0                       ; BIT 4,A           ; Test bit 4 (top of screen)
       clr  af
       movb *r1+,a                     ; LD A,(HL)         ; Get table value
       czc  @bit4,r0
       jeq  polar_to_screen_2          ; JR Z,$B1FD        ; Skip negating if not top of screen
;       andi af,>ff00
       neg a                           ; NEG               ; -table value
polar_to_screen_2:                     ; >b1fd
;      ab   @>01(ix),a                 ; ADD A,(IX+$00)    ; +center y ($60) (changed since high endian)
       ab   @center_of_projection+1,a  ; ADD A,(IX+$00)    ; +center y ($60) (changed since high endian)
       sb   @bytes+>04,a               ; SUB $04           ; -4 (adjust for sprite size)
       movb a,d                        ; LD D,A            ; Store as sprite y
;       inc  hl                         ; INC HL            ; Next table address
       movb *r1,a                      ; LD A,(HL)         ; Get table value
       czc  @bit5l,de                  ; BIT 5,E           ; Test bit 5 of x (left/right)
       jne  polar_to_screen_3          ; JR NZ,$B20B       ; Skip negating if right
;       andi af,>ff00
       neg a                           ; NEG               ; -table value
polar_to_screen_3:                     ; >b20b
;       ab   *ix,a                      ; ADD A,(IX+$01)    ; +center x ($80 or $B5 or ?) (changed since high endian)
       ab   @center_of_projection,a
       sb   @bytes+>04,a               ; SUB $04           ; -4 (adjust for sprite size)
       movb a,@e                       ; LD E,A            ; Store as sprite x
;       socb a,a                        ; OR A              ; Clear carry flag
       jmp  polar_to_screen_4          ; JR $B212          ; To return
polar_to_screen_5:                     ; >b217
       li   de,>f500                   ; LD DE,$F500       ; Set return position outside screen
       seto @carry                     ; SCF               ; Set carry flag
polar_to_screen_4:                      ; >b212
       rt                            ; RET               ; ...

;* Random number generator (RST $20)
;*
;* Used by the routine at #R$8015.
;rnd:                                   ; >bfae
;       .push ix                        ; PUSH IX           ;
;       li   ix,random_number           ; LD IX,$731B       ; Last random number
;       movb *ix,a                      ; LD A,(IX+$00)     ; Get byte 0
;       sla  a,1                        ; RLCA              ; Rotate left
;       ; XOR (IX+$00)                  ; XOR (IX+$00)      ; Flip some bits
;       movb @1(ix),r0
;       xor  r0,a
;       srl  a,1                        ; RRCA              ; Rotate right
;       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment byte 1
;       ab   @>01(ix),a                 ; ADD A,(IX+$01)    ; Add byte 1
;       ; AND A                         ; AND A             ; Set flags
;       ; JP PE,$BFC9                   ; JP PE,$BFC9       ; Skip ahead if even parity
;       jop  !
;       jmp  rnd_1
;!      ab   one,@>01(ix)               ; INC (IX+$01)      ; Else increment byte 1
;rnd_1:                                 ; >bfc9
;       movb a,*ix                      ; LD (IX+$00),A     ; Set byte 0
;       .pop ix                         ; POP IX            ;
;       rt                              ; RET               ;
