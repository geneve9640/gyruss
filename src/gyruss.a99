       a    de,hl                      ; ADD HL,DE         ; ...
       sb   one,@c                     ; DEC C             ; Row counter
       jne  _8bc6                      ; JR NZ,$8BC6       ; Outer loop for 3 bytes
       .ret                            ; RET               ; 

* Manage waves
* 
* Used by the routine at #R$80E8.
manage_waves:                          ; >8bd9
       movb @status_flags,a            ; LD A,($71EB)      ; Check bit for all waves completed
       movb a,r0                       ; BIT 1,A           ; ...
       andi r0,>0200                   ;                   
       jeq  !                          ; RET NZ            ; Return if set
       .ret                            ;                   
!
       movb @outcoming_enemies,a       ; LD A,($725C)      ; Outcoming enemies
       socb a,a                        ; OR A              ; Is it zero?
       jeq  !                          ; JP NZ,$8C68       ; If not, jump ahead to add enemy
       b    @handle_wave_outcoming     ;                   
!
       movb @active_enemies,a          ; LD A,($722C)      ; Get active enemies
       socb a,a                        ; OR A              ; Return if not zero
       jeq  !                          ; RET NZ            ; ...
       .ret                            ;                   
!
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       andi a,>0300                    ; AND $03           ; 3 of 4 times,
       jne  _8bfc                      ; JR NZ,$8BFC       ; skip ahead
       movb @countdown_to_wave,a       ; LD A,($71F0)      ; Get counter value
       sb   one,a                      ; DEC A             ; Decrement value
       jgt  !                          ; JP M,$8BFC        ; If negative, skip ahead
       b    @_8bfc                     ;                   
!
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; Save counter again
_8bfc:                                 ; >8bfc
       movb @wave,a                    ; LD A,($7201)      ; Get wave
       cb   a,@bytes+>04               ; CP $04            ; Compare to 4
       jl   manage_wave_lt_4           ; JR C,$8C30        ; If < 4, jump ahead
       jeq  manage_wave_eq_4           ; JR Z,$8C07        ; If = 4, jump ahead
       jmp  init_mine_sub_stage        ; JR $8C1E          ; If > 4, jump ahead

* Manage wave = 4
* 
* Used by the routine at #R$8BD9.
manage_wave_eq_4:                      ; >8c07
       movb @status_flags,a            ; LD A,($71EB)      ; Test for chance stage
       movb a,r0                       ; BIT 3,A           ; ...
       andi r0,>0800                   ;                   
       jne  init_mine_sub_stage        ; JR NZ,$8C1E       ; If set, set bit for all waves completed
       movb @center_map_entries,a      ; LD A,($722B)      ; Number of center enemies
       cb   a,@bytes+>06               ; CP $06            ; If >= 6,
       jhe  init_mine_sub_stage        ; JR NC,$8C1E       ; Then init mine sub-stage
       .rst >20                        ; RST $20           ; Random number
