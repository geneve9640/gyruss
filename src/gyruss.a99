* { #UDGARRAY8,,4($909E-$90D5-16)(graphics-909E.png) }
* TABLE#
mine_graphics:                         ; >9096
       byte >00,>02,>01,>21,>17,>0D,>17,>17
       byte >1B,>75,>0B,>06,>03,>04,>08,>00
       byte >00,>00,>08,>90,>E0,>F0,>F8,>F8
       byte >FE,>F8,>70,>E0,>90,>08,>00,>00
       byte >00,>08,>04,>03,>07,>0D,>77,>17
       byte >1B,>15,>0B,>06,>09,>10,>00,>00
