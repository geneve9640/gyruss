sat_vdp_address:                       ; >73f2
       data >0000

* Sprite pattern table VDP address
       data >0000

* Name table VDP address
name_table_vdp_address:                ; >73f6
       data >0000

* OS RAM
       bss 8

* Unused
       bss 3072

* ROM header
       byte >55,>AA

* Pointer to sprite name table
       data >0000

* Pointer to sprite order table
       data sprite_allocation_table

* Pointer to temporary storage in RAM
       data buffer

* Pointer to controller memory map
       data >0000

* Pointer to start address
       data entry

* RST $08
_800c:                                 ; >800c
       b    @add_a_to_hl               ; JP $9AB3          ; Add A to HL

* RST $10
_800f:                                 ; >800f
       b    @vdp_write_byte            ; JP $9AC3          ; Write VDP byte (DE = address, A = value)

* RST $18
       b    @write_register            ; JP $1FD9          ; WRITE_REGISTER (B = reg, C = value)

* RST $20
_8015:                                 ; >8015
       b    @rnd                       ; JP $BFAE          ; Random number generator

* RST $28
_8018:                                 ; >8018
       b    @allocate_sprite           ; JP $AD49          ; Allocate_sprite

* RST $30
_801b:                                 ; >801b
       b    @load_sprite_pattern       ; JP $AD8B          ; Load sprite pattern

* RST $38
       b    @write_vram                ; JP $1FDF          ; WRITE_VRAM (HL = source, DE = dest, BC = count)

* NMI
_8021:                                 ; >8021
       b    @interrupt_routine         ; JP $8501          ; Interrupt routine

       aorg >a000

* Entry point
entry:                                 ; >8024
       li   sp,_73ba                   ; LD SP,$73BA       ; Init stack pointer
       ; OUT ($C0),A                   ; OUT ($C0),A       ; TODO: check code. Controller enable
       li   hl,center_of_projection    ; LD HL,$7000       ; Clear RAM
       li   de,center_of_projection+>0001 ; LD DE,$7001       ; #R$7000+1
       li   bc,>03b9                   ; LD BC,$03B9       ; ...
       movb @l,*hl                     ; LD (HL),L         ; ...
       .ldir                           ; LDIR              ; ...
       li   hl,entry_wait_fire+>0019   ; LD HL,$8060       ; Set center of projection
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       .call @init_sound               ; CALL $9ADE        ; Init sound
       .call @start_screen             ; CALL $90D6        ; Start screen
       li   hl,write_vram+>0a51        ; LD HL,$2A30       ; 180 * 60 frames
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Set screensaver countdown
entry_wait_fire:                       ; >8047
       .halt                           ; HALT              ; Wait for interrupt
       .call @display_stars            ; CALL $AFFF        ; Display stars
       li   hl,>0000                   ; LD HL,$0000       ; Controller 0, segment 0
       .call @decoder                  ; CALL $1F79        ; DECODER
       movb h,r0                       ; BIT 6,H           ; Test fire
       andi r0,>4000                   ;                   
       jne  new_game                   ; JR NZ,$8064       ; Jump if fire pressed
       li   hl,>0100                   ; LD HL,$0100       ; Controller 1, segment 0
       .call @decoder                  ; CALL $1F79        ; DECODER
       movb h,r0                       ; BIT 6,H           ; Test fire
       andi r0,>4000                   ;                   
       jeq  entry_wait_fire            ; JR Z,$8047        ; Loop until fire pressed
       li   hl,status_flags            ; LD HL,$71EB       ; Set two-player flag
       socb @bits+7,*hl                ; SET 7,(HL)        ; ...
* This entry point is used by the routine at #R$81ED. Fire pressed
new_game:                              ; >8064
       li   hl,>0000                   ; LD HL,$0000       ; 
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Clear screensaver countdown
       li   hl,>1800                   ; LD HL,$1800       ; Name table address
       li   de,>0300                   ; LD DE,$0300       ; Name table size
       sb   a,a                        ; XOR A             ; Zero
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM (clear screen)
       li   hl,write_vram+>003d        ; LD HL,$201C       ; Last 4 bytes of color table
       li   de,>0004                   ; LD DE,$0004       ; 4 bytes
       movb @bytes+>f1,a               ; LD A,$F1          ; Set to white/black
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       li   hl,current_player          ; LD HL,$71F1       ; Clear RAM  from $71F1
       li   de,frame_counter           ; LD DE,$71F2       ; To $7256
       sb   a,a                        ; XOR A             ; ...
       movb a,*hl                      ; LD (HL),A         ; ...
       li   bc,>0065                   ; LD BC,$0065       ; ...
       .ldir                           ; LDIR              ; ...
       movb @status_flags,a            ; LD A,($71EB)      ; Clear all but two-player flag
       andi a,>8000                    ; AND $80           ; ...
       movb a,@status_flags            ; LD ($71EB),A      ; ...
       movb @bytes+>05,a               ; LD A,$05          ; 5 Lives
       movb a,@lives                   ; LD ($71FF),A      ; Set lives
       ab   one,a                      ; INC A             ; Increment to 6
       movb a,@score_extra_life_1_msb  ; LD ($71F8),A      ; Set #R$71F6+2 to 6 (extra life at 60000)
       movb a,@score_extra_life_2_msb  ; LD ($71FE),A      ; Set #R$71FC+2 to 6 (extra life at 60000)
       movb one,a                      ; LD A,$01          ; Stage
       movb a,@stage                   ; LD ($7200),A      ; Set to 1
       .call @init_center_enemies      ; CALL $AA7D        ; Init variables
       li   hl,stage_msg               ; LD HL,$853C       ; Display stage message
       li   de,>1af8                   ; LD DE,$1AF8       ; ...
       li   bc,>0005                   ; LD BC,$0005       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       li   de,>1802                   ; LD DE,$1802       ; Display '1' at the top left corner
_80b5:                                 ; >80b5
       movb @bytes+>31,a               ; LD A,$31          ; ...
       .rst >10                        ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Display '-' next to '1'
       movb @bytes+>2d,a               ; LD A,$2D          ; ...
       .rst >10                        ; RST $10           ; Write VDP byte
       sb   a,a                        ; XOR A             ; Parameter to display score
       .call @display_score            ; CALL $A699        ; Display score player 1
       movb @status_flags,a            ; LD A,($71EB)      ; Flags
       movb a,r0                       ; BIT 7,A           ; Test bit for two players
       andi r0,>8000                   ;                   
       jeq  _80e0                      ; JR Z,$80E0        ; If bit is reset then skip ahead
       li   de,>181e                   ; LD DE,$181E       ; Display '-' at the top right corner
       movb @bytes+>2d,a               ; LD A,$2D          ; ...
       .rst >10                        ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Display '2' next to '-'
       movb @bytes+>32,a               ; LD A,$32          ; ...
       .rst >10                        ; RST $10           ; Write VDP byte
       movb one,a                      ; LD A,$01          ; 
       .call @display_score            ; CALL $A699        ; Display score player 2
       li   hl,lives                   ; LD HL,$71FF       ; Save player data in VDP RAM, starting with lives?
       li   de,>1300                   ; LD DE,$1300       ; VDP address
       li   bc,>002d                   ; LD BC,$002D       ; 45 bytes
       .rst >38                        ; RST $38           ; WRITE_VRAM
_80e0:                                 ; >80e0
       movb r,a                        ; LD A,R            ; Random number seed
       movb a,@random_number+>0001     ; LD ($731C),A      ; Init random number
       .call @init_stage               ; CALL $8212        ; Initialize stage

* Main loop
* 
* Used by the routines at #R$81AE and #R$83D0.
main_loop:                             ; >80e8
       li   hl,interrupt_flag          ; LD HL,$725A       ; Flag set by interrupt routine
_80eb:                                 ; >80eb
       movb *hl,r0                     ; BIT 0,(HL)        ; Test flag
       andi r0,>0100                   ;                   
       jeq  _80eb                      ; JR Z,$80EB        ; Wait until set
       szcb @bits+0,*hl                ; RES 0,(HL)        ; Clear flag
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER (read VDP status)
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       .call @handle_collisions        ; CALL $9796        ; Handle collisions
       .call @create_or_display_mines  ; CALL $8E2D        ; 
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       .call @manage_waves             ; CALL $8BD9        ; Manage waves
       .call @create_sprite_from_map_entry ; CALL $AAF1        ; Create sprite from map entry
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       .call @create_laser_fence_or_meteor ; CALL $8D50        ; Create laser fence
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       .call @display_score            ; CALL $A699        ; Display score
       movb @status_flags,a            ; LD A,($71EB)      ; Status flags
       movb a,r0                       ; BIT 2,A           ; Test bit 2
       andi r0,>0400                   ;                   
       jeq  !                          ; JP NZ,$8139       ; Exit main loop if set
       b    @died                      ;                   
!
       movb a,r0                       ; BIT 1,A           ; Test bit 1
       andi r0,>0200                   ;                   
       jeq  main_loop                  ; JR Z,$80E8        ; Loop if not set
       movb @total_enemies,a           ; LD A,($7206)      ; Get total enemies
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Add enemy shots
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       jne  !                          ; JP Z,$832A        ; Stage completed when sum is zero
       b    @stage_completed           ;                   
!
       jmp  main_loop                  ; JR $80E8          ; Loop

* Died
* 
* Used by the routine at #R$80E8.
died:                                  ; >8139
       .call @stop_tune                ; CALL $9B87        ; Stop tune
       movb @bytes+>03,a               ; LD A,$03          ; Play explosion sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Reset main loop flag
       szcb @bits+6,*hl                ; RES 6,(HL)        ; ...
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       .call @reset_enemy_sprite_types ; CALL $8AE6        ; Update sprite types $0F - $11
       .call @explode                  ; CALL $A3E1        ; Explosion
_814f:                                 ; >814f
       movb @active_enemies,a          ; LD A,($722C)      ; Get active enemies
       socb a,a                        ; OR A              ; 
       jne  _815e                      ; JR NZ,$815E       ; 
       movb @total_enemies,a           ; LD A,($7206)      ; Get total enemies
       li   hl,center_map_entries      ; LD HL,$722B       ; 
       cb   a,*hl                      ; CP (HL)           ; 
       jeq  lose_life                  ; JR Z,$8170        ; 
_815e:                                 ; >815e
       .halt                           ; HALT              ; 
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @create_or_display_mines  ; CALL $8E2D        ; 
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       jmp  _814f                      ; JR $814F          ; 

* Lose life
* 
* Used by the routine at #R$8139.
lose_life:                             ; >8170
       .call @reset_outcoming_enemies  ; CALL $8D21        ; Reset outcoming enemies
       li   hl,stage_death_count       ; LD HL,$7204       ; Increase number of times died within stage
       ab   one,*hl                    ; INC (HL)          ; ...
       li   hl,lives                   ; LD HL,$71FF       ; Lives
       sb   one,*hl                    ; DEC (HL)          ; Lose life
       jne  switch_player              ; JR NZ,$81AE       ; Jump if lives left
* Game over
       li   de,>1c00                   ; LD DE,$1C00       ; 
       movb @bytes+>d0,a               ; LD A,$D0          ; 
       .rst >10                        ; RST $10           ; Write VDP byte
       .call @display_player           ; CALL $830E        ; Display player
       li   hl,game_over_msg           ; LD HL,$85DD       ; Display GAME OVER
       li   de,>19cb                   ; LD DE,$19CB       ; ...
       li   bc,>0009                   ; LD BC,$0009       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       sb   b,b                        ; LD B,$00          ; Stars for 256 frames
_8192:                                 ; >8192
       .push bc                        ; PUSH BC           ; ...
       .halt                           ; HALT              ; ...
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .pop bc                         ; POP BC            ; ...
       sb   one,b                      ; DJNZ $8192        ; ...
       jne  _8192                      ;                   
       .call @clear_rows_9_and_14      ; CALL $84ED        ; Clear rows 9 and 14
       li   hl,status_flags            ; LD HL,$71EB       ; Test for two players
       movb *hl,r0                     ; BIT 7,(HL)        ; ...
       andi r0,>8000                   ;                   
       jne  !                          ; JP Z,$81ED        ; If not, wait for restart
       b    @wait_for_restart          ;                   
!
       movb *hl,r0                     ; BIT 5,(HL)        ; Is one player already game over=
       andi r0,>2000                   ;                   
       jeq  !                          ; JP NZ,$81ED       ; If so, wait for restart
       b    @wait_for_restart          ;                   
!
       socb @bits+5,*hl                ; SET 5,(HL)        ; Else flag that one player game over
       jmp  _81b9                      ; JR $81B9          ; And switch player

* Switch player
* 
* Used by the routine at #R$8170.
switch_player:                         ; >81ae
       movb @status_flags,a            ; LD A,($71EB)      ; Test for two players
       movb a,r0                       ; BIT 7,A           ; ...
       andi r0,>8000                   ;                   
       jeq  _81e2                      ; JR Z,$81E2        ; Skip ahead if one player
       movb *hl,r0                     ; BIT 5,(HL)        ; Test for ?
       andi r0,>2000                   ;                   
       jne  _81e2                      ; JR NZ,$81E2       ; Skip ahead if not set
* This entry point is used by the routine at #R$8170.
_81b9:                                 ; >81b9
       li   hl,buffer                  ; LD HL,$71A3       ; Restore player data from VDP RAM into buffer
       li   de,>1300                   ; LD DE,$1300       ; ...
       li   bc,>002d                   ; LD BC,$002D       ; ...
       .call @write_vram+>0003         ; CALL $1FE2        ; READ_VRAM
       li   hl,lives                   ; LD HL,$71FF       ; Save player data to VDP RAM
       li   de,>1300                   ; LD DE,$1300       ; ...
       li   bc,>002d                   ; LD BC,$002D       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       li   hl,buffer                  ; LD HL,$71A3       ; Copy data from buffer to right place
       li   de,lives                   ; LD DE,$71FF       ; ...
       li   bc,>002d                   ; LD BC,$002D       ; ...
       .ldir                           ; LDIR              ; ...
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       xor  one,a                      ; XOR $01           ; Switch player
       movb a,@current_player          ; LD ($71F1),A      ; Save again
_81e2:                                 ; >81e2
       .call @init_stage               ; CALL $8212        ; Initialize stage
       li   hl,other_flags             ; LD HL,$7256       ; Set flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @main_loop                 ; JP $80E8          ; To main loop

* Wait for restart
* 
* Used by the routine at #R$8170.
wait_for_restart:                      ; >81ed
       li   hl,write_vram+>2671        ; LD HL,$4650       ; 300 seconds
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; Set screensaver countdown
_81f3:                                 ; >81f3
       .halt                           ; HALT              ; 
       li   hl,>0001                   ; LD HL,$0001       ; Controller 0, segment 1
       .call @decoder                  ; CALL $1F79        ; DECODER
       movb @l,a                       ; LD A,L            ; 
       cb   a,@bytes+>0a               ; CP $0A            ; 
       jne  !                          ; JP Z,$8064        ; Start a new game
       b    @new_game                  ;                   
!
       cb   a,@bytes+>0f               ; CP $0F            ; 
       jeq  !                          ; JP NZ,$0000       ; Reset
       b    @>0000                     ;                   
!
       li   hl,>0000                   ; LD HL,$0000       ; Controller 0, segment 0
       .call @decoder                  ; CALL $1F79        ; DECODER
       movb h,r0                       ; BIT 6,H           ; Test fire
       andi r0,>4000                   ;                   
       jeq  !                          ; JP NZ,$8064       ; Start a new game
       b    @new_game                  ;                   
!
       jmp  _81f3                      ; JR $81F3          ; Loop

* Init stage
* 
* Initialize stage and display X WARPS TO Y message. Used by the routines at
* #R$8024, #R$81AE and #R$83D0.
init_stage:                            ; >8212
       li   hl,ship_background_data    ; LD HL,$722E       ; Clear $28 bytes from $722E
       li   de,ship_background_data+>0001 ; LD DE,$722F       ; ...
       li   bc,>0028                   ; LD BC,$0028       ; ...
       sb   *hl,*hl                    ; LD (HL),$00       ; ...
       .ldir                           ; LDIR              ; ...
       movb one,a                      ; LD A,$01          ; Set sprite countdown to 1
       movb a,@sprite_countdown        ; LD ($71EE),A      ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Clear died flag
       szcb @bits+2,*hl                ; RES 2,(HL)        ; ...
* Calculate stage data index
       movb @completed_stages,a        ; LD A,($7205)      ; Get completed stages
       socb a,a                        ; OR A              ; Test if zero
       jne  _823e                      ; JR NZ,$823E       ; If not, skip ahead to set max value
       movb @stage,a                   ; LD A,($7200)      ; Stage
       cb   a,@bytes+>04               ; CP $04            ; Compare stage to 4
       jhe  _8240                      ; JR NC,$8240       ; Jump if stage >= 4, to set value = stage / 4 + 1
       movb a,b                        ; LD B,A            ; B = stage 1-3
       sb   a,a                        ; XOR A             ; A = 0
       sb   one,b                      ; DEC B             ; B = 0-2
       jeq  _8245                      ; JR Z,$8245        ; If zero then skip ahead to save value
       ab   one,a                      ; INC A             ; Stage = 2 or 3, set A = 1
       jmp  _8245                      ; JR $8245          ; Skip ahead to save value
_823e:                                 ; >823e
       movb @bytes+>18,a               ; LD A,$18          ; 24
_8240:                                 ; >8240
       srl  a,1                        ; SRL A             ; Divide stage by 4
       srl  a,1                        ; SRL A             ; ...
       ab   one,a                      ; INC A             ; + 1
_8245:                                 ; >8245
       movb a,@stage_data_index        ; LD ($7203),A      ; Save value (0 - 7)
* Display stage number
       movb @stage,a                   ; LD A,($7200)      ; Current stage
       li   hl,completed_stages        ; LD HL,$7205       ; Completed stages
       ab   *hl,a                      ; ADD A,(HL)        ; Add to stage
       li   de,>1afe                   ; LD DE,$1AFE       ; VDP address (stage number tens)
       cb   a,@bytes+>0a               ; CP $0A            ; 
       jl   _8267                      ; JR C,$8267        ; Jump if < 10
       sb   b,b                        ; LD B,$00          ; Divide by ten into B
_8258:                                 ; >8258
       sb   @bytes+>0a,a               ; SUB $0A           ; ...
       joc  _825f                      ; JR C,$825F        ; TODO: check code. ...
       ab   one,b                      ; INC B             ; ...
       jmp  _8258                      ; JR $8258          ; ...
_825f:                                 ; >825f
       ab   @bytes+>0a,a               ; ADD A,$0A         ; Restore ones
       movb a,@c                       ; LD C,A            ; Save in C
       movb b,a                        ; LD A,B            ; Tens
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       .rst >10                        ; RST $10           ; Write VDP byte
       movb @c,a                       ; LD A,C            ; Ones
_8267:                                 ; >8267
       inc  de                         ; INC DE            ; Increment VDP address to stage number ones
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       .rst >10                        ; RST $10           ; Write VDP byte
* Display X WARPS TO Y message
       movb @wave,a                    ; LD A,($7201)      ; Check whether you just died
       socb a,a                        ; OR A              ; So we want to display READY instead
       jne  _82ba                      ; JR NZ,$82BA       ; And if so jump ahead
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       movb a,b                        ; LD B,A            ; Save in B
       srl  a,1                        ; SRL A             ; Divide by 2
       andi a,>0e00                    ; AND $0E           ; Clamp to 0, 2, 4, 6, 8, 10, 12
       li   hl,planet_table            ; LD HL,$9398       ; Base planet table
       .rst >08                        ; RST $08           ; Add A to HL
       movb *hl,@e                     ; LD E,(HL)         ; Get LSB of planet data
       inc  hl                         ; INC HL            ; To MSB
       movb *hl,d                      ; LD D,(HL)         ; Get MSB of planet data
       li   hl,>0010                   ; LD HL,$0010       ; Planet name offset is 16
       a    de,hl                      ; ADD HL,DE         ; Add planet data address
       .push hl                        ; PUSH HL           ; Save it
       li   de,buffer+>0001            ; LD DE,$71A4       ; Buffer address for the string #R$71A3+1
       movb b,a                        ; LD A,B            ; Restore stage
       andi a,>0300                    ; AND $03           ; Clamp to 0, 1, 2, 3 (0 not an option?)
       cb   a,@bytes+>03               ; CP $03            ; If 3 we have reached it's a chance stage
       jeq  _82bf                      ; JR Z,$82BF        ; Then jump ahead
       li   r0,3*256                   ; XOR $03           ; Flip the bits, so we know how many warps TO the planet
       xor  r0,a                       ;                   
       ab   @bytes+>30,a               ; ADD A,$30         ; Add ASCII 0
       movb a,*de                      ; LD (DE),A         ; Store number in the buffer
       inc  de                         ; INC DE            ; Next buffer address
       li   hl,warps_msg               ; LD HL,$859C       ; WARPS message
       li   bc,>0005                   ; LD BC,$0005       ; Copy 5 bytes '_WARP'
       cb   a,@bytes+>31               ; CP $31            ; If the number is less than 2,
       jeq  _82a0                      ; JR Z,$82A0        ; then skip ahead
       inc  bc                         ; INC BC            ; Otherwise copy one more byte '_WARPS'
_82a0:                                 ; >82a0
       .ldir                           ; LDIR              ; Make the copy
       li   hl,to_msg                  ; LD HL,$85A2       ; Copy _TO_ message
       li   bc,>0004                   ; LD BC,$0004       ; 4 bytes
       .ldir                           ; LDIR              ; Make the copy
       .pop hl                         ; POP HL            ; Restore the planet name address
       movb *hl,@c                     ; LD C,(HL)         ; Get length of name
       inc  hl                         ; INC HL            ; Next byte
       .ldir                           ; LDIR              ; Copy planet name
       .ex_de_hl                       ; EX DE,HL          ; Now HL=destination and DE=source
       li   de,buffer+>0001            ; LD DE,$71A4       ; Buffer address for the string #R$71A3+1
       s    de,hl                      ; SBC HL,DE         ; Now HL contain the length of the string
       .ex_de_hl                       ; EX DE,HL          ; Now DE=length and HL=$71A4
       dec  hl                         ; DEC HL            ; HL=#R$71A3
       movb @e,*hl                     ; LD (HL),E         ; Set length
       jmp  _82c3                      ; JR $82C3          ; Jump ahead
_82ba:                                 ; >82ba
       li   hl,ready_msg               ; LD HL,$8589       ; Ready message
       jmp  _82c3                      ; JR $82C3          ; Skip ahead
_82bf:                                 ; >82bf
       .pop hl                         ; POP HL            ; Drop the pushed planet name address
       li   hl,chance_stage_msg        ; LD HL,$858F       ; Chance stage message
_82c3:                                 ; >82c3
       movb @bytes+>20,a               ; LD A,$20          ; At this point HL contains a pointer to the length
                                                           ; prefixed message to print
       sb   *hl,a                      ; SUB (HL)          ; 32 - string length
       srl  a,1                        ; SRL A             ; / 2 = offset to center line
       li   de,>1a00                   ; LD DE,$1A00       ; VDP address of line start
       ab   @e,a                       ; ADD A,E           ; Add address to offset
       movb a,@e                       ; LD E,A            ; Copy back to destination
       movb *hl,@c                     ; LD C,(HL)         ; Length
       sb   b,b                        ; LD B,$00          ; MSB of length
       inc  hl                         ; INC HL            ; Increment source to text
       .rst >38                        ; RST $38           ; WRITE_VRAM Display the X WARPS TO Y message
* Display ship and stars with music for a short while
       .call @display_player           ; CALL $830E        ; Display player if 2 player
       sb   b,b                        ; LD B,$00          ; For calculating ...
       movb @stage,a                   ; LD A,($7200)      ; Get stage
       li   hl,completed_stages        ; LD HL,$7205       ; Add completed stages
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       cb   a,one                      ; CP $01            ; If 1 then skip ahead with B = 0
       jeq  _82f6                      ; JR Z,$82F6        ; ...
       andi a,>0300                    ; AND $03           ; Stage mod 4
       movb @bytes+>05,b               ; LD B,$05          ; Set B = 5
       cb   a,one                      ; CP $01            ; And skip ahead if stage mod 4 < 1
       jl   _82f6                      ; JR C,$82F6        ; ...
       movb @bytes+>03,b               ; LD B,$03          ; Set B = 3
       jeq  _82f6                      ; JR Z,$82F6        ; And skip ahead if stage mod 4 = 1
       movb @bytes+>04,b               ; LD B,$04          ; Set B = 4
       cb   a,@bytes+>02               ; CP $02            ; And skip ahead if stage mod 4 = 2
       jeq  _82f6                      ; JR Z,$82F6        ; ...
       movb @bytes+>06,b               ; LD B,$06          ; Set B = 6
_82f6:                                 ; >82f6
       movb b,a                        ; LD A,B            ; Set A = B
       .call @call_play_tune           ; CALL $9E91        ; Play selected tune
       .call @display_lives            ; CALL $A6D2        ; Display lives
       .call @init_sprite_data         ; CALL $ACDF        ; Init sprite data
       .call @initial_game_loop        ; CALL $A33B        ; Initial game loop
       .call @init_mine_variables_2    ; CALL $8E8D        ; Init some variables
       li   hl,status_flags            ; LD HL,$71EB       ; Update status flags
       szcb @bits+4,*hl                ; RES 4,(HL)        ; ...
       socb @bits+6,*hl                ; SET 6,(HL)        ; Set main loop flag
       .ret                            ; RET               ; 

* Display player message
* 
* Used by the routines at #R$8170 and #R$82BF.
display_player:                        ; >830e
       movb @status_flags,a            ; LD A,($71EB)      ; Status flags
       movb a,r0                       ; BIT 7,A           ; Check bit for 2 players
       andi r0,>8000                   ;                   
       jne  !                          ; RET Z             ; Return if not set
       .ret                            ;                   
!
       li   hl,player_msg              ; LD HL,$8581       ; PLAYER 1 message
       li   de,>192c                   ; LD DE,$192C       ; VDP address
       li   bc,>0008                   ; LD BC,$0008       ; 8 characters
       .rst >38                        ; RST $38           ; WRITE_VRAM
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       socb a,a                        ; OR A              ; Is it player 1?
       jne  !                          ; RET Z             ; The return
       .ret                            ;                   
!
       movb @bytes+>32,a               ; LD A,$32          ; ASCII 2
       li   de,>1933                   ; LD DE,$1933       ; VDP address
       .rst >10                        ; RST $10           ; Write VDP byte
       .ret                            ; RET               ; 

* Stage completed
* 
* Used by the routine at #R$80E8.
stage_completed:                       ; >832a
       movb @bytes+>08,a               ; LD A,$08          ; Set counter for later
       movb a,@counter_stage_completed ; LD ($7259),A      ; ...
       li   hl,status_flags            ; LD HL,$71EB       ; Clear main loop flag
       szcb @bits+6,*hl                ; RES 6,(HL)        ; ...
       .call @read_register            ; CALL $1FDC        ; READ_REGISTER
       movb *hl,r0                     ; BIT 3,(HL)        ; If bit 3 is set
       andi r0,>0800                   ;                   
       jeq  !                          ; JP NZ,$8429       ; Then it was a chance stage
       b    @display_bonus             ;                   
!
* This entry point is used by the routines at #R$8450 and #R$846B.
_833c:                                 ; >833c
       equ  $
       movb @bytes+>5a,b               ; LD B,$5A          ; 90
_833e:                                 ; >833e
       .push bc                        ; PUSH BC           ; 
       .halt                           ; HALT              ; Wait interrupt
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ; 
       sb   one,b                      ; DJNZ $833E        ; Loop for 90 frames
       jne  _833e                      ;                   
       .call @stop_tune                ; CALL $9B87        ; Stop tune
       .call @clear_rows_9_and_14      ; CALL $84ED        ; Clear rows 9 and 14
       movb @stage,a                   ; LD A,($7200)      ; Stage
       andi a,>0300                    ; AND $03           ; Stage mod 4
       cb   a,@bytes+>02               ; CP $02            ; If not planet reached (2)
       jne  _8368                      ; JR NZ,$8368       ; Then skip ahead
       movb one,a                      ; LD A,$01          ; Play tune 1
       .call @call_play_tune           ; CALL $9E91        ; ...
       jmp  _836d                      ; JR $836D          ; 
_8368:                                 ; >8368
       movb @bytes+>05,a               ; LD A,$05          ; If not planet reached then play sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
_836d:                                 ; >836d
       li   hl,status_flags            ; LD HL,$71EB       ; 
       socb @bits+0,*hl                ; SET 0,(HL)        ; 
       socb @bits+4,*hl                ; SET 4,(HL)        ; 
       movb @stage,a                   ; LD A,($7200)      ; Stage
       movb a,b                        ; LD B,A            ; B = stage
       andi a,>0300                    ; AND $03           ; Stage mod 4
       cb   a,@bytes+>02               ; CP $02            ; If not planet reached (2)
       jne  _838a                      ; JR NZ,$838A       ; Then skip displaying planet
       movb b,a                        ; LD A,B            ; Stage
       srl  a,1                        ; SRL A             ; Divide by 4
       srl  a,1                        ; SRL A             ; ...
       ab   one,a                      ; INC A             ; + 1
       .call @display_planet           ; CALL $9175        ; Display planet A
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
* Warp
_838a:                                 ; >838a
       .halt                           ; HALT              ; Wait interrupt
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       li   hl,counter_stage_completed ; LD HL,$7259       ; Decrement counter that start at 8
       sb   one,*hl                    ; DEC (HL)          ; ...
       jne  _83cb                      ; JR NZ,$83CB       ; If not zero yet then skip loop body
       movb @bytes+>08,*hl             ; LD (HL),$08       ; Reset counter
       li   ix,sprite_data             ; LD IX,$7002       ; Pointer sprite 0
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment polar y
       ab   one,@>0d(ix)               ; INC (IX+$0D)      ; Increment polar y for sprite 1
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>12               ; CP $12            ; Is polar y 18?
       jne  _83b2                      ; JR NZ,$83B2       ; No, skip ahead
       .push af                        ; PUSH AF           ; 
       .call @clear_row_7              ; CALL $920D        ; Clear row 7 (planet name)
       .pop af                         ; POP AF            ; 
_83b2:                                 ; >83b2
       cb   a,@bytes+>2b               ; CP $2B            ; Is polar y 43?
       jeq  next_stage                 ; JR Z,$83D0        ; Yes, break out of loop
       cb   a,@bytes+>15               ; CP $15            ; Is polar y 21?
       jne  _83c2                      ; JR NZ,$83C2       ; No, skip ahead
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color of sprite 0
       movb @bytes+>09,@>17(ix)        ; LD (IX+$17),$09   ; Set color of sprite 1
_83c2:                                 ; >83c2
       .rst >30                        ; RST $30           ; Load sprite pattern sprite 0
       li   ix,_700e                   ; LD IX,$700E       ; Sprite 1
       .rst >30                        ; RST $30           ; Load sprite pattern sprite 1
       .call @display_ship_background_patterns ; CALL $A808        ; Display ship background patterns
_83cb:                                 ; >83cb
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       jmp  _838a                      ; JR $838A          ; Loop

* Next stage
* 
* Used by the routine at #R$832A.
next_stage:                            ; >83d0
       li   hl,status_flags            ; LD HL,$71EB       ; Flags
       szcb @bits+0,*hl                ; RES 0,(HL)        ; 
       szcb @bits+1,*hl                ; RES 1,(HL)        ; 
       sb   a,a                        ; XOR A             ; 
       movb a,@wave                    ; LD ($7201),A      ; Clear wave
       movb a,@enemies_hit             ; LD ($7202),A      ; Clear enemies destroyed
       movb @stage,a                   ; LD A,($7200)      ; Stage
       ab   one,a                      ; INC A             ; Next stage
       cb   a,@bytes+>18               ; CP $18            ; Did we reach 24?
       jl   _83ec                      ; JR C,$83EC        ; No, skip ahead
       li   hl,completed_stages        ; LD HL,$7205       ; Get the total stages completed
       ab   *hl,a                      ; ADD A,(HL)        ; And add 24
       movb a,*hl                      ; LD (HL),A         ; Save again
       sb   a,a                        ; XOR A             ; And set stage to zero
_83ec:                                 ; >83ec
       movb a,@stage                   ; LD ($7200),A      ; Save stage
       li   hl,status_flags            ; LD HL,$71EB       ; Flags
       szcb @bits+3,*hl                ; RES 3,(HL)        ; Reset bit 3
       movb @stage,a                   ; LD A,($7200)      ; Stage
       andi a,>0300                    ; AND $03           ; Mod 4
       cb   a,@bytes+>03               ; CP $03            ; Is it a chance stage?
       jne  _83ff                      ; JR NZ,$83FF       ; No, skip ahead
       socb @bits+3,*hl                ; SET 3,(HL)        ; Yes, set flag
_83ff:                                 ; >83ff
       sb   a,a                        ; XOR A             ; Reset death count
       movb a,@stage_death_count       ; LD ($7204),A      ; ...
       .call @display_planet           ; CALL $9175        ; Undraw planet
       li   hl,write_vram+>003d        ; LD HL,$201C       ; Set 4 colors to white/black
       li   de,>0004                   ; LD DE,$0004       ; ...
       movb @bytes+>f1,a               ; LD A,$F1          ; ...
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       li   hl,>0700                   ; LD HL,$0700       ; Address in pattern table
       li   de,>0100                   ; LD DE,$0100       ; 256 bytes = 32 patterns
       sb   a,a                        ; XOR A             ; Clear
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       movb @other_flags,a             ; LD A,($7256)      ; Save flags
       .push af                        ; PUSH AF           ; ...
       .call @init_stage               ; CALL $8212        ; Init stage
       .pop af                         ; POP AF            ; Restore flags
       movb a,@other_flags             ; LD ($7256),A      ; ...
       b    @main_loop                 ; JP $80E8          ; Jump to main loop

* Display bonus
* 
* Used by the routine at #R$832A.
display_bonus:                         ; >8429
       movb @bonus_enemies_hit,a       ; LD A,($7255)      ; Number of ships destroyed in chance stage
       cb   a,@bytes+>28               ; CP $28            ; Is it 40?
       jeq  perfect_bonus              ; JR Z,$846B        ; Then it's perfect
       .push af                        ; PUSH AF           ; Save ships
       li   hl,bonus_msg               ; LD HL,$85A6       ; Display BONUS
       li   de,>192d                   ; LD DE,$192D       ; ...
       li   bc,>0005                   ; LD BC,$0005       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       li   hl,bonus_numbers_msg       ; LD HL,$85AB       ; Display 100 X ..  ..00
       li   de,>19c9                   ; LD DE,$19C9       ; ...
       li   bc,>000e                   ; LD BC,$000E       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       .pop af                         ; POP AF            ; Restore ships
       .push af                        ; PUSH AF           ; Save again
       movb @bytes+>30,b               ; LD B,$30          ; 48
_8449:                                 ; >8449
       sb   @bytes+>0a,a               ; SUB $0A           ; Ships - 10
       joc  display_hits               ; JR C,$8450        ; TODO: check code. Jump if ships < 10, A is now -10 to -1
       ab   one,b                      ; INC B             ; +1 for every 10 ships
       jmp  _8449                      ; JR $8449          ; Loop

* Display hits
* 
* Used by the routine at #R$8429.
display_hits:                          ; >8450
       ab   @bytes+>3a,a               ; ADD A,$3A         ; Add ASCII for zero + 10
       li   de,>19d0                   ; LD DE,$19D0       ; Ones in number of ships
       .rst >10                        ; RST $10           ; Write VDP byte
       li   de,>19d4                   ; LD DE,$19D4       ; Hundreds in bonus
       .rst >10                        ; RST $10           ; Write VDP byte
       movb b,a                        ; LD A,B            ; Tens
       li   de,>19cf                   ; LD DE,$19CF       ; Tens in number of ships
       .rst >10                        ; RST $10           ; Write VDP byte
       li   de,>19d3                   ; LD DE,$19D3       ; Thousands in bonus
       .rst >10                        ; RST $10           ; Write VDP byte
       .pop bc                         ; POP BC            ; Restore ships destroyed
       movb b,a                        ; LD A,B            ; If it zero?
       socb a,a                        ; OR A              ; ...
       jne  !                          ; JP Z,$833C        ; Then jump back to complete stage
       b    @_833c                     ;                   
!
       jmp  _8486                      ; JR $8486          ; Else add B x 100 bonus points

* Perfect bonus
* 
* Used by the routine at #R$8429.
perfect_bonus:                         ; >846b
       movb @bytes+>02,a               ; LD A,$02          ; Play a tune
       .call @call_play_tune           ; CALL $9E91        ; ...
       li   hl,congratulations_msg     ; LD HL,$85B9       ; Display CONGRATULATIONS
       li   de,>1928                   ; LD DE,$1928       ; ...
       li   bc,>0010                   ; LD BC,$0010       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       li   hl,perfect_msg             ; LD HL,$85C9       ; Display PERFECT 10000 PTS
       li   de,>19c6                   ; LD DE,$19C6       ; ...
       li   bc,>0014                   ; LD BC,$0014       ; ...
       .rst >38                        ; RST $38           ; WRITE_VRAM
       movb @bytes+>64,b               ; LD B,$64          ; 100 times
* This entry point is used by the routine at #R$8450.
_8486:                                 ; >8486
       li   hl,>0100                   ; LD HL,$0100       ; 100 points
_8489:                                 ; >8489
       .push hl                        ; PUSH HL           ; 
       .push bc                        ; PUSH BC           ; 
       .call @add_score                ; CALL $A6EC        ; Add 100 points to score
       movb @current_player,a          ; LD A,($71F1)      ; Current player
       .call @display_score            ; CALL $A699        ; Display score
       movb @bytes+>07,b               ; LD B,$07          ; 7 frames
_8496:                                 ; >8496
       .halt                           ; HALT              ; Wait for interrupt
       .push bc                        ; PUSH BC           ; 
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ; 
       sb   one,b                      ; DJNZ $8496        ; Loop 7 times
       jne  _8496                      ;                   
       .pop bc                         ; POP BC            ; 
       .pop hl                         ; POP HL            ; 
       sb   one,b                      ; DJNZ $8489        ; Loop number of ships times
       jne  _8489                      ;                   
       b    @_833c                     ; JP $833C          ; Jump back to complete stage

* Update frames and upload sprites
* 
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$832A, #R$846B, #R$A33B
* and #R$A3E1.
next_frame_upl_sprites:                ; >84b1
       li   hl,frame_counter           ; LD HL,$71F2       ; Update frame counter
       ab   one,*hl                    ; INC (HL)          ; ...
       movb *hl,a                      ; LD A,(HL)         ; Get new value
       andi a,>0100                    ; AND $01           ; Every second frame ...
       jne  _84c8                      ; JR NZ,$84C8       ; go directly to upload sprite data
       movb @_700e,a                   ; LD A,($700E)      ; Else get type of sprite 1
       cb   a,one                      ; CP $01            ; Is it 1 (ship 2)?
       jne  _84c8                      ; JR NZ,$84C8       ; If not upload sprite data
       li   hl,_700e+>000b             ; LD HL,$7019       ; Get color of sprite 1
       movb *hl,a                      ; LD A,(HL)         ; ...
       li   r0,4*256                   ; XOR $04           ; Flip bit 4
       xor  r0,a                       ;                   
       movb a,*hl                      ; LD (HL),A         ; And set color back
_84c8:                                 ; >84c8
       b    @upload_sprite_data        ; JP $ACF9          ; Upload sprite data

* Upload patterns
* 
* Used by the routine at #R$90D6.
* 
* I: HL Pointer to start index and count
upload_patterns:                       ; >84cb
       sb   d,d                        ; LD D,$00          ; 
       movb *hl,@e                     ; LD E,(HL)         ; DE = start index
       inc  hl                         ; INC HL            ; 
       movb *hl,@c                     ; LD C,(HL)         ; 
       sb   b,b                        ; LD B,$00          ; BC = count
       .push bc                        ; PUSH BC           ; 
       .pop iy                         ; POP IY            ; IY = count
       inc  hl                         ; INC HL            ; HL now points to graphics data
       movb @bytes+>03,a               ; LD A,$03          ; Table code (3 = pattern generator table)
       b    @init_table+>0006          ; JP $1FBE          ; PUT_VRAM

* Get stage data address
* 
* Used by the routines at #R$8878, #R$8A53, #R$8A76, #R$8C68, #R$8D50, #R$8E9D,
* #R$900E and #R$AAF1.
* 
* O:IY Stage data address
stage_data_addr:                       ; >84db
       .push de                        ; PUSH DE           ; 
       movb @stage_data_index,a        ; LD A,($7203)      ; Get value (0 - 6)
       ab   a,a                        ; ADD A,A           ; Multiply by 8
       ab   a,a                        ; ADD A,A           ; ...
       ab   a,a                        ; ADD A,A           ; ...
       movb a,@e                       ; LD E,A            ; Add #R$8541
       sb   d,d                        ; LD D,$00          ; ...
       li   iy,stage_data_table        ; LD IY,$8541       ; ...
       a    de,iy                      ; ADD IY,DE         ; ...
       .pop de                         ; POP DE            ; 
       .ret                            ; RET               ; 

* Clear rows 9 and 14
* 
* Used by the routines at #R$8170 and #R$832A.
clear_rows_9_and_14:                   ; >84ed
       li   hl,>1920                   ; LD HL,$1920       ; Name table row 9
       li   de,>0020                   ; LD DE,$0020       ; 32 bytes
       sb   a,a                        ; XOR A             ; Clear
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       li   hl,>19c0                   ; LD HL,$19C0       ; Name table row 14
       li   de,>0020                   ; LD DE,$0020       ; 32 bytes
       sb   a,a                        ; XOR A             ; Clear
       b    @fill_vram                 ; JP $1F82          ; FILL_VRAM

* Interrupt routine
* 
* Calls sound player and handles screen saver Used by the routine at #R$8021.
interrupt_routine:                     ; >8501
       .push ix                        ; PUSH IX           ; 
       .push iy                        ; PUSH IY           ; 
       .push hl                        ; PUSH HL           ; 
       .push de                        ; PUSH DE           ; 
       .push bc                        ; PUSH BC           ; 
       .push af                        ; PUSH AF           ; 
       mov  @screensaver_countdown,hl  ; LD HL,($7257)     ; Counter
       movb h,a                        ; LD A,H            ; Check if zero
       socb @l,a                       ; OR L              ; ...
       jeq  _8522                      ; JR Z,$8522        ; If counter is 0 then skip ahead
       dec  hl                         ; DEC HL            ; Otherwise decrement
       mov  hl,@screensaver_countdown  ; LD ($7257),HL     ; and save.
       movb h,a                        ; LD A,H            ; Check again if zero
       socb @l,a                       ; OR L              ; ...
       jne  _8522                      ; JR NZ,$8522       ; If not then skip ahead, otherwise blank screen
       li   bc,>0180                   ; LD BC,$0180       ; Display off, interrupt off
       .rst >18                        ; RST $18           ; WRITE_REGISTER
       li   bc,>0701                   ; LD BC,$0701       ; Black border
       .rst >18                        ; RST $18           ; WRITE_REGISTER
_8520:                                 ; >8520
       jmp  _8520                      ; JR $8520          ; Loop
_8522:                                 ; >8522
       .call @sound_player             ; CALL $9B99        ; Sound player
       movb @status_flags,a            ; LD A,($71EB)      ; 
       movb a,r0                       ; BIT 6,A           ; 
       andi r0,>4000                   ;                   
       jne  !                          ; CALL Z,$1FDC      ; READ_REGISTER
       .call @read_register            ;                   
!
       li   hl,interrupt_flag          ; LD HL,$725A       ; 
       socb @bits+0,*hl                ; SET 0,(HL)        ; 
       .pop af                         ; POP AF            ; 
       .pop bc                         ; POP BC            ; 
       .pop de                         ; POP DE            ; 
       .pop hl                         ; POP HL            ; 
       .pop iy                         ; POP IY            ; 
       .pop ix                         ; POP IX            ; 
       ; RETN                          ; RETN              ; TODO: check code. 

* STAGE message
stage_msg:                             ; >853c
       text 'STAGE'

* Stage data (8 bytes per stage)
* 
* #TABLE(default, default)
* { =h Byte offset | =h Purpose }
* { $00 | Speed }
* { $01 | Max enemy shots }
* { $02 | Enemy shooting speed }
* { $03 | Unknown }
* { $04 | Unknown }
* { $05 | Unknown }
* { $06 | Time between waves }
* { $07 | Unknown }
* TABLE#
stage_data_table:                      ; >8541
       byte >02,>00,>28,>3F,>01,>50,>1E,>00
       byte >02,>01,>28,>3F,>02,>50,>19,>02
       byte >02,>01,>19,>1F,>02,>46,>14,>03
       byte >02,>02,>23,>1F,>03,>46,>14,>03
       byte >02,>02,>1E,>0F,>03,>32,>0A,>03
       byte >02,>03,>14,>0F,>03,>28,>0A,>03
       byte >01,>03,>0F,>0F,>04,>28,>05,>03
       byte >01,>03,>0F,>0F,>04,>1E,>05,>03

* PLAYER message
player_msg:                            ; >8581
       text 'PLAYER',>00,'1'

* READY message
ready_msg:                             ; >8589
       text >05,'READY'

* CHANCE STAGE message
chance_stage_msg:                      ; >858f
       text >0c,'CHANCE',>00,'STAGE'

* WARPS message
warps_msg:                             ; >859c
       text >00,'WARPS'

* TO message
to_msg:                                ; >85a2
       text >00,'TO',>00

* BONUS message
bonus_msg:                             ; >85a6
       text 'BONUS'

* Bonus points message
bonus_numbers_msg:                     ; >85ab
       text '100',>00,'X',>00,'..',>00,>00,'..00'

* CONGRATULATIONS message
congratulations_msg:                   ; >85b9
       text 'CONGRATULATIONS?'

* PERFECT message
perfect_msg:                           ; >85c9
       text 'PERFECT?',>00,>00,>00,'10000',>00,'PTS'

* GAME OVER message
game_over_msg:                         ; >85dd
       text 'GAME',>00,'OVER'

* Process sprites
* 
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$832A, #R$846B and
* #R$A3E1.
process_sprites:                       ; >85e6
       li   hl,sprite_countdown        ; LD HL,$71EE       ; Decrement counter 1
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,sprite_countdown_2      ; LD HL,$7260       ; Decrement counter 2
       sb   one,*hl                    ; DEC (HL)          ; ...
       movb @countdown_at_shoot,a      ; LD A,($71EF)      ; Decrement counter stopping at 0
       sb   one,a                      ; DEC A             ; ...
       jgt  !                          ; JP M,$85F8        ; ...
       b    @_85f8                     ;                   
!
       movb a,@countdown_at_shoot      ; LD ($71EF),A      ; ...
_85f8:                                 ; >85f8
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       szcb @bits+4,*hl                ; RES 4,(HL)        ; Reset laser fence flag
       li   hl,sprite_allocation_table+>0002 ; LD HL,$7185       ; Table address #R$7183+2 (skip ship sprites)
* This entry point is used by the routine at #R$8A41.
_8600:                                 ; >8600
       .push hl                        ; PUSH HL           ; Save table address
       li   de,sprite_allocation_table ; LD DE,$7183       ; Sprite allocation table
       sb   a,a                        ; XOR A             ; Clear carry
       s    de,hl                      ; SBC HL,DE         ; HL = offset into table
       movb @allocated_sprites,a       ; LD A,($7182)      ; Allocated sprites
       cb   a,@l                       ; CP L              ; Compare to offset
       .pop hl                         ; POP HL            ; Restore table address
       jne  !                          ; JP Z,$8A53        ; Jump when we have reached the last allocation
       b    @all_sprites_processed     ;                   
!
       .push hl                        ; PUSH HL           ; Push allocation table address
       movb *hl,@l                     ; LD L,(HL)         ; Get sprite data table index
       sb   h,h                        ; LD H,$00          ; ...
       a    hl,hl                      ; ADD HL,HL         ; Multiply by 4
       a    hl,hl                      ; ADD HL,HL         ; ...
       movb h,d                        ; LD D,H            ; Store in DE
       movb @l,@e                      ; LD E,L            ; ...
       a    hl,hl                      ; ADD HL,HL         ; Multiplied by 8
       a    de,hl                      ; ADD HL,DE         ; Multiplied by 12
       .ex_de_hl                       ; EX DE,HL          ; DE = sprite data table offset
       li   ix,sprite_data             ; LD IX,$7002       ; Base sprite data table address
       a    de,ix                      ; ADD IX,DE         ; IX = sprite data table address
       li   hl,return_from_sprite_handler ; LD HL,$8A41       ; Push return address of routine at #R$8A41
       .push hl                        ; PUSH HL           ; ...
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       movb a,@>05(ix)                 ; LD (IX+$05),A     ; Copy it to byte 5
       cb   a,@bytes+>7f               ; CP $7F            ; Is it to be deallocated?
       jeq  !                          ; JP NZ,$865A       ; If not, jump ahead
       b    @handle_sprite_type_02     ;                   
!
* This entry point is used by the routines at #R$8654, #R$8673, #R$867D and
* #R$8815.
deallocate_sprite:                     ; >862f
       equ  $
       movb @b255,*ix                  ; LD (IX+$00),$FF   ; Set as not allocated
       .pop hl                         ; POP HL            ; Pop return address
       .pop hl                         ; POP HL            ; Restore allocation table address of sprite to be
                                                           ; deallocated
       .push hl                        ; PUSH HL           ; Push it again
       li   de,sprite_allocation_table ; LD DE,$7183       ; Sprite allocation table
       sb   a,a                        ; XOR A             ; Clear carry
       s    de,hl                      ; SBC HL,DE         ; HL = offset into table
       movb @allocated_sprites,a       ; LD A,($7182)      ; Decrement number of allocated sprites
       sb   one,a                      ; DEC A             ; ...
       movb a,@allocated_sprites       ; LD ($7182),A      ; ...
       sb   @l,a                       ; SUB L             ; Allocated sprites - offset = number of allocations
                                                           ; after this one
       jeq  _8650                      ; JR Z,$8650        ; If it was the last one, there's nothing to do
       movb a,@c                       ; LD C,A            ; BC = number of allocations to move
       sb   b,b                        ; LD B,$00          ; ...
       .pop de                         ; POP DE            ; DE = allocation table address
       .push de                        ; PUSH DE           ; ...
       movb d,h                        ; LD H,D            ; HL = allocation table address
       movb @e,@l                      ; LD L,E            ; ...
       inc  hl                         ; INC HL            ; HL = allocation table address + 1
       .ldir                           ; LDIR              ; Copy allocations after to close hole
_8650:                                 ; >8650
       .pop hl                         ; POP HL            ; Restore allocation table address
       b    @_8600                     ; JP $8600          ; Proceed with next sprite

* Deallocate enemy
* 
* Used by the routines at #R$870C, #R$873E and #R$8848.
deallocate_enemy:                      ; >8654
       li   hl,total_enemies           ; LD HL,$7206       ; Decrease total enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       jmp  deallocate_sprite          ; JR $862F          ; Deallocate sprite

* Handle sprite type $02
* 
* Used by the routine at #R$85E6.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_type_02:                 ; >865a
       cb   a,@bytes+>02               ; CP $02            ; Is sprite type $02?
       jeq  !                          ; JP NZ,$867D       ; If not proceed to next handler
       b    @handle_sprite_types_04_0c ;                   
!
* Sprite type $02 (shot)
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       ab   one,a                      ; INC A             ; Move shot
       ab   one,a                      ; INC A             ; ...
       movb a,@>01(ix)                 ; LD (IX+$01),A     ; And save again
       cb   a,@bytes+>08               ; CP $08            ; Is polar y now 7?
       jne  _8673                      ; JR NZ,$8673       ; If not, jump ahead
       movb @bytes+>05,@>0b(ix)        ; LD (IX+$0B),$05   ; Set color
       .ret                            ; RET               ; Return to #R$8A41
_8673:                                 ; >8673
       cb   a,@bytes+>2b               ; CP $2B            ; Is polar y 43?
       jhe  !                          ; RET C             ; Return if less than
       .ret                            ;                   
!
       li   hl,active_shots            ; LD HL,$7253       ; Decrease active shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       b    @deallocate_sprite         ; JP $862F          ; Deallocate sprite

* Handle sprite type $04 - $0C
* 
* Used by the routine at #R$865A.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_types_04_0c:             ; >867d
       cb   a,@bytes+>04               ; CP $04            ; Is sprite type < $04
       jl   handle_sprite_type_14      ; JR C,$86DE        ; Then jump
       cb   a,@bytes+>0d               ; CP $0D            ; Is it >= $0D
       jhe  handle_sprite_type_14      ; JR NC,$86DE       ; Then jump
* Sprite types $04 - $0C (enemy remains, numbers)
       sb   one,@>03(ix)               ; DEC (IX+$03)      ; Decrement counter
       jeq  !                          ; RET NZ            ; Return if not zero
       .ret                            ;                   
!
       ab   one,*ix                    ; INC (IX+$00)      ; Increment sprite type
       movb @bytes+>0f,@>03(ix)        ; LD (IX+$03),$0F   ; Reset counter
       cb   a,@bytes+>04               ; CP $04            ; Is sprite type destroyed enemy?
       jne  !                          ; RET Z             ; Then return
       .ret                            ;                   
!
       movb @>06(ix),a                 ; LD A,(IX+$06)     ; Else get replacement type (probably number)
       socb a,a                        ; OR A              ; If zero
       jne  !                          ; JP Z,$862F        ; Then deallocate sprite
       b    @deallocate_sprite         ;                   
!
       movb a,*ix                      ; LD (IX+$00),A     ; Set new type
       movb @bytes+>3c,@>03(ix)        ; LD (IX+$03),$3C   ; Counter
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ; No replacement type
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       .rst >30                        ; RST $30           ; Load sprite pattern
       .push ix                        ; PUSH IX           ; Save sprite data address
       .rst >28                        ; RST $28           ; Allocate new sprite for last digits of points
       .pop iy                         ; POP IY            ; IY = old sprite
       movb @bytes+>0c,*ix             ; LD (IX+$00),$0C   ; Set type if new sprite (number 00)
       movb @bytes+>3c,@>03(ix)        ; LD (IX+$03),$3C   ; Counter
       movb @bytes+>0f,@>0b(ix)        ; LD (IX+$0B),$0F   ; Set color
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Set polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Set polar x
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ; No replacement type
       .rst >30                        ; RST $30           ; Load sprite pattern
       movb @>08(iy),a                 ; LD A,(IY+$08)     ; Get screen y of old sprite
       movb a,@>08(ix)                 ; LD (IX+$08),A     ; Set screen y of new sprite
       movb @>09(iy),a                 ; LD A,(IY+$09)     ; Get screen x of old sprite
       ab   @bytes+>08,a               ; ADD A,$08         ; Add 8
       movb a,@>09(ix)                 ; LD (IX+$09),A     ; Set screen x of new sprite
       .pop bc                         ; POP BC            ; Pop return address
       b    @_8a4e                     ; JP $8A4E          ; Jump back into sprite handler loop

* Handle sprite type  $14
* 
* Used by the routine at #R$867D.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_type_14:                 ; >86de
       cb   a,@bytes+>14               ; CP $14            ; Is sprite type $014
       jne  handle_sprite_types_12_13  ; JR NZ,$86E9       ; If not, jump ahead
* Sprite type $14 (meteor)
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite types $12 - $13
* 
* Used by the routine at #R$86DE.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_types_12_13:             ; >86e9
       cb   a,@bytes+>12               ; CP $12            ; Is sprite type < $012
       jl   handle_sprite_type_03      ; JR C,$870C        ; If so, jump ahead
       cb   a,@bytes+>14               ; CP $14            ; Is sprite type >= $014
       jhe  handle_sprite_type_03      ; JR NC,$870C       ; If so, jump ahead
* Sprite types $12 - $13 (enemy missile)
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       movb a,b                        ; LD B,A            ; Store in B
       andi a,>0100                    ; AND $01           ; Every 2nd frame
       jeq  !                          ; RET NZ            ; Return to #R$8A41
       .ret                            ;                   
!
       movb b,a                        ; LD A,B            ; Frame counter
       andi a,>0f00                    ; AND $0F           ; Mod 16
       jne  _8705                      ; JR NZ,$8705       ; If not zero then skip animation
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       xor  one,a                      ; XOR $01           ; Flip bit 0 to change between $12 and $13
       movb a,*ix                      ; LD (IX+$00),A     ; Save new type
_8705:                                 ; >8705
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite type $03
* 
* Used by the routine at #R$86E9.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_type_03:                 ; >870c
       cb   a,@bytes+>03               ; CP $03            ; Is sprite type $03?
       jne  handle_sprite_types_15_17  ; JR NZ,$873E       ; If not, jump ahead
* Sprite type $03 (double shot pickup)
       movb @status_flags,a            ; LD A,($71EB)      ; Check if you have died
       movb a,r0                       ; BIT 2,A           ; ...
       andi r0,>0400                   ;                   
       jeq  !                          ; JP NZ,$8654       ; If so, deallocate and return
       b    @deallocate_enemy          ;                   
!
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>07(ix),a                 ; LD A,(IX+$07)     ; X velocity, set to $02 or $FE when created
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Add to polar x
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save again
       sb   one,@>03(ix)               ; DEC (IX+$03)      ; Counter, set to $10 when created
       jlt  !                          ; RET P             ; Return if > 0
       .ret                            ;                   
!
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Get ship polar x
       movb @>02(ix),b                 ; LD B,(IX+$02)     ; Get polar x
       .call @polar_x_distance         ; CALL $9A86        ; Polar x distance
       cb   a,@bytes+>04               ; CP $04            ; Is it >= 4
       jl   !                          ; RET NC            ; Then return
       .ret                            ;                   
!
       li   hl,other_flags             ; LD HL,$7256       ; Set double shot flag
       socb @bits+1,*hl                ; SET 1,(HL)        ; ...
       b    @deallocate_enemy          ; JP $8654          ; Deallocate and return

* Handle sprite types $15 - $17
* 
* Used by the routine at #R$870C.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_types_15_17:             ; >873e
       cb   a,@bytes+>15               ; CP $15            ; Is sprite type < $15
       jl   handle_sprite_types_0e_11  ; JR C,$8790        ; If so, jump ahead
       cb   a,@bytes+>18               ; CP $18            ; Is sprite type >= $18
       jhe  handle_sprite_types_0e_11  ; JR NC,$8790       ; If so, jump ahead
* sprite types $15 - $17 (laser fence)
       movb @bytes+>07,b               ; LD B,$07          ; Mask = 7
       movb @status_flags,a            ; LD A,($71EB)      ; Check if you have died
       movb a,r0                       ; BIT 2,A           ; ...
       andi r0,>0400                   ;                   
       jeq  _8751                      ; JR Z,$8751        ; If not, skip next
       movb @bytes+>03,b               ; LD B,$03          ; Else set Mask = 3
_8751:                                 ; >8751
       movb @frame_counter,a           ; LD A,($71F2)      ; Frame counter
       ; AND B                         ; AND B             ; TODO: check code. AND mask
       jne  _875d                      ; JR NZ,$875D       ; If not zero, skip next 2
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
_875d:                                 ; >875d
       li   hl,other_flags             ; LD HL,$7256       ; Flags
       socb @bits+4,*hl                ; SET 4,(HL)        ; Set laser fence flag
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>17               ; CP $17            ; If not laser fence center
       jeq  !                          ; RET NZ            ; Then return to #R$8A41
       .ret                            ;                   
!
       movb @other_flags,a             ; LD A,($7256)      ; If bit 3 is reset
       movb a,r0                       ; BIT 3,A           ; ...
       andi r0,>0800                   ;                   
       jne  !                          ; JP Z,$8654        ; Then deallocate
       b    @deallocate_enemy          ;                   
!
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get polar x
       ab   @>03(ix),a                 ; ADD A,(IX+$03)    ; Add velocity
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Save new polar x
       li   hl,_7261                   ; LD HL,$7261       ; Did center reach end 2?
       cb   a,*hl                      ; CP (HL)           ; ...
       jeq  _8787                      ; JR Z,$8787        ; Then skip ahead
       inc  hl                         ; INC HL            ; Did center reach end 1?
       cb   a,*hl                      ; CP (HL)           ; ...
       jeq  !                          ; RET NZ            ; If not, return to #R$8A41
       .ret                            ;                   
!
_8787:                                 ; >8787
       equ  $
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Switch direction
       neg a                           ; NEG               ; ...
       movb a,@>03(ix)                 ; LD (IX+$03),A     ; ...
       .ret                            ; RET               ; Return to #R$8A41

* Handle sprite types $0E - $11
* 
* Used by the routine at #R$873E.
* 
* I:A Sprite type
* I:IX Sprite data
handle_sprite_types_0e_11:             ; >8790
       cb   a,@bytes+>0e               ; CP $0E            ; Is sprite type < $0E
       jhe  !                          ; JP C,$899E        ; If so, jump ahead
       b    @handle_sprite_types_18_1c ;                   
!
       cb   a,@bytes+>12               ; CP $12            ; Is sprite type >= $12
       jl   !                          ; JP NC,$899E       ; If so, jump ahead
       b    @handle_sprite_types_18_1c ;                   
!
* Sprite type $0E - $11 (enemies)
       movb @>07(ix),r0                ; BIT 7,(IX+$07)    ; Check bit 7 of flags
       andi r0,>8000                   ;                   
       jeq  !                          ; JP NZ,$88FE       ; Update sprite path
       b    @update_sprite_path        ;                   
!
       movb @>01(ix),r0                ; BIT 7,(IX+$01)    ; Check bit 7 of polar y
       andi r0,>8000                   ;                   
       jeq  !                          ; JP NZ,$8825       ; If set, move towards viewer
       b    @move_towards_viewer       ;                   
!
       movb @>07(ix),r0                ; BIT 6,(IX+$07)    ; Check bit 6 of flags
       andi r0,>4000                   ;                   
       jne  create_map_entry_for_sprite ; JR NZ,$87D5       ; Create map entry for enemy sprite
       movb @>07(ix),r0                ; BIT 2,(IX+$07)    ; Check bit 2 of flags
       andi r0,>0400                   ;                   
       jeq  !                          ; JP NZ,$8825       ; Move towards viewer
       b    @move_towards_viewer       ;                   
!
       movb @>07(ix),r0                ; BIT 0,(IX+$07)    ; Check bit 0 of flags
       andi r0,>0100                   ;                   
       jeq  !                          ; JP NZ,$885F       ; Create enemy shot and ...
       b    @_885f                     ;                   
!
       movb @sprite_countdown_2,a      ; LD A,($7260)      ; Sprite countdown 2
       socb a,a                        ; OR A              ; Return if not zero
       jeq  !                          ; RET NZ            ; ...
       .ret                            ;                   
!
_87c1:                                 ; >87c1
       equ  $
       .call @create_enemy_shot        ; CALL $8A76        ; Create enemy shot
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Ship polar x
       .call @move_towards_x           ; CALL $8AC0        ; Move towards x
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; Return to #R$8A41

* Create map entry for enemy sprite
* 
* Search for a value (pattern OR $80) in map. If not found, allocate an entry.
* If found, calculate coordinates and move towards them. Used by the routine at
* #R$8790.
* 
* I: IX Sprite data of enemy
create_map_entry_for_sprite:           ; >87d5
       movb @sprite_countdown,a        ; LD A,($71EE)      ; Return if countdown
       socb a,a                        ; OR A              ; is not zero
       jeq  !                          ; RET NZ            ; ...
       .ret                            ;                   
!
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get pattern
       socb @bytes+>80,a               ; OR $80            ; Set bit 7
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       li   hl,center_enemy_map        ; LD HL,$7207       ; Address of map
_87e7:                                 ; >87e7
       cb   a,*hl                      ; CP (HL)           ; Check entry
       jeq  _87f5                      ; JR Z,$87F5        ; Break out if found
       inc  hl                         ; INC HL            ; Next map address
       sb   one,b                      ; DJNZ $87E7        ; Loop up to 36 times
       jne  _87e7                      ;                   
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get pattern
       socb @bytes+>80,a               ; OR $80            ; Set bit 7
       b    @allocate_map_entry        ; JP $AAA6          ; Add pattern to map. Return to #R$8A41
_87f5:                                 ; >87f5
       .call @polar_coord_from_map     ; CALL $AB38        ; Now DE contains polar y,x
       movb @e,a                       ; LD A,E            ; Get x from map
       cb   a,@>02(ix)                 ; CP (IX+$02)       ; Compare with polar x
       jeq  _8801                      ; JR Z,$8801        ; If same, skip ahead
       b    @move_towards_x            ; JP $8AC0          ; Else jump out to #R$8AC0
_8801:                                 ; >8801
       movb @bytes+>0e,*ix             ; LD (IX+$00),$0E   ; Change sprite type to enemy
* Move towards y
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,d                        ; CP D              ; Compare with polar y from map
       jeq  return_enemy_to_map        ; JR Z,$8815        ; If same, jump ahead
       joc  _8811                      ; JR C,$8811        ; TODO: check code. If less than, skip to increment polar y
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       .ret                            ; RET               ; Return to #R$8A41
_8811:                                 ; >8811
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Increment polar y
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Return enemy to map
* 
* Used by the routine at #R$8801.
* 
* I:IX Sprite data of enemy
return_enemy_to_map:                   ; >8815
       movb @>0b(ix),a                 ; LD A,(IX+$0B)     ; Get color (why not pattern?)
       movb a,*hl                      ; LD (HL),A         ; Set in map
       li   hl,active_enemies          ; LD HL,$722C       ; Decrease active enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,other_flags             ; LD HL,$7256       ; Set a flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @deallocate_sprite         ; JP $862F          ; Deallocate sprite and return

* Enemy movement: Move enemy towards viewer
* 
* Used by the routine at #R$8790.
* 
* I:IX Sprite data of enemy
move_towards_viewer:                   ; >8825
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Change sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>f2               ; CP $F2            ; Return if not $F2 (-14)
       jeq  !                          ; RET NZ            ; Else continue into #R$8835
       .ret                            ;                   
!

* Enemy movement: Determine action when out of screen
* 
* Used by the routine at #R$8A2D.
* 
* I:IX Sprite data of enemy
handle_out_of_screen:                  ; >8835
       equ  $
       movb @>07(ix),r0                ; BIT 3,(IX+$07)    ; If a flag is reset
       andi r0,>0800                   ;                   
       jeq  _8848                      ; JR Z,$8848        ; Then skip ahead and determine what to do
* This entry point is used by the routine at #R$8848.
_883b:                                 ; >883b
       movb @bytes+>2a,@>01(ix)        ; LD (IX+$01),$2A   ; Reset polar y back to center
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Reset polar x
       movb @bytes+>40,@>07(ix)        ; LD (IX+$07),$40   ; Set flags
       .ret                            ; RET               ; Return to #R$8A41
_8848:                                 ; >8848
       movb @>07(ix),r0                ; BIT 4,(IX+$07)    ; Test flag
       andi r0,>1000                   ;                   
       jeq  _8853                      ; JR Z,$8853        ; If not set, skip ahead
       .rst >20                        ; RST $20           ; Random number
       andi a,>0300                    ; AND $03           ; 0 - 3
       jne  _883b                      ; JR NZ,$883B       ; If not 0, jump back
_8853:                                 ; >8853
       li   hl,active_enemies          ; LD HL,$722C       ; Decrement active enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,other_flags             ; LD HL,$7256       ; Set flag
       socb @bits+5,*hl                ; SET 5,(HL)        ; ...
       b    @deallocate_enemy          ; JP $8654          ; Deallocate and return

* Enemy movement: Create enemy shot and move
* 
* Used by the routine at #R$8790. Called and jumped.
* 
* I:IX Sprite data of enemy
_885f:                                 ; >885f
       .call @create_enemy_shot        ; CALL $8A76        ; Create enemy shot
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y
       cb   a,@bytes+>22               ; CP $22            ; Is it < $22
       jl   _8878                      ; JR C,$8878        ; Then jump ahead
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
       movb @bytes+>02,@>03(ix)        ; LD (IX+$03),$02   ; Set counter
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       ab   one,@>05(ix)               ; INC (IX+$05)      ; Mark for pattern reload
       .ret                            ; RET               ; 

