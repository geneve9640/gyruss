* Polar x distance
* 
* Used by the routines at #R$870C, #R$9796, and #R$9861.
* 
* I: A Polar x1
* I: B Polar x2
polar_x_distance:                      ; >9a86
       movb a,@temp_polar_x            ; LD ($726F),A      ; Store polar x1
       sb   b,a                        ; SUB B             ; Polar x1 - polar x2
       jnc  _9a8e                      ; JR NC,$9A8E       ; TODO: check code. Jump ahead of >= 0
       neg a                           ; NEG               ; Else make positive
_9a8e:                                 ; >9a8e
       cb   a,@bytes+>20               ; CP $20            ; Is it < 32?
       jhe  !                          ; RET C             ; Then return
       .ret                            ;                   
!
       movb @temp_polar_x,a            ; LD A,($726F)      ; Restore polar x1
       cb   a,@bytes+>20               ; CP $20            ; Is it >= 32?
       jhe  _9a9a                      ; JR NC,$9A9A       ; Then skip ahead
       ab   @bytes+>40,a               ; ADD A,$40         ; Else add 64
_9a9a:                                 ; >9a9a
       movb a,@c                       ; LD C,A            ; Store in C
       movb b,a                        ; LD A,B            ; Get polar x2
       cb   a,@bytes+>20               ; CP $20            ; Is it >= 32?
       jhe  _9aa2                      ; JR NC,$9AA2       ; Then skip ahead
       ab   @bytes+>40,a               ; ADD A,$40         ; Else add 64
_9aa2:                                 ; >9aa2
       sb   @c,a                       ; SUB C             ; Subtract the modified polar x1
       joc  !                          ; RET NC            ; TODO: check code. Return if >= 0
       .ret                            ;                   
!
       neg a                           ; NEG               ; Else make positive
       .ret                            ; RET               ; And return

* Score table
score_table:                           ; >9aa7
       byte >05,>06
       byte >10,>07
       byte >15,>08
       byte >20,>09
       byte >25,>0A
       byte >30,>0B

