* Send data for all channels to PSG
* 
* Used by the routine at #R$9B99.
all_channels_data_to_psg:              ; >a2bb
       movb @bytes+>9f,a               ; LD A,$9F          ; Mute channel 1
       movb @bytes+>90,@c              ; LD C,$90          ; Tone 1 attenuation
       movb @bytes+>80,d               ; LD D,$80          ; Tone 1 frequency
       mov  @ptr_psg_tone_1_data,ix    ; LD IX,($7272)     ; IX=#R$7287
       .call @tone_data_to_psg         ; CALL $A314        ; Play tone or mute
       movb @bytes+>bf,a               ; LD A,$BF          ; Mute channel 2
       movb @bytes+>b0,@c              ; LD C,$B0          ; Tone 2 attenuation
       movb @bytes+>a0,d               ; LD D,$A0          ; Tone 2 frequency
       mov  @ptr_psg_tone_2_data,ix    ; LD IX,($7274)     ; IX=#R$7291
       .call @tone_data_to_psg         ; CALL $A314        ; Play tone or mute
       movb @bytes+>df,a               ; LD A,$DF          ; Mute channel 3
       movb @bytes+>d0,@c              ; LD C,$D0          ; Tone 3 attenuation
       movb @bytes+>c0,d               ; LD D,$C0          ; Tone 3 frequency
       mov  @ptr_psg_tone_3_data,ix    ; LD IX,($7276)     ; IX=#R$729B
       .call @tone_data_to_psg         ; CALL $A314        ; Play tone or mute
       movb @b255,a                    ; LD A,$FF          ; Mute noise
       movb @bytes+>f0,@c              ; LD C,$F0          ; Noise attenuation
       mov  @ptr_psg_noise_data,ix     ; LD IX,($7270)     ; IX=#R$727D
       movb *ix,@e                     ; LD E,(IX+$00)     ; Get byte 0
       ab   one,@e                     ; INC E             ; If it was zero
       jne  noise_data_to_psg          ; JR NZ,$A2F3       ; Then jump ahead
       ; OUT ($FF),A                   ; OUT ($FF),A       ; TODO: check code. Else mute
       .ret                            ; RET               ; 

* Send data for noise channel to PSG
* 
* Used by the routine at #R$A2BB.
* 
* I:(IX+$04) Attenuation/noise control AAAAXNNN
noise_data_to_psg:                     ; >a2f3
       .call @attn_or_noise_to_psg     ; CALL $A303        ; Send attenuation to PSG
       movb @>04(ix),a                 ; LD A,(IX+$04)     ; Get sound byte
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       li   hl,last_noise_operation    ; LD HL,$7278       ; Compare to stored value
       cb   a,*hl                      ; CP (HL)           ; ...
       jne  !                          ; RET Z             ; Return if same
       .ret                            ;                   
!
       movb a,*hl                      ; LD (HL),A         ; Else store new value
       movb @bytes+>e0,@c              ; LD C,$E0          ; and make noise (continue into #R$A303)

* Send attenuation or noise control bytes to PSG
* 
* Used by the routines at #R$A2F3 and #R$A31D.
* 
* I:C Operation in upper nybble 1CC0XXXX or 1CC1XXXX
* I:(IX+$04): Attenuation/noise AAAAXNNN or attenuation/freq AAAA00FF
attn_or_noise_to_psg:                  ; >a303
       movb @>04(ix),a                 ; LD A,(IX+$04)     ; Get sound byte
       movb @c,r0                      ; BIT 4,C           ; If bit 4 of operation is 0, i.e. noise control
       andi r0,>1000                   ;                   
       jeq  _a30e                      ; JR Z,$A30E        ; Then skip shifting
       srl  a,1                        ; RRCA              ; TODO: check code. Swap bits 4-7 and 0-3
       srl  a,1                        ; RRCA              ; TODO: check code. ...
       srl  a,1                        ; RRCA              ; TODO: check code. ...
       srl  a,1                        ; RRCA              ; TODO: check code. ...
_a30e:                                 ; >a30e
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3
       socb @c,a                       ; OR C              ; Apply operation (attenuation or noise control) to bits
                                                           ; 4-7
       ; OUT ($FF),A                   ; OUT ($FF),A       ; TODO: check code. Send to PSG
       .ret                            ; RET               ; 

* Send data for tone channel to PSG
* 
* Used by the routine at #R$A2BB.
* 
* I:A Mute operation for channel
* I:C Attenuation operation for channel
* I:D Tone operation for channel
* I:(IX+$00): $00 for tone else mute
tone_data_to_psg:                      ; >a314
       movb *ix,@e                     ; LD E,(IX+$00)     ; Get byte 0
       ab   one,@e                     ; INC E             ; If byte 0 was 0 then this is not 0
       jne  attn_and_freq_to_psg       ; JR NZ,$A31D       ; Jump for tone
       ; OUT ($FF),A                   ; OUT ($FF),A       ; TODO: check code. Mute
       .ret                            ; RET               ; 

* Send attenuation and frequency bytes to PSG
* 
* Used by the routine at #R$A314. Note: The value is actually 111,861 /
* frequency, so higher numbers give lower notes
* 
* I:C Attenuation operation in upper nybble (1CC1XXXX)
* I:D Tone operation in upper nybble (1CC0XXXX)
* I:(IX+$03) Frequency LSB
* I:(IX+$04) Attenuation/frequency MSB (AAAA00FF)
attn_and_freq_to_psg:                  ; >a31d
       .call @attn_or_noise_to_psg     ; CALL $A303        ; Set attenuation
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Frequency LSB
       andi a,>0f00                    ; AND $0F           ; Isolate bits 0-3 of frequency
       socb d,a                        ; OR D              ; Apply operation to bits 4-7
       ; OUT ($FF),A                   ; OUT ($FF),A       ; TODO: check code. Send to PSG
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Frequency LSB (FFFFFFFF)
       andi a,>f000                    ; AND $F0           ; Isolate bits 4-7 of frequency (FFFF0000)
       movb a,d                        ; LD D,A            ; Save it
       movb @>04(ix),a                 ; LD A,(IX+$04)     ; Get frequency MSB (AAAA00FF)
       andi a,>0f00                    ; AND $0F           ; Isolate lower nybble with bits 8-9 of frequency
                                                           ; (000000FF)
       socb d,a                        ; OR D              ; Now FFFF00FF in wrong order
       srl  a,1                        ; RRCA              ; TODO: check code. FFFFF00F
       srl  a,1                        ; RRCA              ; TODO: check code. FFFFFF00
       srl  a,1                        ; RRCA              ; TODO: check code. 0FFFFFF0
       srl  a,1                        ; RRCA              ; TODO: check code. 00FFFFFF
       ; OUT ($FF),A                   ; OUT ($FF),A       ; TODO: check code. Send to PSG
       .ret                            ; RET               ; 

* Initial game loop
* 
* Used by the routine at #R$82BF.
initial_game_loop:                     ; >a33b
       li   hl,_80b5                   ; LD HL,$80B5       ; New center of projection at bottom center for
                                                           ; implosion
       mov  hl,@tmp_center_of_projection ; LD ($72C5),HL     ; Set #R$72C5, which will be copied to #R$7000
       li   hl,status_flags            ; LD HL,$71EB       ; Status flags
       socb @bits+4,*hl                ; SET 4,(HL)        ; Set bit 4
* Allocate 6 dot sprites for the implosion that becomes the ship
       li   iy,_a4b2                   ; LD IY,$A4B2       ; Sprite init data
       movb @bytes+>06,b               ; LD B,$06          ; Allocate 6 sprites
_a34c:                                 ; >a34c
       .rst >28                        ; RST $28           ; Allocate sprite
       movb @bytes+>0d,*ix             ; LD (IX+$00),$0D   ; Sprite type is $0D (a dot)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       .rst >30                        ; RST $30           ; Load sprite pattern
       movb @bytes+>16,@>01(ix)        ; LD (IX+$01),$16   ; Polar y
       movb *iy,a                      ; LD A,(IY+$00)     ; Get init data
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Polar x
       movb @bytes+>09,@>0b(ix)        ; LD (IX+$0B),$09   ; Set color (pink)
       inc  iy                         ; INC IY            ; Next init data
       sb   one,b                      ; DJNZ $A34C        ; Loop for 6 sprites
       jne  _a34c                      ;                   
* Display implosion
       movb @bytes+>14,b               ; LD B,$14          ; 20
_a36e:                                 ; >a36e
       .push bc                        ; PUSH BC           ; Save counter
       .call @move_dots                ; CALL $A471        ; Move dots
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       .halt                           ; HALT              ; Wait interrupt
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $A36E        ; Loop 20 times
       jne  _a36e                      ;                   
* Allocate ship etc.
       .call @init_sprite_data         ; CALL $ACDF        ; 
       .rst >28                        ; RST $28           ; Allocate sprite
       sb   *ix,*ix                    ; LD (IX+$00),$00   ; Sprite type $00 (ship body)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>06,@>0b(ix)        ; LD (IX+$0B),$06   ; Set color (red)
       .rst >30                        ; RST $30           ; Load sprite pattern
       .rst >28                        ; RST $28           ; Allocate sprite
       movb one,*ix                    ; LD (IX+$00),$01   ; Sprite type $01 (ship exhaust)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>04,@>0b(ix)        ; LD (IX+$0B),$04   ; Set color (blue)
       .rst >30                        ; RST $30           ; Load sprite pattern
       .call @display_ship_background_patterns ; CALL $A808        ; Display ship background patterns
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       movb @bytes+>07,a               ; LD A,$07          ; Play a sound
       .call @call_play_sound          ; CALL $9EA3        ; ...
* Game loop 60 times
       movb @bytes+>3c,b               ; LD B,$3C          ; 60
_a3b6:                                 ; >a3b6
       .halt                           ; HALT              ; Wait interrupt
       .push bc                        ; PUSH BC           ; Save counter
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @control_ship             ; CALL $A73C        ; Control ship
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $A3B6        ; Loop 60 times
       jne  _a3b6                      ;                   
       li   hl,>1a00                   ; LD HL,$1A00       ; Clear warps line
       li   de,>0020                   ; LD DE,$0020       ; ...
       sb   a,a                        ; XOR A             ; ...
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       movb @status_flags,a            ; LD A,($71EB)      ; Status
       movb a,r0                       ; BIT 7,A           ; Check bit for 2 players
       andi r0,>8000                   ;                   
       jne  !                          ; RET Z             ; Return if not
       .ret                            ;                   
!
       li   hl,>192c                   ; LD HL,$192C       ; Clear player message
       li   de,>0008                   ; LD DE,$0008       ; ...
       sb   a,a                        ; XOR A             ; ...
       b    @fill_vram                 ; JP $1F82          ; FILL_VRAM and return

* Explode
* 
* Used by the routine at #R$8139.
explode:                               ; >a3e1
       movb @bytes+>2a,a               ; LD A,$2A          ; 
       movb a,@sprite_data+>0001       ; LD ($7003),A      ; 
       .call @display_ship_background_patterns ; CALL $A808        ; Display ship background patterns
       movb @bytes+>7f,a               ; LD A,$7F          ; Not allocated
       movb a,@sprite_data             ; LD ($7002),A      ; 1st sprite
       movb a,@_700e                   ; LD ($700E),A      ; 2nd sprite
       movb @active_shots,a            ; LD A,($7253)      ; Active shots
       socb a,a                        ; OR A              ; If zero
       jeq  _a413                      ; JR Z,$A413        ; Then skip ahead
* Deallocate all shots
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data table
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       movb @bytes+>20,b               ; LD B,$20          ; 32 sprites
       movb @bytes+>02,a               ; LD A,$02          ; Is it type $02 (shot)?
_a402:                                 ; >a402
       cb   a,*ix                      ; CP (IX+$00)       ; ...
       jne  _a40f                      ; JR NZ,$A40F       ; No, then skip
       movb @bytes+>7f,*ix             ; LD (IX+$00),$7F   ; Set as not allocated
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
_a40f:                                 ; >a40f
       a    de,ix                      ; ADD IX,DE         ; Next sprite
       sb   one,b                      ; DJNZ $A402        ; Loop 32 times
       jne  _a402                      ;                   
* Set center of projection for explosion
_a413:                                 ; >a413
       mov  @sprite_data+>0008,hl      ; LD HL,($700A)     ; Y and X of 1st sprite
       li   bc,>0404                   ; LD BC,$0404       ; Add 4 to each
       a    bc,hl                      ; ADD HL,BC         ; ...
       mov  hl,@tmp_center_of_projection ; LD ($72C5),HL     ; Save it in #R$72C5, which will be copied to #R$7000
       movb @sprite_data+>0002,a       ; LD A,($7004)      ; Byte 2 of 1st sprite
       movb a,@_72c7                   ; LD ($72C7),A      ; Save it temporary
* Allocate 6 sprites for explosion
       li   iy,_a4b8                   ; LD IY,$A4B8       ; 
       movb @bytes+>06,b               ; LD B,$06          ; Allocate 6 sprites
_a429:                                 ; >a429
       .rst >28                        ; RST $28           ; Allocate sprite
       movb @bytes+>0d,*ix             ; LD (IX+$00),$0D   ; Sprite type is $0D (a dot)
       sb   @>01(ix),@>01(ix)          ; LD (IX+$01),$00   ; Polar y
       sb   @>02(ix),@>02(ix)          ; LD (IX+$02),$00   ; Polar x
       movb @bytes+>09,@>0b(ix)        ; LD (IX+$0B),$09   ; Set color (pink)
       .rst >30                        ; RST $30           ; Load sprite pattern
       movb @_72c7,a                   ; LD A,($72C7)      ; Restore byte 2 of 1st sprite
       ab   *iy,a                      ; ADD A,(IY+$00)    ; Add data from table
       andi a,>3f00                    ; AND $3F           ; Mod $40
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Set polar x on new sprite
       movb @bytes+>2a,@>01(ix)        ; LD (IX+$01),$2A   ; Set polar y
       inc  iy                         ; INC IY            ; Next init data
       sb   one,b                      ; DJNZ $A429        ; Loop for 6 sprites
       jne  _a429                      ;                   
* Game loop for 3 seconds
       movb @bytes+>14,b               ; LD B,$14          ; 20
_a450:                                 ; >a450
       .push bc                        ; PUSH BC           ; Outer loop
       .call @move_dots                ; CALL $A471        ; Move dots
       .call @upload_sprite_data       ; CALL $ACF9        ; Upload sprite data
       movb @bytes+>09,b               ; LD B,$09          ; 9
_a459:                                 ; >a459
       .halt                           ; HALT              ; Inner loop
       .push bc                        ; PUSH BC           ; 
       .call @display_stars            ; CALL $AFFF        ; Display stars
       .call @process_sprites          ; CALL $85E6        ; Process sprites
       .call @display_center_enemies   ; CALL $AB72        ; Display center enemies
       .call @create_or_display_mines  ; CALL $8E2D        ; 
       .call @next_frame_upl_sprites   ; CALL $84B1        ; Upload sprites
       .pop bc                         ; POP BC            ; 
       sb   one,b                      ; DJNZ $A459        ; Loop 9 times
       jne  _a459                      ;                   
       .pop bc                         ; POP BC            ; 
       sb   one,b                      ; DJNZ $A450        ; Loop 20 times
       jne  _a450                      ;                   
       .ret                            ; RET               ; 

* Move explosion dots
* 
* Change polar y of sprite types $0D, according to bit 2 of #R$71EB. Used by
* the routines at #R$A33B and #R$A3E1.
move_dots:                             ; >a471
       mov  @tmp_center_of_projection,hl ; LD HL,($72C5)     ; Copy #R$72C5 to #R$7000
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       movb @bytes+>20,b               ; LD B,$20          ; 32 sprites
       li   ix,sprite_data             ; LD IX,$7002       ; Sprite data
* This entry point is used by the routine at #R$A4A0.
_a47d:                                 ; >a47d
       movb *ix,a                      ; LD A,(IX+$00)     ; Get type
       cb   a,@bytes+>0d               ; CP $0D            ; Is it $0D (a dot)?
       jne  _a4a4                      ; JR NZ,$A4A4       ; If not then move to next sprite
       .push bc                        ; PUSH BC           ; Save counter
       movb @>01(ix),d                 ; LD D,(IX+$01)     ; Polar y
       movb @>02(ix),@e                ; LD E,(IX+$02)     ; Polar x
       .call @polar_to_screen          ; CALL $B1C6        ; Polar to screen
       movb d,@>08(ix)                 ; LD (IX+$08),D     ; Set y
       movb @e,@>09(ix)                ; LD (IX+$09),E     ; Set x
       movb @status_flags,a            ; LD A,($71EB)      ; Status
       movb a,r0                       ; BIT 2,A           ; Test bit
       andi r0,>0400                   ;                   
       jne  _a4a0                      ; JR NZ,$A4A0       ; If 1, decrement polar y
       ab   one,@>01(ix)               ; INC (IX+$01)      ; Else increment polar y
       jmp  _a4a3                      ; JR $A4A3          ; Skip next
_a4a0:                                 ; >a4a0
       sb   one,@>01(ix)               ; DEC (IX+$01)      ; Decrement polar y
_a4a3:                                 ; >a4a3
       .pop bc                         ; POP BC            ; Restore counter
_a4a4:                                 ; >a4a4
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       a    de,ix                      ; ADD IX,DE         ; Next sprite
       sb   one,b                      ; DJNZ $A47D        ; Loop 32 times
       jne  _a47d                      ;                   
       li   hl,entry_wait_fire+>0019   ; LD HL,$8060       ; Set #R$7000 back to original value
       mov  hl,@center_of_projection   ; LD ($7000),HL     ; ...
       .ret                            ; RET               ; 

