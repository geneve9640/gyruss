* Convert polar to screen coordinates
* 
* Used by the routines at #R$8F0F, #R$8F55, #R$A471, #R$AB72 and #R$ADD1.
* 
* I:IX Pointer to sprite data
* I:D Polar y
* I:E Polar x
* O:D Screen y
* O:E Screen x
* O:Carry flag set if out of screen
polar_to_screen:                       ; >b1c6
       .push ix                        ; PUSH IX           ; 
       .push hl                        ; PUSH HL           ; 
       .push bc                        ; PUSH BC           ; 
       movb @bytes+>0b,a               ; LD A,$0B          ; 11
       ab   d,a                        ; ADD A,D           ; Polar y + 11
       jgt  !                          ; JP M,$B217        ; If this is 128 or more (polar y > 116 or polar y <
       b    @_b217                     ;                   
!
                                                           ; -11), then set position outside screen and return
       movb a,@l                       ; LD L,A            ; Calculate table address, with polar y = -11
                                                           ; corresponding to row 0
       sb   h,h                        ; LD H,$00          ; and polar y = 0 corresponding to row 11
       a    hl,hl                      ; ADD HL,HL         ; (y + 11) * 32
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    hl,hl                      ; ADD HL,HL         ; ...
       movb @e,a                       ; LD A,E            ; x
       movb @e,r0                      ; BIT 4,E           ; Is bit 4 set (top left or lower right quadrants)?
       andi r0,>1000                   ;                   
       jeq  _b1de                      ; JR Z,$B1DE        ; Jump if not
       inv  a                          ; CPL               ; Else invert (0 -> 15, 1 -> 14, etc.)
_b1de:                                 ; >b1de
       andi a,>0f00                    ; AND $0F           ; Use the first 4 inverted bits
       ab   a,a                        ; ADD A,A           ; x2 (2 bytes per x)
       ab   @l,a                       ; ADD A,L           ; Add to address
       movb a,@l                       ; LD L,A            ; ...
       jnc  _b1e6                      ; JR NC,$B1E6       ; TODO: check code. ...
       ab   one,h                      ; INC H             ; ...
_b1e6:                                 ; >b1e6
       li   bc,polar_to_screen_table   ; LD BC,$B21D       ; Lookup table base address
       a    bc,hl                      ; ADD HL,BC         ; Add to address
       movb *hl,a                      ; LD A,(HL)         ; Get table value
       cb   a,@b255                    ; CP $FF            ; If $FF
       jeq  _b217                      ; JR Z,$B217        ; Then set position outside screen and return
       li   ix,center_of_projection    ; LD IX,$7000       ; Center of projection
       movb @e,a                       ; LD A,E            ; x
       srl  a,1                        ; RRCA              ; TODO: check code. Shift right
       ; XOR E                         ; XOR E             ; TODO: check code. Bit 4 is now set if bit 5 (left/right) and bit 4 (top
                                                           ; left/lower right) were different, i.e. top of screen
       movb a,r0                       ; BIT 4,A           ; Test bit 4 (top of screen)
       andi r0,>1000                   ;                   
       movb *hl,a                      ; LD A,(HL)         ; Get table value
       jeq  _b1fd                      ; JR Z,$B1FD        ; Skip negating if not top of screen
       neg a                           ; NEG               ; -table value
_b1fd:                                 ; >b1fd
       ab   *ix,a                      ; ADD A,(IX+$00)    ; +center y ($60)
       sb   @bytes+>04,a               ; SUB $04           ; -4 (adjust for sprite size)
       movb a,d                        ; LD D,A            ; Store as sprite y
       inc  hl                         ; INC HL            ; Next table address
       movb *hl,a                      ; LD A,(HL)         ; Get table value
       movb @e,r0                      ; BIT 5,E           ; Test bit 5 of x (left/right)
       andi r0,>2000                   ;                   
       jne  _b20b                      ; JR NZ,$B20B       ; Skip negating if right
       neg a                           ; NEG               ; -table value
_b20b:                                 ; >b20b
       ab   @>01(ix),a                 ; ADD A,(IX+$01)    ; +center x ($80 or $B5 or ?)
       sb   @bytes+>04,a               ; SUB $04           ; -4 (adjust for sprite size)
       movb a,@e                       ; LD E,A            ; Store as sprite x
       socb a,a                        ; OR A              ; Clear carry flag
_b212:                                 ; >b212
       .pop bc                         ; POP BC            ; Return
       .pop hl                         ; POP HL            ; ...
       .pop ix                         ; POP IX            ; ...
       .ret                            ; RET               ; ...
_b217:                                 ; >b217
       li   de,>f500                   ; LD DE,$F500       ; Set return position outside screen
       ; SCF                           ; SCF               ; TODO: check code. Set carry flag
       jmp  _b212                      ; JR $B212          ; To return

* Polar to screen coordinates lookup table
* 
* 16 (y, x) pairs (32 bytes) for each depth value (polar y) (y, x) are offsets
* from center of screen
polar_to_screen_table:                 ; >b21d
       byte >FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>5C,>78,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF
       byte >FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>5F,>69,>57,>72,>4B,>7B,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF
       byte >FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>5A,>63,>52,>6B,>47,>74,>3E,>7A,>FF,>FF,>FF,>FF,>FF,>FF,>FF,>FF
