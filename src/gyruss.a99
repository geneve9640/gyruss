       movb a,@>08(iy)                 ; LD (IY+$08),A     ; ...
       movb @>04(iy),@l                ; LD L,(IY+$04)     ; Get patterns address
       movb @>05(iy),h                 ; LD H,(IY+$05)     ; ...
