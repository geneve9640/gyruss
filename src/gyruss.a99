       jl   _8c3e                      ; JR C,$8C3E        ; Then skip ahead
       sb   @bytes+>14,a               ; SUB $14           ; - 20
       jmp  _8c16                      ; JR $8C16          ; Loop until small enough

* Init mine sub-stage
* 
* Used by the routines at #R$8BD9 and #R$8C07. Init mine sub-stage when wave >
* 4 or wave = 4 and not chance stage.
init_mine_sub_stage:                   ; >8c1e
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@outcoming_enemies       ; LD ($725C),A      ; Reset outcoming enemies
       movb a,@countdown_to_wave       ; LD ($71F0),A      ; Reset counter
