* Remove shot
* 
* Used by the routines at #R$9934, #R$99A0, #R$99B1 and #R$9A08.
* 
* I:D Color of 'explosion'
* I:IX Sprite data of shot
remove_shot:                           ; >9a1c
       movb @bytes+>04,*ix             ; LD (IX+$00),$04   ; Set sprite type to destroyed
       movb d,@>0b(ix)                 ; LD (IX+$0B),D     ; Set color
       movb @bytes+>0f,@>03(ix)        ; LD (IX+$03),$0F   ; Set animation counter
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       sb   @>06(ix),@>06(ix)          ; LD (IX+$06),$00   ; 
       li   hl,active_shots            ; LD HL,$7253       ; Decrement active shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies (hmm, why here?)
       sb   one,*hl                    ; DEC (HL)          ; ...
       .ret                            ; RET               ; 

