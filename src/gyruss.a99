       movb b,@>03(ix)                 ; LD (IX+$03),B     ; Set counter
       .ret                            ; RET               ; Return to #R$8A41

* Enemy movement: Called with random probability.
* 
* Used by the routine at #R$8878.
_88a7:                                 ; >88a7
       movb @>03(ix),a                 ; LD A,(IX+$03)     ; Get counter
       sb   one,a                      ; DEC A             ; Counter - 1
       movb a,b                        ; LD B,A            ; Store in B
       ab   @>02(ix),a                 ; ADD A,(IX+$02)    ; Add polar x
