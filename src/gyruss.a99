       inc  hl                         ; INC HL            ; Next table address
       movb *hl,a                      ; LD A,(HL)         ; Get MSB
       movb a,@>02(ix)                 ; LD (IX+$02),A     ; Store in tune data buffer
       movb one,@>05(ix)               ; LD (IX+$05),$01   ; Set countdown
       inc  hl                         ; INC HL            ; Next table address
