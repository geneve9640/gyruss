* Init center enemies
* 
* Used by the routine at #R$8024.
init_center_enemies:                   ; >aa7d
       li   hl,center_enemy_map        ; LD HL,$7207       ; Set whole #R$7207 to $FF
       li   de,center_enemy_map+>0001  ; LD DE,$7208       ; ...
       li   bc,>0023                   ; LD BC,$0023       ; ...
       movb @b255,*hl                  ; LD (HL),$FF       ; ...
       .ldir                           ; LDIR              ; ...
       sb   a,a                        ; XOR A             ; A = 0
       movb a,@center_map_entries      ; LD ($722B),A      ; Clear number of map entries
       movb a,@center_enemy_processed  ; LD ($72CD),A      ; Clear center enemy processed
       movb a,@y_counter               ; LD ($72D3),A      ; Clear y counter
       movb a,@x_counter               ; LD ($72D4),A      ; Clear x counter
       ab   one,a                      ; INC A             ; A = 1
       movb a,@y_counter_direction     ; LD ($72D2),A      ; Set y counter direction
       movb @bytes+>e0,a               ; LD A,$E0          ; Set first name used for center enemies in buffer 1
       movb a,@center_enemies_name_1   ; LD ($72CE),A      ; ...
       ab   @bytes+>10,a               ; ADD A,$10         ; First name used for center enemies in buffer 2
       movb a,@center_enemies_name_2   ; LD ($72CF),A      ; ...
       .ret                            ; RET               ; 

* Allocate map entry
* 
* Used by the routines at #R$87D5 and #R$8D21.
* 
* I: A value to place in #R$7207 at an unused spot
allocate_map_entry:                    ; >aaa6
       .push hl                        ; PUSH HL           ; 
       .push de                        ; PUSH DE           ; 
       .push bc                        ; PUSH BC           ; 
       .push af                        ; PUSH AF           ; Save value to write
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of entries
       cb   a,@bytes+>24               ; CP $24            ; If map is full
       jeq  _aade                      ; JR Z,$AADE        ; Then return
       movb @status_flags,a            ; LD A,($71EB)      ; If all waves completed flag is set
       movb a,r0                       ; BIT 1,A           ; The search backwards
       andi r0,>0200                   ;                   
       jne  _aac6                      ; JR NZ,$AAC6       ; Else search forwards
       li   hl,center_enemy_map+>0023  ; LD HL,$722A       ; Start at end of #R$7207
       movb @b255,a                    ; LD A,$FF          ; Byte to search for
_aabd:                                 ; >aabd
       cb   a,*hl                      ; CP (HL)           ; Check byte
       jne  _aac3                      ; JR NZ,$AAC3       ; Break out if not $FF
       dec  hl                         ; DEC HL            ; Previous address
       jmp  _aabd                      ; JR $AABD          ; Loop forever
_aac3:                                 ; >aac3
       inc  hl                         ; INC HL            ; HL now points to group of $FF at the end of buffer
       jmp  _aad1                      ; JR $AAD1          ; Skip next loop
_aac6:                                 ; >aac6
       li   hl,center_enemy_map        ; LD HL,$7207       ; Start at beginning of #R$7207
       movb @b255,a                    ; LD A,$FF          ; Byte to search for
_aacb:                                 ; >aacb
       cb   a,*hl                      ; CP (HL)           ; Check byte
       jeq  _aad1                      ; JR Z,$AAD1        ; Break out if found HL now points to first $FF in buffer
       inc  hl                         ; INC HL            ; Next address
       jmp  _aacb                      ; JR $AACB          ; Loop forever
_aad1:                                 ; >aad1
       .pop af                         ; POP AF            ; Restore value to write
       movb a,*hl                      ; LD (HL),A         ; Set byte to A
       li   hl,center_map_entries      ; LD HL,$722B       ; Increment number of entries
       ab   one,*hl                    ; INC (HL)          ; ...
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
       jmp  _aadf                      ; JR $AADF          ; Skip popping AF
_aade:                                 ; >aade
       .pop af                         ; POP AF            ; 
_aadf:                                 ; >aadf
       .pop bc                         ; POP BC            ; 
       .pop de                         ; POP DE            ; 
       .pop hl                         ; POP HL            ; 
       .ret                            ; RET               ; 

* Deallocate map entry
* 
* Used by the routines at #R$99A0, #R$AB17 and #R$AB53.
* 
* I:HL Address in #R$7207
deallocate_map_entry:                  ; >aae3
       .push hl                        ; PUSH HL           ; Save map address
       movb @b255,*hl                  ; LD (HL),$FF       ; Set entry to $FF
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
       li   hl,center_map_entries      ; LD HL,$722B       ; Decrement number of entries
       sb   one,*hl                    ; DEC (HL)          ; ...
       .pop hl                         ; POP HL            ; Restore map address
       .ret                            ; RET               ; 

* Create enemy sprite from map entry
* 
* Search for value >= $80 in map and deallocate if found. Then allocate a
* sprite with data from map. Used by the routine at #R$80E8.
create_sprite_from_map_entry:          ; >aaf1
       movb @status_flags,a            ; LD A,($71EB)      ; Is all waves completed flag set?
       movb a,r0                       ; BIT 1,A           ; ...
       andi r0,>0200                   ;                   
       jne  !                          ; RET Z             ; Return if not
       .ret                            ;                   
!
       movb a,r0                       ; BIT 2,A           ; Is died flag set?
       andi r0,>0400                   ;                   
       jeq  !                          ; RET NZ            ; Return if so
       .ret                            ;                   
!
       .call @stage_data_addr          ; CALL $84DB        ; Get stage data address in IY
       movb @active_enemies,a          ; LD A,($722C)      ; Get number of active enemies
       cb   a,@>04(iy)                 ; CP (IY+$04)       ; Compare with byte 4 of stage data
       jl   !                          ; RET NC            ; Return if active enemies >= byte 4
       .ret                            ;                   
!
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of map entries
       socb a,a                        ; OR A              ; Return if zero
       jne  !                          ; RET Z             ; ...
       .ret                            ;                   
!
       li   hl,center_enemy_map+>0023  ; LD HL,$722A       ; End of #R$7207
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       movb @bytes+>80,a               ; LD A,$80          ; Value to compare with
_ab10:                                 ; >ab10
       cb   a,*hl                      ; CP (HL)           ; Test byte
       jhe  _ab17                      ; JR NC,$AB17       ; If >= $80 then skip ahead
       dec  hl                         ; DEC HL            ; Previous byte
       sb   one,b                      ; DJNZ $AB10        ; Loop through whole map
       jne  _ab10                      ;                   
       .ret                            ; RET               ; Not found - return
* Create sprite
_ab17:                                 ; >ab17
       movb *hl,a                      ; LD A,(HL)         ; Get value from map
       .push af                        ; PUSH AF           ; Save it
       .call @deallocate_map_entry     ; CALL $AAE3        ; Deallocate map entry
       .call @polar_coord_from_map     ; CALL $AB38        ; Now DE contains polar y,x
       .rst >28                        ; RST $28           ; Allocate sprite
       movb @e,@>02(ix)                ; LD (IX+$02),E     ; Set polar x
       movb d,@>01(ix)                 ; LD (IX+$01),D     ; Set polar x
       movb @bytes+>10,*ix             ; LD (IX+$00),$10   ; Set sprite type
       .pop af                         ; POP AF            ; Restore value from map
       movb a,@>0b(ix)                 ; LD (IX+$0B),A     ; Use it as color (may temporary since it's >= $80?)
       socb @bits+0,@>07(ix)           ; SET 0,(IX+$07)    ; Set flag
       .rst >30                        ; RST $30           ; Load sprite pattern
       li   hl,active_enemies          ; LD HL,$722C       ; Increment number of active enemies
       ab   one,*hl                    ; INC (HL)          ; ...
       .ret                            ; RET               ; 

* Sprite coordinates from map
* 
* Returns polar sprite coordinates from an entry in the map. Used by the
* routines at #R$87F5, #R$9861, #R$AB17 and #R$AB72.
* 
* I:HL Map address
* O:D Polar y
* O:E Polar x
polar_coord_from_map:                  ; >ab38
       .push hl                        ; PUSH HL           ; Save map address
       li   de,center_enemy_map        ; LD DE,$7207       ; Base address of map
       socb a,a                        ; OR A              ; Clear carry
       s    de,hl                      ; SBC HL,DE         ; Map address - map base (offset 0 - 35)
       a    hl,hl                      ; ADD HL,HL         ; x2 = offset
       li   de,start_coordinates_table ; LD DE,$AC87       ; Table address
       a    de,hl                      ; ADD HL,DE         ; Add offset
       movb @x_counter,a               ; LD A,($72D4)      ; Get x counter
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@e                       ; LD E,A            ; Store in E
       inc  hl                         ; INC HL            ; Next table address
       movb @y_counter,a               ; LD A,($72D3)      ; Get y counter
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       movb a,d                        ; LD D,A            ; Store in D
       .pop hl                         ; POP HL            ; Restore map address
       .ret                            ; RET               ; 

* Deallocate sprite from map
* 
* Search for sprite pattern in map and deallocate if found. Used by the
* routines at #R$9934 and #R$9A49.
* 
* I: IX sprite data
deallocate_sprite_from_map:            ; >ab53
       movb @>07(ix),r0                ; BIT 6,(IX+$07)    ; Test bit
       andi r0,>4000                   ;                   
       jne  !                          ; RET Z             ; Return if not set
       .ret                            ;                   
!
       .push hl                        ; PUSH HL           ; 
       .push bc                        ; PUSH BC           ; 
       li   hl,center_enemy_map        ; LD HL,$7207       ; Map address
       movb @bytes+>24,b               ; LD B,$24          ; Size of map
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get sprite pattern
       socb @bytes+>80,a               ; OR $80            ; Set bit 7
_ab64:                                 ; >ab64
       cb   a,*hl                      ; CP (HL)           ; Compare with map entry
       jeq  _ab6c                      ; JR Z,$AB6C        ; Break out if found
       inc  hl                         ; INC HL            ; Next map address
       sb   one,b                      ; DJNZ $AB64        ; Loop through whole map
       jne  _ab64                      ;                   
       jmp  _ab6f                      ; JR $AB6F          ; Not found - return
_ab6c:                                 ; >ab6c
       .call @deallocate_map_entry     ; CALL $AAE3        ; Deallocate map entry
_ab6f:                                 ; >ab6f
       .pop bc                         ; POP BC            ; 
       .pop hl                         ; POP HL            ; 
       .ret                            ; RET               ; 

* Display distant enemies at the center of the screen
* 
* Used by the routines at #R$8024, #R$8139, #R$832A, #R$846B, #R$A33B and
* #R$A3E1.
display_center_enemies:                ; >ab72
       li   hl,update_counters_countdown ; LD HL,$72CB       ; Countdown for when to update counters
       sb   one,*hl                    ; DEC (HL)          ; -1
       jlt  !                          ; JP P,$ABA0        ; If > 0, then don't update other counters
       b    @_aba0                     ;                   
!
       movb @bytes+>0f,*hl             ; LD (HL),$0F       ; Reset to 15
       movb @y_counter,a               ; LD A,($72D3)      ; Y counter
       li   hl,y_counter_direction     ; LD HL,$72D2       ; Add direction 1 or -1
       ab   *hl,a                      ; ADD A,(HL)        ; ...
       movb a,@y_counter               ; LD ($72D3),A      ; Store y counter
       jlt  !                          ; JP P,$AB8A        ; If y counter > 0 then skip ahead
       b    @_ab8a                     ;                   
!
       neg a                           ; NEG               ; Else make positive
_ab8a:                                 ; >ab8a
       cb   a,one                      ; CP $01            ; If not 1
       jne  _ab9b                      ; JR NZ,$AB9B       ; Then skip ahead
       movb *hl,a                      ; LD A,(HL)         ; IF 1, get direction
       neg a                           ; NEG               ; Reverse direction
       movb a,*hl                      ; LD (HL),A         ; Store direction
       movb @x_counter,a               ; LD A,($72D4)      ; x counter
       ab   one,a                      ; INC A             ; +1
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@x_counter               ; LD ($72D4),A      ; Store x counter
_ab9b:                                 ; >ab9b
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Set flag
       socb @bits+0,*hl                ; SET 0,(HL)        ; ...
_aba0:                                 ; >aba0
       movb @center_enemy_processed,a  ; LD A,($72CD)      ; Get enemy to process
       cb   a,@bytes+>24               ; CP $24            ; If 36,
       jne  !                          ; JP Z,$ABFF        ; Then jump to update name table
       b    @display_center_enemies_names ;                   
!
       socb a,a                        ; OR A              ; If 0 then erase all enemies
       jne  _abc4                      ; JR NZ,$ABC4       ; Else jump ahead
       mov  @center_enemies_name_2,hl  ; LD HL,($72CF)     ; Get first name used for center enemies
       sb   h,h                        ; LD H,$00          ; Set MSB to 0
       a    hl,hl                      ; ADD HL,HL         ; Multiply by 8
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    hl,hl                      ; ADD HL,HL         ; ...
       li   de,>0000                   ; LD DE,$0000       ; Add pattern table address
       a    de,hl                      ; ADD HL,DE         ; ...
       mov  hl,@center_enemies_pattern ; LD ($72D0),HL     ; Save VDP address
       li   de,>0080                   ; LD DE,$0080       ; Clear 16 patterns
       sb   a,a                        ; XOR A             ; ...
       .call @fill_vram                ; CALL $1F82        ; FILL_VRAM
       movb @center_enemy_processed,a  ; LD A,($72CD)      ; Get enemy to process
_abc4:                                 ; >abc4
       movb a,@c                       ; LD C,A            ; BC = enemy to process
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,center_enemy_map        ; LD HL,$7207       ; Add map address
       a    bc,hl                      ; ADD HL,BC         ; ...
       movb *hl,r0                     ; BIT 7,(HL)        ; If unallocated
       andi r0,>8000                   ;                   
       jeq  !                          ; JP NZ,$ABFA       ; Then update counter and return
       b    @_abfa                     ;                   
!
       .call @polar_coord_from_map     ; CALL $AB38        ; Now DE contains polar y,x
       .call @polar_to_screen          ; CALL $B1C6        ; Convert polar to screen
       .push de                        ; PUSH DE           ; Save screen coordinates
       movb *hl,a                      ; LD A,(HL)         ; Get map value
       srl  a,1                        ; RRA               ; TODO: check code. Isolate 3 bits
       srl  a,1                        ; RRA               ; TODO: check code. ...
       andi a,>0e00                    ; AND $0E           ; ...
       movb a,@c                       ; LD C,A            ; And load into BC
       sb   b,b                        ; LD B,$00          ; ...
       li   hl,pixel_offsets_table     ; LD HL,$ACCF       ; Add table base address
       a    bc,hl                      ; ADD HL,BC         ; ...
       .call @plot_pixel               ; CALL $AC47        ; Plot pixel
       movb *hl,a                      ; LD A,(HL)         ; Get x offset
       socb a,a                        ; OR A              ; If zero
       jeq  _abef                      ; JR Z,$ABEF        ; Then skip ahead
       ab   @e,a                       ; ADD A,E           ; Add to screen x
       movb a,@e                       ; LD E,A            ; ...
       .call @plot_pixel               ; CALL $AC47        ; Plot pixel
_abef:                                 ; >abef
       inc  hl                         ; INC HL            ; Next table address
       .pop de                         ; POP DE            ; Restore screen coordinates
       movb *hl,a                      ; LD A,(HL)         ; Get y offset
       socb a,a                        ; OR A              ; If zero
       jeq  _abfa                      ; JR Z,$ABFA        ; Then skip ahead
       ab   d,a                        ; ADD A,D           ; Add to screen x
       movb a,d                        ; LD D,A            ; ...
       .call @plot_pixel               ; CALL $AC47        ; Plot pixel
_abfa:                                 ; >abfa
       li   hl,center_enemy_processed  ; LD HL,$72CD       ; Update counter
       ab   one,*hl                    ; INC (HL)          ; ...
       .ret                            ; RET               ; 

* Update name table to display center enemies
* 
* Used by the routine at #R$AB72.
display_center_enemies_names:          ; >abff
       li   hl,center_enemies_redraw   ; LD HL,$72CC       ; Test flag
       movb *hl,r0                     ; BIT 0,(HL)        ; If not set
       andi r0,>0100                   ;                   
       jne  !                          ; RET Z             ; Then return
       .ret                            ;                   
!
       szcb @bits+0,*hl                ; RES 0,(HL)        ; Else reset flag
       movb @center_map_entries,a      ; LD A,($722B)      ; Get number of map entries
       socb a,a                        ; OR A              ; Skip ahead if zero
       jeq  erase_center_enemies       ; JR Z,$AC32        ; ...
       li   de,>194e                   ; LD DE,$194E       ; Name table VDP address
       movb @center_enemies_name_2,a   ; LD A,($72CF)      ; Get first name used for center enemies
       movb @bytes+>04,@c              ; LD C,$04          ; 4 rows
_ac15:                                 ; >ac15
       movb @bytes+>04,b               ; LD B,$04          ; 4 columns
_ac17:                                 ; >ac17
       .rst >10                        ; RST $10           ; Write VDP byte
       ab   one,a                      ; INC A             ; Next name
       inc  de                         ; INC DE            ; Next VDP address
       sb   one,b                      ; DJNZ $AC17        ; Loop for 4 columns
       jne  _ac17                      ;                   
       li   hl,>001c                   ; LD HL,$001C       ; One row down
       a    de,hl                      ; ADD HL,DE         ; ...
       .ex_de_hl                       ; EX DE,HL          ; ...
       sb   one,@c                     ; DEC C             ; Row counter
       jne  _ac15                      ; JR NZ,$AC15       ; Loop for 4 rows
       mov  @center_enemies_name_1,hl  ; LD HL,($72CE)     ; Swap #R$72CE and #R$72CF
       movb @l,a                       ; LD A,L            ; ...
       movb h,@l                       ; LD L,H            ; ...
       movb a,h                        ; LD H,A            ; ...
       mov  hl,@center_enemies_name_1  ; LD ($72CE),HL     ; ...
       sb   a,a                        ; XOR A             ; Reset center enemy to process
       movb a,@center_enemy_processed  ; LD ($72CD),A      ; ...
       .ret                            ; RET               ; 

* Erase center enemies
* 
* Used by the routine at #R$ABFF.
erase_center_enemies:                  ; >ac32
       li   de,>194e                   ; LD DE,$194E       ; Name table VDP address
       sb   a,a                        ; XOR A             ; Space
       movb @bytes+>04,@c              ; LD C,$04          ; 4 rows
_ac38:                                 ; >ac38
       movb @bytes+>04,b               ; LD B,$04          ; 4 columns
_ac3a:                                 ; >ac3a
       .rst >10                        ; RST $10           ; Write VDP byte
       inc  de                         ; INC DE            ; Next VDP address
       sb   one,b                      ; DJNZ $AC3A        ; Loop for 4 columns
       jne  _ac3a                      ;                   
       li   hl,>001c                   ; LD HL,$001C       ; One row down
       a    de,hl                      ; ADD HL,DE         ; ...
       .ex_de_hl                       ; EX DE,HL          ; ...
       sb   one,@c                     ; DEC C             ; Row counter
       jne  _ac38                      ; JR NZ,$AC38       ; Lopp for 4 rows
       .ret                            ; RET               ; 

* Plot pixel
* 
* Plot pixel in center enemies bit map. Used by the routine at #R$AB72.
* 
* D: Screen y
* E: Screen x
* I: HL Address in #R$ACCF
plot_pixel:                            ; >ac47
       .push hl                        ; PUSH HL           ; 
       movb d,a                        ; LD A,D            ; Screen y
       sb   @bytes+>50,a               ; SUB $50           ; - 80
       srl  a,1                        ; SRL A             ; / 2
       andi a,>fc00                    ; AND $FC           ; Y offset (byte offset * 4)
       movb a,@c                       ; LD C,A            ; Store in C
       movb @e,a                       ; LD A,E            ; Screen x
       sb   @bytes+>70,a               ; SUB $70           ; - 112
       jnc  _ac56                      ; JR NC,$AC56       ; TODO: check code. If < 0
       sb   a,a                        ; XOR A             ; Then set to 0
_ac56:                                 ; >ac56
       cb   a,@bytes+>20               ; CP $20            ; If < 32
       jl   _ac5c                      ; JR C,$AC5C        ; Then skip ahead
       movb @bytes+>0f,a               ; LD A,$0F          ; ELse set to 15
_ac5c:                                 ; >ac5c
       srl  a,1                        ; SRL A             ; / 8
       srl  a,1                        ; SRL A             ; ...
       srl  a,1                        ; SRL A             ; ...
       ab   @c,a                       ; ADD A,C           ; Add y offset
       ab   a,a                        ; ADD A,A           ; * 8
       ab   a,a                        ; ADD A,A           ; ...
       ab   a,a                        ; ADD A,A           ; ...
       movb a,@c                       ; LD C,A            ; Store in C
       movb d,a                        ; LD A,D            ; Screen y
       andi a,>0700                    ; AND $07           ; Pixel offset within pattern
       ab   @c,a                       ; ADD A,C           ; Add to offset
       movb a,@c                       ; LD C,A            ; Store in C
       sb   b,b                        ; LD B,$00          ; B = 0
       mov  @center_enemies_pattern,hl ; LD HL,($72D0)     ; Get VDP address of centre enemy patterns
       a    bc,hl                      ; ADD HL,BC         ; VDP address
       movb @e,a                       ; LD A,E            ; Screen x
       andi a,>0700                    ; AND $07           ; Pixel x offset within pattern
       movb @bytes+>80,b               ; LD B,$80          ; Leftmost pixel
       jeq  _ac7e                      ; JR Z,$AC7E        ; Skip ahead if zero offset
_ac79:                                 ; >ac79
       srl  b,1                        ; SRL B             ; Shift right 0-7 times
       sb   one,a                      ; DEC A             ; ...
       jne  _ac79                      ; JR NZ,$AC79       ; ...
_ac7e:                                 ; >ac7e
       .ex_de_hl                       ; EX DE,HL          ; DE = VDP address, HL = coordinates
       .call @vdp_read_byte            ; CALL $9AD0        ; Read VDP byte
       socb b,a                        ; OR B              ; Apply pixel
       .rst >10                        ; RST $10           ; Write VDP byte
       .ex_de_hl                       ; EX DE,HL          ; DE = coordinates
       .pop hl                         ; POP HL            ; 
       .ret                            ; RET               ; 

* Start coordinates for sprites
* 
* Polar x, polar y
start_coordinates_table:               ; >ac87
       byte >05,>28,>10,>28,>1A,>28,>25,>28,>30,>28,>3A,>28
       byte >00,>28,>0A,>28,>15,>28,>20,>28,>2A,>28,>35,>28
       byte >05,>26,>10,>26,>1A,>26,>25,>26,>30,>26,>3A,>26
       byte >00,>26,>0A,>26,>15,>26,>20,>26,>2A,>26,>35,>26
       byte >05,>24,>10,>24,>1A,>24,>25,>24,>30,>24,>3A,>24
       byte >00,>24,>0A,>24,>15,>24,>20,>24,>2A,>24,>35,>24

* Table of pixel offsets for drawing center enemies
pixel_offsets_table:                   ; >accf
       byte >01,>00,>FF,>01,>00,>FF,>01,>01
       byte >01,>00,>FF,>01,>00,>01,>FF,>FF

* Init sprite data
* 
* Used by the routines at #R$82BF, #R$90D6 and #R$A33B.
init_sprite_data:                      ; >acdf
       li   ix,sprite_data             ; LD IX,$7002       ; Address of sprite data
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       movb @bytes+>20,b               ; LD B,$20          ; Number of sprites
       sb   a,a                        ; XOR A             ; 
       movb a,@allocated_sprites       ; LD ($7182),A      ; Number of allocated sprites
_acec:                                 ; >acec
       movb a,@>0a(ix)                 ; LD (IX+$0A),A     ; Set pattern
* This entry point is used by the routine at #R$AC47.
       movb @b255,*ix                  ; LD (IX+$00),$FF   ; Set as unallocated
       ab   one,a                      ; INC A             ; 
       a    de,ix                      ; ADD IX,DE         ; Advance to next sprite
       sb   one,b                      ; DJNZ $ACEC        ; Loop for 32 sprites
       jne  _acec                      ;                   
       .ret                            ; RET               ; 

* Upload sprite data to VDP
* 
* Used by the routines at #R$832A, #R$84B1, #R$90D6, #R$A33B and #R$A3E1.
upload_sprite_data:                    ; >acf9
       mov  @sat_vdp_address,de        ; LD DE,($73F2)     ; VDP address of sprite allocation table
       li   hl,allocated_sprites       ; LD HL,$7182       ; Get number of allocated sprites
       movb *hl,a                      ; LD A,(HL)         ; ...
       movb a,b                        ; LD B,A            ; Store in B
_ad02:                                 ; >ad02
       .push bc                        ; PUSH BC           ; Save counter
       inc  hl                         ; INC HL            ; Next allocation
       movb *hl,a                      ; LD A,(HL)         ; Get sprite index
       ab   a,a                        ; ADD A,A           ; * 2
       ab   a,a                        ; ADD A,A           ; * 4
       movb a,@c                       ; LD C,A            ; 
       ab   a,a                        ; ADD A,A           ; * 8
       ab   @c,a                       ; ADD A,C           ; * 12 (may overflow?)
       .push hl                        ; PUSH HL           ; Save sprite allocation table address
       li   hl,sprite_data+>0008       ; LD HL,$700A       ; First y address in sprite data table
       .rst >08                        ; RST $08           ; Add A to HL
       li   bc,>0004                   ; LD BC,$0004       ; Write 4 bytes for each sprite
       .push de                        ; PUSH DE           ; Save destination
       .call @write_vram               ; CALL $1FDF        ; WRITE_VRAM
       .pop hl                         ; POP HL            ; Restore destination
       li   bc,>0004                   ; LD BC,$0004       ; Add 4 to destination
       a    bc,hl                      ; ADD HL,BC         ; ...
       .ex_de_hl                       ; EX DE,HL          ; ...
       .pop hl                         ; POP HL            ; Restore sprite allocation table address
       .pop bc                         ; POP BC            ; Restore counter
       sb   one,b                      ; DJNZ $AD02        ; Loop for each sprite
       jne  _ad02                      ;                   
       movb @bytes+>d0,a               ; LD A,$D0          ; End marker byte
       .rst >10                        ; RST $10           ; Write VDP byte
       movb @allocated_sprites,a       ; LD A,($7182)      ; Get number of allocation sprites
       cb   a,@bytes+>05               ; CP $05            ; Is it < 5
       jhe  !                          ; RET C             ; Then return
       .ret                            ;                   
!
* Rotate sprite allocation table
       sb   @bytes+>04,a               ; SUB $04           ; 
       movb a,@c                       ; LD C,A            ; Number of sprites above 4
       sb   b,b                        ; LD B,$00          ; 
       .push bc                        ; PUSH BC           ; 
       li   hl,sprite_allocation_table+>0002 ; LD HL,$7185       ; From 2nd entry of allocation table
       li   de,buffer                  ; LD DE,$71A3       ; To buffer
       li   bc,>0002                   ; LD BC,$0002       ; Copy 2 bytes
       .ldir                           ; LDIR              ; 
       li   de,sprite_allocation_table+>0002 ; LD DE,$7185       ; From 4th to 2nd entry of allocation table
       .pop bc                         ; POP BC            ; Copy number of sprites above 4 bytes
       .ldir                           ; LDIR              ; 
       li   hl,buffer                  ; LD HL,$71A3       ; From buffer to end of allocation table
       li   bc,>0002                   ; LD BC,$0002       ; Copy 2 bytes
       .ldir                           ; LDIR              ; 
       .ret                            ; RET               ; 

* Allocate sprite (RST $28)
* 
* Used by the routine at #R$8018.
* 
* O:IX holds sprite address
allocate_sprite:                       ; >ad49
       .push hl                        ; PUSH HL           ; 
       .push de                        ; PUSH DE           ; 
       .push bc                        ; PUSH BC           ; 
       li   hl,sprite_data             ; LD HL,$7002       ; Address of sprite data
       li   de,>000c                   ; LD DE,$000C       ; Size of each sprite
       li   bc,write_vram+>0021        ; LD BC,$2000       ; Number of sprites and sprite index
       movb @bytes+>7e,a               ; LD A,$7E          ; 
_ad57:                                 ; >ad57
       cb   a,*hl                      ; CP (HL)           ; 
       jl   _ad64                      ; JR C,$AD64        ; If >= $7F ($FF from init), sprite is available
       ab   one,@c                     ; INC C             ; Sprite index++
       a    de,hl                      ; ADD HL,DE         ; Advance to next sprite
       sb   one,b                      ; DJNZ $AD57        ; Loop for up to 32 sprites
       jne  _ad57                      ;                   
       li   ix,>03e8                   ; LD IX,$03E8       ; Not found, set to address in ROM (?)
       jmp  _ad87                      ; JR $AD87          ; And return
_ad64:                                 ; >ad64
       .push hl                        ; PUSH HL           ; Save sprite address
       movb *hl,r0                     ; BIT 7,(HL)        ; Is bit 7 set, i.e. $FF?
       andi r0,>8000                   ;                   
       jeq  _ad75                      ; JR Z,$AD75        ; If not, skip recoding in allocation table
       li   hl,allocated_sprites       ; LD HL,$7182       ; Allocated sprites
       ab   one,*hl                    ; INC (HL)          ; Record one more
       movb *hl,a                      ; LD A,(HL)         ; Read number back
       ab   @l,a                       ; ADD A,L           ; Add number to HL
       movb a,@l                       ; LD L,A            ; ...
       joc  !                          ; JP NC,$AD74       ; TODO: check code. ...
       b    @_ad74                     ;                   
!
       ab   one,h                      ; INC H             ; ...
_ad74:                                 ; >ad74
       movb @c,*hl                     ; LD (HL),C         ; Record sprite index in table
_ad75:                                 ; >ad75
       .pop ix                         ; POP IX            ; IX now holds sprite address
       sb   @>07(ix),@>07(ix)          ; LD (IX+$07),$00   ; Init sprite
       sb   @>03(ix),@>03(ix)          ; LD (IX+$03),$00   ; Set counter to 0
       movb @b255,@>04(ix)             ; LD (IX+$04),$FF   ; Set loaded patten index to none
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
_ad87:                                 ; >ad87
       .pop bc                         ; POP BC            ; 
       .pop de                         ; POP DE            ; 
       .pop hl                         ; POP HL            ; 
       .ret                            ; RET               ; 

* Load sprite pattern (RST $30)
* 
* Ensure sprite pattern is loaded and set screen position Used by the routine
* at #R$801B.
* 
* I:IX Pointer to sprite data
load_sprite_pattern:                   ; >ad8b
       .push hl                        ; PUSH HL           ; 
       .push de                        ; PUSH DE           ; 
       .push bc                        ; PUSH BC           ; 
       .push iy                        ; PUSH IY           ; 
       movb *ix,@e                     ; LD E,(IX+$00)     ; DE = Sprite type
       sb   d,d                        ; LD D,$00          ; ...
       li   hl,graphics_pointer_offsets_table ; LD HL,$B8DD       ; Table of offsets for each sprite type into table at
                                                           ; #R$B8FA
       a    de,hl                      ; ADD HL,DE         ; Add sprite type
       movb *hl,@e                     ; LD E,(HL)         ; Get graphics pointer offset for sprite type
       li   hl,graphics_pointers_table ; LD HL,$B8FA       ; Table of pointers to graphics
       a    de,hl                      ; ADD HL,DE         ; HL now points to graphics pointer (control word)
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get polar y, which determines which scale we want
       li   de,>0000                   ; LD DE,$0000       ; Pattern index within sprite type
       movb a,r0                       ; BIT 7,A           ; If bit 7 of polar y is set, skip ahead with E=0
       andi r0,>8000                   ;                   
       jne  _adb7                      ; JR NZ,$ADB7       ; ...
       cb   a,@bytes+>15               ; CP $15            ; Skip ahead if polar y < 21
       jl   _adb7                      ; JR C,$ADB7        ; ...
       ab   one,@e                     ; INC E             ; Else set E = 1
       cb   a,@bytes+>1a               ; CP $1A            ; Skip ahead if polar y < 26
       jl   _adb7                      ; JR C,$ADB7        ; ...
       ab   one,@e                     ; INC E             ; Else set E = 2
       cb   a,@bytes+>22               ; CP $22            ; Skip ahead if polar y < 34
       jl   _adb7                      ; JR C,$ADB7        ; ...
       ab   one,@e                     ; INC E             ; Else set E = 3
_adb7:                                 ; >adb7
       movb @e,a                       ; LD A,E            ; A = pattern index
       cb   a,*hl                      ; CP (HL)           ; Compare with control word LSB (number of patterns for
                                                           ; sprite type)
       jl   _adbd                      ; JR C,$ADBD        ; Jump if number of patterns > pattern index (?)
       movb *hl,a                      ; LD A,(HL)         ; Get number of patterns
       sb   one,a                      ; DEC A             ; Minus 1
_adbd:                                 ; >adbd
       inc  hl                         ; INC HL            ; Advance to MSB (transformation)
       movb *hl,b                      ; LD B,(HL)         ; B = transformation
       movb a,@c                       ; LD C,A            ; C = number of patterns - 1
       movb @>02(ix),a                 ; LD A,(IX+$02)     ; Get polar x
       ab   @bytes+>02,a               ; ADD A,$02         ; Plus 2
       andi a,>3f00                    ; AND $3F           ; Mod 64
       movb a,@>05(ix)                 ; LD (IX+$05),A     ; Save in sprite data
       ab   one,b                      ; INC B             ; If transformation = 0
       sb   one,b                      ; DEC B             ; ...
       jne  _add1                      ; JR NZ,$ADD1       ; Then skip ahead
       sb   a,a                        ; XOR A             ; Else set A = 0
       jmp  _add7                      ; JR $ADD7          ; And skip ahead
_add1:                                 ; >add1
       srl  a,1                        ; SRL A             ; Divide polar x by 2
       sb   one,b                      ; DJNZ $ADD1        ; B times
       jne  _add1                      ;                   
       ab   a,a                        ; ADD A,A           ; * 4
       ab   a,a                        ; ADD A,A           ; ...
_add7:                                 ; >add7
       ab   @c,a                       ; ADD A,C           ; + number of patterns - 1
       movb a,b                        ; LD B,A            ; Copy result into B, which is the index of pattern to
                                                           ; fetch within sprite type
       cb   a,@>04(ix)                 ; CP (IX+$04)       ; Same as existing?
       jeq  _ae11                      ; JR Z,$AE11        ; If so, skip ahead
       movb a,@>04(ix)                 ; LD (IX+$04),A     ; Save new value
       movb *ix,@l                     ; LD L,(IX+$00)     ; HL = Sprite type
       sb   h,h                        ; LD H,$00          ; ...
       a    hl,hl                      ; ADD HL,HL         ; * 2
       li   de,sprite_pattern_vdp_addrs_table ; LD DE,$72E0       ; Table address
       a    de,hl                      ; ADD HL,DE         ; #R$72E0 + sprite type * 2
       movb *hl,@e                     ; LD E,(HL)         ; Get LSB of VDP address
       inc  hl                         ; INC HL            ; TO MSB
       movb *hl,d                      ; LD D,(HL)         ; Get MSB of VDP address
       movb b,@l                       ; LD L,B            ; HL = Index of pattern to fetch within sprite type
       sb   h,h                        ; LD H,$00          ; ...
       a    hl,hl                      ; ADD HL,HL         ; Multiply by 8
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    hl,hl                      ; ADD HL,HL         ; ...
       a    de,hl                      ; ADD HL,DE         ; And add base VDP address
       .ex_de_hl                       ; EX DE,HL          ; Move HL into DE, which becomes source address
       li   hl,buffer                  ; LD HL,$71A3       ; Buffer
       li   bc,>0008                   ; LD BC,$0008       ; Read 8 bytes
       .call @write_vram+>0003         ; CALL $1FE2        ; READ_VRAM
       movb @>0a(ix),a                 ; LD A,(IX+$0A)     ; Get pattern
       ab   a,a                        ; ADD A,A           ; Multiply by 8
       ab   a,a                        ; ADD A,A           ; ...
       ab   a,a                        ; ADD A,A           ; ...
       movb a,@e                       ; LD E,A            ; ...
       movb @bytes+>08,d               ; LD D,$08          ; DE = $800 + pattern * 8
       li   hl,buffer                  ; LD HL,$71A3       ; Source
       li   bc,>0008                   ; LD BC,$0008       ; Write 8 bytes
       .call @write_vram               ; CALL $1FDF        ; WRITE_VRAM
_ae11:                                 ; >ae11
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,one                      ; CP $01            ; If 1, i.e. ship exhaust
       jeq  _ae2b                      ; JR Z,$AE2B        ; Then skip ahead
       movb @>01(ix),d                 ; LD D,(IX+$01)     ; Polar y
       movb @>02(ix),@e                ; LD E,(IX+$02)     ; Polar x
       .call @polar_to_screen          ; CALL $B1C6        ; Polar to screen
       movb d,@>08(ix)                 ; LD (IX+$08),D     ; Set y
       movb @e,@>09(ix)                ; LD (IX+$09),E     ; Set x
       joc  handle_off_screen_sprite   ; JR C,$AE54        ; TODO: check code. If carry, sprite is outside visible screen, skip ahead
       jmp  _ae4e                      ; JR $AE4E          ; Return
_ae2b:                                 ; >ae2b
       li   hl,exhaust_position_table  ; LD HL,$AFDD       ; If sprite type is ship exhaust, set HL to table address
       movb @>04(ix),a                 ; LD A,(IX+$04)     ; Pattern index
       andi a,>0300                    ; AND $03           ; Mod 4
       jne  _ae3f                      ; JR NZ,$AE3F       ; If not zero, skip ahead
       movb @>05(ix),a                 ; LD A,(IX+$05)     ; Get polar x (saved by #R$ADC7?)
       srl  a,1                        ; RRA               ; TODO: check code. / 2
       andi a,>1e00                    ; AND $1E           ; 0, 2, 4 ... $1E
       li   hl,exhaust_position_table+>0002 ; LD HL,$AFDF       ; #R$AFDD+2
       .rst >08                        ; RST $08           ; Add A to HL
_ae3f:                                 ; >ae3f
       movb @sprite_data+>0008,a       ; LD A,($700A)      ; Ship screen y
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       movb a,@>08(ix)                 ; LD (IX+$08),A     ; Set y
       inc  hl                         ; INC HL            ; Next table address
       movb @sprite_data+>0009,a       ; LD A,($700B)      ; Ship screen x
       ab   *hl,a                      ; ADD A,(HL)        ; Add table value
       movb a,@>09(ix)                 ; LD (IX+$09),A     ; Set x
* This entry point is used by the routines at #R$AE54 and #R$AE75.
_ae4e:                                 ; >ae4e
       .pop iy                         ; POP IY            ; 
       .pop bc                         ; POP BC            ; 
       .pop de                         ; POP DE            ; 
       .pop hl                         ; POP HL            ; 
       .ret                            ; RET               ; 

* Handle sprite outside visible screen
* 
* Used by the routine at #R$ADD1.
handle_off_screen_sprite:              ; >ae54
       movb *ix,a                      ; LD A,(IX+$00)     ; Get sprite type
       cb   a,@bytes+>0c               ; CP $0C            ; If < $0C
       jl   _ae86                      ; JR C,$AE86        ; Then set off-screen values and return
       cb   a,@bytes+>0e               ; CP $0E            ; If >= $0C and < $0E
       jl   _ae67                      ; JR C,$AE67        ; Then jump ahead
       cb   a,@bytes+>12               ; CP $12            ; If >= $0E and < $12
       jl   _ae4e                      ; JR C,$AE4E        ; Then just return
       cb   a,@bytes+>18               ; CP $18            ; If >= $18
       jhe  _ae4e                      ; JR NC,$AE4E       ; Then just return
_ae67:                                 ; >ae67
       cb   a,@bytes+>12               ; CP $12            ; If >= $12 and < $12 (not possible)
       jl   _ae75                      ; JR C,$AE75        ; Then decrement total enemies
       cb   a,@bytes+>14               ; CP $14            ; If >= $14 and < $18
       jhe  _ae75                      ; JR NC,$AE75       ; Then decrement total enemies
       li   hl,active_enemy_shots      ; LD HL,$7252       ; Decrement active enemy shots
       sb   one,*hl                    ; DEC (HL)          ; ...
       jmp  _ae86                      ; JR $AE86          ; Set off-screen values and return
_ae75:                                 ; >ae75
       li   hl,total_enemies           ; LD HL,$7206       ; Decrement total enemies
       sb   one,*hl                    ; DEC (HL)          ; ...
       cb   a,@bytes+>15               ; CP $15            ; If < $15
       jl   _ae86                      ; JR C,$AE86        ; Then set off-screen values and return
       cb   a,@bytes+>18               ; CP $18            ; If >= $18
       jhe  _ae86                      ; JR NC,$AE86       ; Then set off-screen values and return
       li   hl,other_flags             ; LD HL,$7256       ; $15 - $17 Reset flag
       szcb @bits+3,*hl                ; RES 3,(HL)        ; ...
_ae86:                                 ; >ae86
       movb @bytes+>7f,*ix             ; LD (IX+$00),$7F   ; Set as not allocated
       sb   @>09(ix),@>09(ix)          ; LD (IX+$09),$00   ; Set x
       movb @bytes+>f8,@>08(ix)        ; LD (IX+$08),$F8   ; Set y
       jmp  _ae4e                      ; JR $AE4E          ; 

* Upload sprite patterns
* 
* Fill VDP RAM from $2100 to $3868 with sprite patterns that may be rotated and
* flipped. One new pattern is generated with each call. Builds a table of VDP
* addresses in #R$72E0. Used by the routine at #R$90D6.
upload_sprite_patterns:                ; >ae94
       movb @sprite_type_processed,a   ; LD A,($72D5)      ; Get sprite type
       cb   a,@b255                    ; CP $FF            ; If maxed out
       jne  !                          ; RET Z             ; Then return
       .ret                            ;                   
!
       mov  @upload_destination,hl     ; LD HL,($72D8)     ; Get destination address (only used locally)
       movb h,a                        ; LD A,H            ; Is it zero?
       socb @l,a                       ; OR L              ; ...
       jne  _aead                      ; JR NZ,$AEAD       ; No - skip ahead
       li   hl,write_vram+>0121        ; LD HL,$2100       ; Yes - set it to $2100
       mov  hl,@upload_destination     ; LD ($72D8),HL     ; ...
       li   hl,sprite_pattern_vdp_addrs_table ; LD HL,$72E0       ; Set source to #R$72E0 (pointer to a RAM block)
       mov  hl,@upload_source          ; LD ($72DC),HL     ; ...
_aead:                                 ; >aead
       movb @transformation_processed,a ; LD A,($72D6)      ; Get transformation process
       li   hl,pattern_processed       ; LD HL,$72D7       ; OR with pattern processed
       socb *hl,a                      ; OR (HL)           ; ...
       jne  _aec4                      ; JR NZ,$AEC4       ; If any is non-zero skip ahead
       mov  @upload_source,hl          ; LD HL,($72DC)     ; HL = #R$72E0 initially. Table for storing VDP
                                                           ; addresses.
       mov  @upload_destination,de     ; LD DE,($72D8)     ; DE = $2100 initially. Destination in VDP RAM.
       movb @e,*hl                     ; LD (HL),E         ; Write destination address to word pointed to table.
       inc  hl                         ; INC HL            ; ...
       movb d,*hl                      ; LD (HL),D         ; ...
       inc  hl                         ; INC HL            ; ...
       mov  hl,@upload_source          ; LD ($72DC),HL     ; Save updated pointer, e.g. $72E0
_aec4:                                 ; >aec4
       movb @sprite_type_processed,a   ; LD A,($72D5)      ; Get sprite type
       li   hl,graphics_pointer_offsets_table ; LD HL,$B8DD       ; Table of 29 offsets into table at #R$B8FA
       .rst >08                        ; RST $08           ; Add A to HL
       movb *hl,@e                     ; LD E,(HL)         ; Load DE with offset
       sb   d,d                        ; LD D,$00          ; ...
       li   hl,graphics_pointers_table ; LD HL,$B8FA       ; Table of pointers to graphics
       a    de,hl                      ; ADD HL,DE         ; Add offset
       mov  hl,@graphics_pointer_address ; LD ($72DA),HL     ; Save address of pointer (control word)
       movb @pattern_processed,a       ; LD A,($72D7)      ; Get pattern being processed
       ab   one,a                      ; INC A             ; Increment
       ab   a,a                        ; ADD A,A           ; Double
       .rst >08                        ; RST $08           ; Add A to HL, so HL not points to a patten pointer in
                                                           ; #R$B8FA
       movb *hl,@e                     ; LD E,(HL)         ; Set DE = pointer to graphics
       inc  hl                         ; INC HL            ; ...
       movb *hl,d                      ; LD D,(HL)         ; ...
       .ex_de_hl                       ; EX DE,HL          ; Now HL points to graphics
       movb @transformation_processed,a ; LD A,($72D6)      ; Get transformation processed
       andi a,>0300                    ; AND $03           ; 0, 1, 2, 3
       ab   a,a                        ; ADD A,A           ; 0, 2, 4, 6
       ab   a,a                        ; ADD A,A           ; 0, 4, 8, 12
       ab   a,a                        ; ADD A,A           ; 0, 8, 16, 24
       .rst >08                        ; RST $08           ; Add A to HL
       li   de,buffer                  ; LD DE,$71A3       ; Buffer
       mov  de,@pattern_address        ; LD ($72DE),DE     ; Store as source address
       li   bc,>0008                   ; LD BC,$0008       ; Copy 8 bytes
       .ldir                           ; LDIR              ; of graphics data info buffer
       mov  @graphics_pointer_address,hl ; LD HL,($72DA)     ; Get address of graphics pointer (control word)
       inc  hl                         ; INC HL            ; To MSB
       movb *hl,a                      ; LD A,(HL)         ; Get MSB (transformation)
       socb a,a                        ; OR A              ; Is it 0, i.e. no transformation
       jeq  _af15                      ; JR Z,$AF15        ; Then skip ahead
       li   ix,transformation_processed ; LD IX,$72D6       ; Pointer to transformation
       movb *ix,r0                     ; BIT 2,(IX+$00)    ; Is bit 2 set?
       andi r0,>0400                   ;                   
       jeq  _af09                      ; JR Z,$AF09        ; If not, skip ahead
       .call @rotate                   ; CALL $AF6B        ; Rotate left
_af09:                                 ; >af09
       movb *ix,r0                     ; BIT 3,(IX+$00)    ; Is bit 3 set?
       andi r0,>0800                   ;                   
       jne  _af15                      ; JR NZ,$AF15       ; If not, skip ahead
       .call @flip_vertical            ; CALL $AFAE        ; Upside down
       .call @flip_horizontal          ; CALL $AFC2        ; Mirror
_af15:                                 ; >af15
       mov  @pattern_address,hl        ; LD HL,($72DE)     ; Source for writing to VDP RAM
       mov  @upload_destination,de     ; LD DE,($72D8)     ; Destination
       li   bc,>0008                   ; LD BC,$0008       ; 8 bytes
       .call @write_vram               ; CALL $1FDF        ; WRITE_VRAM
       mov  @upload_destination,hl     ; LD HL,($72D8)     ; Get destination address
       li   bc,>0008                   ; LD BC,$0008       ; Add 8
       a    bc,hl                      ; ADD HL,BC         ; ...
       mov  hl,@upload_destination     ; LD ($72D8),HL     ; Write back
upload_next_pattern:                   ; >af2c
       mov  @graphics_pointer_address,ix ; LD IX,($72DA)     ; Get address of graphics pointer (control word)
       movb @pattern_processed,a       ; LD A,($72D7)      ; Get pattern processed
       ab   one,a                      ; INC A             ; Increment it
       cb   a,*ix                      ; CP (IX+$00)       ; When it reaches LSB of control word (pattern count)
       jhe  upload_next_transformation ; JR NC,$AF3E       ; Then move to next transformation
       movb a,@pattern_processed       ; LD ($72D7),A      ; Otherwise store new value
       ; SCF                           ; SCF               ; TODO: check code. Set carry flag
       .ret                            ; RET               ; 
upload_next_transformation:            ; >af3e
       sb   a,a                        ; XOR A             ; 
       movb a,@pattern_processed       ; LD ($72D7),A      ; Set pattens processed zero
       movb @>01(ix),a                 ; LD A,(IX+$01)     ; Get transformation
       socb a,a                        ; OR A              ; Is it zero?
       jeq  upload_next_sprite_type    ; JR Z,$AF55        ; Then move to next sprite type
       movb @transformation_processed,a ; LD A,($72D6)      ; Get transformation processed
       ab   one,a                      ; INC A             ; Increment it
       cb   a,@bytes+>10               ; CP $10            ; When it reaches 16
       jhe  upload_next_sprite_type    ; JR NC,$AF55       ; Then move to next sprite type
       movb a,@transformation_processed ; LD ($72D6),A      ; Otherwise store new value
       ; SCF                           ; SCF               ; TODO: check code. Set carry flag
       .ret                            ; RET               ; 
upload_next_sprite_type:               ; >af55
       sb   a,a                        ; XOR A             ; 
       movb a,@transformation_processed ; LD ($72D6),A      ; Set transformation processed to zero
       movb @sprite_type_processed,a   ; LD A,($72D5)      ; Increment sprite type processed
       ab   one,a                      ; INC A             ; ...
       movb a,@sprite_type_processed   ; LD ($72D5),A      ; ...
       li   hl,>001d                   ; LD HL,$001D       ; When it's <= $1D (29), which is the last sprite type
       cb   a,@l                       ; CP L              ; ...
       jhe  !                          ; RET C             ; Then return
       .ret                            ;                   
!
       movb @b255,a                    ; LD A,$FF          ; Else set it to $FF (done)
       movb a,@sprite_type_processed   ; LD ($72D5),A      ; ...
       .ret                            ; RET               ; 

* Rotate pattern
* 
* Take a pattern pointed to by #R$72DE and rotate it left 90 degrees. Returns
* address of rotate pattern in #R$72DE. Used by the routine at #R$AE94.
rotate:                                ; >af6b
       mov  @pattern_address,hl        ; LD HL,($72DE)     ; HL = source address
       .push hl                        ; PUSH HL           ; Copy source into IY
       .pop iy                         ; POP IY            ; ...
       li   de,>0008                   ; LD DE,$0008       ; HL = destination address
       a    de,hl                      ; ADD HL,DE         ; ...
       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
;       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
_af7a:                                 ; >af7a
       li   r0,1
       clr  r2
rotate_1:
;       sla  *iy,1                      ; RL (IY+$00)       ; TODO: check code. Shift bit 7 of source byte 0 into carry
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. Shift carry into bit 7 of destination byte
;       sla  @>01(iy),1                 ; RL (IY+$01)       ; TODO: check code. x2
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>02(iy),1                 ; RL (IY+$02)       ; TODO: check code. x3
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>03(iy),1                 ; RL (IY+$03)       ; TODO: check code. x4
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>04(iy),1                 ; RL (IY+$04)       ; TODO: check code. x5
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>05(iy),1                 ; RL (IY+$05)       ; TODO: check code. x6
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>06(iy),1                 ; RL (IY+$06)       ; TODO: check code. x7
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
;       sla  @>07(iy),1                 ; RL (IY+$07)       ; TODO: check code. x8
;       sra  *hl,1                      ; RR (HL)           ; TODO: check code. ...
       srl  r2,1
       movb *iy+,r1
       sla  r1,0
       jnc  !
       socb @bytes+>80,r2
!      inc  r0
       ci   r0,8
       jle  rotate_1
       ai   iy,-8
       movb r2,*hl+
;       inc  hl                         ; INC HL            ; Next destination
       sb   one,b                      ; DJNZ $AF7A        ; Repeat 8 times
       jne  _af7a                      ;                   
       .ret                            ; RET               ; 

* Flip pattern vertically
* 
* Take a pattern pointed to by #R$72DE and flip it vertically (upside down).
* Returns address of result in #R$72DE. Used by the routine at #R$AE94.
flip_vertical:                         ; >afae
       mov  @pattern_address,de        ; LD DE,($72DE)     ; DE = source address
       li   hl,>0010                   ; LD HL,$0010       ; HL = right after end of destination buffer
       a    de,hl                      ; ADD HL,DE         ; ...
       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
_afb8:                                 ; >afb8
       movb *de,a                      ; LD A,(DE)         ; Get source byte
       dec  hl                         ; DEC HL            ; Destination address moves backwards
       movb a,*hl                      ; LD (HL),A         ; Store result
       inc  de                         ; INC DE            ; Next source
       sb   one,b                      ; DJNZ $AFB8        ; Repeat 8 times
       jne  _afb8                      ;                   
       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
       .ret                            ; RET               ; 

* Flip pattern horizontally
* 
* Take a pattern pointed to by #R$72DE and flip it horizontally (mirrored).
* Returns address of result in #R$72DE. Used by the routine at #R$AE94.
flip_horizontal:                       ; >afc2
       mov  @pattern_address,de        ; LD DE,($72DE)     ; DE = source address
       li   hl,>0008                   ; LD HL,$0008       ; HL = destination address
       a    de,hl                      ; ADD HL,DE         ; ...
       mov  hl,@pattern_address        ; LD ($72DE),HL     ; Store destination
       .ex_de_hl                       ; EX DE,HL          ; HL = source, DE = destination
       movb @bytes+>08,b               ; LD B,$08          ; 8 bytes in pattern
_afd0:                                 ; >afd0
;       movb @bytes+>80,a               ; LD A,$80          ; Result starts with 10000000
       li   r1,>8000
       li   r2,8
       sb   a,a
       movb *hl,r0
_afd2:                                 ; >afd2
;       sla  *hl,1                      ; RL (HL)           ; TODO: check code. Shift source byte left, bit 7 to carry
;       srl  a,1                        ; RRA               ; TODO: check code. Shift right, carry to bit 7, bit 0 to carry
;       jnc  _afd2                      ; JR NC,$AFD2       ; TODO: check code. Repeat until bit 7 reaches carry (8 times)
       srl  a,1
       sla  r0,1
       jnc  !
       socb r1,a
!      dec  r2
       jne  _afd2
       movb a,*de                      ; LD (DE),A         ; Store result
       inc  de                         ; INC DE            ; Next destination
       inc  hl                         ; INC HL            ; Next source
       sb   one,b                      ; DJNZ $AFD0        ; Repeat 8 times
       jne  _afd0                      ;                   
       .ret                            ; RET               ; 

* Ship exhaust position relative to ship body
exhaust_position_table:                ; >afdd
       byte >00,>00,>08,>00,>06,>FF,>06,>FB
_afe5:                                 ; >afe5
       byte >05,>FB,>00,>F9,>FF,>FA,>FB,>FB
       byte >FC,>FB,>F9,>00,>FA,>01,>FB,>05
       byte >FB,>05,>00,>07,>01,>05,>05,>05
       byte >05,>06

* Display stars
* 
* Used by the routines at #R$8024, #R$8139, #R$8170, #R$832A, #R$832A, #R$846B,
* #R$90D6, #R$A33B and #R$A3E1.
display_stars:                         ; >afff
       li   hl,stars_countdown         ; LD HL,$71EC       ; Counter from 7 to 0
       sb   one,*hl                    ; DEC (HL)          ; Count down
       jlt  !                          ; RET P             ; Return
       .ret                            ;                   
!
       movb @bytes+>07,*hl             ; LD (HL),$07       ; Reset counter to 7
       movb @status_flags,a            ; LD A,($71EB)      ; Get some flag
       movb a,r0                       ; BIT 0,A           ; Test bit 0
       andi r0,>0100                   ;                   
       jeq  _b00f                      ; JR Z,$B00F        ; 
       movb @bytes+>03,*hl             ; LD (HL),$03       ; If bit 0 is set then reset counter to 3
_b00f:                                 ; >b00f
       sb   @c,@c                      ; LD C,$00          ; Set mask to undraw
       .call @display_star_frame       ; CALL $B023        ; 
       movb @star_frame,a              ; LD A,($731A)      ; Get star frame
       ab   @bytes+>02,a               ; ADD A,$02         ; Add 2
       cb   a,@bytes+>0c               ; CP $0C            ; < 12 ?
       jl   _b01e                      ; JR C,$B01E        ; Yes, skip ahead
       sb   a,a                        ; XOR A             ; 
_b01e:                                 ; >b01e
       movb a,@star_frame              ; LD ($731A),A      ; Set star frame to zero
       movb @b255,@c                   ; LD C,$FF          ; Set mask to draw

* Display star frame
* 
* Used by the routine at #R$AFFF.
* 
* I:C Mask $00 or $FF
display_star_frame:                    ; >b023
       movb @star_frame,a              ; LD A,($731A)      ; 0, 2, 4, 6, 8, 10
       li   hl,star_frame_lookup       ; LD HL,$B04F       ; Table of pointers
       .rst >08                        ; RST $08           ; Add A to HL
       movb *hl,@e                     ; LD E,(HL)         ; Get LSB
       inc  hl                         ; INC HL            ; 
       movb *hl,d                      ; LD D,(HL)         ; Get MSB
       mov  @name_table_vdp_address,hl ; LD HL,($73F6)     ; Get VDP address (always 0)
       .ex_de_hl                       ; EX DE,HL          ; Now HL holds address of star frame table to use
_b031:                                 ; >b031
       movb *hl,a                      ; LD A,(HL)         ; Get byte from table
       socb a,a                        ; OR A              ; 
       jne  !                          ; RET Z             ; Zero terminates
       .ret                            ;                   
!
       jgt  !                          ; JP M,$B046        ; If bit 7 is set it's a change of VDP address
       b    @_b046                     ;                   
!
       .call @vdp_read_byte            ; CALL $9AD0        ; vdp_read_byte from DE
       cb   a,@bytes+>18               ; CP $18            ; >= 18
       jhe  _b041                      ; JR NC,$B041       ; Then skip writing
       movb *hl,a                      ; LD A,(HL)         ; Get byte from table
       ; AND C                         ; AND C             ; TODO: check code. Apply mask
       .rst >10                        ; RST $10           ; Write VDP byte A to DE
_b041:                                 ; >b041
       inc  de                         ; INC DE            ; Next VDP address
_b042:                                 ; >b042
       inc  hl                         ; INC HL            ; Next table address
       b    @_b031                     ; JP $B031          ; Loop
_b046:                                 ; >b046
       andi a,>7f00                    ; AND $7F           ; Reset bit 7
       ab   @e,a                       ; ADD A,E           ; Add VDP address LSB
       movb a,@e                       ; LD E,A            ; Write back to E
       jnc  _b042                      ; JR NC,$B042       ; TODO: check code. Loop if no carry
       ab   one,d                      ; INC D             ; Increment MSB if carry
       jmp  _b042                      ; JR $B042          ; Loop

* Star frame lookup
star_frame_lookup:                     ; >b04f
       data star_frame_0
       data star_frame_1
       data star_frame_2
       data star_frame_3
       data star_frame_4
       data star_frame_5

