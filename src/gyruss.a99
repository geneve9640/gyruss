       byte >3E,>7C,>FC,>FC,>78,>30,>00,>00
       byte >00,>80,>C0,>E0,>E0,>E0,>C0,>C0
       byte >F8,>7C,>7E,>7E,>3C,>18,>00,>00
       byte >00,>00,>00,>00,>0C,>1E,>3F,>3F
       byte >1E,>0C,>00,>00,>00,>00,>00,>00
       byte >00,>00,>38,>7C,>FE,>FE,>FE,>7C
       byte >38,>10,>30,>78,>FC,>FC,>78,>30

