* Enemy movement: Move sprite along path and update sprite type
* 
* Used by the routine at #R$88FE.
* 
* I:IX Sprite data
* I:HL Path address
move_animate_sprite_along_path:        ; >8936
       movb *hl,a                      ; LD A,(HL)         ; Get path byte
       mov  @wave_data_address,hl      ; LD HL,($725D)     ; Get wave data address
       movb @>03(ix),r0                ; BIT 0,(IX+$03)    ; If bit 0 of counter is reset
       andi r0,>0100                   ;                   
       jeq  _8941                      ; JR Z,$8941        ; Then skip moving to next byte
       inc  hl                         ; INC HL            ; Else move to next byte
_8941:                                 ; >8941
