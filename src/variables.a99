       byte >00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00

* Number of center enemies
*
* Number of map entries in #R$7207
center_map_entries:                    ; >722b
       byte >00

* Number of active enemies
*
* Excluding enemies at the center of the screen.
active_enemies:                        ; >722c
       byte >00

* Number of 3-spheres/mines left
*
* 3 - 0 during mines sub-stage.
mines_left:                            ; >722d
       byte >00

* Ship background data
ship_background_data:                  ; >722e
       byte >00,>00,>00,>00,>00,>00,>00,>00,>00

* Mines background data
*
* 3x9 bytes
* #TABLE(default, default)
* { =h Byte | =h Purpose }
* { $00 | Screen x }
* { $01 | Screen y }
* { $02 | Name table address of area to clear LSB }
* { $03 | Name table address of area to clear MSB }
* { $04 | Patterns address LSB }
* { $05 | Patterns address MSB }
* { $06 | Name }
* { $07 | Polar y }
* { $08 | Polar x }
* TABLE#
mines_background_data:                 ; >7237
       byte >00,>00,>00,>00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00,>00,>00,>00
       byte >00,>00,>00,>00,>00,>00,>00,>00,>00

* Active enemy shots
*
* Set to $FF during explosion
active_enemy_shots:                    ; >7252
       byte >00

* Number of active shots
active_shots:                          ; >7253
       byte >00

* Mines destroyed
mines_destroyed:                       ; >7254
       byte >00

* Enemies destroyed in chance stage
bonus_enemies_hit:                     ; >7255
       byte >00

* Other flags
*
* #TABLE(default, default)
* { =h Bit | =h Purpose }
* { $00 | Fire pressed last time }
* { $01 | Double shot pickup }
* { $02 | Set when mines exist }
* { $03 | Ever set? Reset when laser fence destroyed }
* { $04 | Set when laser fence exists }
* { $05 | Set when stage starts. Reset when wave starts. Set when enemy hit }
* { $06 | Set when wave starts }
* { $07 | Unused }
* TABLE#
other_flags:                           ; >7256
       byte >00

* Countdown to screen off
screensaver_countdown:                 ; >7257
       data >0000

* Counter used when approaching planet
counter_stage_completed:               ; >7259
       byte >00

* Interrupt flag
