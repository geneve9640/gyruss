       byte >00

* Pointer to data for PSG noise generator
*
* Points to #R$727D for tune. Changed (by #R$9CE3) to #R$72A5 for sound fx
ptr_psg_noise_data:                    ; >7270
       data >0000

* Pointer to data for PSG tone generator 1
*
* Points to #R$7287 for tune.
ptr_psg_tone_1_data:                   ; >7272
       data >0000

* Pointer to data for PSG tone generator 2
*
* Points to #R$7291 for tune.
